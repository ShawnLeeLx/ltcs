      { id:'ch8c2_purify', requiresFavor:{npc:'smithkeep_ice',min:40}, text:'✨ 尝试净化 - 用翡翠之心拯救', effect:'purify_frost', desc:'霜翼加入助战(最终战龙族助战),但需要消耗翡翠之心/碎片' },
      { id:'ch8c3_wait', text:'⏳ 暂缓决定 - 先去灰烬平原找解药', effect:'delay_frost', desc:'霜翼暂时稳定,获得龙族线索,灰烬平原难度-10%' }
    ]
