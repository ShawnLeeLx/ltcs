var NPC_DIALOGS = {
  // Chapter 1 NPCs
  roland: {
    name: '守卫队长·罗兰德', portrait: '🛡️',
    lines: [
      { text: '"你是新来的冒险者？白城最近不太平，商会会长遇刺，全城戒严。"他上下打量你，\"你看起来倒是不怕事。\"',
        choices: [
          { label: '我是来调查遇刺案的', next: 1, effect: 'favor', favorAmt: 2 },
          { label: '我只是路过的旅人', next: 4 },
          { label: '你对暗影了解多少？', next: 5, requireFavor: 30 }
        ]
      },
      // Branch A: Investigator path
      { text: '"调查？哼，比守卫队靠谱的倒不多。"他压低声音，\"现场留了块黑石板，法师塔的人说是失传的龙语——千年前就没入懂的东西。\"',
        choices: [
          { label: '龙语？给我说说', next: 2 },
          { label: '谁可能是凶手？', next: 3, effect: 'favor', favorAmt: 1 }
        ]
      },
      { text: '"龙语是上古龙族的文字，据说能操控天地之力。但这块石板上的龙语……法师说跟古籍里的不一样，像是被篡改过。"他摇摇头，\"去问学者艾琳娜，她比我懂得多。\"', next: -1 },
      { text: '"凶手？三个穿黑袍的，走路姿势怪得很——不像是活人。"他犹豫了一下，\"去找铁匠铺的瘸腿汉克，他值夜班时可能看到了更多。但小心，这城里现在谁都不能信。\"', next: -1 },
      // Branch B: Passerby path
      { text: '"旅人？那你最好快点离开。这城里最近不太安全，夜里更别出门。"他顿了顿，\"不过……如果你改变主意，我也不会拒绝多一双眼睛。\"', next: -1 },
      // Branch C: Favor-locked - shadow knowledge
      { text: '"暗影……"他四下看了看，\"你既然跟我这么熟了，我不瞒你。那些黑袍人走的不是活人的路子，他们身上有腐朽的气息。矿洞深处的影子，跟他们是同源的。\"他握紧剑柄，\"有人想把暗影引回地面。\"',
        choices: [
          { label: '我们能做什么？', next: 6, effect: 'favor', favorAmt: 3 },
          { label: '告诉我更多关于暗影的事', next: 7, requireFavor: 60 }
        ]
      },
      { text: '"保持警惕，积攒力量。守卫队会守住城门，但城墙内的事……要靠像你这样的人。"他拍了拍你的肩膀，\"去找汉克，他的锻造手艺对暗影有克制效果。\"', next: -1 },
      { text: '"……千年前，五色龙族封印了暗影之祖。那个封印正在松动。"他的声音几乎听不见，\"龙心石碎片是封印的关键——有人在收集它们，目的绝不是好事。"他直视你，\"这件事，知道的人越少越好。\"',
        choices: [
          { label: '我会阻止他们', next: 8, effect: 'favor', favorAmt: 5 },
          { label: '为什么告诉我这些？', next: 9 }
        ]
      },
      { text: '"好。"他简短地点头，\"去找卡里斯——龙族后裔，他在龙域。如果你真是站在我们这边的，他会告诉你龙心石的位置。\"', next: -1 },
      { text: '"因为你是我见过唯一不退缩的。"他苦笑，\"守卫队里有内鬼，我不敢跟任何人说这些。但你不一样。"', next: -1 }
    ],
    storyPhases: [
      { afterChapter: 1, lines: [
          {"text": "\"案子有进展了？黑石板上的龙语，艾琳娜说跟千年前的不一样——被篡改过。\"他皱眉，\"有人刻意改变了龙语的含义，这是在解封。\"", "next": 1},
          {"text": "\"去找汉克，他的龙纹碎片也许能拼出线索。我守在这里——白城不能没有守卫。\"", "next": -1}
        ] },
      { afterChapter: 3, lines: [
          {"text": "\"矿洞里的暗影比我想的更危险。那些影子不是活物——它们是被驱使的。\"", "next": 1},
          {"text": "\"你的剑法有长进。但面对暗影，钢铁不够——需要龙纹铸造的武器。找汉克。\"", "next": -1}
        ] },
      { afterChapter: 8, lines: [
          {"text": "\"我必须告诉你一件事。\"他深吸一口气，\"守卫队副队长——他跟黑袍人有联系。我一直在暗中监视，但现在装不下去了。\"", "next": 1},
          {"text": "\"如果你在日冕塔找到证据，我可以动手抓人。否则……我会继续等。\"他握紧剑，\"有时候，等比冲更难。\"", "next": -1}
        ] }
    ]},
  hank: {
    name: '瘸腿汉克', portrait: '⚒️',
    lines: [
      { text: '"嗤，又是被罗兰德派来的？守卫队那帮废物，只会盘问老实人。"他头也不抬，锤子敲在铁砧上发出清脆的响声，\"那晚的事？行，反正闲着也是闲着。\"',
        choices: [
          { label: '你到底看到了什么？', next: 1 },
          { label: '你对龙纹了解多少？', next: 5, requireFavor: 20 },
          { label: '能帮我锻造暗影克制的武器吗？', next: 8, requireFavor: 50 }
        ]
      },
      // Branch A: What did you see?
      { text: '"三个穿黑袍的，鬼鬼祟祟从商会后门溜出来。走路姿势怪得很——膝盖不弯，脚掌着地无声。"他停顿了一下，\"像提线木偶。\"',
        choices: [
          { label: '提线木偶？被什么控制的？', next: 2, effect: 'favor', favorAmt: 2 },
          { label: '他们往哪去了？', next: 3 }
        ]
      },
      { text: '"我打铁打了三十年，什么金属没摸过？那几个人手上拿的东西，不是金属，不是骨头——但我的炉火感应到了它。冰冷的、活的。"他压低声音，\"暗影在操控他们。\"', next: -1 },
      { text: '"西边，出了城门往矿洞方向。"他犹豫了一下，从工作台下摸出一块碎片，\"这个——我在他们留下的痕迹旁捡的。温热的，上面有龙纹。罗兰德收走了一块大的，但这个……我留着。\"',
        choices: [
          { label: '这块碎片能用来做什么？', next: 4, effect: 'favor', favorAmt: 1 },
          { label: '我去找老吴打听', next: 4 }
        ]
      },
      { text: '"龙纹碎片可以淬入钢铁，锻造出对暗影有克制效果的武器。但我不确定我的手艺够不够——需要更多碎片和秘银。"他摆摆手，\"去找西门附近的老吴，那家伙收破烂收到什么奇怪的东西都有。但小心，他有点邪门。\"', next: -1 },
      // Branch B: Favor-locked - dragon patterns
      { text: '"龙纹……"他放下锤子，眼神变了，\"你知道龙纹是龙族的血写的符文吗？每一道纹路都是一个龙族生命的最后印记。"他指着墙上挂着的龙牙锤，\"这把锤子上的纹路，是我师傅从龙冢偷出来的。\"',
        choices: [
          { label: '龙纹能对抗暗影？', next: 6, effect: 'favor', favorAmt: 2 },
          { label: '你师傅是谁？', next: 7 }
        ]
      },
      { text: '"龙纹是暗影的天敌。龙族封印暗影时，用的就是龙纹。但现在龙纹快失传了——只有极少数铁匠还记得怎么把龙纹铸入钢铁。"他苦笑，\"我就是那极少数之一。给我龙纹碎片和秘银，我能锻出连暗影之祖都忌惮的武器。\"', next: -1 },
      { text: '"我师傅……"他沉默良久，\"他为了从龙冢取出龙纹，把自己的命搭进去了。临死前把这把锤和手艺传给我，说——\'铸出封暗影之刃，才算对得起这些龙纹。\'"他重新拿起锤子，\"我还在等那个机会。\"', next: -1 },
      // Branch C: Favor-locked - forge shadow-bane weapon
      { text: '"你真想让我锻？"他罕见地露出认真的表情，\"龙纹淬火不是闹着玩的——每铸一把，都要消耗一块龙纹碎片，而且成功率只有七成。失败的代价……"他指了指自己的瘸腿，\"就是这个。\"',
        choices: [
          { label: '我相信你的手艺', next: 9, effect: 'favor', favorAmt: 5 },
          { label: '有办法提高成功率吗？', next: 10 }
        ]
      },
      { text: '"……行。把龙纹碎片和秘银给我，我试试。"他拿起龙牙锤，炉火映照出他眼中的光，\"这次，不会再失败。\"（在铁匠铺的打造栏中，现已解锁暗影克制武器配方）', next: -1 },
      { text: '"秘银纯度越高越好。还有——如果在深渊里找到\'暗影精华\'，混入淬火液能让龙纹更加锋利。"他犹豫了一下，\"但别告诉罗兰德——他不会同意用暗影的东西来锻造。\"', next: -1 }
    ],
    storyPhases: [
      { afterChapter: 2, lines: [
          {"text": "\"……你问那天晚上看到什么？呵，一个瘸腿铁匠看到的，你未必想知道。\"", "next": 1},
          {"text": "\"……算了。如果你真要去矿洞，带上这个——用龙血矿渣淬的，对暗影有效。\"", "next": -1}
        ] },
      { afterChapter: 4, lines: [
          {"text": "\"迷雾谷的精灵遗迹……你去过？那地方的符文，跟矿洞里找到的是同一套。\"", "next": 1},
          {"text": "\"我在想办法复现那种合金。但缺材料——如果你在迷雾谷找到蓝色晶石，带给我。\"", "next": -1}
        ] },
      { afterChapter: 7, lines: [
          {"text": "\"你带来的那些材料……够了。\"他沉默地走到炉前，\"这次我铸一把真正的——龙纹暗影之刃。\"", "next": 1},
          {"text": "\"但你要答应我一件事。如果铸成了，这把剑要用来终结暗影——不是为了权力，不是为了钱。\"他看着炉火，\"我师傅就是这样要求的。\"", "next": -1}
        ] }
    ]},
  elena: {
    name: '学者艾琳娜', portrait: '📖',
    lines: [
      { text: '"你也是来问黑石板的事？看来罗兰德把我这儿当情报站了。"她合上手中的古籍，\"龙语——我勉强翻译了一部分：\'龙神之心的碎片将指引归途\'。这似乎是指某种封印的线索。\"',
        choices: [
          { label: '龙心石是什么？', next: 1, effect: 'favor', favorAmt: 2 },
          { label: '封印的线索？说具体点', next: 4 },
          { label: '你能教我龙语吗？', next: 7, requireFavor: 40 }
        ]
      },
      // Branch A: Dragon Heart Stone
      { text: '"龙心石——如果传说是真的，千年前五色龙族为争夺它而爆发大战。"她翻开另一本笔记，\"它被分成了七块碎片散落各地。每一块都蕴含着足以改变天地的力量。\"',
        choices: [
          { label: '谁在收集碎片？', next: 2, effect: 'favor', favorAmt: 1 },
          { label: '碎片在哪里？', next: 3 }
        ]
      },
      { text: '"神龙教。一个以为唤醒远古龙神就能获得永生的狂热教派。"她的声音变冷，\"他们已经找到了至少三块碎片——矿洞里的仪式就是他们在尝试激活碎片。如果七块合一，暗影龙神将重新降临，整个艾尔德兰都会被吞噬。\"', next: -1 },
      { text: '"散落在大陆各处——矿洞、森林、沼泽、火山……每个碎片都被龙族用不同的方式封印。"她苦笑，\"但封印在衰弱，有些已经被神龙教找到了。你必须在他们之前拿到碎片——或者，至少阻止他们使用。\"', next: -1 },
      // Branch B: Seal details
      { text: '"封印是第一纪元末龙族内战时设下的。五条古龙用各自的生命力编织了封印，将暗影龙神困在深渊。"她指着书上的图示，\"龙心石碎片就是封印的锚点——拿走碎片，封印就会出现裂缝。\"',
        choices: [
          { label: '所以收集碎片反而危险？', next: 5 },
          { label: '有办法修复封印吗？', next: 6, requireFavor: 20 }
        ]
      },
      { text: '"没错。这是一个两难：放任碎片被神龙教拿走，封印崩溃；自己收集碎片，同样在拆封印。"她叹了口气，\"唯一的出路是找到修复封印的方法——或者找到一种不需要龙心石就能对抗暗影的力量。我正在研究古籍中的线索。\"', next: -1 },
      { text: '"修复封印需要龙语——真正的龙语，不是石板上被篡改的那种。"她罕见地犹豫了一下，\"我母亲……她是龙语学者的后裔。她临终前留下了一些笔记，但我一直没有勇气打开。如果你能从龙域带回更多龙文样本，也许我能破译出修复封印的方法。\"', next: -1 },
      // Branch C: Favor-locked - learn dragon tongue
      { text: '"教龙语？"她的眼睛亮了起来，\"你认真的？龙语是世界上最古老的语言，每一道音节都能共振天地。但要学它，不只是记住符号——你得感受龙的意志。\"',
        choices: [
          { label: '我愿意学', next: 8, effect: 'favor', favorAmt: 3 },
          { label: '学龙语有什么用？', next: 9 }
        ]
      },
      { text: '"……好。我教你第一个音节：\'Aeth\'——龙语中的\'永恒\'。发音的时候，想象你站在龙族千年的记忆中。"她闭上眼，空气中似乎有细微的震动。\"感觉到了吗？那就是龙语的共鸣。当你能读出更多音节，就能阅读那些古代碑文，甚至激活龙族遗迹中的机关。\"', next: -1 },
      { text: '"龙语是解读龙族遗迹的钥匙——那些遗迹中藏着武器、知识、甚至封印的修补方法。"她严肃地看着你，\"而且，如果暗影龙神的封印上写的是龙语，能读懂它就意味着能理解如何加固——或者如何从内部瓦解。这就是为什么神龙教迫切想要篡改龙文的含义。\"', next: -1 }
    ],
    storyPhases: [
      { afterChapter: 2, lines: [
          {"text": "\"森林里的暗影越来越猖獗了。妈妈让我留在这里，但……我也想帮忙。\"", "next": 1},
          {"text": "\"你见过那些暗影的样子吗？它们像是被什么控制了——不是野兽，更像是……傀儡。\"", "next": -1}
        ] },
      { afterChapter: 5, lines: [
          {"text": "\"翡翠沼泽的毒瘴……妈妈说过，那不只是毒，是封印外泄的信号。\"", "next": 1},
          {"text": "\"如果我也能去那些地方……我懂草药和解毒，也懂龙文。让我帮你吧。\"", "next": -1}
        ] },
      { afterChapter: 8, lines: [
          {"text": "\"我终于打开妈妈的笔记了。\"她的声音有些颤抖，\"里面记载了一种仪式——不用龙心石就能修复封印的方法。但代价……需要一个龙语学者作为媒介。\"", "next": 1},
          {"text": "\"别担心，我不是要牺牲自己。仪式需要的是知识，不是生命。但你必须从深渊带回原初之龙的吐息——那是最纯粹的龙语共鸣。\"", "next": -1}
        ] }
    ]},
  // Chapter 2 NPCs
  darkblade: {
    name: '强盗头目·暗刃', portrait: '🗡️',
    lines: [
      { text: '"又一个送死的？白城那帮蠢货派了多少人来了？我都数不清了。"他抱臂靠在石柱上，嘴角挂着嘲讽，\"不过你看着跟之前的不太一样——眼神里没有恐惧。有意思。\"',
        choices: [
          { label: '你为什么信神龙教？', next: 1 },
          { label: '龙神会毁掉一切，包括你', next: 5 },
          { label: '少废话，动手吧', next: 8 }
        ]
      },
      // Branch A: Why believe in Dragon God cult?
      { text: '"为什么？"他愣了一下，随后大笑，\"因为你不知道穷是什么滋味。铁岭的矿工们挖了一辈子矿，到头来连吃饱饭都做不到。神龙教来了之后——给我们饭吃，给我们武器，给我们尊严。\"',
        choices: [
          { label: '他们给了你什么尊严？', next: 2, effect: 'favor', favorAmt: 1 },
          { label: '所以你宁愿当他们的打手？', next: 3 }
        ]
      },
      { text: '"尊严就是——没有人敢再踩在我们头上！"他攥紧拳头，\"那些贵族、商人、城主……他们把我们当矿渣。但龙神不挑人——只要你信，你就是兄弟。这比什么正义都实在。\"', next: -1 },
      { text: '"打手？"他眼神一暗，\"你说的也不是没有道理……"他沉默了几秒，\"但你不了解矿洞深处的东西。那些仪式……不是我这种小角色能叫停的。我已经没有回头路了。\"',
        choices: [
          { label: '什么时候都不晚', next: 4 },
          { label: '那就别怪我', next: 8 }
        ]
      },
      { text: '"……"他长长地叹了口气，\"你知道吗，上一个跟我说这种话的人，现在躺在堡垒的地下室里。我亲手把他扔进去的。"他看着自己的手，\"但有时候晚上，我能听到他的声音。他说——\'还没晚\'。"他收起刀，\"我会让你过去。但别以为这是投诚——我只是……累了。\"', next: -1 },
      // Branch B: Dragon God will destroy you too
      { text: '"毁掉我？"他冷笑，\"你以为我不知道？那些碎片合体之后会发生什么，我没亲眼见过，但猜得到。可你有没有想过——也许这个世界本来就该被毁掉？\"',
        choices: [
          { label: '你在说什么？', next: 6 },
          { label: '世界再烂也值得救', next: 7 }
        ]
      },
      { text: '"铁岭的矿井塌了三次，每次城主都说会修，每次死人都白死。暗森林的村庄被暗影吞噬，没有一兵一卒去救。"他苦笑，\"这个世界对底层人来说，早就毁掉了。龙神只是让上面的人也尝尝滋味。\"', next: -1 },
      { text: '"……你这种人。"他摇了摇头，语气里嘲讽少了，多了一丝说不清的东西，\"好吧，也许你是对的。也许不是。但我已经走得太远了，改不了了。你走吧——我不会拦你。但下次见面，别指望我手下留情。\"', next: -1 },
      // Branch C: Skip to fight
      { text: '"哈哈！爽快！"他拔出双刀，\"我欣赏直来直去的人——可惜你站错了边。来吧，让我看看白城派来的人有几斤几两！\"', next: -1 }
    ]
  },
  // Chapter 3 NPCs
  mystic_wu: {
    name: '神秘人·老吴', portrait: '🔮',
    lines: [
      { text: '"你终于来了……我等你很久了。"他从阴影中走出，佝偻的身形在昏暗的巷道里几乎看不见，\"不是以收破烂的身份，而是以\'守望者\'的身份。你知道这个词的份量吗？\"',
        choices: [
          { label: '守望者是什么人？', next: 1, effect: 'favor', favorAmt: 2 },
          { label: '你怎么知道我会来？', next: 4 },
          { label: '我不信你', next: 7 }
        ]
      },
      // Branch A: Who are the Watchers?
      { text: '"千年来，我们守望者一直在监视龙神之门的封印。"他的眼神变得锐利，\"每个时代都有人试图打开那扇门——我们就是阻止他们的人。但现在，封印正在被破坏，而守望者只剩我一个了。\"',
        choices: [
          { label: '其他守望者呢？', next: 2 },
          { label: '神龙教已经找到了几块碎片？', next: 3, effect: 'favor', favorAmt: 1 }
        ]
      },
      { text: '"死了。上一个守望者三十年前死于深渊裂缝——他是我的师傅。再上一个，百年前死于神龙教暗杀。"他沉默片刻，\"我们不是战士，只是观察者和记录者。但当没有人能站出来的时候，守望者也得拿起剑。\"', next: -1 },
      { text: '"六块。"他伸出手，六根手指微微发抖，\"神龙教已经找到了六块龙心石碎片。只剩下最后一块——龙眠之地的那块。那是龙族战争的最终战场，也是封印最薄弱的地方。\"他直视你，\"你必须在他们之前赶到那里。但在此之前，先阻止矿洞里的仪式。\"', next: -1 },
      // Branch B: How did you know?
      { text: '"守望者能看到命运的丝线——不是未来，而是可能性的轨迹。"他从破旧的口袋里摸出一颗暗淡的水晶，\"这颗水晶在三天前开始发光，指向你来的方向。它从来不会骗我。\"',
        choices: [
          { label: '这水晶是什么？', next: 5, effect: 'favor', favorAmt: 2 },
          { label: '命运可以被改变吗？', next: 6, requireFavor: 30 }
        ]
      },
      { text: '"命运之核——第一纪元龙族长老用水晶眼球铸造的。它能感应龙心石碎片的波动，也能看到与碎片产生共鸣的人。"他把水晶递给你，\"你握着它——感觉到了吗？温热的，像心跳。这说明你身上有龙的潜力。好好保管它，它会指引你找到碎片。\"', next: -1 },
      { text: '"命运不是河流——它是蛛网。每一个选择都改变整张网的形状。"他罕见地笑了，\"我见过无数种可能：有的世界里你败在了矿洞，有的世界里你在灰烬平原倒下，有的世界里……你坐在了万古王座上。"他收起笑容，\"但所有可能性里，你都没有退缩。所以我在这里等你。\"', next: -1 },
      // Branch C: I don't trust you
      { text: '"不信？明智。"他坦然点头，\"在这个时代，信任是最奢侈的东西。但你不信我也没关系——去矿洞看看吧。用你自己的眼睛确认暗影是否正在苏醒。等你亲眼看到了，再来找我。\"',
        choices: [
          { label: '好，我自己去看', next: 8 },
          { label: '你至少给我点线索', next: 9, effect: 'favor', favorAmt: 1 }
        ]
      },
      { text: '"去。但记住一件事——矿洞里的吟唱声不是回声，是有人在指挥。别被声音引导到深处，那是一条有去无回的路。"他转身隐入阴影，\"我会在你需要的时候出现。\"', next: -1 },
      { text: '"……行。"他犹豫了一下，从口袋里摸出一张破旧的地图，\"矿洞的三层有一条暗河，沿着暗河走能绕过神龙教的岗哨。这张图是我师傅三十年前画的，河道可能变了，但总比没有强。"他盯着你，\"现在你信了吗？\"', next: -1 }
    ],
    storyPhases: [
      { afterChapter: 3, lines: [
          {"text": "\"矿洞的仪式被你打断了，但暗影的气息没有消失——它只是转移了。\"他面色凝重，\"神龙教不会善罢甘休。\"", "next": 1},
          {"text": "\"去铁岭——矿洞深处的暗影与那里的铁矿有某种共鸣。铁岭的旅店老板可能知道更多。\"", "next": -1}
        ] },
      { afterChapter: 6, lines: [
          {"text": "\"六块碎片已经被神龙教收集了。第七块……在龙眠之地。\"他的声音沙哑，\"但我发现了一件事——碎片可以被'净化'，让神龙教无法使用。\"", "next": 1},
          {"text": "\"翡翠之心有这个力量。带上它去龙域，找到龙族后裔，他会告诉你怎么做。时间不多了。\"", "next": -1}
        ] },
      { afterChapter: 10, lines: [
          {"text": "\"命运之核告诉我……最后的选择不是在战场上，而是在你心里。\"他直视你的眼睛，\"当暗影龙神站在你面前，你会怎么做？\"", "next": 1},
          {"text": "\"有些人选择毁灭它，有些人选择封印它，有些人……选择接纳它。每一种选择都有代价，而只有你能决定。不管你选什么——我不会阻拦。\"", "next": -1}
        ] }
    ]},
  xuanming: {
    name: '神龙教护法·玄冥', portrait: '🐉',
    lines: [
      { text: '"来得正好!本座正需要几个祭品来完成最后的仪式!"', next: 1 },
      { text: '"放心,你们的牺牲将换来一个新世界的诞生!在远古龙神的荣光下,颤抖吧!"', next: -1 }
    ]
  },
  // === Boss pre-battle dialogues (per region) ===
  boss_lake: {
    name: '哥布林酋长', portrait: '👑',
    lines: [
      { text: '"嘎嘎嘎!又一个两脚兽闯进我的地盘!"', next: 1 },
      { text: '"这片湖是我的!水里闪闪发光的东西也是我的!你休想拿走!"', next: 2 },
      { text: '"小的们!给我上!......什么?都跑了?哼,那就由本酋长亲自来解决你!"', next: -1 }
    ]
  },
  boss_darkforest: {
    name: '狼王霜牙', portrait: '🐺',
    lines: [
      { text: '*低沉的咆哮从密林深处传来,银白色的巨狼缓缓走出阴影*', next: 1 },
      { text: '"人类的气味......又有人来打扰森林的安宁了。"', next: 2 },
      { text: '"这片森林是我的领地。想过去?先让我尝尝你的骨头有多硬!"', next: -1 }
    ]
  },
  boss_fortress: {
    name: '铁面匪首', portrait: '💀',
    lines: [
      { text: '"铁面帮的地盘,闲人免进。不过你既然来了,就别想走了。"', next: 1 },
      { text: '"那些石头上的符文?关你什么事。有人付了大价钱让我们守在这里。"', next: 2 },
      { text: '"既然你不肯转身,那就让你见识一下--铁面的双刀!"', next: -1 }
    ]
  },
  boss_mine: {
    name: '深渊蠕虫', portrait: '🪱',
    lines: [
      { text: '*矿洞深处传来令人牙酸的摩擦声,地面的碎石开始震动*', next: 1 },
      { text: '"嘶......嘶嘶......又有生物进入了我的领域......"', next: 2 },
      { text: '*巨大的触须从黑暗中伸出,酸液滴落在地上发出嘶嘶声*', next: -1 }
    ]
  },
  boss_snowpeak: {
    name: '冰霜女巫', portrait: '🧊',
    lines: [
      { text: '"又一个不知死活的冒险者......这片雪山已经埋葬了多少像你这样的人?"', next: 1 },
      { text: '"永恒的寒冰是我的力量之源。你能感受到吗?你的血液正在凝固。"', next: 2 },
      { text: '"冰霜的审判,现在降临!"', next: -1 }
    ]
  },
  boss_coastcave: {
    name: '深渊克拉肯', portrait: '🦑',
    lines: [
      { text: '*海水突然退去,露出了幽暗的洞穴深处。一个巨大的阴影在水中缓缓浮现*', next: 1 },
      { text: '"咕噜噜......千年沉睡被打扰了......小小的生物......"', next: 2 },
      { text: '*八条巨触同时从水面探出,海水被搅成漩涡*', next: -1 }
    ]
  },
  boss_misthollow: {
    name: '雾隐幻灵', portrait: '🌫️',
    lines: [
      { text: '"你不该来这里的......迷雾之中,一切都是虚妄......"', next: 1 },
      { text: '"我们曾也是活人,但迷雾吞噬了我们的肉体,只留下无尽的怨恨......"', next: 2 },
      { text: '"加入我们吧......在雾中,你将不再痛苦......永远......不再......"', next: -1 }
    ]
  },
  boss_jademarsh: {
    name: '沼泽九头蛇', portrait: '🐲',
    lines: [
      { text: '*沼泽深处传来此起彼伏的嘶吼,仿佛有无数声音在同时咆哮*', next: 1 },
      { text: '*九个头颅从毒雾中逐一探出,每双眼睛都锁定着你*', next: 2 },
      { text: '*毒液从各个颚中滴落,所到之处草木枯萎*', next: -1 }
    ]
  },
  boss_stormcape: {
    name: '风暴泰坦', portrait: '⛈️',
    lines: [
      { text: '*天空突然暗了下来,一道紫色的闪电劈在你面前*', next: 1 },
      { text: '"区区凡人,竟敢踏入风暴之神的领地?"', next: 2 },
      { text: '"让雷电告诉你,何为天地之力!"', next: -1 }
    ]
  },
  boss_windisland: {
    name: '风神龙', portrait: '🐉',
    lines: [
      { text: '*飓风骤然停歇,一只金色的巨龙从云层中俯冲而下*', next: 1 },
      { text: '"千年以来,你是第一个登上这座岛屿的凡人。有勇气,但还不够。"', next: 2 },
      { text: '"风神之怒,将把你的名字从世间吹散!"', next: -1 }
    ]
  },
  boss_dragontemple: {
    name: '暗影祭司', portrait: '🧙',
    lines: [
      { text: '"终于......龙神殿又迎来了一位访客。可惜,你来的是时候,却站错了位置。"', next: 1 },
      { text: '"千年的献祭即将完成。龙神殿的暗影需要一个容器--而你的灵魂,刚刚好。"', next: 2 },
      { text: '"跪下,迎接暗影龙神的降临吧!"', next: -1 }
    ]
  },
  boss_ashplains: {
    name: '灰烬凤凰', portrait: '🔥',
    lines: [
      { text: '*空气中弥漫着焦灼的气味,灰烬中一抹赤红的光芒开始跳动*', next: 1 },
      { text: '"我已在灰烬中涅槃了九十九次。每一次重生,都让我更接近永恒。"', next: 2 },
      { text: '"你将是我的第一百次涅槃的祭品!浴火重生吧!"', next: -1 }
    ]
  },
  boss_volcano: {
    name: '熔岩巨龙', portrait: '🌋',
    lines: [
      { text: '*火山口突然安静了下来,连岩浆都停止了流动*', next: 1 },
      { text: '"......有人来了。从遥远的南方,带着龙心石的气息。"', next: 2 },
      { text: '"千年的沉睡被打破。既然你来了,就留在火中吧--永远。"', next: -1 }
    ]
  },
  boss_abyssgate: {
    name: '虚空大帝', portrait: '🌑',
    lines: [
      { text: '"你终于站在了深渊之门前。回头看看你走过的路,那一切都毫无意义。"', next: 1 },
      { text: '"虚空才是世界的真相。存在不过是偶然,而非必然。让我向你证明。"', next: 2 },
      { text: '"你的存在,到此为止。"', next: -1 }
    ]
  },
  boss_shadowrealm: {
    name: '影之自身', portrait: '🪞',
    lines: [
      { text: '*暗影中走出一个身影--和你一模一样,却散发着不自然的黑色光芒*', next: 1 },
      { text: '"你以为你在追杀暗影?不,你一直在逃避自己。我就是你压抑的恐惧、贪婪和愤怒。"', next: 2 },
      { text: '"打败我?你就是在打败你自己。准备好了吗?"', next: -1 }
    ]
  },
  boss_throneofages: {
    name: '万古之王', portrait: '🗿',
    lines: [
      { text: '*王座上的身影缓缓睁开双眼,金色的瞳孔中映照着整个世界的兴衰*', next: 1 },
      { text: '"你走了很远才来到这里,凡人。但你是否明白,你追寻的到底是什么?"', next: 2 },
      { text: '"龙陨落不是终结,而是开始。而你,将决定下一个五百年。来吧,证明你的资格!"', next: -1 }
    ]
  },
  // ═══════════════════════════════════════════════════
  // Ch3-6 Town NPCs - Story-driven inn & tavern dialogues
  // ═══════════════════════════════════════════════════
  innkeep_iron: {
    name: '铁岭旅店老板', portrait: '🍺',
    lines: [
      { text: '"矿洞?那是我们铁岭的命脉--铁矿养活了半个城。但最近......矿工们不敢下去了。"', next: 1 },
      { text: '"他们说深处传来了声音,不是落石,不是风声--是某种吟唱。低沉的、古老的吟唱。"', next: 2 },
      { text: '"上次派下去的探队,只有一个人回来了。他什么都没说,只是不停地画圈--一个蛇咬着自己尾巴的圈。"', next: -1 }
    ]
  },
  innkeep_tid: {
    name: '潮汐港旅店老板', portrait: '⚓',
    lines: [
      { text: '"你问最近海上的怪事?嘿,你算是问对人了。我这里水手最多的,什么故事都听过。"', next: 1 },
      { text: '"三个月前开始,深海里出现了紫色的光。不是磷光--磷光是蓝绿色的,这个不一样。渔民们说,那光照到的地方,鱼都翻了白肚。"', next: 2 },
      { text: '"还有更怪的--有人说半夜看到海面上站着一个人。不是踩水,是站在水面上。黑袍,面朝东方,一动不动。"', next: 3 },
      { text: '"老港口的地下室里有些旧海图,是我爷爷那辈人留下的。你要是有兴趣,去翻翻看?说不定能找到点线索。"', next: -1 }
    ]
  },
  innkeep_sun: {
    name: '日冕塔旅店老板', portrait: '📜',
    lines: [
      { text: '"学者们最近都疯了--彻夜不休地研究古文献,连饭都顾不上吃。"', next: 1 },
      { text: '"大贤者伊兰说,她在星象仪里看到了不该出现的东西--天空中多了一颗星,一颗从古代记录中消失的星。"', next: 2 },
      { text: '"那颗星叫\'渊瞳\',传说中暗影龙神的眼目。古籍记载,它只在龙神苏醒前夕才会重现。"', next: 3 },
      { text: '"如果你真想了解真相,去找塔顶的伊兰大人吧。不过她最近脾气不太好,当心点。"', next: -1 }
    ]
  },
  smithkeep_drag: {
    name: '龙域铁匠', portrait: '⚒️',
    lines: [
      { text: '"你手上的武器还行,但到了龙域就不够看了。这里的怪物,皮比龙鳞还硬。"', next: 1 },
      { text: '"我锻造用的是龙骨炭--把远古龙骨烧成炭,掺进铁水里。只有这样锻造的武器才能伤到暗影生物。"', next: 2 },
      { text: '"龙神殿的暗影正在蔓延。上周有一队巡逻兵失踪了,找到他们的时候......他们还活着,但眼睛变成了紫色,什么都不记得了。"', next: -1 }
    ]
  },
  smithkeep_ice: {
    name: '冰礁铁匠', portrait: '❄️',
    lines: [
      { text: '"冰炼术是我家的祖传技艺--在零下百度的极寒中锻造,让金属的晶体结构达到最紧密的状态。"', next: 1 },
      { text: '"但这种锻造有个代价--每次冰炼,都要消耗锻造者的一部分体温。我爷爷锻造了四十年,最后冻死在了炉火旁。"', next: 2 },
      { text: '"冰礁港的地下冰窖里封着一把剑,是初代龙骑士的佩剑。据说只有通过龙神殿试炼的人才能拔出来。如果你真去了那里......替我看看那把剑还在不在。"', next: -1 }
    ]
  },
  // ═══════════════════════════════════════════════════
  // Ch4-12 Region NPCs - Story-advancing dialogues per area
  // ═══════════════════════════════════════════════════
  mist_spirit: {
    name: '雾中精灵', portrait: '🌫️',
    lines: [
      { text: '"你看见了雾中的我？"半透明的身影在迷雾中若隐若现，\"那说明你的心还没有被暗影侵蚀……还没有。但雾会改变一切。\"',
        choices: [
          { label: '你是谁？', next: 1, effect: 'favor', favorAmt: 2 },
          { label: '这里发生了什么？', next: 4 },
          { label: '怎么净化暗影？', next: 7, requireFavor: 20 }
        ]
      },
      // Branch A: Who are you?
      { text: '"我们精灵族曾在这片山谷中歌唱千年。"她的声音像风铃，但透着悲伤，\"第一纪元末，龙族内战，我们选择了中立——不帮龙，不帮暗影。暗影龙神因此诅咒了我们，让我们的肉体消散，只剩回响困在雾中。\"',
        choices: [
          { label: '诅咒能解除吗？', next: 2, effect: 'favor', favorAmt: 2 },
          { label: '你们为什么不反抗？', next: 3 }
        ]
      },
      { text: '"诅咒来自龙神——只有龙族的力量才能打破它。"她的光芒微微变亮，\"翡翠之心是精灵女王最后的遗产，它保留着我们种族的记忆。如果你能找到它，也许我们还有救……也许。\"', next: -1 },
      { text: '"反抗？"她发出一声低笑，\"我们试过。一千年前，精灵战士们向暗影龙神宣战——三天之内，全军化为迷雾。暗影不怕刀剑，它怕的是纯粹的光。而我们……已经没有光了。\"', next: -1 },
      // Branch B: What happened here?
      { text: '"暗影从北方蔓延而来。"她的身影颤动了一下，\"起初只是雾变浓了——我们以为是天气。然后雾开始吞噬声音，接着吞噬颜色，最后吞噬生命。\"',
        choices: [
          { label: '暗影的源头在哪？', next: 5 },
          { label: '还有精灵活着吗？', next: 6, effect: 'favor', favorAmt: 1 }
        ]
      },
      { text: '"龙神殿。"她的声音突然坚定，\"暗影不是自然现象——它是从龙神殿的封印裂缝里渗出来的。每一次封印衰弱，雾就更浓一些。要止住暗影，必须从源头封堵——但那需要龙族的力量。\"', next: -1 },
      { text: '"活着……"她沉默了很久，\"在雾最深处，精灵女王还沉睡在翡翠祭坛上。她的身体已经变成了翡翠的一部分，但意识还在。如果你能到达祭坛，她会帮助你。但祭坛周围盘着九头蛇——那是暗影的看门狗。\"', next: -1 },
      // Branch C: Favor-locked - how to purify
      { text: '"净化暗影？"她的眼睛突然亮了起来，\"翡翠之心还沉在沼泽深处。它是精灵族最后的纯粹之物——唯一能净化暗影的东西。但它也被腐蚀了，需要真诚之心唤醒它。\"',
        choices: [
          { label: '真诚之心是什么意思？', next: 8, effect: 'favor', favorAmt: 3 },
          { label: '我去找翡翠之心', next: 9 }
        ]
      },
      { text: '"不是勇气，不是力量——是真正为他人的痛苦而心痛。"她伸手触碰你的胸口，指尖冰凉如雾，\"你的心里……有光。很微弱，但是真的。带着这份心去沼泽，翡翠之心会回应你。我相信你。\"', next: -1 },
      { text: '"去吧。但记住——翡翠之心不是武器，它是镜子。它会映出你内心最真实的模样。如果你心中有暗影……它也会映出来。\"她的身影渐渐消散，\"我在雾中等你的好消息。\"', next: -1 }
    ],
    storyPhases: [
      { afterChapter: 5, lines: [
          {"text": "\"翡翠之心……你找到了。\"她的身影比上次清晰了许多，\"我能感觉到它的光芒在驱散迷雾。我们精灵族……也许还有希望。\"", "next": -1}
        ] },
      { afterChapter: 8, lines: [
          {"text": "\"龙神殿的封印在继续衰弱。即使翡翠之心暂时净化了这里的暗影，只要源头不堵住，雾还会回来。\"她的声音里多了一丝急切，\"你必须去龙域。这是精灵族最后的请求。\"", "next": -1}
        ] }
    ]},
  swamp_witch: {
    name: '沼泽巫医', portrait: '🐸',
    lines: [
      { text: '"嘶嘶……又一个闯入沼泽的傻瓜。"她从蘑菇堆后探出头，满脸褶子挤成一笑，\"别怕，老婆子不吃人……只吃蘑菇。不过你闻起来不像本地人。\"',
        choices: [
          { label: '我在找翡翠之心', next: 1 },
          { label: '沼泽里有什么危险？', next: 4, effect: 'favor', favorAmt: 1 },
          { label: '你能治疗暗影侵蚀吗？', next: 7, requireFavor: 25 }
        ]
      },
      // Branch A: Looking for Emerald Heart
      { text: '"翡翠之心？"她的笑凝住了，\"你知道那东西在哪吗——神庙祭坛。但周围盘着一条九头蛇。它不是普通的野兽，是暗影的看门狗，专门看守不该被发现的东西。\"',
        choices: [
          { label: '九头蛇怎么对付？', next: 2, effect: 'favor', favorAmt: 2 },
          { label: '你见过它？', next: 3 }
        ]
      },
      { text: '"硬来？你死定了。它每断一头便生两头，越打越多。"她从烂泥里翻出一个瓶子，\"但龙族的火焰能永断其根。你身上……有龙的气息。这瓶蛇毒解药给你，免费——不是因为心善，是因为翡翠之心落入暗影之手，我这片沼泽也保不住。\"', next: -1 },
      { text: '"见过？"她打了个寒颤，\"三十年来只见过一次。它从神庙地下钻出来的那天，沼泽里所有动物发疯一样往南跑。我也跑了——但跑了一半回头看，整片沼泽已经被暗影吞了一半。老婆子是靠一瓶蛇毒解药和三碗迷魂汤才活下来的。\"', next: -1 },
      // Branch B: Swamp dangers
      { text: '"危险？"她咯咯笑了，\"你踩的每一脚都可能踩到毒蛇窝，呼吸的每一口空气都有瘴气。但这都不是真正的危险。\"',
        choices: [
          { label: '真正的危险是什么？', next: 5, effect: 'favor', favorAmt: 1 },
          { label: '你怎么活下来的？', next: 6 }
        ]
      },
      { text: '"真正的危险是——这片沼泽在吃人的记忆。"她指了指自己的头，\"你待得越久，越记不清自己是谁、从哪来。那些迷路的旅人不是死在蛇毒和瘴气里，是忘了一切之后走进了沼泽深处，再也没有出来。\"', next: -1 },
      { text: '"老婆子有自己的法子。"她从脖子上摘下一个护符，\"这是我奶奶传的——里面封着一小段记忆，关于我是谁。每天早上看一眼，就不会被沼泽吃掉。你要是在沼泽待久了，也最好找个东西提醒自己。\"', next: -1 },
      // Branch C: Favor-locked - cure shadow
      { text: '"暗影侵蚀？让我看看。"她抓起你的手，指甲冰凉，仔细端详你的皮肤，\"你确实碰过暗影的东西——手上有一条细细的黑纹。还早，不算深。\"',
        choices: [
          { label: '能治吗？', next: 8, effect: 'favor', favorAmt: 3 },
          { label: '不治会怎样？', next: 9 }
        ]
      },
      { text: '"能。但需要三样东西：月石粉、精灵眼泪、和一滴你自己的血。我有月石粉，精灵眼泪……你去迷雾谷找精灵要。至于血嘛——现在就给我。"她掏出一根骨针，在你指尖扎了一下，在瓶口接了三滴，\"三天后回来，药能配好。\"', next: -1 },
      { text: '"黑纹会慢慢扩散——先是手，再是手臂，最后到心脏。到了心脏就晚了：你会变成暗影的一部分，永远困在沼泽里。"她语气平淡，像在说天气，\"不过你还有时间。大概……两周？\"', next: -1 }
    ]
  },
  sage_ilan: {
    name: '大贤者伊兰', portrait: '🔮',
    lines: [
      { text: '"你带来了翡翠之心……让我看看。"她伸出苍白的手指，触碰那颗翡翠。翡翠微微发光，\"果然。这颗翡翠中封印着精灵女王最后的记忆。第一纪元末，龙族内战，精灵族选择了中立——暗影龙神因此诅咒了精灵，让他们永远困在迷雾与沼泽之中。\"',
        choices: [
          { label: '精灵女王的记忆能解读吗？', next: 1, effect: 'favor', favorAmt: 2 },
          { label: '暗影的真正起源是什么？', next: 4, requireFavor: 20 },
          { label: '我下一步该去哪？', next: 7 }
        ]
      },
      // Branch A: Decoding queen's memory
      { text: '"需要特殊的龙语仪式。"她翻开一本古籍，\"精灵女王将记忆封入翡翠时，用的是第一纪元的龙语咒文。要解封，需要三个龙语音节——我知道其中一个：\'Aeth\'。\"',
        choices: [
          { label: '其他两个音节在哪？', next: 2, effect: 'favor', favorAmt: 2 },
          { label: '解封后会发生什么？', next: 3 }
        ]
      },
      { text: '"一个在深渊最深处——原初之龙的墓地。另一个……"她犹豫了一下，\"在暗影龙神的巢穴。好消息是你不需要同时集齐三个音节，只需要知道它们的发音顺序。我已经推算出顺序了——但还差最后确认。\"', next: -1 },
      { text: '"精灵女王会苏醒——短暂地。她会告诉你第一纪元的真相：暗影是如何诞生的，以及为什么龙族内战。"她的眼神变得锐利，\"但真相有时候比暗影更可怕。你确定你想知道吗？\"', next: -1 },
      // Branch B: Favor-locked - true origin
      { text: '"暗影不是入侵者，它是从封印裂缝里漏出来的。"她的声音压低了，\"但更准确地说——暗影是龙神力量被污染后的产物。第一纪元的龙族内战，不是龙打龙。是龙打自己内心的暗影。\"',
        choices: [
          { label: '龙神内心的暗影？', next: 5, effect: 'favor', favorAmt: 3 },
          { label: '所以暗影能被消灭吗？', next: 6 }
        ]
      },
      { text: '"每条龙都有光与暗。暗影龙神不是外来的怪物——它是龙神自身暗面的具现。当龙族的贪婪、恐惧和愤怒达到极致，暗面就会脱离本体，化为独立的存在。"她看着你，\"这也是为什么暗影不能被简单消灭——它不是敌人，它是存在的另一面。\"', next: -1 },
      { text: '"消灭？不能。但可以封印，或者……接纳。"她翻开最后一页，\"两种结局：一是修复封印，让暗影重新回到龙神体内——但这需要龙神自愿接受自己的暗面。二是让光与暗重新平衡，让世界接受暗影也是存在的一部分。你最终要做出选择。\"', next: -1 },
      // Branch C: Where to go next
      { text: '"龙域。"她毫不犹豫，\"龙神殿中保存着第一纪元的完整文献——包括暗影的真正起源。风暴角是通往龙域的唯一通道。"她递给你一张手绘地图，\"小心风暴角的元素风暴——它不是自然现象，是世界裂隙的征兆。\"', next: -1 }
    ],
    storyPhases: [
      { afterChapter: 6, lines: [
          {"text": "\"啊，你来了。我在古籍里找到了一段记载——关于龙神封印的薄弱点。\"", "next": 1},
          {"text": "\"暗影不是入侵者，它是从封印裂缝里漏出来的。要彻底解决，要么修复封印，要么……用同样强大的力量对抗。\"", "next": -1}
        ] },
      { afterChapter: 8, lines: [
          {"text": "\"龙神殿的文献比我想象的更完整。暗影不是敌人——它是龙神力量被污染后的产物。\"", "next": 1},
          {"text": "\"你需要找到原初之龙的核心。它在深渊最深处，也是暗影的源头。但这趟旅程……九死一生。\"", "next": -1}
        ] }
    ]},
  guard_karl: {
    name: '龙卫统领卡尔', portrait: '🗡️',
    lines: [
      { text: '"你就是带着翡翠之心来的那个人？"他上下打量你，铠甲上的龙纹在暗光中闪烁，\"我听过你的名号——湖畔猎手，森林行者。但龙域不是你之前去过的地方。\"',
        choices: [
          { label: '龙域出了什么问题？', next: 1, effect: 'favor', favorAmt: 1 },
          { label: '你是龙卫？', next: 4 },
          { label: '我该怎么准备？', next: 7, requireFavor: 20 }
        ]
      },
      // Branch A: What's wrong in Dragon Realm?
      { text: '"暗影不是从外面来的——它是从龙神殿里渗出来的。"他的声音压得很低，\"守殿的龙族长老们……他们已经不再是原来的自己了。暗影在吞噬他们的意志，把他们变成守卫封印的傀儡。\"',
        choices: [
          { label: '长老们还能救吗？', next: 2, effect: 'favor', favorAmt: 2 },
          { label: '封印有多严重？', next: 3 }
        ]
      },
      { text: '"我不确定。上个月我带队突入龙神殿外围，看到了一个长老——他的眼睛完全黑了，但嘴角在笑。不是疯狂的笑，是……痛苦的笑。好像他还有意识，但身体已经不听使唤了。"他握紧剑柄，\"如果我们能净化暗影，也许他们能恢复。\"', next: -1 },
      { text: '"严重到——如果不在这个月蚀之前重新封印，暗影龙神将完全苏醒。"他的语气像在念报告，\"龙卫的文献记载，上一次封印是在五百年前，用了五条古龙的生命。现在我们没有龙了。只有你。\"', next: -1 },
      // Branch B: Who are the Dragon Guard?
      { text: '"龙卫——龙骑士团最后的后裔。"他拍了拍铠甲上的龙纹，\"一千年前的龙骑士团有三百人，人龙合一，所向披靡。但龙族内战后，龙不再与人类结契。我们只剩下铠甲和名字。\"',
        choices: [
          { label: '还有龙骑士活着吗？', next: 5, effect: 'favor', favorAmt: 2 },
          { label: '你们在守什么？', next: 6 }
        ]
      },
      { text: '"活着？"他的眼神闪烁了一下，\"传说在灰烬平原的深处，还有一头沉睡的古龙——霜翼。它在一千年前受了重伤，至今在自我修复。如果能唤醒它……也许龙骑士团还能重建。"他摇头，\"但我已经找了二十年，没有找到入口。\"', next: -1 },
      { text: '"守龙神殿。这是我们唯一的使命。"他指向北方，\"龙神殿是封印的核心，也是暗影的源头。我们龙卫——剩下来的十二人——日夜轮流守在外围。但暗影越来越强，我们越来越弱。冰礁港还有一队愿意战斗的人，去那里补给，然后……去龙神殿。这是最后的防线了。\"', next: -1 },
      // Branch C: Favor-locked - how to prepare
      { text: '"准备？"他认真地看着你，从腰间解下一枚徽章，\"带着这个。龙神殿里的暗影会侵蚀人的意志——这枚徽章里有龙卫的誓约之力，能暂时抵御暗影。不过只有一次效果，用完就碎。\"',
        choices: [
          { label: '你确定要给我？', next: 8, effect: 'favor', favorAmt: 3 },
          { label: '暗影侵蚀是什么样的？', next: 9 }
        ]
      },
      { text: '"确定。"他把徽章塞到你手里，\"龙卫的使命是守护封印——而你，是唯一有机会修复封印的人。我的职责不是守着徽章等死，是把它交给能用的人。"他拍了拍你的肩，\"去吧。活着回来。\"', next: -1 },
      { text: '"先是幻觉——你会看到最恐惧的东西。然后是遗忘——你会忘记自己是谁。最后是顺从——你会觉得暗影才是对的。"他的声音里有一丝颤抖，\"上个月，我的副手……他没有撑过来。我亲手——"他停顿了，\"总之，戴着徽章，别取下来。\"', next: -1 }
    ]
  },
  frostwing_echo: {
    name: '霜翼的低语', portrait: '🐲',
    lines: [
      { text: '*你感受到一阵寒意，但不是来自冰雪——而是来自一头远古巨龙的意识碎片。它在冰层之下沉睡了一千年。*',
        choices: [
          { label: '你是谁？', next: 1, effect: 'favor', favorAmt: 3 },
          { label: '暗影是什么？', next: 4, requireFavor: 30 },
          { label: '我该怎么对抗暗影？', next: 7, requireFavor: 40 }
        ]
      },
      // Branch A: Who are you?
      { text: '"霜翼……曾经是龙骑士团的搭档。"意识碎片在震动，\"一千年前的最后一战，我燃烧了全部生命力封印暗影。肉身已死，但意识……还残留在冰层中。千年了……终于有人带着翡翠之心来到了这里。\"',
        choices: [
          { label: '龙骑士团发生了什么？', next: 2, effect: 'favor', favorAmt: 2 },
          { label: '你为什么还留在这里？', next: 3 }
        ]
      },
      { text: '"龙骑士团——三百人与龙结契，本应所向披靡。但暗影龙神不是外面的敌人——它是龙神自身的暗面。当龙族内战时，有些龙被暗影侵蚀，龙骑士被迫杀自己的搭档……"意识剧烈震颤，\"我的骑士……他最后选择了和我一起封印暗影。\"', next: -1 },
      { text: '"因为封印需要守护者。"冰层下传来微弱的脉动，\"我的意识就是封印的一部分——只要我还清醒，暗影就无法从冰层裂缝中逃出。但我的意识在衰退……再过几十年，我就会消散，封印也会随之崩塌。\"', next: -1 },
      // Branch B: Favor-locked - What is shadow?
      { text: '"暗影不是一种力量——暗影是一种选择。"冰层的温度骤降，\"每个生灵的内心都有一片暗影：贪婪、恐惧、愤怒。当这些被放大到极致，便形成了暗影龙神。它不是外来的入侵者——它是存在的另一半。\"',
        choices: [
          { label: '所以消灭暗影是不可能的？', next: 5, effect: 'favor', favorAmt: 3 },
          { label: '有没有龙成功对抗了自己的暗面？', next: 6 }
        ]
      },
      { text: '"消灭？不。但可以平衡。"冰层下传来一声叹息，\"第一纪元的龙族之所以强大，是因为他们接纳了自己的暗面——光与暗共存，才是完整的龙。内战的悲剧在于……他们试图消灭暗面，反而让暗面脱离控制。\"', next: -1 },
      { text: '"有。原初之龙——第一条龙——它从未与暗面分离。光暗一体，无分彼此。"意识变得微弱，\"它的核心沉在深渊最深处。如果你能找到它，也许能学会如何……与暗影共存，而非对抗。\"', next: -1 },
      // Branch C: Favor-locked - how to fight
      { text: '"对抗暗影？用暗影的方法对抗暗影是没用的。"冰层裂开一条缝，渗出一缕寒气，\"你需要理解它——不是理解它的弱点，而是理解它的本质。\"',
        choices: [
          { label: '本质是什么？', next: 8, effect: 'favor', favorAmt: 3 },
          { label: '龙神殿有答案吗？', next: 9 }
        ]
      },
      { text: '"暗影的本质是——被拒绝的自我。"寒气凝成了冰花，\"当年龙族拒绝自己的暗面，暗面才化为独立的存在。你如果也拒绝它，它只会更强。唯一的路是……接纳。这不容易，但这是正确的路。去火山深处吧，那里是第一纪元终结之地，也是暗影诞生之地。\"', next: -1 },
      { text: '"龙神殿保存着原初之龙的遗训。但它被暗影侵蚀了——里面的文献可能已经被篡改。不要全信你读到的东西，用你自己的心去判断。"意识消散前最后一句话：\"记住——击败暗影不是唯一的答案。\"', next: -1 }
    ]
  },
  ash_hermit: {
    name: '灰烬隐者', portrait: '🔥',
    lines: [
      { text: '"你在灰烬中寻找什么？答案？真相？还是只是……活着的理由？"他从火堆旁抬起头，满脸灰烬，眼中却映着异常清明的光，\"坐吧。火还没灭。\"',
        choices: [
          { label: '第一纪元最后一战发生了什么？', next: 1, effect: 'favor', favorAmt: 2 },
          { label: '你为什么住在这里？', next: 4 },
          { label: '封印还能撑多久？', next: 7, requireFavor: 25 }
        ]
      },
      // Branch A: Last battle of First Era
      { text: '"五条古龙联手对抗暗影龙神。"他用树枝拨了拨火，\"它们燃烧了自己的生命力，将暗影封印在火山深处。那场战斗持续了七天七夜——灰烬平原就是这么来的。整片草原被龙火烧成焦土，千年了还没长出一棵草。\"',
        choices: [
          { label: '五条古龙都死了？', next: 2, effect: 'favor', favorAmt: 2 },
          { label: '暗影是怎么被封印的？', next: 3 }
        ]
      },
      { text: '"四死一伤。活下来的那条——霜翼——飞到了冰礁港，把自己冻在冰层里自我修复。一千年了，还在修。"他叹了口气，\"所以你看，即使是古龙，对付暗影也是惨胜。而你现在连一条龙都没有。\"', next: -1 },
      { text: '"不是关住暗影——是让暗影回到龙神体内。五条古龙合力打开了一个通道，将暗影龙神推回了龙神的意识深处，然后由霜翼从外部加固封印。"他看着火，\"但封印不是永恒的。每一百年衰弱一分，而现在是最后期限。\"', next: -1 },
      // Branch B: Why live here?
      { text: '"因为我在等。"他看着火山口，\"三十年前，我是个考古学家，来灰烬平原研究第一纪元的战场遗迹。结果发现了一件不该发现的东西——龙神殿的入口。\"',
        choices: [
          { label: '龙神殿入口在哪？', next: 5, effect: 'favor', favorAmt: 2 },
          { label: '你进去了吗？', next: 6 }
        ]
      },
      { text: '"火山口北壁，第七道裂纹。"他在地上画了个位置，\"但我警告你——入口有龙语封印，只有懂得三个音节的人才能打开。我知道一个：\'Verath\'。剩下的你自己去找。\"', next: -1 },
      { text: '"进去了。走了三步就出来了。"他的声音突然变冷，\"里面不是建筑——是活的。墙壁在呼吸，地面在脉动，空气里有心跳声。那是龙神还活着的证明——它在封印深处沉睡，但还活着。我不敢再进去。\"', next: -1 },
      // Branch C: Favor-locked - how long for seal?
      { text: '"封印撑不到下一个满月。"他从怀里掏出一块刻满龙文的石板，\"这是我三十年来的观测记录。封印的衰弱速度在加快——不是线性衰减，是指数级。还有大约……十七天。\"',
        choices: [
          { label: '还有办法加固吗？', next: 8, effect: 'favor', favorAmt: 3 },
          { label: '十七天后会怎样？', next: 9 }
        ]
      },
      { text: '"临时加固？可以。在月蚀之前用龙语音节做一次小型封印仪式，能争取三个月。但最终还是要进入龙神殿，从内部修复封印。"他递过石板，\"拿去吧——上面的龙文是仪式的关键步骤。你比我更有资格做这件事。\"', next: -1 },
      { text: '"暗影龙神完全苏醒。它不需要身体——它是纯粹的意识，会侵蚀一切有意识的生灵。从龙域开始，向北蔓延，直到整个世界都被暗影笼罩。"他平静地说，\"除非有人在此之前进入龙神殿，做出选择。修复封印，或者……接纳暗影。两条路都通向终点，但走法完全不同。\"', next: -1 }
    ]
  },
  void_voice: {
    name: '虚空之声', portrait: '🌑',
    lines: [
      { text: '"你听到了我的声音……"黑暗中传来回响，没有来源，没有方向，仿佛从存在本身的缝隙中渗出，\"说明你已经触碰到了世界的边界。大多数人终其一生都不会走到这一步。\"',
        choices: [
          { label: '你是暗影龙神吗？', next: 1 },
          { label: '世界的边界是什么？', next: 4, effect: 'favor', favorAmt: 2 },
          { label: '我该怎么选？', next: 7, requireFavor: 35 }
        ]
      },
      // Branch A: Are you the Shadow Dragon God?
      { text: '"暗影龙神？不——也不完全是。"回响变得复杂，像多个声音在低语，\"暗影龙神是龙神暗面的具现。而我……我是暗面意识到自己存在之后，产生的那一丝质疑。它杀戮、侵蚀、吞噬——我怀疑。\"',
        choices: [
          { label: '你在质疑暗影？', next: 2, effect: 'favor', favorAmt: 3 },
          { label: '你是暗影的弱点？', next: 3 }
        ]
      },
      { text: '"质疑存在的意义。"回响变轻了，\"暗影没有意志——它只有本能：吞噬、扩张、填补虚无。但我在吞噬的过程中，产生了一个不该有的念头：\'为什么要吞噬？\'这个念头让我……有了意识。\"', next: -1 },
      { text: '"弱点？"回响中传来一丝类似笑的声音，\"你可以这么理解。但打蛇打七寸——你不能用刀剑攻击一个念头。你想利用我，需要的是理解，不是武力。\"', next: -1 },
      // Branch B: What is the boundary of the world?
      { text: '"世界不是无限的。"回响在空间中扩散，\"存在的边界之外，是纯粹的虚无——没有光，没有暗，没有时间，没有空间。暗影就是从存在的缝隙中渗出的虚无。哪里有生命，哪里就有缝隙，就有暗影。这是宇宙的另一半。\"',
        choices: [
          { label: '没有暗影会怎样？', next: 5, effect: 'favor', favorAmt: 2 },
          { label: '所以暗影不可能被消灭？', next: 6 }
        ]
      },
      { text: '"没有暗影的世界……"回响颤抖了一下，\"我曾经用模拟推演过。光没有了暗的对照，便不再是光——它只是白色的虚无。生命不再有恐惧，也不会有勇气；不再有失去，也不会有珍惜。存在会变成……一潭死水。\"', next: -1 },
      { text: '"不可能。"回响很确定，\"暗影是存在的必然产物——就像影子是光的必然伴侣。你可以封印它、压制它、驱逐它，但它总会回来。唯一的问题是：下一次回来的时候，你准备好接纳它了吗？\"', next: -1 },
      // Branch C: Favor-locked - how to choose
      { text: '"你现在有两个选择——毁灭暗影，让世界失衡；或者接纳暗影，让光与暗重新达成平衡。"回响沉寂了一瞬，\"万古王座上的那个存在，也在等待同样的答案。\"',
        choices: [
          { label: '你会支持哪个选择？', next: 8, effect: 'favor', favorAmt: 3 },
          { label: '两个选择都很难', next: 9 }
        ]
      },
      { text: '"我……"回响犹豫了——这是一千年来它第一次犹豫，\"我本是暗影的一部分，按理应该支持暗影吞噬一切。但那个质疑——\'为什么要吞噬\'——让我看到了第三种可能：不是消灭，也不是放任，而是……对话。光与暗之间的对话。\"', next: -1 },
      { text: '"当然很难。"回响变轻，近乎温柔，\"但你知道为什么你是第一个走到这里的人吗？因为其他人要么选择了消灭——然后暗影总会回来；要么选择了放任——然后被暗影吞噬。你是第一个还在犹豫的人。犹豫不是软弱——犹豫意味着你在真正思考。\"', next: -1 }
    ]
  },
  // ═══════════════════════════════════════════════════
  // Town NPCs - Complete coverage for all 7 towns
  // ═══════════════════════════════════════════════════
  innkeep_white: {
    name: '白城旅店老板娘', portrait: '☕',
    lines: [
      { text: '"又来了一个新人?先坐下喝杯热茶吧。"', next: 1 },
      { text: '"......你也是冲着坠星湖那光来的?这几天到处都在传。实话跟你说——那光不是好事。"', next: 2, clueId: 'clue_lake_glow' },
      { text: '"城主下令不许任何人靠近湖边,但我有后门的钥匙。夜里你从后门出去,绕过守卫就能到湖畔。"', next: 3 },
      { text: '"别说是我给的钥匙。还有——小心点。之前去的几个人,都没回来。"', next: -1 }
    ]
  ,
    storyPhases: [
      { afterChapter: 1, lines: [
          {"text": "\"哟，又来啦？看你这疲惫样，哥布林那边没少给你添麻烦吧。\"", "next": 1},
          {"text": "\"说起来，最近城里来了些奇怪的人……商队里混进了生面孔，你路上小心。\"", "next": -1}
        ] },
      { afterChapter: 3, lines: [
          {"text": "\"矿工那边传来消息，说地下有东西在……共鸣。你如果去铁岭，帮忙留意下。\"", "next": 1},
          {"text": "\"对了，你跟那个瘸腿汉克聊过没？他懂的东西，比他自己愿意承认的多。\"", "next": -1}
        ] }
    ]},
  smith_white: {
    name: '白城铁匠·老赵', portrait: '🔨',
    lines: [
      { text: '"哟,新来的?看你这身板,不像是要来打铁的。修装备?还是买新家伙?"', next: 1 },
      { text: '"我跟你说,这白城的铁矿虽然不算顶级,但胜在稳定。铁岭那边的矿是好,可你也得有命运回来啊。"', next: 2 },
      { text: '"想学打铁?先把这几个桶搬到后院去--开个玩笑。你要是真有好材料,尽管拿来,老赵的手艺不会让你失望。"', next: -1 }
    ]
  },
  lord_white: {
    name: '白城城主·李承安', portrait: '🏛️',
    lines: [
      { text: '"你就是公会推荐来的冒险者?看起来还年轻......不过年轻也好,有些事情,老了反而做不了。"', next: 1 },
      { text: '"白城是这片区域最后的秩序堡垒。北有矿洞异变,东有森林蔓延的暗影,我需要能处理这些事的人。"', next: 2 },
      { text: '"去证明你的价值吧。等你解决了真正的威胁,再来见我--我会给你应得的奖赏。"', next: -1 }
    ]
  },
  // 铁岭城
  smith_iron: {
    name: '铁岭铁匠·赫尔曼', portrait: '⚒️',
    lines: [
      { text: '"铁岭的锻造术传承了七代!每一把从我这炉子里出来的武器,都能在战场上传三代!"', next: 1 },
      { text: '"最近矿洞出的铁矿质量下降了......混了些说不清的东西。我试着用它打了一柄剑,淬火的时候炉火变成了绿色。"', next: 2 },
      { text: '"你要是能从矿洞深处带些纯净的秘银矿回来,我给你打一把能传家的家伙。这是铁匠的承诺!"', next: -1 }
    ]
  },
  lord_iron: {
    name: '铁岭城城主·矿王巴克', portrait: '⛏️',
    lines: [
      { text: '"铁岭靠矿吃饭,矿出了问题,铁岭就得断粮。你不帮忙,我们全城都得喝西北风。"', next: 1 },
      { text: '"矿洞深处的那个东西......我派了三队人下去,只回来了三个。回来的那个不停说\'蛇,蛇,蛇\'......"', next: -1 }
    ]
  },
  // 潮汐港
  innkeep_tid_port: {
    name: '潮汐港旅店·海风驿', portrait: '🌊',
    lines: [
      { text: '"欢迎来到海风驿!一杯烈酒,一碟咸鱼,窗外就是大海--还有比这更惬意的事吗?"', next: 1 },
      { text: '"最近海路不太平。船队出发后,有三艘再也没回来。老船长说是海怪,我觉得没那么简单......"', next: 2 },
      { text: '"你要是准备出海,先去铁匠那把武器磨利了。潮蚀海洞里的东西,可不是拿拳头能解决的。"', next: -1 }
    ]
  },
  lord_tid: {
    name: '潮汐港口主·银鳍夫人', portrait: '🐚',
    lines: [
      { text: '"潮汐港从来不靠城墙防御--大海就是我们最好的屏障。但现在,大海本身似乎成了威胁。"', next: 1 },
      { text: '"海洞深处涌出的暗潮,不是自然现象。有人在里面搅动了不该搅动的东西。"', next: -1 }
    ]
  },
  // 日冕塔
  innkeep_sun_full: {
    name: '日冕塔旅店·日晷轩', portrait: '☀️',
    lines: [
      { text: '"日冕塔,学者的天堂!这里的茶比酒贵,书比剑多。不过你放心,我还是有酒的。"', next: 1 },
      { text: '"塔里的大法师们最近焦头烂额--说是感应到了来自东方的魔力波动,像是什么封印正在松动。"', next: 2 },
      { text: '"风暴角那边?我去过一次。风大得能把人吹成风筝,但那儿的景色,啧啧,一辈子忘不了。"', next: -1 }
    ]
  },
  lord_sun: {
    name: '日冕塔塔主·贤者伊兰', portrait: '📖',
    lines: [
      { text: '"知识是最锋利的武器,也是最坚固的盾牌。你若想在风暴中存活,先学会理解风暴。"', next: 1 },
      { text: '"风暴角的元素异动不是偶然--它与世界裂隙有关。你越早前往龙域边境,就越能理解这一切。"', next: -1 }
    ]
  },
  // 龙域边境
  innkeep_dragon: {
    name: '龙域旅店·龙息酒馆', portrait: '🔥',
    lines: [
      { text: '"龙息酒馆,一百二十年了!当年我爷爷开的店,那时候这儿还真有龙--在地平线上飞来飞去的。"', next: 1 },
      { text: '"龙没了,但龙留下的东西还在。灰烬平原下面,据说埋着整个龙骑士团的装备库。当然,也埋着他们战死的原因。"', next: 2 },
      { text: '"你要是真敢去火山口,记得带够药水。那地方的温度......呵,连铁匠的炉子都自愧不如。"', next: -1 }
    ]
  },
  lord_dragon: {
    name: '龙域守将·卡尔将军', portrait: '🐉',
    lines: [
      { text: '"二十年前,我是唯一从灰烬平原活着回来的人。我的战友......全留在了那里。"', next: 1 },
      { text: '"火山口里的东西正在苏醒。不是龙,比龙更古老。龙族曾经将它封印在那里,但封印正在崩解。"', next: 2 },
      { text: '"如果你能深入龙神殿,也许能找到加固封印的方法--或者,找到对抗它的力量。"', next: -1 }
    ]
  },
  // 冰礁港
  innkeep_ice: {
    name: '冰礁旅店·暖炉小屋', portrait: '❄️',
    lines: [
      { text: '"进来进来!外面冻成那样,就我这儿还暖和点。炉子烧的是鲸脂,耐烧!"', next: 1 },
      { text: '"冰下的东西?别问我,我不想知道。渔夫们说偶尔能听到冰层下面传来的声音......像是歌唱,又像是哭泣。"', next: 2 },
      { text: '"你要是真打算凿冰下去--带上我的酒。不是壮胆,是万一回不来,好歹喝过最后一杯好的。"', next: -1 }
    ]
  },
  lord_ice: {
    name: '冰礁港镇长·老约根', portrait: '🧊',
    lines: [
      { text: '"冰礁港靠海吃饭,但现在海冻住了。渔船出不了港,贸易也断了。"', next: 1 },
      { text: '"风神岛......那地方平时没人敢去。传说岛上的风能撕碎一切,但也能带走一切--包括暗影。"', next: -1 }
    ]
  },
  // ═══ 故事关键NPC ═══
  forest_wanderer: {
    name: '森林流浪者', portrait: '🌲',
    lines: [
      { text: '"你也是来闯堡垒的？"他从树影后探出身，一身旧皮甲，眼睛却锐利得像猎鹰，\"前面那帮穿黑甲的家伙可不是善茬。三天前冒出来的，不到半天就把堡垒占了。\"',
        choices: [
          { label: '他们是什么人？', next: 1, effect: 'favor', favorAmt: 1 },
          { label: '你怎么知道这些？', next: 4 },
          { label: '堡垒有别的入口吗？', next: 7, requireFavor: 15 }
        ]
      },
      // Branch A: Who are they?
      { text: '"黑铁兄弟会——至少他们是这么叫自己的。"他啐了一口，\"但我看他们就是神龙教的走狗。身上那股暗影味儿，隔着十里地都能闻到。\"',
        choices: [
          { label: '神龙教已经渗透到这里了？', next: 2, effect: 'favor', favorAmt: 2 },
          { label: '他们有多少人？', next: 3 }
        ]
      },
      { text: '"渗透？他们根本不藏着。"他指着堡垒方向，\"那些黑甲兵白天在堡垒外巡逻，夜间在内部举行什么仪式。我亲眼看到——祭坛上有一块发光的石头，跟暗影一个颜色。那是龙心石碎片，我敢打赌。\"', next: -1 },
      { text: '"正门守卫大约二十人，轮班制。但堡垒里面有多少，我不确定——我只进去过一次，差点没出来。"他摸了摸腰间的伤疤，\"不过他们有个弱点：白天只留两个守卫，其他人都在睡觉。夜猫子战术，白天就是软肋。\"', next: -1 },
      // Branch B: How do you know?
      { text: '"我在这一带混了十五年了。"他从腰间解下一个水壶灌了一口，\"猎过狼，采过药，也替人带过路。森林有自己的规矩——活下来的都是消息灵通的。\"',
        choices: [
          { label: '能帮我带路吗？', next: 5, effect: 'favor', favorAmt: 2 },
          { label: '你一个人住在这？', next: 6 }
        ]
      },
      { text: '"带路？"他犹豫了一下，\"我不会跟你进去——我还有自己的事。但我可以告诉你堡垒的弱点：西侧有个排水口，能爬进去。代价是弄脏你的衣服，但总比正面强攻好。"他递给你一张手绘的草图，\"暗门的位置我标了——那堡垒是第一纪元造的，里头机关多得很。\"', next: -1 },
      { text: '"有同伴。两个——一头叫灰牙的狼，一只叫阿飞的鹰。"他吹了声口哨，树丛中传来窸窣声，\"够了。人多了反而碍事。而且……最近森林里的暗影越来越浓，我也不敢太靠近堡垒。那些暗影会侵蚀动物的意志——灰牙上周差点咬了我。\"', next: -1 },
      // Branch C: Favor-locked - alternative entry
      { text: '"想走捷径？"他看了你一眼，从怀里摸出一把旧钥匙，\"堡垒东面有个废弃的矿道入口，被灌木盖住了。这是三年前一个矿工给我的——他说矿道直通堡垒地下室。我没试过，但比排水口体面。\"',
        choices: [
          { label: '矿道安全吗？', next: 8, effect: 'favor', favorAmt: 3 },
          { label: '为什么给我这个？', next: 9 }
        ]
      },
      { text: '"安全？"他嗤笑，\"三百年没维护的矿道，你自己想。不过有一点——矿道里没有暗影气息。那些黑甲兵明显不知道这条道，否则早就封了。他们只防着正门和排水口。\"', next: -1 },
      { text: '"因为你跟我不一样。"他难得认真起来，\"我来森林是为了活着。你来是为了干掉那帮杂碎。有区别。"他把钥匙塞到你手里，\"拿着。如果你成功了，这一带的旅人就安全了。如果你失败了——反正我也是一个人，没什么好失去的。\"', next: -1 }
    ],
    clueId: 'clue_fortress_entry'
  },
  // ═══ 补充NPC对话 - V21 ═══
  shopkeep_white: {
    name: '白城商店老板', portrait: '🧴',
    lines: [
      { text: '"欢迎欢迎!我这什么都卖,只要你有金币。"', next: 1 },
      { text: '"最近湖那边闹哥布林,生意受了点影响......你看上去像能打的,要不要去帮帮忙?"', next: 2 },
      { text: '"对了,学者艾琳娜昨天来买了好多草药,说是发现了什么古代文献......城里最近怪事多。"', next: -1 }
    ]
  },
  jade_guardian: {
    name: '翡翠守护者', portrait: '💚',
    lines: [
      { text: '"你踏入翡翠沼泽,便已触碰了古老的誓约。"', next: 1 },
      { text: '"我是这片沼泽的守护者,千年前,龙族将封印托付给我们。那些蛇......它们试图破坏封印。"', next: 2 },
      { text: '"九头蛇每断一头便生两头,唯有龙族的火焰能永断其根。你......身上有龙的气息。"', next: -1 }
    ],
    clueId: 'clue_hydra_weakness'
  ,
    storyPhases: [
      { afterChapter: 5, lines: [
          {"text": "\"……外来者。你带着龙的气息。很淡，但确实有。\"", "next": 1},
          {"text": "\"翡翠之心不是给你这种人的。但……如果你能通过古神的试炼，我可以破例。\"", "next": -1}
        ] },
      { afterChapter: 6, lines: [
          {"text": "\"你通过了试炼。但这还不够——翡翠之心的力量，需要你自己的心来匹配。\"", "next": 1},
          {"text": "\"去日冕高塔吧。那里的学者知道更多关于龙族封印的事。时间是你的敌人。\"", "next": -1}
        ] }
    ]},
  captain_storm: {
    name: '风暴船长', portrait: '⚓',
    lines: [
      { text: '"嘿!你看上去不像水手。来风暴海角做什么?"', next: 1 },
      { text: '"这片海域最近不太平,海底有什么东西在蠢蠢欲动。我的船被巨浪掀翻过两次了。"', next: 2 },
      { text: '"如果你要出海,带上这个——是我祖父留下的航海罗盘。它能在迷雾中指引方向。"', next: -1 }
    ]
  ,
    storyPhases: [
      { afterChapter: 5, lines: [
          {"text": "\"海上最近不太平。你如果在海岸附近看到发光的漩涡——别靠近，那是暗影渗透的入口。\"", "next": 1},
          {"text": "\"你知道日冕高塔吗？那边的学者在追踪这些异常。你往东走的话，可以去看看。\"", "next": -1}
        ] },
      { afterChapter: 7, lines: [
          {"text": "\"日冕高塔的观测站传来消息——龙族的遗产正在苏醒。你如果去龙域，小心点。\"", "next": 1},
          {"text": "\"其实……我见过龙。很小的时候，在风暴里。它看了我一眼，然后消失了。\"", "next": -1}
        ] }
    ]},
  karis: {
    name: '龙族后裔·卡里斯', portrait: '🐉',
    lines: [
      { text: '"你......闻起来不像龙域的人。但你的眼神里有火焰。"', next: 1 },
      { text: '"我是最后的纯血龙族后裔。这片土地上曾经龙族遍地,直到暗影降临。"', next: 2 },
      { text: '"暗影龙王......它曾经是我们的一员。被暗影腐蚀后,它背叛了一切。现在它坐在王座上,等待吞噬最后的龙族之火。"', next: 3 },
      { text: '"如果你要去龙之神殿,我可以教你龙息之术。但前提是——你愿意为龙族而战。"', next: -1 }
    ]
  ,
    storyPhases: [
      { afterChapter: 7, lines: [
          {"text": "\"龙域不欢迎外来者。但……你身上的气息，跟龙神殿里的雕像有点像。\"", "next": 1},
          {"text": "\"龙族不是消失了——我们还在，只是换了一种方式存在。你会在龙神殿里明白的。\"", "next": -1}
        ] },
      { afterChapter: 9, lines: [
          {"text": "\"你从龙神殿出来了……还活着，比我预想的要坚强。\"", "next": 1},
          {"text": "\"灰烬平原的火山最近很不稳定。如果你要去，带上火抗的药剂——那种地方，不是人能久待的。\"", "next": -1}
        ] }
    ]},
  eric: {
    name: '指挥官埃里克', portrait: '⚔️',
    lines: [
      { text: '"新面孔?我是龙域守备指挥官埃里克。这里的防务由我负责。"', next: 1 },
      { text: '"暗影的力量在增长,我们已经失去了两个前哨站。士兵们疲惫不堪,补给线也断了。"', next: 2 },
      { text: '"如果你愿意帮忙,我可以给你提供武器和装备。铁匠铺的东西随你挑——打完折。"', next: -1 }
    ]
  },
  frostwing_survivor: {
    name: '霜翼信使', portrait: '❄️',
    lines: [
      { text: '"你......能看到我?大多数人看不到霜翼一族。"', next: 1 },
      { text: '"我是从北边来的,冰礁出了大事。极光里出现了裂缝,暗影正在从裂缝中渗透。"', next: 2 },
      { text: '"霜翼长老的遗言是:找到龙族后裔,只有龙火才能封住裂缝。拜托你了......"', next: -1 }
    ]
  },
  ancient_dragon_spirit: {
    name: '古龙之魂', portrait: '🐲',
    lines: [
      { text: '"你终于来了......我等了千年。"', next: 1 },
      { text: '"我是第一纪元的龙族长老。暗影之王曾是我们的战友,但他在深渊中迷失了自己。"', next: 2 },
      { text: '"龙之神殿是最后的防线。如果你能通过试炼,我将传授你龙语——那是打开终焉之门的钥匙。"', next: -1 }
    ]
  ,
    storyPhases: [
      { afterChapter: 12, lines: [
          {"text": "\"……你终于到了。我等了三千年，等一个能走到这里的人。\"", "next": 1},
          {"text": "\"暗影不是敌人——它是我死前最后一口气息化成的。要拯救这个世界，你需要接纳它，而不是消灭它。\"", "next": -1}
        ] }
    ]},
  ash_wanderer: {
    name: '灰烬行者', portrait: '🔥',
    lines: [
      { text: '"灰烬......到处都是灰烬。这里曾经是繁华的城邦,现在只剩下回忆。"', next: 1 },
      { text: '"火山里住着一位先知,她能看见未来的碎片。但她的预言总是模棱两可......"', next: 2 },
      { text: '"如果你要去火山深处,穿上耐热的衣服。还有——别喝岩浆湖里的水,不管多渴。"', next: -1 }
    ]
  ,
    storyPhases: [
      { afterChapter: 9, lines: [
          {"text": "\"你从火山口活下来了？有意思……大多数进去的人，都没有出来。\"", "next": 1},
          {"text": "\"这片灰烬底下，埋着上一个纪元的文明。龙骑士的遗产……如果你够强，可以去寻找。\"", "next": -1}
        ] },
      { afterChapter: 11, lines: [
          {"text": "\"深渊的门已经开了。你真的要进去？里面的东西……会看你最深处的恐惧。\"", "next": 1},
          {"text": "\"我不是吓你。我自己进去过——出来的时候，头发全白了。那还是三十年前的事。\"", "next": -1}
        ] }
    ]},
  flame_seer: {
    name: '炎先知', portrait: '👁️',
    lines: [
      { text: '"火焰告诉我,你会来。一切都在预言之中。"', next: 1 },
      { text: '"暗影之王的本质不是黑暗,而是虚无。他想要抹除一切存在,让世界回归混沌。"', next: 2 },
      { text: '"通往深渊之门需要三样东西:龙族的火焰、精灵的祝福、以及......一个愿意牺牲的人。"', next: -1 }
    ]
  ,
    storyPhases: [
      { afterChapter: 9, lines: [
          {"text": "\"……火焰告诉我的不多，但每一条都准得吓人。\"", "next": 1},
          {"text": "\"深渊的火焰和火山不一样——那是原初之龙吐息的余烬。如果你要去，带够解咒的药材。\"", "next": -1}
        ] },
      { afterChapter: 11, lines: [
          {"text": "\"最后的预言……你会在深渊里面对自己。不是战斗，是选择。\"", "next": 1},
          {"text": "\"无论如何选择，记得——火焰不会骗你，但你的心会。带上火抗药剂，还有……勇气。\"", "next": -1}
        ] }
    ]},
  gatekeeper_abyss: {
    name: '深渊守门人', portrait: '🌑',
    lines: [
      { text: '"站住。你不知道门后是什么。"', next: 1 },
      { text: '"我是深渊的守门人,在此驻守千年。门后是暗影的源头,一切黑暗的起点。"', next: 2 },
      { text: '"如果你想进去,必须证明自己不会被暗影吞噬。告诉我——你最害怕的是什么?"', next: -1 }
    ]
  ,
    storyPhases: [
      { afterChapter: 11, lines: [
          {"text": "\"你来了。门的另一边，是你的执念化成的影子。\"", "next": 1},
          {"text": "\"打败它，门会开。但……门后面的东西，可能比影子更让你难以接受。\"", "next": -1}
        ] },
      { afterChapter: 12, lines: [
          {"text": "\"你从深渊出来了……看来你做出了选择。\"", "next": 1},
          {"text": "\"不管你选了什么，龙途的尽头就在前方。去王座吧——那里有最后的真相在等你。\"", "next": -1}
        ] }
    ]},
  shadow_whisperer: {
    name: '暗影低语者', portrait: '👤',
    lines: [
      { text: '"你听到了吗?那些低语......它们在呼唤你。"', next: 1 },
      { text: '"我不是暗影的仆从,我是它的囚徒。暗影之王将我困在这里,让我替他收集灵魂。"', next: 2 },
      { text: '"我能教你隐入暗影的方法,但代价是......你必须带着我的记忆走出去。我不想被遗忘。"', next: -1 }
    ]
  },
  shadow_dragon: {
    name: '暗影龙王', portrait: '🐲',
    lines: [
      { text: '"你来了。我终于等到了能走到这里的人。"', next: 1 },
      { text: '"你以为我是邪恶的?不......我只是看清了真相。这个世界本不该存在,龙族的创造是一个错误。"', next: 2 },
      { text: '"但如果你坚持要阻止我......那就用你的力量来说服我吧!"', next: -1 }
    ]
  }
};

// Show chapter intro - parchment-style cinematic text
function showChapterIntro(chapterId) {
  var intro = CHAPTER_INTROS[chapterId];
  if (!intro) return;

  var html = '';
  html += '<div class="chapter-intro">';
  html += '<div class="chapter-intro-inner">';
  // Chapter title
  html += '<div class="chapter-intro-title">' + intro.title + '</div>';
  html += '<div class="chapter-intro-sub">' + intro.subtitle + '</div>';
  html += '<div class="chapter-divider">---- ✦ ----</div>';
  // Quote
  html += '<div class="chapter-quote">' + intro.quote.replace(/\n/g, '<br>') + '</div>';
  html += '<div class="chapter-divider">---- ✦ ----</div>';
  // Narration
  html += '<div class="chapter-narration">' + intro.narration.replace(/\n/g, '<br><br>') + '</div>';
  // Continue
  // Check for story choice at chapter start
  if (STORY_CHOICES[chapterId] && !(G.storyChoices && G.storyChoices[chapterId])) {
    html += '<div style="margin-top:12px">';
    html += '<button class="btn" onclick="showStoryChoice(\'' + chapterId + '\')" style="width:100%;border:1px solid #d4a017;background:#2a1a0a;color:#d4a017">✦ 命运的选择...</button>';
    html += '</div>';
  }
  // Continue - return to the scene that was active before story view
  var returnFn = G._currentScene || 'sceneWorldMap';
  html += '<button class="btn btn-primary" onclick="' + returnFn + '()" style="margin-top:16px;width:100%">继续冒险</button>';
  html += '</div>';
  html += '</div>';
  render(html);
}

// Show NPC dialog - interactive conversation
function showDialog(npcId, startLine) {
  // Remember which scene opened this dialog, so we can return there
  if (!G._dialogReturnScene) G._dialogReturnScene = 'sceneTown';
  if (startLine === 0) {
    // Starting a new dialog - capture current scene
    G._dialogReturnScene = G._currentScene || 'sceneTown';
  }

  var npc = NPC_DIALOGS[npcId];
  if (!npc) return;
  var idx = startLine || 0;
  // Story-aware dialog: select from storyPhases if available
  var dialogLines = npc.lines || [];
  if (npc.storyPhases && G._completedChapters) {
    for (var _spi = npc.storyPhases.length - 1; _spi >= 0; _spi--) {
      if (G._completedChapters.indexOf(String(npc.storyPhases[_spi].afterChapter)) >= 0) {
        dialogLines = npc.storyPhases[_spi].lines;
        break;
      }
    }
  }
  var line = dialogLines[idx];
  if (!line) return;

  var html = '';
  html += '<div class="npc-dialog">';
  html += '<div class="npc-portrait">' + npc.portrait + '</div>';
  html += '<div class="npc-name">' + npc.name + '</div>';
  html += '<div class="npc-text">' + line.text.replace(/\n/g, '<br>') + '</div>';

  // ── Choice branch support ──
  if (line.choices && line.choices.length > 0) {
    // Multi-choice dialog: render option buttons
    for (var ci = 0; ci < line.choices.length; ci++) {
      var ch = line.choices[ci];
      // Condition check: requireFavor, requireFlag, requireChapter
      var locked = false;
      var lockReason = '';
      if (ch.requireFavor) {
        var favor = getNpcAffection(npcId);
        if (favor < ch.requireFavor) { locked = true; lockReason = '需要好感度' + ch.requireFavor; }
      }
      if (ch.requireFlag && !G[ch.requireFlag]) { locked = true; lockReason = '需要: ' + (ch.requireFlagLabel || ch.requireFlag); }
      if (ch.requireChapter) {
        var chapters = G._completedChapters || [];
        if (chapters.indexOf(String(ch.requireChapter)) < 0) { locked = true; lockReason = '需完成第' + ch.requireChapter + '章'; }
      }
      if (locked) {
        html += '<button class="btn" disabled style="opacity:0.4;cursor:not-allowed;margin:3px;flex:1">🔒 ' + (ch.label || '???') + ' <span style="font-size:0.8em;color:#888">(' + lockReason + ')</span></button>';
      } else {
        // Build onclick: apply effects then navigate
        var onclickParts = [];
        if (ch.effect === 'favor') onclickParts.push('addNpcAffection(\'' + npcId + '\',' + (ch.favorAmt || 2) + ')');
        if (ch.effect === 'flag') onclickParts.push('G._' + ch.flag + '=true');
        if (ch.effect === 'gold') onclickParts.push('G.gold+=' + ch.goldAmt);
        if (ch.effect === 'xp') onclickParts.push('G.xp+=' + ch.xpAmt + ';doLevelUp()');
        if (ch.effect === 'custom' && ch.customFn) onclickParts.push(ch.customFn);
        onclickParts.push('showDialog(\'' + npcId + '\',' + ch.next + ')');
        html += '<button class="btn" style="margin:3px;flex:1" onclick="' + onclickParts.join(';') + '">' + (ch.label || '继续') + '</button>';
      }
    }
  } else if (line.next >= 0) {
    html += '<button class="btn" onclick="showDialog(\'' + npcId + '\',' + line.next + ')">继续</button>';
  } else {
    // End of conversation - trigger story talk_to_npc
    checkStoryTriggers('talk_to_npc', npcId);
    // Also trigger find_clue if this NPC gives a clue
    if (npc.clueId) checkStoryTriggers('find_clue', npc.clueId);
    // ─── Quest offer from NPC ───
    var npcQids = _npcQuestMap[npcId] || [];
    for (var nqi = 0; nqi < npcQids.length; nqi++) {
      var nqId = npcQids[nqi];
      if (G.quests.indexOf(nqId) >= 0) continue;               // already accepted
      if (G.questProgress[nqId] && G.questProgress[nqId].done) continue;  // already done
      var nqDef = _findQuestById(nqId);
      if (!nqDef) continue;
      var nqReqMet = !nqDef.requires || (G.questProgress[nqDef.requires] && G.questProgress[nqDef.requires].done);
      if (!nqReqMet) continue;
      html += '<div style="background:#2a2a1a;border:1px solid #d4a017;border-radius:8px;padding:12px;margin:8px 0">';
      html += '<div style="color:#d4a017;font-weight:bold;margin-bottom:4px">📋 ' + nqDef.name + '</div>';
      html += '<div style="color:#aaa;font-size:0.9em">' + nqDef.desc + '</div>';
      html += '<div style="color:#888;font-size:0.85em;margin-top:4px">🎯 ' + nqDef.objective + '</div>';
      html += '<div style="color:#8a8;font-size:0.85em">🎁 ' + nqDef.reward + '</div>';
      html += '</div>';
      html += '<button class="btn btn-primary" onclick="acceptQuest(\'' + nqId + '\');showDialog(\'' + npcId + '\',' + startLine + ')">✅ 接受任务</button>';
      break; // show one quest at a time
    }
    // Return to the scene that opened the dialog
    if (G._pendingBossBattle) {
      G._pendingBossBattle = false;
      var _wb = G.battle;
      var _waveMsg = (_wb && _wb.totalWaves > 0) ? '👑 第1波/共' + _wb.totalWaves + '波 — ' + _wb.waves[0].label : '👑 首领战!';
      html += '<button class="btn btn-danger" onclick="renderBattle(\'' + _waveMsg + '\')">⚔️ 开战!</button>';
    } else {
      var returnFn = G._dialogReturnScene || 'sceneTown';
      G._dialogReturnScene = null; // clear after use
      html += '<button class="btn btn-primary" onclick="' + returnFn + '()">返回</button>';
    }
  }
  html += '</div>';
  render(html);
}

function initGame() {
  G = {
    // Core
    name: '', level: 1, xp: 0, nextXp: 100,
    // Stats
    str: 10, agi: 10, int: 10, cha: 10, luk: 10,
    // Resources
    hp: 100, maxHp: 100, mp: 50, maxMp: 50, gold: 50,
    // Progress
    origin: null, location: 'whitecity',
    // Inventory
    inventory: [], equipment: { weapon: null, helmet: null, armor: null, gloves: null, boots: null, belt: null, necklace: null, ring: null },
    skills: [], attrPts: 0, skillPts: 0,
    // Battle
    inBattle: false, battle: null,
    // Misc
    totalBattlesWon: 0, totalBattlesLost: 0,
    cargo: [], keys: 0,
    // Mini-map state
    miniMapPos: null,
    // Quests
    quests: [], activeQuest: null, questProgress: {}, guildQuests: [], sideQuestProgress: {}, // { questId: { current: N, done: bool } }
    // Main story progress
    storyProgress: null, // { chapterId, completed: { objId: true } }
    // Flags
    forestCleared: false,
    // Boss defeated per location-area
    bossDefeated: {},
    eliteDefeated: {},
    // Game started (can't re-select origin)
    gameStarted: false,
    // Pending level ups
    pendingLevelUps: 0,
    // Trade system
    marketEvent: null,
    _tradeTab: 'buy',
    _tradeVisited: false,
    // NPC affection
    npcRelations: {},  // { npcId: { level: N, gifts: N } }
    // Play time tracking
    _playStartTs: null,
    _accumulatedPlaySec: 0,
    _lastSaveScene: null,
    _tutorial: null, // null = existing save (no tutorial), { step, done, skipped } = new player
    _tradeMissions: null, // { active: [], doneToday: [] }
    _weather: null, // { north, central, south, _transitionCount }
    // A4: Story flags — explicit initialization for all 29 story choice outcomes
    _eastPath: false, _westPath: false, _lootBonus: 0, _socialBonus: 0,
    _dragonAlly: false, _humanAlly: false, _neutralPath: false,
    _altruistRoute: false, _egoRoute: false, _balanceRoute: false,
    _sealChosen: false, _shadowReduction: 0, _rushPath: false,
    _heartReturned: false, _heartTaken: false, _heartShard: false,
    _seekTruth: false, _critBonus: 0,
    _seekMercy: false, _mercyKill: false,
    _purifyFrost: false, _delayFrost: false,
    _destroyShadow: false, _understandShadow: false,
    _resistWhisper: false, _listenWhisper: false, _shareWhisper: false,
    _finalDestroy: false, _finalAccept: false, _finalSacrifice: false,
    _dragonOfferings: {}, _permStatBoosts: {},
    // A3: Wave battle system
    _waveNoDamage: true, _waveBattlesCompleted: 0, _wavePerfectClear: 0,
    _waveTempAtk: 0, _waveTempDef: 0
  };
  // Inject heal-popup CSS
  var _hpStyle = document.createElement('style');
  _hpStyle.textContent = '.heal-popup{color:#22c55e!important;text-shadow:0 0 4px #000,0 0 8px #0f0!important;}';
  document.head.appendChild(_hpStyle);
  // Restore location unlock state based on story progress
  _restoreLocationUnlocks();
}

// Restore which locations are unlocked based on completed chapters
// Map old chapter IDs to new ones for savegame compatibility
var _OLD_CHAPTER_MAP = {
  'ch1_first_quest': 'ch1_lake_mystery',
  'ch1_explore': 'ch1_lake_explore',
  'ch1_boss': 'ch1_boss_pre',
  'ch2_forest': 'ch2_forest_warning',
  'ch2_fortress': 'ch2_fortress_discovery',
  'ch3_mine': 'ch3_mine_entrance'
};

function _resolveChapterId(chapterId) {
  // If the ID is not in STORY, try mapping from old ID
  var found = STORY.find(function(s) { return s.id === chapterId; });
  if (found) return chapterId;
  return _OLD_CHAPTER_MAP[chapterId] || chapterId;
}

function _restoreLocationUnlocks() {
  // Always reset to initial state first
  var locKeys = Object.keys(LOCATIONS);
  for (var i = 0; i < locKeys.length; i++) {
    LOCATIONS[locKeys[i]].unlocked = (locKeys[i] === 'whitecity');
  }
  // Replay unlocks based on all completed story chapters
  if (!G.storyProgress || !G.storyProgress.chapterId) return;
  var resolvedId = _resolveChapterId(G.storyProgress.chapterId);
  var currentIdx = -1;
  for (var j = 0; j < STORY.length; j++) {
    if (STORY[j].id === resolvedId) { currentIdx = j; break; }
  }
  // If still not found, unlock based on player level as fallback
  if (currentIdx < 0) {
    // Estimate progress: unlock locations based on level
    var _lv = G.level || 1;
    if (_lv >= 5) { if (LOCATIONS.lake) LOCATIONS.lake.unlocked = true; }
    if (_lv >= 8) { if (LOCATIONS.darkforest) LOCATIONS.darkforest.unlocked = true; }
    if (_lv >= 12) { if (LOCATIONS.fortress) LOCATIONS.fortress.unlocked = true; }
    if (_lv >= 16) { if (LOCATIONS.mine) LOCATIONS.mine.unlocked = true; }
    if (_lv >= 20) { if (LOCATIONS.ironridge) LOCATIONS.ironridge.unlocked = true; }
    if (_lv >= 25) { if (LOCATIONS.tidport) LOCATIONS.tidport.unlocked = true; if (LOCATIONS.snowpeak) LOCATIONS.snowpeak.unlocked = true; if (LOCATIONS.coastcave) LOCATIONS.coastcave.unlocked = true; }
    return;
  }
  // Unlock all locations from chapters up to and including current
  for (var k = 0; k <= currentIdx; k++) {
    var unlocks = CHAPTER_UNLOCKS[STORY[k].id] || [];
    for (var m = 0; m < unlocks.length; m++) {
      if (LOCATIONS[unlocks[m]]) LOCATIONS[unlocks[m]].unlocked = true;
    }
  }
}

// ═══════════════════════════════════════════════════════════
// SAVE/LOAD SYSTEM - localStorage persistence
// ═══════════════════════════════════════════════════════════
var SAVE_SLOTS = 3;
var SAVE_KEY_PREFIX = 'dragonpath_save_';

function saveGame(slot) {
  if (slot === undefined || slot === null) slot = 1;
  // Snapshot current scene for scene restoration on load
  if (!G._lastSaveScene) G._lastSaveScene = G._currentScene || 'sceneTown';
  // Calculate play time
  if (!G._playStartTs && G.gameStarted) G._playStartTs = Date.now();
  var playSeconds = G._playStartTs ? Math.floor((Date.now() - G._playStartTs) / 1000) + (G._accumulatedPlaySec || 0) : (G._accumulatedPlaySec || 0);
  var saveData = {
    version: 8,
    timestamp: Date.now(),
    G: JSON.parse(JSON.stringify(G))
  };
  // Store play time in save data (not in G to avoid circular bloat)
  saveData.playSeconds = playSeconds;
  // Remove non-serializable / runtime-only fields
  delete saveData.G.inBattle;
  delete saveData.G.battle;
  delete saveData.G.attackMode;
  // Keep _currentScene, _lastSaveScene, miniMapPos, _inDeepDive, _ddFloor etc for scene restoration
  try {
    localStorage.setItem(SAVE_KEY_PREFIX + slot, JSON.stringify(saveData));
    toast('💾 存档' + slot + '号位保存成功!');
    return true;
  } catch(e) {
    toast('❌ 存档失败: ' + e.message);
    return false;
  }
}

function loadGame(slot) {
  if (slot === undefined || slot === null) slot = 1;
  try {
    var raw = localStorage.getItem(SAVE_KEY_PREFIX + slot);
    if (!raw) { toast('📭 存档' + slot + '号位为空'); return false; }
    var saveData = JSON.parse(raw);
    if (!saveData || !saveData.G) { toast('❌ 存档数据损坏'); return false; }
    // Version migration
    var saveVer = saveData.version || 1;
    // Restore game state
    var savedG = saveData.G;
    // Merge with current G to preserve any new fields
    for (var key in savedG) {
      if (savedG.hasOwnProperty(key)) G[key] = savedG[key];
    }
    // ═══ A4: Explicit field migration / defaults ═══
    // Ensure critical collection fields exist
    if (!G.materials) G.materials = {};
    if (!G.npcRelations) G.npcRelations = {};
    if (!G.bossDefeated) G.bossDefeated = {};
    if (!G.eliteDefeated) G.eliteDefeated = {};
    if (!G.quests) G.quests = [];
    if (!G.guildQuests) G.guildQuests = [];
    if (!G.sideQuestProgress) G.sideQuestProgress = {};
    if (!G.equipment) G.equipment = { weapon:null, helmet:null, armor:null, gloves:null, boots:null, belt:null, necklace:null, ring:null };
    // A4: Story flags — ensure all 29 flags have correct defaults if missing from old saves
    if (G._eastPath === undefined) G._eastPath = false;
    if (G._westPath === undefined) G._westPath = false;
    if (G._lootBonus === undefined) G._lootBonus = 0;
    if (G._socialBonus === undefined) G._socialBonus = 0;
    if (G._dragonAlly === undefined) G._dragonAlly = false;
    if (G._humanAlly === undefined) G._humanAlly = false;
    if (G._neutralPath === undefined) G._neutralPath = false;
    if (G._altruistRoute === undefined) G._altruistRoute = false;
    if (G._egoRoute === undefined) G._egoRoute = false;
    if (G._balanceRoute === undefined) G._balanceRoute = false;
    if (G._sealChosen === undefined) G._sealChosen = false;
    if (G._shadowReduction === undefined) G._shadowReduction = 0;
    if (G._rushPath === undefined) G._rushPath = false;
    if (G._heartReturned === undefined) G._heartReturned = false;
    if (G._heartTaken === undefined) G._heartTaken = false;
    if (G._heartShard === undefined) G._heartShard = false;
    if (G._seekTruth === undefined) G._seekTruth = false;
    if (G._critBonus === undefined) G._critBonus = 0;
    if (G._seekMercy === undefined) G._seekMercy = false;
    if (G._mercyKill === undefined) G._mercyKill = false;
    if (G._purifyFrost === undefined) G._purifyFrost = false;
    if (G._delayFrost === undefined) G._delayFrost = false;
    if (G._destroyShadow === undefined) G._destroyShadow = false;
    if (G._understandShadow === undefined) G._understandShadow = false;
    if (G._resistWhisper === undefined) G._resistWhisper = false;
    if (G._listenWhisper === undefined) G._listenWhisper = false;
    if (G._shareWhisper === undefined) G._shareWhisper = false;
    if (G._finalDestroy === undefined) G._finalDestroy = false;
    if (G._finalAccept === undefined) G._finalAccept = false;
    if (G._finalSacrifice === undefined) G._finalSacrifice = false;
    // A3: Wave battle system defaults
    if (G._waveNoDamage === undefined) G._waveNoDamage = true;
    if (G._waveBattlesCompleted === undefined) G._waveBattlesCompleted = 0;
    if (G._wavePerfectClear === undefined) G._wavePerfectClear = 0;
    if (G._waveTempAtk === undefined) G._waveTempAtk = 0;
    if (G._waveTempDef === undefined) G._waveTempDef = 0;
    // C10: Dragon offering / permanent stat boosts
    if (!G._dragonOfferings) G._dragonOfferings = {};
    if (!G._permStatBoosts) G._permStatBoosts = {};
    // A4: Version 6 → 7 migration — reconstruct story flags from storyChoices/storyProgress if missing
    if (saveVer < 7 && G.storyChoices) {
      // Map storyChoices effect keys to their flag assignments
      var _effectFlagMap = {
        'east_path': ['_eastPath', true],
        'west_path': ['_westPath', true],
        'dragon_ally': ['_dragonAlly', true],
        'human_ally': ['_humanAlly', true],
        'neutral_path': ['_neutralPath', true],
        'altruist': ['_altruistRoute', true],
        'ego': ['_egoRoute', true],
        'balance': ['_balanceRoute', true],
        'seal_chosen': ['_sealChosen', true],
        'rush_path': ['_rushPath', true],
        'return_heart': ['_heartReturned', true],
        'take_heart': ['_heartTaken', true],
        'shard_heart': ['_heartShard', true],
        'seek_truth': ['_seekTruth', true],
        'seek_mercy': ['_seekMercy', true],
        'mercy_kill': ['_mercyKill', true],
        'purify_frost': ['_purifyFrost', true],
        'delay_frost': ['_delayFrost', true],
        'destroy_shadow': ['_destroyShadow', true],
        'understand_shadow': ['_understandShadow', true],
        'resist_whisper': ['_resistWhisper', true],
        'listen_whisper': ['_listenWhisper', true],
        'share_whisper': ['_shareWhisper', true],
        'final_destroy': ['_finalDestroy', true],
        'final_accept': ['_finalAccept', true],
        'final_sacrifice': ['_finalSacrifice', true]
      };
      // Numeric flags that need value restoration from effects
      var _effectNumMap = {
        'east_path': ['_lootBonus', 0.2],
        'luk_bonus': ['_lootBonus', 0.15],
        'social_bonus': ['_socialBonus', 0.1],
        'seal_chosen': ['_shadowReduction', 0.1],
        'return_heart': ['_shadowReduction', 0.15],
        'do_duty': ['_critBonus', 0.05]
      };
      for (var eff in G.storyChoices) {
        if (G.storyChoices[eff]) {
          if (_effectFlagMap[eff] && !G[_effectFlagMap[eff][0]]) {
            G[_effectFlagMap[eff][0]] = _effectFlagMap[eff][1];
          }
          if (_effectNumMap[eff]) {
            G[_effectNumMap[eff][0]] = (G[_effectNumMap[eff][0]] || 0) + _effectNumMap[eff][1];
          }
        }
      }
    }
    // A4: Ensure other commonly-forgotten runtime fields
    if (!G.storyChoices) G.storyChoices = {};
    if (!G.permStats) G.permStats = {};
    if (G.permStats.str === undefined) G.permStats.str = 0;
    if (G.permStats.agi === undefined) G.permStats.agi = 0;
    if (G.permStats.int === undefined) G.permStats.int = 0;
    if (G.permStats.cha === undefined) G.permStats.cha = 0;
    if (G.permStats.luk === undefined) G.permStats.luk = 0;
    if (!G.completedQuests) G.completedQuests = [];
    if (!G.chaptersCompleted) G.chaptersCompleted = {};
    if (!G.dd) G.dd = { floor:0, shopBuys:{}, permBuffCount:0, permBuffs:[] };
    if (!G.dd.permBuffs) G.dd.permBuffs = [];
    if (!G._setCompleteCount) G._setCompleteCount = {};
    if (!G._tradeMissions) G._tradeMissions = { active:[], doneToday:[] };
    if (!G._weather) G._weather = null;
    if (!G._tutorial) G._tutorial = null;
    if (!G._skillCooldowns) G._skillCooldowns = {};
    if (G._perfectBattles === undefined) G._perfectBattles = 0;
    if (G._rareKills === undefined) G._rareKills = 0;
    if (G._enemyKills === undefined) G._enemyKills = 0;
    if (G._fullExploredLocs === undefined) G._fullExploredLocs = [];
    if (G._fullExploreCount === undefined) G._fullExploreCount = 0;
    if (!G._mapMarkers) G._mapMarkers = [];
    if (!G.achievementCount) G.achievementCount = {};
    if (!G.storyProgress) G.storyProgress = { chapterId: null, completed: {} };
    if (!G.storyProgress.chosenEffects) G.storyProgress.chosenEffects = [];
    // Migrate old accessory slot
    if (G.equipment.accessory && !G.equipment.necklace && !G.equipment.ring) { G.equipment.necklace = G.equipment.accessory; delete G.equipment.accessory; }
    G.inBattle = false;
    G.battle = null;
    // Migrate old chapter IDs to new ones
    if (G.storyProgress && G.storyProgress.chapterId) {
      var resolvedId = _resolveChapterId(G.storyProgress.chapterId);
      if (resolvedId !== G.storyProgress.chapterId) {
        G.storyProgress.chapterId = resolvedId;
      }
    }
    // Restore location unlocks
    _restoreLocationUnlocks();
    // Play time tracking
    G._playStartTs = Date.now();
    G._accumulatedPlaySec = saveData.playSeconds || 0;
    // Scene restoration: determine which scene to navigate to
    G._pendingSceneRestore = _determineLoadScene(saveData);
    toast('📂 存档' + slot + '号位读取成功!');
    return true;
  } catch(e) {
    toast('❌ 读档失败: ' + e.message);
    return false;
  }
}

function _determineLoadScene(saveData) {
  // Priority: deep dive > mini map > town > world map
  var savedG = saveData.G;
  // 1. If player was in deep dive, restore to sceneDeepDive
  if (savedG._inDeepDive && savedG._ddFloor) {
    return 'sceneDeepDive';
  }
  // 2. If player had miniMapPos and location is non-town, restore to enterMiniMap
  var loc = LOCATIONS[savedG.location];
  if (savedG.miniMapPos && loc && loc.unlocked && loc.type !== 'town' && loc.mapConfig) {
    return 'enterMiniMap';
  }
  // 3. If player was in a town location, restore to sceneTown
  if (loc && loc.unlocked && loc.type === 'town') {
    return 'sceneTown';
  }
  // 4. Fallback: saved scene or world map
  return savedG._lastSaveScene || savedG._currentScene || 'sceneWorldMap';
}

function _restoreSceneAfterLoad() {
  // Called after loadGame to navigate to the correct scene
  if (!G._pendingSceneRestore) {
    sceneWorldMap();
    return;
  }
  var target = G._pendingSceneRestore;
  delete G._pendingSceneRestore;
  // Clear combat/battle flags before scene switch
  G.inBattle = false;
  G.battle = null;
  // Skip auto-redirect in sceneWorldMap to prevent loops
  if (target === 'enterMiniMap' || target === 'sceneWorldMap') {
    G._skipAutoRedirect = true;
  }
  try {
    if (typeof window[target] === 'function') {
      window[target]();
    } else {
      sceneWorldMap();
    }
  } catch(e) {
    sceneWorldMap();
  }
  // Reset skip flag after a tick
  if (G._skipAutoRedirect) {
    setTimeout(function() { G._skipAutoRedirect = false; }, 100);
  }
}

function getSaveInfo(slot) {
  try {
    var raw = localStorage.getItem(SAVE_KEY_PREFIX + slot);
    if (!raw) return null;
    var saveData = JSON.parse(raw);
    if (!saveData || !saveData.G) return null;
    var d = new Date(saveData.timestamp);
    var savedG = saveData.G;
    var loc = LOCATIONS[savedG.location];
    var locName = loc ? loc.name : (savedG.location || '???');
    // Play time formatting
    var totalSec = saveData.playSeconds || 0;
    var hrs = Math.floor(totalSec / 3600);
    var mins = Math.floor((totalSec % 3600) / 60);
    var playTimeStr = '';
    if (hrs > 0) playTimeStr = hrs + 'h' + mins + 'm';
    else playTimeStr = mins + 'm';
    // Chapter info
    var chapterStr = '';
    if (savedG.storyProgress && savedG.storyProgress.chapterId) {
      var ch = STORY.find(function(s) { return s.id === savedG.storyProgress.chapterId; });
      if (ch) chapterStr = ch.title || ch.id;
    }
    return {
      name: savedG.name || '冒险者',
      level: savedG.level || 1,
      origin: savedG.origin ? savedG.origin.name : '???',
      gold: savedG.gold || 0,
      hp: savedG.hp ? Math.floor(savedG.hp / (savedG.maxHp || 1) * 100) : 100,
      location: locName,
      chapter: chapterStr,
      playTime: playTimeStr,
      inDeepDive: !!savedG._inDeepDive,
      ddFloor: savedG._ddFloor || 0,
      time: (d.getMonth()+1) + '/' + d.getDate() + ' ' + d.getHours() + ':' + String(d.getMinutes()).padStart(2,'0')
    };
  } catch(e) { return null; }
}

function deleteSave(slot) {
  try {
    localStorage.removeItem(SAVE_KEY_PREFIX + slot);
    toast('🗑️ 存档' + slot + '号位已删除');
  } catch(e) { toast('❌ 删除失败'); }
}

function exportSave(slot) {
  try {
    var raw = localStorage.getItem(SAVE_KEY_PREFIX + slot);
    if (!raw) { toast('📭 该槽位为空'); return; }
    // Create downloadable file
    var blob = new Blob([raw], {type: 'application/json'});
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = 'dragonpath_save_' + slot + '_' + Date.now() + '.json';
    a.click();
    URL.revokeObjectURL(url);
    toast('📤 存档导出成功!');
  } catch(e) { toast('❌ 导出失败: ' + e.message); }
}

function importSave(slot) {
  // Create file input
  var input = document.createElement('input');
  input.type = 'file';
  input.accept = '.json';
  input.onchange = function(e) {
    var file = e.target.files[0];
    if (!file) return;
    var reader = new FileReader();
    reader.onload = function(ev) {
      try {
        var data = JSON.parse(ev.target.result);
        if (!data || !data.G) { toast('❌ 无效的存档文件'); return; }
        localStorage.setItem(SAVE_KEY_PREFIX + slot, ev.target.result);
        toast('📥 存档导入成功!');
        sceneSaveLoad();
      } catch(err) {
        toast('❌ 导入失败: ' + err.message);
      }
    };
    reader.readAsText(file);
  };
  input.click();
}

function sceneSaveLoad() {
  var html = '';
  html += '<div class="scene-title">💾 存档/读档</div>';

  // Check if any saves exist
  var anySaves = false;
  try { for (var si = 0; si < 4; si++) { if (localStorage.getItem('dragonpath_save_' + si)) { anySaves = true; break; } } } catch(e) {}

  if (!anySaves) {
    html += '<div class="inv-empty" style="margin:20px 0">暂无存档,开始冒险后会自动存档。</div>';
    html += '<div class="btns">';
    html += '<button class="btn" onclick="sceneIntro()">↩️ 返回</button>';
    html += '</div>';
    render(html);
    return;
  }

  // Auto-save slot (slot 0)
  var autoInfo = getSaveInfo(0);
  html += '<div class="save-slot save-slot-auto">';
  html += '<div class="slot-header">🔄 自动存档</div>';
  if (autoInfo) {
    html += _renderSaveSlotInfo(autoInfo);
    html += '<div class="slot-btns">';
    html += '<button class="btn btn-small" onclick="loadGame(0);_restoreSceneAfterLoad()">📂 读取</button>';
    html += '<button class="btn btn-small" onclick="exportSave(0)">📤</button>';
    html += '</div>';
  } else {
    html += '<div class="slot-info" style="opacity:0.4">暂无自动存档</div>';
  }
  html += '</div>';

  // Manual save slots (1-3)
  for (var i = 1; i <= SAVE_SLOTS; i++) {
    var info = getSaveInfo(i);
    html += '<div class="save-slot">';
    html += '<div class="slot-header">📁 手动存档 ' + i + '</div>';
    if (info) {
      html += _renderSaveSlotInfo(info);
      html += '<div class="slot-btns">';
      html += '<button class="btn btn-small" onclick="loadGame(' + i + ');_restoreSceneAfterLoad()">📂 读档</button>';
      html += '<button class="btn btn-small" onclick="saveGame(' + i + ');sceneSaveLoad()">💾 覆盖</button>';
      html += '<button class="btn btn-small" onclick="exportSave(' + i + ')">📤</button>';
      html += '<button class="btn btn-small btn-danger" onclick="if(confirm(\'确定删除存档' + i + '?\')){deleteSave(' + i + ');sceneSaveLoad()}">🗑️</button>';
      html += '</div>';
    } else {
      html += '<div class="slot-info" style="opacity:0.4">空存档位</div>';
      html += '<div class="slot-btns">';
      html += '<button class="btn btn-small" onclick="saveGame(' + i + ');sceneSaveLoad()">💾 保存</button>';
      html += '<button class="btn btn-small" onclick="importSave(' + i + ')">📥</button>';
      html += '</div>';
    }
    html += '</div>';
  }

  html += '<div class="slot-note">⚠️ 存档保存在浏览器本地,清除浏览器数据会丢失存档 · 📤📤可导出/导入备份</div>';
  html += '<div class="btns">';
  var returnScene = (G.gameStarted) ? 'sceneWorldMap' : 'sceneIntro';
  html += '<button class="btn" onclick="' + returnScene + '()">返回</button>';
  if (G.gameStarted) html += '<button class="btn" onclick="restartTutorial()" style="font-size:0.85em">📖 重看引导</button>';
  html += '</div>';
  render(html);
}

function _renderSaveSlotInfo(info) {
  var html = '';
  html += '<div class="slot-info">';
  html += '<span style="font-weight:bold">' + info.name + '</span> | Lv.' + info.level + ' ' + info.origin + ' | 💰' + info.gold;
  html += '</div>';
  // Second line: location + HP + chapter
  html += '<div class="slot-info" style="font-size:0.85em;opacity:0.9">';
  html += '📍 ' + info.location;
  if (info.inDeepDive && info.ddFloor) html += ' <span style="color:#a855f7">🕳️ 深渊' + info.ddFloor + '层</span>';
  html += ' | ❤️' + info.hp + '%';
  if (info.chapter) html += ' | 📖 ' + info.chapter;
  html += '</div>';
  // Third line: play time + save time
  html += '<div class="slot-time">';
  if (info.playTime) html += '⏱️ ' + info.playTime + ' ';
  html += info.time;
  html += '</div>';
  return html;
}

function autoSave() {
  if (G && G.name && G.gameStarted) {
    saveGame(0); // slot 0 = auto-save
  }
}

// Auto-save on milestones (not timer) - triggered from endBattle(completeStoryChapter) and boss defeat
// Removed: setInterval timer auto-save to reduce save frequency

// ═══════════════════════════════════════════════════════════
// UTILS
// ═══════════════════════════════════════════════════════════

function rand(min, max) { return Math.floor(Math.random() * (max - min + 1)) + min; }
function getEffStat(stat) {
  var base = G[stat] || 0;
  var eqKeys = ['weapon','helmet','armor','gloves','boots','belt','necklace','ring'];
  for (var i = 0; i < eqKeys.length; i++) {
    var item = G.equipment[eqKeys[i]];
    if (!item) continue;
    // Direct stat on item (includes affix-applied values from generateRandomDrop)
    if (item[stat]) base += (item[stat] || 0);
    // Also check affixes for this stat
    if (item.affixes && Array.isArray(item.affixes)) {
      for (var ai = 0; ai < item.affixes.length; ai++) {
        if (item.affixes[ai].stat === stat) base += (Number(item.affixes[ai].value) || 0);
      }
    }
  }
  // NPC affinity buffs (stat bonuses from NPC relationships)
  if (G._npcBuffs) { for (var _k in G._npcBuffs) { if (_k.endsWith('_' + stat)) base += G._npcBuffs[_k]; } }
  // C10: Dragon offering permanent stat boosts
  if (G._permStatBoosts && G._permStatBoosts[stat]) base += G._permStatBoosts[stat];
  // Set bonus: Lucky Merchant 2-piece lukBonus
  if (stat === 'luk') {
    var sbLuk = calcSetBonuses();
    if (sbLuk.lukBonus) base += sbLuk.lukBonus;
  }
  return base;
}

function calcMaxHp() {
  var effStr = getEffStat('str');
  var base = 100 + effStr * 5;
  // All equipment hp (direct + affixes) via getEffStat
  base += getEffStat('hp');
  // Set bonus: Giant prefix or guardian defMult
  var hpMult = 0;
  var eqKeys = ['weapon','helmet','armor','gloves','boots','belt','necklace','ring'];
  for (var gi = 0; gi < eqKeys.length; gi++) {
    var eqItem = G.equipment[eqKeys[gi]];
    if (eqItem && eqItem.prefix && eqItem.prefix.stat === 'maxHp') hpMult += eqItem.prefix.mult;
  }
  var sb = calcSetBonuses();
  if (sb.hpMult) hpMult += sb.hpMult;
  if (hpMult > 0) base = Math.floor(base * (1 + hpMult));
  // NPC affinity buffs
  if (G._npcBuffs) { for (var _k in G._npcBuffs) { if (_k.endsWith('_hp')) base += G._npcBuffs[_k]; } }
  // C10: Dragon offering permanent HP boost
  if (G._permStatBoosts && G._permStatBoosts.maxHp) base += G._permStatBoosts.maxHp;
  return base;
}
function calcMaxMp() { return 50 + getEffStat('int') * 3 + (G._permStatBoosts && G._permStatBoosts.maxMp ? G._permStatBoosts.maxMp : 0); }
function calcAtk() {
  var base = getEffStat('str') * 2 + getEffStat('atk');
  // Prefix bonuses (multiplicative)
  var eqKeys = ['weapon','helmet','armor','gloves','boots','belt','necklace','ring'];
  for (var pi = 0; pi < eqKeys.length; pi++) {
    var pItem = G.equipment[eqKeys[pi]];
    if (pItem && pItem.prefix) {
      if (pItem.prefix.stat === 'atk') base = Math.floor(base * (1 + (pItem.prefix.mult || 0)));
      if (pItem.prefix.stat === 'atkFlat') base += (pItem.prefix.value || 0);
    }
  }
  var sb = calcSetBonuses();
  // NPC affinity buffs
  if (G._npcBuffs) { for (var _k in G._npcBuffs) { if (_k.endsWith('_atk')) base += G._npcBuffs[_k]; } }
  // A3: Wave temp buff
  if (G._waveTempAtk) base += G._waveTempAtk;
  return base;
}
function calcMagicAtk() {
  var base = Math.floor(getEffStat('int') * 1.5) + getEffStat('matk');
  // Prefix (multiplicative)
  var eqKeys = ['weapon','helmet','armor','gloves','boots','belt','necklace','ring'];
  for (var mi = 0; mi < eqKeys.length; mi++) {
    var mItem = G.equipment[eqKeys[mi]];
    if (mItem && mItem.prefix) {
      if (mItem.prefix.stat === 'matk') base = Math.floor(base * (1 + (mItem.prefix.mult || 0)));
    }
  }
  // Set bonus: arcane_sage matkMult
  var sb = calcSetBonuses();
  if (sb.matkMult) base = Math.floor(base * (1 + sb.matkMult));
  return base;
}
function calcSkillDmg(sk) {
  var base = rand(sk.dmgMin, sk.dmgMax);
  if (sk.damageType === 'magic') {
    base += Math.floor(calcMagicAtk() * 0.6);
  } else if (sk.damageType === 'physical') {
    base += Math.floor(calcAtk() * 0.5);
  } else {
    // hybrid or unspecified: average of both
    base += Math.floor((calcAtk() + calcMagicAtk()) * 0.3);
  }
  // Apply weather modifier
  base = applyWeatherToDamage(base, sk.damageType === 'magic', G.location);
  return base;
}
function calcDef() {
  var base = getEffStat('def');
  // Prefix (multiplicative)
  var eqKeys = ['weapon','helmet','armor','gloves','boots','belt','necklace','ring'];
  for (var di = 0; di < eqKeys.length; di++) {
    var dItem = G.equipment[eqKeys[di]];
    if (dItem && dItem.prefix) {
      if (dItem.prefix.stat === 'def') base = Math.floor(base * (1 + (dItem.prefix.mult || 0)));
    }
  }
  // Set bonus: guardian defMult
  var sb = calcSetBonuses();
  if (sb.defMult) base = Math.floor(base * (1 + sb.defMult));
  // NPC affinity buffs
  if (G._npcBuffs) { for (var _k in G._npcBuffs) { if (_k.endsWith('_def')) base += G._npcBuffs[_k]; } }
  // A3: Wave temp buff
  if (G._waveTempDef) base += G._waveTempDef;
  return base;
}
function calcCrit() {
  var base = 5 + getEffStat('luk') * 0.5 + getEffStat('critRate');
  var eqKeys = ['weapon','helmet','armor','gloves','boots','belt','necklace','ring'];
  for (var ci = 0; ci < eqKeys.length; ci++) {
    var cItem = G.equipment[eqKeys[ci]];
    if (cItem) {
      if (cItem.critRate) base += (Number(cItem.critRate) || 0) * 100;
      if (cItem.effects && Array.isArray(cItem.effects)) {
        for (var ck = 0; ck < cItem.effects.length; ck++) {
          if (cItem.effects[ck].type === 'crit') base += (Number(cItem.effects[ck].value) || 0) * 100;
        }
      }
    }
  }
  var sb = calcSetBonuses();
  if (sb.critBonus) base += (Number(sb.critBonus) || 0) * 100;
  // A4: Story choice crit bonus (do_duty = +5%)
  if (G._critBonus) base += G._critBonus * 100;
  // C10: Dragon offering permanent crit boost
  if (G._permStatBoosts && G._permStatBoosts.critRate) base += G._permStatBoosts.critRate * 100;
  return isNaN(base) ? 5 : Math.min(50, base);
}
function calcCritDmg() { return 0.5 + getEffStat('luk') * 0.02; }
function calcDodge() {
  var base = getEffStat('agi') * 0.8 + getEffStat('dodge');
  var eqKeys = ['weapon','helmet','armor','gloves','boots','belt','necklace','ring'];
  for (var di = 0; di < eqKeys.length; di++) {
    var dItem = G.equipment[eqKeys[di]];
    if (dItem) {
      if (dItem.dodge) base += (Number(dItem.dodge) || 0) * 100;
      if (dItem.prefix && dItem.prefix.stat === 'dodge') base += (Number(dItem.prefix.mult) || 0) * 100;
    }
  }
  var sb = calcSetBonuses();
  if (sb.dodgeBonus) base += (Number(sb.dodgeBonus) || 0) * 100;
  return isNaN(base) ? 0 : Math.min(40, base);
}
function calcNextXp(lvl) { return Math.floor(150 + lvl * lvl * 18 + lvl * 80); }
function updateStatus() {
  var el = document.getElementById('status');
  if (!el) return;
  var ch = getCurrentChapter();
  var prog = ch ? getChapterProgress() : null;
  var chLabel = prog ? ' <span class="status-chapter" onclick="showStory()" style="cursor:pointer;color:#d4a017">📖' + prog.done + '/' + prog.total + '</span>' : '';
  var statusHtml = 'Lv.' + G.level + ' | ❤️' + G.hp + '/' + G.maxHp + ' | 💧' + G.mp + '/' + G.maxMp + ' | 💰' + G.gold + chLabel;
  // Show active buffs/debuffs in battle
  if (G.battle) {
    var b = G.battle;
    var buffs = [];
    if (b.atkBuff && b.atkBuffTurns > 0) buffs.push('⚔️+' + Math.floor(b.atkBuff * 100) + '%(' + b.atkBuffTurns + ')');
    if (b.defBuff && b.defBuffTurns > 0) buffs.push('🛡️+' + Math.floor(b.defBuff * 100) + '%(' + b.defBuffTurns + ')');
    if (G._tempAtkBuff && G._tempAtkBuffTurns > 0) buffs.push('⚔️⬆(' + G._tempAtkBuffTurns + ')');
    if (b.defending) buffs.push('🛡️防御');
    if (b.shield && b.shield > 0) buffs.push('💠' + b.shield);
    if (G._poisoned && G._poisoned > 0) buffs.push('🧪毒' + Math.floor(G._poisoned));
    if (G._burning && G._burning > 0) buffs.push('🔥燃' + Math.floor(G._burning));
    if (G._bleeding && G._bleeding > 0) buffs.push('🩸血' + Math.floor(G._bleeding));
    if (G._stunned && G._stunTurns > 0) buffs.push('💫晕' + G._stunTurns);
    if (G._frozen && G._freezeTurns > 0) buffs.push('❄️冻' + G._freezeTurns);
    if (G._slowed && G._slowTurns > 0) buffs.push('🐌慢' + G._slowTurns);
    if (buffs.length > 0) statusHtml += ' | ' + buffs.join(' ');
  }
  el.innerHTML = statusHtml;
  // D3: Hide mobile nav during battle
  var nav = document.getElementById('mobileNav');
  if (nav) nav.style.display = (G.inBattle || G.battle) ? 'none' : '';
}
function render(html) { var el = document.getElementById('game'); if (el) el.innerHTML = html; }
function toast(msg) { var el = document.getElementById('toast'); if (el) { el.textContent = msg; el.style.opacity = 1; setTimeout(function() { el.style.opacity = 0; }, 2000); } }


// ═══════════════════════════════════════════════════════════
// SCENE: INTRO
// ═══════════════════════════════════════════════════════════

function sceneIntro() {
  var html = '';
  html += '<div class="scene-title">龙途传说</div>';
  html += '<div class="scene-text" style="text-align:center;line-height:2">';
  html += '<p style="font-size:1.1em;color:#f0c040">五百年前,龙陨落于此。</p>';
  html += '<p>它的血渗入大地,化作十二座城镇;</p>';
  html += '<p>它的鳞片散落四方,成为冒险者追逐的宝藏。</p>';
  html += '<p style="margin-top:12px;color:#888">如今,商路连接着这些城镇,而危险潜伏在道路之外。</p>';
  html += '<p style="margin-top:12px;color:#c0d0f0;font-size:1.05em">你,一个无名之辈,站在命运的岔路口。</p>';
  html += '<p style="color:#e8c170">追寻龙鳞的秘密,还是铸造自己的商路帝国?</p>';
  html += '<p style="color:#888;font-size:0.9em;margin-top:8px">无论选择哪条路--龙途之上,唯勇者行。</p>';
  html += '</div>';
  html += '<div class="btns">';
  html += '<button class="btn btn-primary" onclick="sceneSelectOrigin()">🎮 开始冒险</button>';
  // Always show load button
  html += '<button class="btn" onclick="sceneSaveLoad()">📂 读取存档</button>';
  html += '</div>';
  render(html);
  updateStatus();
}

function sceneWorldIntro() {
  var html = '';
  html += '<div class="scene-title">世界观</div>';
  html += '<div class="scene-text">';
  html += '<p>五百年前,龙陨落于此。</p>';
  html += '<p>它的血渗入大地,化作十二座城镇;它的鳞片散落四方,成为冒险者追逐的宝藏。</p>';
  html += '<p>如今,商路连接着这些城镇,而危险潜伏在道路之外。</p>';
  html += '<p>你,一个无名之辈,站在白城的城门前。</p>';
  html += '<p>你的故事,才刚刚开始。</p>';
  html += '</div>';
  html += '<button class="btn" onclick="sceneIntro()">↩️ 返回</button>';
  render(html);
}

// ═══════════════════════════════════════════════════════════
// SCENE: SELECT ORIGIN (with back button)
// ═══════════════════════════════════════════════════════════

function sceneSelectOrigin() {
  var html = '';
  html += '<div class="scene-title">选择你的起源</div>';
  html += '<div class="scene-desc">起源决定初始属性和特殊能力,不影响后期发展</div>';

  for (var i = 0; i < ORIGINS.length; i++) {
    var o = ORIGINS[i];
    html += '<div class="origin-card" onclick="selectOrigin(' + i + ')">';
    html += '<div class="origin-emoji">' + o.emoji + '</div>';
    html += '<div class="origin-name">' + o.name + '</div>';
    html += '<div class="origin-attrs">';
    // Show each attr with icon + name + value, clickable for info
    var akeys = ['str','agi','int','cha','luk'];
    for (var j = 0; j < akeys.length; j++) {
      var k = akeys[j];
      var ai = ATTR_INFO[k];
      html += '<span class="attr-tag" onclick="event.stopPropagation();showAttrInfo(\'' + k + '\')" style="cursor:help;border-bottom:1px dashed ' + ai.color + '">' + ai.icon + ai.name + ' ' + o.attr[k] + '</span>';
    }
    html += '</div>';
    html += '<div class="origin-skill">' + o.skill.emoji + ' ' + o.skill.name + ' <span class="skill-type">' + o.skill.type + '</span></div>';
    html += '<div class="origin-skill-desc">' + o.skill.desc + '</div>';
    html += '</div>';
  }

  // Attr info tooltip container
  html += '<div id="attrTooltip" class="attr-tooltip" style="display:none"></div>';

  html += '<button class="btn" onclick="sceneIntro()">↩️ 返回主菜单</button>';
  render(html);
  updateStatus();
}

function showAttrInfo(key) {
  var info = ATTR_INFO[key];
  if (!info) return;
  var el = document.getElementById('attrTooltip');
  if (!el) return;

  var showing = el.getAttribute('data-key');
  if (showing === key) { el.style.display = 'none'; el.setAttribute('data-key', ''); return; }

  var h = '<div class="attr-tooltip-header" style="color:' + info.color + '">' + info.icon + ' ' + info.name + '</div>';
  h += '<div class="attr-tooltip-desc">' + info.desc + '</div>';
  h += '<div class="attr-tooltip-affects"><strong>影响:</strong>' + info.affects.join('、') + '</div>';

  el.innerHTML = h;
  el.style.display = 'block';
  el.setAttribute('data-key', key);
}

function showSkillDetail(skillId) {
  var sk = SKILLS.find(function(s) { return s.id === skillId; });
  if (!sk) return;
  var el = document.getElementById('skillTooltip');
  if (!el) return;

  var showing = el.getAttribute('data-key');
  if (showing === skillId) { el.style.display = 'none'; el.setAttribute('data-key', ''); return; }

  var dmgTypeLabel = sk.damageType === 'magic' ? '🔮 魔法' : sk.damageType === 'physical' ? '⚔️ 物理' : '⚡ 混合';
  var categoryLabel = sk.category === 'spell' ? '📖 法术' : sk.category === 'combat' ? '🗡️ 战斗技能' : '❓ 未知';
  var targetLabel = sk.target === '群攻' ? '🎯 群攻' : sk.target === '自身' ? '🛡️ 自身' : '🎯 单体';

  var h = '<div class="attr-tooltip-header" style="color:#ffcc44">' + sk.emoji + ' ' + sk.name + '</div>';
  h += '<div class="attr-tooltip-desc">' + sk.desc + '</div>';
  h += '<div class="attr-tooltip-affects"><strong>类型:</strong> ' + categoryLabel + ' | ' + dmgTypeLabel + ' | ' + targetLabel + '</div>';
  h += '<div class="attr-tooltip-affects"><strong>消耗:</strong> 💧 ' + sk.cost + ' MP';
  if (sk.reqLevel) h += ' | <strong>等级要求:</strong> Lv.' + sk.reqLevel;
  h += '</div>';
  if (sk.dmgMin) h += '<div class="attr-tooltip-affects"><strong>伤害:</strong> ' + sk.dmgMin + '-' + sk.dmgMax + '</div>';
  if (sk.healMin) h += '<div class="attr-tooltip-affects"><strong>治疗:</strong> ' + sk.healMin + '-' + sk.healMax + '</div>';
  if (sk.missiles) h += '<div class="attr-tooltip-affects"><strong>飞弹数:</strong> ' + sk.missiles + '</div>';
  if (sk.hits) h += '<div class="attr-tooltip-affects"><strong>连击数:</strong> ' + sk.hits + '</div>';
  if (sk.shield) h += '<div class="attr-tooltip-affects"><strong>护盾:</strong> ' + sk.shield + '</div>';
  if (sk.stunChance) h += '<div class="attr-tooltip-affects"><strong>眩晕率:</strong> ' + Math.floor(sk.stunChance*100) + '%</div>';
  if (sk.atkBuff) h += '<div class="attr-tooltip-affects"><strong>攻击加成:</strong> +' + Math.floor(sk.atkBuff*100) + '% ' + (sk.buffTurns||2) + '回合</div>';
  if (sk.critBonus) h += '<div class="attr-tooltip-affects"><strong>暴击加成:</strong> +' + sk.critBonus + '%</div>';
  if (sk.stealRate) h += '<div class="attr-tooltip-affects"><strong>偷窃率:</strong> ' + Math.floor(sk.stealRate*100) + '% + AGI加成</div>';

  el.innerHTML = h;
  el.style.display = 'block';
  el.setAttribute('data-key', skillId);
}

function selectOrigin(idx) {
  G.origin = Object.assign({}, ORIGINS[idx]);
  // Apply base attrs
  G.str = G.origin.attr.str;
  G.agi = G.origin.attr.agi;
  G.int = G.origin.attr.int;
  G.cha = G.origin.attr.cha;
  G.luk = G.origin.attr.luk;
  // Apply start skills
  G.skills = G.origin.startSkills ? G.origin.startSkills.slice() : [];
  // Apply start equipment based on origin (7-slot system)
  if (G.origin.id === 'mage') {
    G.equipment.weapon = { id:'apprentice_staff', name:'学徒法杖', type:'equipment', slot:'weapon', atk:2, matk:14, rarity:'common', rarityColor:'#9ca3af', icon:'⚔️', affixes:[], effects:[] };
    G.equipment.armor = { id:'worn_robe', name:'破旧长袍', type:'equipment', slot:'armor', def:2, hp:10, matk:3, rarity:'common', rarityColor:'#9ca3af', icon:'🛡️', affixes:[], effects:[] };
    G.equipment.helmet = { id:'mage_hat', name:'法师帽', type:'equipment', slot:'helmet', def:1, matk:2, rarity:'common', rarityColor:'#9ca3af', icon:'🪖', affixes:[], effects:[] };
    G.skills.push('iceShard');
  } else if (G.origin.id === 'cleric') {
    G.equipment.weapon = { id:'holy_tome', name:'圣典', type:'equipment', slot:'weapon', atk:3, matk:12, rarity:'common', rarityColor:'#9ca3af', icon:'⚔️', affixes:[], effects:[] };
    G.equipment.necklace = { id:'prayer_beads', name:'祈祷念珠', type:'equipment', slot:'necklace', matk:2, luk:1, rarity:'common', rarityColor:'#9ca3af', icon:'💍', affixes:[], effects:[] };
  } else if (G.origin.id === 'warrior') {
    G.equipment.weapon = { id:'rusty_sword', name:'锈剑', type:'equipment', slot:'weapon', atk:8, rarity:'common', rarityColor:'#9ca3af', icon:'⚔️', affixes:[], effects:[] };
    G.equipment.armor = { id:'leather_vest', name:'皮背心', type:'equipment', slot:'armor', def:3, hp:15, rarity:'common', rarityColor:'#9ca3af', icon:'🛡️', affixes:[], effects:[] };
    G.equipment.belt = { id:'war_belt', name:'战带', type:'equipment', slot:'belt', def:1, hp:8, rarity:'common', rarityColor:'#9ca3af', icon:'🔗', affixes:[], effects:[] };
    G.skills.push('powerStrike');
  } else if (G.origin.id === 'hunter') {
    G.equipment.weapon = { id:'short_bow', name:'短弓', type:'equipment', slot:'weapon', atk:7, rarity:'common', rarityColor:'#9ca3af', icon:'⚔️', affixes:[], effects:[] };
    G.equipment.boots = { id:'hunter_boots', name:'猎手靴', type:'equipment', slot:'boots', def:1, dodge:0.02, rarity:'common', rarityColor:'#9ca3af', icon:'👢', affixes:[], effects:[] };
  } else if (G.origin.id === 'trader') {
    G.equipment.weapon = { id:'dagger', name:'匕首', type:'equipment', slot:'weapon', atk:4, rarity:'common', rarityColor:'#9ca3af', icon:'⚔️', affixes:[], effects:[] };
    G.equipment.belt = { id:'coin_pouch', name:'钱袋腰带', type:'equipment', slot:'belt', hp:5, luk:2, rarity:'common', rarityColor:'#9ca3af', icon:'🔗', affixes:[], effects:[] };
    G.equipment.ring = { id:'merchant_ring', name:'商人指环', type:'equipment', slot:'ring', luk:3, rarity:'common', rarityColor:'#9ca3af', icon:'💍', affixes:[], effects:[] };
    G.gold = 80;
  } else if (G.origin.id === 'gambler') {
    G.equipment.weapon = { id:'lucky_coin', name:'幸运硬币', type:'equipment', slot:'weapon', atk:3, luk:5, rarity:'common', rarityColor:'#9ca3af', icon:'⚔️', affixes:[], effects:[] };
    G.equipment.necklace = { id:'dice_pendant', name:'骰子吊坠', type:'equipment', slot:'necklace', luk:3, rarity:'common', rarityColor:'#9ca3af', icon:'💍', affixes:[], effects:[] };
    G.gold = 30;
  }
  // Recalculate stats after equipment
  G.maxHp = calcMaxHp(); G.hp = G.maxHp;
  G.maxMp = calcMaxMp(); G.mp = G.maxMp;
  sceneOriginStory();
}

function sceneOriginStory() {
  var html = '';
  html += '<div class="scene-title">' + G.origin.emoji + ' ' + G.origin.name + '</div>';
  html += '<div class="origin-story">' + G.origin.story + '</div>';

  // Show goal clearly
  html += '<div style="margin:12px 0;padding:10px 14px;background:rgba(240,192,64,0.1);border-left:3px solid #f0c040;border-radius:4px">';
  html += '<div style="color:#f0c040;font-weight:bold;font-size:0.95em;margin-bottom:4px">🎯 你的目标</div>';
  html += '<div style="color:#ccc;font-size:0.9em;line-height:1.6">探索龙陨之地,追寻龙鳞的秘密,在十二座城镇间开辟属于你的商路。战斗让你变强,贸易让你致富,而龙途的真相,只属于走到最后的人。</div>';
  html += '</div>';

  html += '<div class="skill-detail">';
  html += '<div class="skill-name">' + G.origin.skill.emoji + ' ' + G.origin.skill.name + '</div>';
  html += '<div class="skill-meta">[' + G.origin.skill.type + '] [' + G.origin.skill.target + ']</div>';
  html += '<div class="skill-desc">' + G.origin.skill.desc + '</div>';
  html += '</div>';

  html += '<div class="btns">';
  html += '<button class="btn btn-primary" onclick="sceneNameAndAttrs()">✅ 确认选择</button>';
  html += '<button class="btn" onclick="sceneSelectOrigin()">↩️ 重新选择起源</button>';
  html += '</div>';
  render(html);
}

// ═══════════════════════════════════════════════════════════
// SCENE: NAME & ATTRIBUTE ALLOCATION
// ═══════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════
// DATA: Attribute details for tooltip display
// ═══════════════════════════════════════════════════════════
var ATTR_INFO = {
  str: { name: '体魄', icon: '⚔️', color: '#e74c3c',
    brief: '物攻+2, HP+5',
    desc: '体魄决定你的物理攻击力和生命值上限。每点体魄:物攻+2, 最大HP+5。',
    affects: ['物理攻击力', '最大生命值', '重武器装备需求'] },
  agi: { name: '敏捷', icon: '🏹', color: '#2ecc71',
    brief: '闪避+1%, 先手+',
    desc: '敏捷决定你的闪避率和行动顺序。每点敏捷:闪避+1%, 先手值+1。',
    affects: ['闪避率', '先手值', '轻武器装备需求'] },
  int: { name: '智力', icon: '📖', color: '#3498db',
    brief: '魔攻+2, MP+3',
    desc: '智力决定你的魔法攻击力和法力值上限。每点智力:魔攻+2, 最大MP+3。',
    affects: ['魔法攻击力', '最大法力值', '法术学习需求'] },
  cha: { name: '魅力', icon: '💬', color: '#e67e22',
    brief: '商店折扣, 好感度+',
    desc: '魅力影响NPC对你的态度和交易价格。每点魅力:商店价格-1%, NPC好感度获取+5%。',
    affects: ['商店价格折扣', 'NPC好感度获取', '特殊对话选项'] },
  luk: { name: '幸运', icon: '🍀', color: '#9b59b6',
    brief: '暴击+0.5%, 掉落+',
    desc: '幸运影响暴击率和物品掉落品质。每点幸运:暴击率+0.5%, 稀有掉落率+1%。',
    affects: ['暴击率', '物品掉落品质', '随机事件结果'] }
};

var _attrDraft = null;

function sceneNameAndAttrs() {
  // Save name before re-render (if input exists)
  var savedName = '';
  var nameEl = document.getElementById('charName');
  if (nameEl && nameEl.value) savedName = nameEl.value;

  if (!_attrDraft) {
    _attrDraft = { str:G.str, agi:G.agi, int:G.int, cha:G.cha, luk:G.luk, pts:5 };
  }

  var html = '';
  html += '<div class="scene-title">创建角色</div>';

  // Name input - restore saved value
  html += '<div class="scene-desc" style="margin-bottom:8px">给你的英雄起个名字吧!也可以点击🎲随机生成</div>';
  html += '<div class="name-section">';
  html += '<label>你的名字:</label>';
  html += '<input type="text" id="charName" placeholder="请输入名字..." maxlength="12" value="' + savedName + '">';
  html += '<button class="btn-small" onclick="randomName()">🎲 随机</button>';
  html += '</div>';

  html += '<div class="scene-desc">分配 <strong>5点</strong> 自由属性点(点击属性名查看详情)</div>';

  var akeys = ['str','agi','int','cha','luk'];

  for (var i = 0; i < akeys.length; i++) {
    var k = akeys[i];
    var ai = ATTR_INFO[k];
    var cur = _attrDraft[k];
    var baseVal = G[k];
    var delta = cur - baseVal;

    html += '<div class="attr-row-v5" style="border-left:3px solid ' + ai.color + '">';
    html += '<div class="attr-info">';
    html += '<span class="attr-name-v5" onclick="showAttrInfo(\'' + k + '\')" style="cursor:pointer;color:' + ai.color + '">' + ai.icon + ' ' + ai.name + '</span>';
    html += '<span class="attr-hint-v5">' + ai.brief + '</span>';
    html += '</div>';
    html += '<div class="attr-controls">';
    html += '<button class="attr-btn" onclick="adjAttrV5(\'' + k + '\', -1)" ' + (delta <= 0 ? 'disabled' : '') + '>-</button>';
    html += '<span class="attr-value' + (delta > 0 ? ' attr-boosted' : '') + '">' + cur + (delta > 0 ? ' (+' + delta + ')' : '') + '</span>';
    html += '<button class="attr-btn" onclick="adjAttrV5(\'' + k + '\', 1)" ' + (_attrDraft.pts <= 0 ? 'disabled' : '') + '>+</button>';
    html += '</div>';
    html += '</div>';
  }

  // Attr info tooltip container
  html += '<div id="attrTooltip" class="attr-tooltip" style="display:none"></div>';

  html += '<div class="pts-remaining">剩余点数:<span class="pts-num">' + _attrDraft.pts + '</span></div>';

  html += '<div id="nameWarning" style="display:none;color:#e74c3c;font-size:0.9em;margin-top:4px;padding:4px 8px;background:#2a1a1a;border:1px solid #e74c3c;border-radius:4px">⚠️ 请先为你的角色起个名字!</div>';
  html += '<div class="btns">';
  html += '<button class="btn btn-primary" onclick="confirmNameAndAttrs()">✅ 确认</button>';
  html += '<button class="btn" onclick="resetAttrs()">🔄 重置</button>';
  html += '</div>';

  render(html);
}

function randomName() {
  var names = ['亚瑟','艾拉','雷恩','索菲亚','德里克','露娜','卡斯帕','伊芙琳','罗根','米拉'];
  var el = document.getElementById('charName');
  if (el) el.value = names[rand(0, names.length - 1)];
}

function adjAttrV5(key, delta) {
  if (delta > 0 && _attrDraft.pts <= 0) return;
  var newVal = _attrDraft[key] + delta;
  var baseVal = G[key];
  if (delta < 0 && newVal < baseVal) return;
  _attrDraft[key] = newVal;
  _attrDraft.pts -= delta;
  sceneNameAndAttrs();
}

function resetAttrs() {
  _attrDraft = { str:G.str, agi:G.agi, int:G.int, cha:G.cha, luk:G.luk, pts:5 };
  sceneNameAndAttrs();
}

function confirmNameAndAttrs() {
  var nameEl = document.getElementById('charName');
  var name = nameEl && nameEl.value ? nameEl.value.trim() : '';
  if (!name) {
    var warn = document.getElementById('nameWarning');
    if (warn) { warn.style.display = 'block'; warn.scrollIntoView(); }
    toast('⚠️ 请为你的角色起个名字!');
    return;
  }
  G.name = name;

  // Apply attrs
  G.str = _attrDraft.str;
  G.agi = _attrDraft.agi;
  G.int = _attrDraft.int;
  G.cha = _attrDraft.cha;
  G.luk = _attrDraft.luk;

  // Calc HP/MP
  G.maxHp = calcMaxHp();
  G.hp = G.maxHp;
  G.maxMp = calcMaxMp();
  G.mp = G.maxMp;

  _attrDraft = null;
  G.gameStarted = true;
  G._playStartTs = Date.now();
  // Initialize tutorial system for new players
  G._tutorial = { step: 0, done: false, skipped: false };
  updateStatus();

  // Start the main story!
  startStory();
  showChapterIntro(STORY[0].id);
}


// ═══════════════════════════════════════════════════════════
// SCENE: WORLD MAP (illustrated style)
// ═══════════════════════════════════════════════════════════


function sceneWorldMapOverview() {
  G._currentScene = 'sceneWorldMapOverview';
  var html = '';
  html += '<div class="scene-title">🗺️ 全域地图</div>';
  
  // SVG overview map
  var viewW = 560, viewH = 480;
  html += '<div style="position:relative;width:' + viewW + 'px;height:' + viewH + 'px;background:#0a0f14;border:2px solid #2a3a4a;border-radius:10px;overflow:hidden;margin:0 auto">';
  html += '<svg viewBox="0 0 ' + viewW + ' ' + viewH + '" width="' + viewW + '" height="' + viewH + '">';
  
  // Background regions
  // North (y<160): cold/snow
  html += '<rect x="0" y="0" width="' + viewW + '" height="160" fill="#0d1520" opacity="0.6"/>';
  html += '<text x="280" y="30" fill="#4a6a8a" font-size="11" text-anchor="middle">── 北方冻土 ──</text>';
  // Central (160-320): temperate
  html += '<rect x="0" y="160" width="' + viewW + '" height="160" fill="#0d1a0d" opacity="0.6"/>';
  html += '<text x="280" y="190" fill="#4a8a4a" font-size="11" text-anchor="middle">── 中原沃土 ──</text>';
  // South (320-480): volcanic/desert
  html += '<rect x="0" y="320" width="' + viewW + '" height="160" fill="#1a0d0d" opacity="0.6"/>';
  html += '<text x="280" y="350" fill="#8a4a4a" font-size="11" text-anchor="middle">── 南方龙域 ──</text>';
  
  // Draw connections first (as lines)
  var allLocIds = Object.keys(LOCATIONS);
  var drawnConns = {};
  var lcObj = LOC_CONNECTIONS;
  for (var ci = 0; ci < allLocIds.length; ci++) {
    var fromId = allLocIds[ci];
    var fromLoc = LOCATIONS[fromId];
    if (!fromLoc || !fromLoc.x) continue;
    var conns = lcObj[fromId] || [];
    for (var cj = 0; cj < conns.length; cj++) {
      var toId = conns[cj];
      var toLoc = LOCATIONS[toId];
      if (!toLoc || !toLoc.x) continue;
      var connKey = [fromId, toId].sort().join('-');
      if (drawnConns[connKey]) continue;
      drawnConns[connKey] = true;
      var x1 = fromLoc.x * 1.5 + 30, y1 = fromLoc.y * 1.2 + 50;
      var x2 = toLoc.x * 1.5 + 30, y2 = toLoc.y * 1.2 + 50;
      var isPath = fromLoc.unlocked && toLoc.unlocked;
      html += '<line x1="' + x1 + '" y1="' + y1 + '" x2="' + x2 + '" y2="' + y2 + '" stroke="' + (isPath ? '#3a5a3a' : '#1a2a1a') + '" stroke-width="1.5" stroke-dasharray="' + (isPath ? 'none' : '4,4') + '"/>';
    }
  }
  
  // Draw location nodes
  for (var li = 0; li < allLocIds.length; li++) {
    var lid = allLocIds[li];
    var loc = LOCATIONS[lid];
    if (!loc || !loc.x) continue;
    var cx = loc.x * 1.5 + 30, cy = loc.y * 1.2 + 50;
    var isUnlocked = loc.unlocked;
    var isCurrent = lid === G.location;
    var r = isCurrent ? 14 : (loc.type === 'town' ? 11 : 8);
    var fill = isCurrent ? '#d4a017' : (isUnlocked ? (loc.type === 'town' ? '#4a8a4a' : '#6a8aaa') : '#2a2a2a');
    var stroke = isCurrent ? '#f1c40f' : (isUnlocked ? '#5a5a5a' : '#1a1a1a');
    
    html += '<circle cx="' + cx + '" cy="' + cy + '" r="' + r + '" fill="' + fill + '" stroke="' + stroke + '" stroke-width="' + (isCurrent ? 3 : 1.5) + '" ' + (isUnlocked ? 'onclick="travelTo(\'' + lid + '\')" style="cursor:pointer"' : '') + '/>';
    if (isCurrent) html += '<circle cx="' + cx + '" cy="' + cy + '" r="' + (r + 5) + '" fill="none" stroke="#d4a017" stroke-width="1" opacity="0.5"><animate attributeName="r" values="' + (r+3) + ';' + (r+8) + ';' + (r+3) + '" dur="2s" repeatCount="indefinite"/><animate attributeName="opacity" values="0.6;0.1;0.6" dur="2s" repeatCount="indefinite"/></circle>';
    if (isUnlocked) {
      var label = loc.emoji + ' ' + (loc.name || lid);
      var _explored = (G._fullExploredLocs || {})[lid];
      html += '<text x="' + cx + '" y="' + (cy + r + 12) + '" fill="' + (isCurrent ? '#d4a017' : '#8a8a8a') + '" font-size="9" text-anchor="middle">' + label.substring(0, 6) + (_explored ? ' ✅' : '') + '</text>';
    }
  }
  
  // === D2: Weather indicator on current location ===
  var w = G._weather;
  if (w && WEATHER_TYPES[w] && LOCATIONS[G.location]) {
    var curLoc = LOCATIONS[G.location];
    if (curLoc.x) {
      var wcx = curLoc.x * 1.5 + 30, wcy = curLoc.y * 1.2 + 50 - 20;
      html += '<text x="' + wcx + '" y="' + wcy + '" fill="#aaa" font-size="10" text-anchor="middle">' + WEATHER_TYPES[w].emoji + '</text>';
    }
  }
  
  html += '</svg></div>';
  
  // Legend
  html += '<div style="margin:8px auto;max-width:560px;display:flex;justify-content:space-around;font-size:0.8em;color:#888">';
  html += '<span>🟡 当前位置</span><span>🟢 城镇</span><span>🔵 野外</span><span>⚫ 未发现</span><span>✅ 已完全探索</span>';
  html += '</div>';
  
  html += '<div style="margin-top:12px">';
  html += '<button class="btn" onclick="sceneWorldMap()" style="width:100%">📋 地点列表</button>';
  html += '</div>';
  render(html);
}

function sceneWorldMap() {
  tickWeather();
  // If player is at a non-town location with a mini-map, go there instead
  // (unless user explicitly navigated to world map via the button)
  var _curLoc = LOCATIONS[G.location];
  if (!G._skipAutoRedirect && _curLoc && _curLoc.unlocked && _curLoc.type !== 'town' && _curLoc.mapConfig && G.miniMapPos) {
    enterMiniMap();
    return;
  }
  updateStatus();
  var html = '';
  html += '<div class="scene-title">🗺️ 世界地图 <button class="btn" onclick="sceneWorldMapOverview()" style="font-size:0.7em;margin-left:8px">🌏 鸟瞰</button></div>';

  var currentLoc = LOCATIONS[G.location];
  var currentName = currentLoc ? currentLoc.name : G.location;
  html += '<div class="scene-desc">📍 当前位置:' + currentName + '</div>';

  // Exploration stats
  var allLocIds = Object.keys(LOCATIONS);
  var discovered = 0, explored = 0;
  for (var esi = 0; esi < allLocIds.length; esi++) {
    if (LOCATIONS[allLocIds[esi]].unlocked) discovered++;
    if ((G._locationVisited || {})[allLocIds[esi]]) explored++;
  }
  html += '<div style="display:flex;gap:12px;margin:8px 0;font-size:0.85em">';
  html += '<span style="color:#4a8a4a">🗺️ 已发现 ' + discovered + '/' + allLocIds.length + '</span>';
  html += '<span style="color:#d4a017">👣 已探索 ' + explored + '/' + allLocIds.length + '</span>';
  html += '</div>';

  // Show current location info
  html += '<div class="mini-area" style="border:2px solid #d4a017">';
  var locEmoji = currentLoc.emoji || (currentLoc.type === 'town' ? '🏰' : (currentLoc.type === 'dungeon' ? '⛏️' : '🌲'));
  html += '<div class="mini-area-name">' + locEmoji + ' ' + currentName + ' <span style="color:#4a4;font-size:0.85em">📍你在这里</span></div>';
  if (currentLoc.townDesc) html += '<div class="mini-area-desc">' + currentLoc.townDesc + '</div>';
  else if (currentLoc.mapConfig) html += '<div class="mini-area-desc">' + currentLoc.mapConfig.desc + '</div>';
  // Enter exploration button for non-town locations with mini-map
  if (currentLoc.type !== 'town' && currentLoc.mapConfig) {
    html += '<button class="btn btn-primary" onclick="enterMiniMap()" style="margin-top:8px;width:100%">🔍 进入探索</button>';
  } else if (currentLoc.type === 'town') {
    html += '<button class="btn btn-primary" onclick="sceneTown()" style="margin-top:8px;width:100%">🏰 进入城镇</button>';
  }
  html += '</div>';

  // Show only adjacent locations
  var connections = LOC_CONNECTIONS[G.location] || [];
  html += '<div class="quest-list-title">可达地点</div>';

  if (connections.length === 0) {
    html += '<div class="inv-empty">无法前往其他地点</div>';
  } else {
    html += '<div class="location-list">';
    for (var i = 0; i < connections.length; i++) {
      var locId = connections[i];
      var locData = LOCATIONS[locId];
      if (!locData) continue;
      var isUnlocked = locData.unlocked;
      var locName = locData.name;
      var le = locData.emoji || (locData.type === 'town' ? '🏰' : (locData.type === 'dungeon' ? '⛏️' : '🌲'));
      var locTypeLabel = locData.type === 'town' ? '城镇' : (locData.type === 'dungeon' ? '迷宫' : '野外');

      if (isUnlocked) {
        html += '<div class="loc-card" onclick="travelTo(\'' + locId + '\')" style="cursor:pointer">';
        html += '<div class="loc-emoji">' + le + '</div>';
        html += '<div class="loc-info">';
        var _locTypeTag = locData.type === 'town' ? '<span class="loc-tag town">城镇</span>' : (locData.type === 'dungeon' ? '<span class="loc-tag dungeon">迷宫</span>' : '<span class="loc-tag wild">野外</span>');
        var _locExplored = (G._fullExploredLocs || {})[locId];
        html += '<div class="loc-name">' + locName + _locTypeTag + (_locExplored ? '<span class="loc-tag explored">✅</span>' : '') + '</div>';
        if (locData.townDesc) html += '<div class="loc-desc">' + locData.townDesc.substring(0, 30) + '...</div>';
        else if (locData.mapConfig) html += '<div class="loc-desc">' + locData.mapConfig.desc.substring(0, 30) + '...</div>';
        html += '</div>';
        html += '</div>';
      } else {
        // Show locked hint - "未发现"
        html += '<div class="loc-card" style="opacity:0.4;cursor:default">';
        html += '<div class="loc-emoji">🔒</div>';
        html += '<div class="loc-info">';
        html += '<div class="loc-name">未发现的区域</div>';
        // Show unlock hint based on quest requirements
        var unlockHint = '';
        var unlockQuests = QUESTS.filter(function(q) { return q.rewardTarget === locId && q.rewardType === 'unlock'; });
        if (unlockQuests.length > 0) {
          unlockHint = '完成任务「' + unlockQuests[0].name + '」可解锁';
        } else if (locId === 'lake' || locId === 'darkforest') {
          unlockHint = '完成序章后自动解锁';
        } else {
          unlockHint = '继续冒险可能会发现新地点...';
        }
        html += '<div class="loc-desc">' + unlockHint + '</div>';
        html += '</div>';
        html += '</div>';
      }
    }
    html += '</div>';
  }

  // Show distant discovered locations as a list (no direct travel)
  var distantLocs = [];
  var allLocIds = Object.keys(LOCATIONS);
  for (var j = 0; j < allLocIds.length; j++) {
    var lid = allLocIds[j];
    if (lid === G.location) continue;
    if (connections.indexOf(lid) >= 0) continue; // already shown above
    if (LOCATIONS[lid].unlocked) distantLocs.push(lid);
  }
  if (distantLocs.length > 0) {
    html += '<div class="quest-list-title" style="color:#666">已发现(需中转前往)</div>';
    html += '<div style="color:#555;font-size:0.85em;margin-bottom:8px">以下地点无法直达,需要经停其他地点</div>';
    for (var k = 0; k < distantLocs.length; k++) {
      var dl = LOCATIONS[distantLocs[k]];
      var dle = dl.type === 'town' ? '🏰' : (dl.type === 'dungeon' ? '⛏️' : '🌲');
      var _dlTypeTag = dl.type === 'town' ? '<span class="loc-tag town">城镇</span>' : (dl.type === 'dungeon' ? '<span class="loc-tag dungeon">迷宫</span>' : '<span class="loc-tag wild">野外</span>');
      var _dlExplored = (G._fullExploredLocs || {})[distantLocs[k]];
      html += '<div class="loc-card" style="opacity:0.5;cursor:default">';
      html += '<div class="loc-emoji">' + dle + '</div>';
      html += '<div class="loc-info">';
      html += '<div class="loc-name">' + dl.name + _dlTypeTag + (_dlExplored ? '<span class="loc-tag explored">✅</span>' : '') + '</div>';
      html += '</div>';
      html += '</div>';
    }
  }

  html += '<div class="btns">';
  if (currentLoc.type === 'town') html += '<button class="btn" onclick="sceneTown()">↩️ 返回城镇</button>';
  else html += '<button class="btn" onclick="enterMiniMap()">↩️ 继续探索</button>';
  html += '</div>';

  render(html);
}


// Get story NPC ID for first visit to a location (based on chapter progress)
function _getStoryNpcForLocation(locId) {
  var map = {
    misthollow: 'mist_spirit',
    jademarsh: 'jade_guardian',
    ashplains: 'ash_wanderer',
    abyssgate: 'gatekeeper_abyss',
    stormcape: 'captain_storm',
    dragontemple: 'karis',
    snowpeak: 'frostwing_survivor',
    volcano: 'flame_seer',
    shadowrealm: 'shadow_whisperer',
    throneofages: 'ancient_dragon_spirit'
  };
  return map[locId] || null;
}

function travelTo(locId) {
  if (!LOCATIONS[locId] || !LOCATIONS[locId].unlocked) {
    toast('🔒 尚未解锁');
    return;
  }
  tickWeather();
  if (G.location === locId) {
    var _here = LOCATIONS[locId];
    if (_here && _here.type === 'town') { sceneTown(); return; }
    else if (_here && _here.mapConfig) { enterMiniMap(); return; }
    toast('你已经在这里了');
    return;
  }
  // === D2: Show location detail before traveling ===
  _showLocDetailAndTravel(locId);
}

// === D2: Location detail popup before travel ===
function _showLocDetailAndTravel(locId) {
  var loc = LOCATIONS[locId];
  var html = '';
  var le = loc.emoji || (loc.type === 'town' ? '🏰' : (loc.type === 'dungeon' ? '⛏️' : '🌲'));
  var typeLabel = loc.type === 'town' ? '城镇' : (loc.type === 'dungeon' ? '迷宫' : '野外');
  var typeTag = loc.type === 'town' ? '<span class="loc-tag town">城镇</span>' : (loc.type === 'dungeon' ? '<span class="loc-tag dungeon">迷宫</span>' : '<span class="loc-tag wild">野外</span>');
  var isExplored = (G._fullExploredLocs || {})[locId];
  
  html += '<div class="scene-title">' + le + ' ' + loc.name + '</div>';
  html += '<div style="margin:8px 0">' + typeTag + (isExplored ? '<span class="loc-tag explored">✅ 完全探索</span>' : '') + '</div>';
  
  // Description
  var desc = loc.townDesc || (loc.mapConfig ? loc.mapConfig.desc : '');
  if (desc) html += '<div class="mini-area-desc">' + desc + '</div>';
  
  // Weather at destination
  var destWeather = getWeather(locId);
  if (destWeather) html += '<div class="mini-weather-bar">目的地天气: ' + destWeather.emoji + ' ' + destWeather.name + '</div>';
  
  // Connected locations
  var conns = LOC_CONNECTIONS[locId] || [];
  if (conns.length > 0) {
    html += '<div style="margin:8px 0;font-size:0.85em;color:#888">相连地点: ';
    for (var ci = 0; ci < conns.length; ci++) {
      var cl = LOCATIONS[conns[ci]];
      if (cl) html += (ci > 0 ? ', ' : '') + cl.emoji + cl.name;
    }
    html += '</div>';
  }
  
  // Travel warning for dangerous areas
  if (loc.type !== 'town') {
    html += '<div style="padding:8px;background:rgba(231,76,60,0.08);border:1px solid rgba(231,76,60,0.2);border-radius:6px;margin:8px 0;font-size:0.85em;color:#e74c3c">⚠️ 危险区域，旅途中可能遭遇敌人</div>';
  }
  
  html += '<div class="btns">';
  html += '<button class="btn btn-primary" onclick="_confirmTravel(\'' + locId + '\')">🚶 前往 ' + loc.name + '</button>';
  html += '<button class="btn" onclick="sceneWorldMap()">↩️ 返回</button>';
  html += '</div>';
  render(html);
}

// === D2: Confirm travel from detail popup ===
function _confirmTravel(locId) {
  G.location = locId;
  var loc = LOCATIONS[locId];
  if (!G._exploredLocs) G._exploredLocs = [];
  if (G._exploredLocs.indexOf(locId) < 0) G._exploredLocs.push(locId);
  if (G.eliteDefeated) {
    for (var ek in G.eliteDefeated) {
      if (ek.indexOf(locId + '_') === 0) delete G.eliteDefeated[ek];
    }
  }
  var _travelEncRate = 0.10 + getWeatherEncounterMod(locId);
  if (Math.random() < _travelEncRate && loc.type !== 'town') {
    G._pendingTravelEncounter = true;
  }
  delete _mapCache[locId];
  updateStatus();
  autoSave();
  var travelNarrations = [
    '旅途漫长,你的靴子沾满了泥尘。',
    '远处的山峦在雾中若隐若现,你沿着古道前行。',
    '路旁的树影婆娑,鸟鸣声中夹杂着风声。',
    '你跨过一条小溪,水面映出你疲惫的面容。',
    '脚下的路渐渐变得崎岖,但你知道目的地就在前方。',
    '一阵凉风吹过,带来远方花朵的芬芳。',
    '途中遇到一队商旅,他们向你点头致意。',
    '路边的里程碑告诉你,离目的地又近了一程。',
    '天空中云层变幻,光影在大地上流转。',
    '你沿着前人踩出的路径,一步步走向远方。'
  ];
  var travelNarr = travelNarrations[rand(0, travelNarrations.length - 1)];
  var w = getWeather(locId);
  toast('🚶 ' + loc.name + ' — ' + travelNarr + ' ' + w.emoji + w.travelMsg, 3000);
  _updateVisitQuestProgress(locId);
  if (G._pendingTravelEncounter) {
    delete G._pendingTravelEncounter;
    setTimeout(function() {
      var travelEnemies = ['bandit', 'wolf', 'goblin', 'spider'];
      if (loc.type === 'dungeon' || loc.levelRange) travelEnemies = ['shadow_spider', 'mist_wraith', 'undead'];
      var enemyId = travelEnemies[rand(0, travelEnemies.length - 1)];
      if (ENEMIES[enemyId]) {
        G._travelEncEnemy = JSON.parse(JSON.stringify(ENEMIES[enemyId]));
        G._travelEncEnemy.hp = Math.floor(G._travelEncEnemy.hp * (0.8 + Math.random() * 0.4));
        G._travelEncEnemy.atk = Math.floor(G._travelEncEnemy.atk * (0.8 + Math.random() * 0.4));
        toast('⚔️ 旅途中遭遇敌人!', 2000);
        setTimeout(function() { startBattleWith(G._travelEncEnemy); delete G._travelEncEnemy; }, 500);
      }
    }, 800);
  }
  var storyNpc = _getStoryNpcForLocation(locId);
  if (storyNpc && !G._storyNpcMet) G._storyNpcMet = {};
  if (storyNpc && !G._storyNpcMet[locId]) {
    G._storyNpcMet[locId] = true;
    if (loc.type === 'town') sceneTown();
    else if (loc.mapConfig) enterMiniMap();
    else sceneWorldMap();
    setTimeout(function() { showDialog(storyNpc, 0); }, 600);
    return;
  }
  if (loc.type === 'town') {
    sceneTown();
  } else if (loc.mapConfig) {
    // enterMiniMap will also fire visit_location trigger
    enterMiniMap();
  } else {
    sceneWorldMap();
  }
}

// ═══════════════════════════════════════════════════════════
// MINI-MAP SYSTEM (per-location exploration)
// ═══════════════════════════════════════════════════════════

function leaveMiniMap() {
  // Reset boss defeated status for this location when leaving
  var loc = LOCATIONS[G.location];
  if (loc) {
    var prefix = G.location + '_';
    for (var key in G.bossDefeated) {
      if (key.indexOf(prefix) === 0) {
        delete G.bossDefeated[key];
      }
    }
  }
  G.miniMapPos = null;
  // Return to the nearest town instead of world map
  // (sceneWorldMap would auto-redirect back to miniMap for non-town locations, creating a loop)
  // Find nearest connected town
  var _nearestTown = 'whitecity';
  var _conns = LOC_CONNECTIONS[G.location] || [];
  for (var _ci = 0; _ci < _conns.length; _ci++) {
    var _cl = LOCATIONS[_conns[_ci]];
    if (_cl && _cl.type === 'town') { _nearestTown = _conns[_ci]; break; }
  }
  G.location = _nearestTown;
  sceneTown();
}

function _goWorldMapFromMiniMap() {
  // Go to world map from mini-map (user explicitly requested)
  // Set a flag so sceneWorldMap doesn't auto-redirect back
  G._skipAutoRedirect = true;
  G.miniMapPos = null;
  sceneWorldMap();
  G._skipAutoRedirect = false;
}

// === D2: BFS pathfinding to nearest special room ===
function _findNearestSpecialRoom(map, fromR, fromC) {
  var specialTypes = { boss: { icon: '👑', label: 'Boss' }, elite: { icon: '💀', label: '精锐' }, treasure: { icon: '📦', label: '宝箱' }, event: { icon: '🔍', label: '事件' } };
  var visited = {};
  var queue = [{ r: fromR, c: fromC, dist: 0, firstDir: null }];
  visited[fromR + ',' + fromC] = true;
  var _dirs = [{dr:-1,dc:0},{dr:1,dc:0},{dr:0,dc:-1},{dr:0,dc:1}];
  while (queue.length > 0) {
    var cur = queue.shift();
    var rm = getRoom(map, cur.r, cur.c);
    if (!rm) continue;
    // Check if this room is a special unvisited room (not the current room)
    if (cur.dist > 0 && specialTypes[rm.type] && !rm.visited) {
      // Skip already defeated bosses
      if (rm.type === 'boss') {
        var bKey = G.location + '_' + cur.r + '_' + cur.c;
        if (G.bossDefeated[bKey]) continue; // keep searching
      }
      return { icon: specialTypes[rm.type].icon, typeLabel: specialTypes[rm.type].label, dist: cur.dist, firstDir: cur.firstDir };
    }
    for (var d = 0; d < _dirs.length; d++) {
      var nR = cur.r + _dirs[d].dr, nC = cur.c + _dirs[d].dc;
      var key = nR + ',' + nC;
      if (visited[key]) continue;
      var nRoom = getRoom(map, nR, nC);
      if (!nRoom || !nRoom.revealed || nRoom.type === 'wall' || nRoom.type === 'water') continue;
      visited[key] = true;
      var fd = cur.firstDir || _dirs[d];
      queue.push({ r: nR, c: nC, dist: cur.dist + 1, firstDir: fd });
    }
  }
  return null; // no special room found
}

function _getLocationEntryNarration(locId) {
  var narrations = {
    lake: '🌅 湖水在晨光中泛着银光,远处的瀑布轰鸣作响。你踏上湿滑的岩石小径,空气中充满了水汽和泥土的气息。坠星湖畔的传说不止一个--有人说湖底藏着陨落之星,也有人说湖中住着古老的水灵。',
    darkforest: '🌲 古木参天,枝叶遮蔽了大部分光线。你踏入森林的那一刻,身后的光亮仿佛被吞噬。地面上覆满苔藓,每一步都悄无声息。远处传来不知名的低吼,告诉你--这里不是人类的地盘。',
    fortress: '🏚️ 断壁残垣间野草丛生,曾经的要塞如今只剩废墟。你跨过倒塌的城门,脚下的石板在裂缝中长出蘑菇。残存的墙壁上还有百年前的刀剑痕迹,无声地诉说着那场惨烈的攻城战。',
    mine: '⛏️ 矿洞入口的木桩已经腐烂,黑暗从洞口涌出如墨水。你点燃火把,光芒在潮湿的岩壁上跳跃。矿石在火光中折射出奇异的色彩,地下深处传来有节奏的敲击声--那是矿工?还是别的什么东西?',
    snowpeak: '🏔️ 寒风如刀,每一口气都冻得肺疼。脚下的积雪没过脚踝,身后的脚印很快被新雪填埋。远处的峰顶隐没在云雾之中,传说那里有被冰封千年的龙蛋。',
    coastcave: '🐚 海洞的入口在退潮时才露出,潮湿的岩壁上长满了荧光海藻。浪花从洞口涌进来又退去,发出叹息般的声响。你的脚步声在洞穴中回荡,惊起了几只蝙蝠。',
    misthollow: '🌫️ 雾气浓得几乎可以用手捧起,五步之外就什么也看不见了。你只能凭借脚下的小径和偶尔传来的水声辨别方向。雾中有东西在移动--是野兽,还是更糟糕的东西?',
    jademarsh: '🌿 翡翠色的水面上浮着奇异的荧光菌,照亮了沼泽中扭曲的枯树。每走一步,泥沼都试图将你的脚拖入深处。远处传来蛙鸣与蛇嘶的合奏,空气中弥漫着腐烂植物和某种甜腻气息。',
    stormcape: '⛈️ 闪电在头顶炸开,雷声几乎震破耳膜。雨水横着打在脸上,你不得不侧身前进。海角尽头的灯塔在暴风中摇摇欲坠,但它仍然亮着--那是这座要塞最后的尊严。',
    windisland: '🌀 风在岛上永远不会停歇。巨石被千百年的风蚀雕成了诡异的形状,风车的叶片飞速旋转发出尖锐的啸声。你必须弯腰才能前行,但当地人走得健步如飞。',
    dragontemple: '🐉 石柱上雕刻的龙纹在幽暗中微微发光,仿佛活了过来。空气中充满了硫磺和焚香混合的气味。每一步都能感受到地面的微震--那是殿堂深处某种巨大生物的呼吸。',
    ashplains: '🔥 地面上覆着一层薄薄的灰烬,每一步都扬起灰色的尘雾。远处的火山口日夜喷吐着红光,将天空染成暗红色。地热从裂缝中涌出,空气灼热得像在呼吸火焰。',
    volcano: '🌋 熔岩从裂缝中缓缓涌出,空气中弥漫着硫磺的刺鼻气味。温度高得让金属靴底发烫,汗水刚冒出就蒸发殆尽。火山口传来的轰鸣声如同巨兽的心跳,越来越响,越来越急。',
    abyssgate: '🕳️ 深渊的裂缝在你脚下延展,冰冷的雾气从中渗出。黑暗仿佛有实体,正在缓慢吞噬周围的一切。你感到一种奇异的吸引力--裂缝似乎在邀请你,又似乎在警告你。',
    shadowrealm: '🪞 灰色的世界没有光也没有影,因为影与形已经分离。你的影子在你身旁独立行走,它模仿你的动作却总慢半拍。地面上映出无数个你的倒影,每一个表情都略有不同。',
    throneofages: '👑 虚空之中,一切声音都被吞噬。王座悬浮在星海之间,由远古巨龙的骸骨铸成。时间在这里折叠,你能同时看到过去的荣光与未来的废墟。万古的等待即将终结。'
  };
  return narrations[locId] || null;
}

function enterMiniMap() {
  tickWeather();
  var loc = LOCATIONS[G.location];
  if (!loc.mapConfig) {
    toast('这里没有可探索的区域');
    return;
  }
  var map = getMapForLocation();
  G.miniMapPos = { r: map.startR, c: map.startC };
  // Mark start as visited
  map.rooms[map.startR][map.startC].visited = true;
  // Story trigger: visited a location
  checkStoryTriggers('visit_location', G.location);
  // First-time entry narration
  if (!G._locationVisited) G._locationVisited = {};
  if (!G._locationVisited[G.location]) {
    G._locationVisited[G.location] = true;
    var entryMsg = _getLocationEntryNarration(G.location);
    renderMiniMap(entryMsg);
    return;
  }
  renderMiniMap();
}

function renderMiniMap(msg) {
  var map = getMapForLocation();
  var room = map.rooms[G.miniMapPos.r][G.miniMapPos.c];

  // Reveal adjacent rooms
  var dirs = [{dr:-1,dc:0},{dr:1,dc:0},{dr:0,dc:-1},{dr:0,dc:1}];
  for (var di = 0; di < dirs.length; di++) {
    var nr = G.miniMapPos.r + dirs[di].dr, nc = G.miniMapPos.c + dirs[di].dc;
    var adjRoom = getRoom(map, nr, nc);
    if (adjRoom) adjRoom.revealed = true;
  }

  var html = '';
  // Calculate exploration percentage
  var totalPassable = 0, totalVisited = 0;
  for (var er = 0; er < map.rooms.length; er++) {
    for (var ec = 0; ec < map.rooms[er].length; ec++) {
      var erm = map.rooms[er][ec];
      if (erm.type !== 'wall') { totalPassable++; if (erm.revealed) totalVisited++; }
    }
  }
  var explorePct = totalPassable > 0 ? Math.floor(totalVisited / totalPassable * 100) : 0;
  if (explorePct >= 100 && !(G._fullExploredLocs||{})[G.location]) {
    if (!G._fullExploredLocs) G._fullExploredLocs = {};
    G._fullExploredLocs[G.location] = true;
    G._fullExploreCount = (G._fullExploreCount || 0) + 1;
    toast('📐 完全探索: ' + LOCATIONS[G.location].name + '!');
    checkAchievements();
  }

  ﻿// === D2: Weather bar ===
  var wHtml = '';
  var w = G._weather;
  if (w && WEATHER_TYPES[w]) {
    var wt = WEATHER_TYPES[w];
    wHtml = '<div class="mini-weather-bar">' + wt.emoji + ' ' + wt.name;
    if (wt.enemyAtkMod && wt.enemyAtkMod !== 1) wHtml += ' <span style="color:' + (wt.enemyAtkMod > 1 ? '#e74c3c' : '#2ecc71') + '">敌攻' + (wt.enemyAtkMod > 1 ? '↑' : '↓') + '</span>';
    if (wt.travelMod && wt.travelMod !== 1) wHtml += ' <span style="color:#e67e22">旅行' + (wt.travelMod > 1 ? '慢' : '快') + '</span>';
    wHtml += '</div>';
  }

  // === D2: Mini radar — nearby POIs ===
  var radarHtml = '';
  var radarItems = [];
  var dirs8 = [{dr:-1,dc:0,dir:'北'},{dr:1,dc:0,dir:'南'},{dr:0,dc:-1,dir:'西'},{dr:0,dc:1,dir:'东'},{dr:-1,dc:-1,dir:'西北'},{dr:-1,dc:1,dir:'东北'},{dr:1,dc:-1,dir:'西南'},{dr:1,dc:1,dir:'东南'}];
  for (var ri = 0; ri < dirs8.length; ri++) {
    var adjR = getRoom(map, G.miniMapPos.r + dirs8[ri].dr, G.miniMapPos.c + dirs8[ri].dc);
    if (adjR && adjR.revealed && adjR.type !== 'wall' && adjR.type !== 'water') {
      var poiIcon = '';
      if (adjR.type === 'boss') poiIcon = '👑';
      else if (adjR.type === 'elite') poiIcon = '💀';
      else if (adjR.type === 'treasure') poiIcon = '📦';
      else if (adjR.type === 'event') poiIcon = '🔍';
      else if (adjR.type === 'trap') poiIcon = '⚠️';
      else if (adjR.type === 'stone') poiIcon = '🪨';
      if (poiIcon) radarItems.push({ dir: dirs8[ri].dir, icon: poiIcon, type: adjR.type, r: G.miniMapPos.r + dirs8[ri].dr, c: G.miniMapPos.c + dirs8[ri].dc });
    }
  }
  if (radarItems.length > 0) {
    radarHtml = '<div class="mini-radar">🔭 ';
    for (var rj = 0; rj < radarItems.length; rj++) {
      var isAdj = (Math.abs(radarItems[rj].r - G.miniMapPos.r) + Math.abs(radarItems[rj].c - G.miniMapPos.c)) === 1;
      radarHtml += '<span class="mini-radar-item"' + (isAdj ? ' onclick="clickGridCell(' + radarItems[rj].r + ',' + radarItems[rj].c + ')"' : '') + '><span class="dir">' + radarItems[rj].dir + '</span> ' + radarItems[rj].icon + '</span>';
    }
    radarHtml += '</div>';
  }

  // === D2: Path hints to nearest unvisited special room ===
  var pathHintHtml = '';
  var _nearestSpecial = _findNearestSpecialRoom(map, G.miniMapPos.r, G.miniMapPos.c);
  if (_nearestSpecial) {
    var _hintDir = _nearestSpecial.firstDir;
    var _hintIcon = _nearestSpecial.icon;
    var _hintDist = _nearestSpecial.dist;
    var _hintType = _nearestSpecial.typeLabel;
    pathHintHtml = '<div class="mini-path-hint" onclick="moveGrid(\'' + (_hintDir.dr > 0 ? '1' : _hintDir.dr < 0 ? '-1' : '0') + '\',\'' + (_hintDir.dc > 0 ? '1' : _hintDir.dc < 0 ? '-1' : '0') + '\')">';
    pathHintHtml += '<span class="arrow">➤</span> ' + _hintIcon + ' ' + _hintType + ' 距离' + _hintDist + '步 → 向' + (_hintDir.dr < 0 ? '北' : _hintDir.dr > 0 ? '南' : '') + (_hintDir.dc < 0 ? '西' : _hintDir.dc > 0 ? '东' : '') + '前进';
    pathHintHtml += '</div>';
  }

  // === D2: Map legend (collapsible) ===
  var legendHtml = '<details style="margin:4px 0"><summary style="color:#666;font-size:0.8em;cursor:pointer">🗺️ 图例</summary>';
  legendHtml += '<div class="map-legend">';
  legendHtml += '<span class="map-legend-item">🚪入口</span>';
  legendHtml += '<span class="map-legend-item">⚔️敌人</span>';
  legendHtml += '<span class="map-legend-item">👑Boss</span>';
  legendHtml += '<span class="map-legend-item">💀精锐</span>';
  legendHtml += '<span class="map-legend-item">📦宝箱</span>';
  legendHtml += '<span class="map-legend-item">🔍事件</span>';
  legendHtml += '<span class="map-legend-item">⚠️陷阱</span>';
  legendHtml += '<span class="map-legend-item">🪨石堆</span>';
  legendHtml += '<span class="map-legend-item">💧水域</span>';
  legendHtml += '<span class="map-legend-item" style="color:#d4a017">● 你</span>';
  legendHtml += '</div></details>';

  html += '<div class="scene-title">' + map.name + ' <span style="font-size:0.7em;color:#888">🔍 ' + explorePct + '%</span></div>';
  if (msg) html += '<div class="mini-msg">' + msg + '</div>';

  ﻿// === D2: Show weather + radar + path hint ===
  html += wHtml;
  html += radarHtml;
  html += pathHintHtml;

  // Current room info
  var typeLabel = '';
  var typeHint = '';
  if (room.type === 'boss') { typeLabel = ' 👑'; typeHint = '危险区域'; }
  else if (room.type === 'elite') { typeLabel = ' 💀'; typeHint = '精锐敌人盘踞此处'; }
  else if (room.type === 'treasure') { typeLabel = ' 📦'; typeHint = '有宝藏'; }
  else if (room.type === 'enemy') { typeLabel = ' ⚔️'; typeHint = '有敌人出没'; }
  else if (room.type === 'trap') { typeLabel = ' ⚠️'; typeHint = '有陷阱!'; }
  else if (room.type === 'event') { typeLabel = ' 🔍'; typeHint = '可以调查'; }
  else if (room.type === 'water') { typeLabel = ' 💧'; typeHint = '水域,无法通行'; }
  else if (room.type === 'start') { typeLabel = ' 🚪'; typeHint = '入口'; }
  else if (room.type === 'wall') { typeLabel = ''; typeHint = ''; }
  html += '<div class="mini-area">';
  html += '<div class="mini-area-name">' + typeLabel + ' ' + room.name + '</div>';
  html += '<div class="mini-area-desc">' + room.desc + (typeHint ? '<br><span style="color:#888;font-size:0.85em">' + typeHint + '</span>' : '') + '</div>';
  html += '</div>';

  // Grid mini map - camera-follow viewport
  html += '<div id="mapViewport" class="mini-map-grid" style="overflow:hidden;-webkit-overflow-scrolling:touch;height:320px;position:relative;border:1px solid #333;border-radius:8px;background:#0a0a0a">';
  html += '<div id="mapLayer" style="position:absolute;will-change:transform;transition:transform 0.18s ease-out">';
  html += renderGridMap(map, G.miniMapPos.r, G.miniMapPos.c);
  html += '</div>';
  html += '</div>';

  // Direction buttons (N/S/E/W) + Room actions
  html += '<div class="mini-controls">';

  // Movement buttons - 3x3 grid layout
  html += '<div class="move-grid">';
  var canN = canMove(map, G.miniMapPos.r - 1, G.miniMapPos.c);
  var canS = canMove(map, G.miniMapPos.r + 1, G.miniMapPos.c);
  var canW = canMove(map, G.miniMapPos.r, G.miniMapPos.c - 1);
  var canE = canMove(map, G.miniMapPos.r, G.miniMapPos.c + 1);
  html += '<div></div>';
  html += '<button class="move-btn" onclick="moveGrid(\'-1\',\'0\')" ' + (canN ? '' : 'disabled') + '>⬆️ 北</button>';
  html += '<div></div>';
  html += '<button class="move-btn" onclick="moveGrid(\'0\',\'-1\')" ' + (canW ? '' : 'disabled') + '>⬅️ 西</button>';
  html += '<div class="move-center">●</div>';
  html += '<button class="move-btn" onclick="moveGrid(\'0\',\'1\')" ' + (canE ? '' : 'disabled') + '>➡️ 东</button>';
  html += '<div></div>';
  html += '<button class="move-btn" onclick="moveGrid(\'1\',\'0\')" ' + (canS ? '' : 'disabled') + '>⬇️ 南</button>';
  html += '<div></div>';
  html += '</div>';

  // Room-specific actions
  html += '<div class="mini-actions">';
  // Enemies auto-trigger on step - no search button needed
  if (room.type === 'treasure') {
    html += '<button class="btn btn-primary" onclick="miniMapTreasure()">📦 搜索宝藏</button>';
  } else if (room.type === 'boss') {
    html += '<button class="btn btn-danger" onclick="miniMapBoss()">👑 挑战首领</button>';
  } else if (room.type === 'elite') {
    html += '<button class="btn btn-danger" onclick="miniMapElite()">💀 挑战精锐</button>';
  } else if (room.type === 'trap') {
    if (G.origin && G.origin.id === 'hunter') {
      html += '<button class="btn" onclick="miniMapTrap()">🕸️ 拆除陷阱(安全)</button>';
    } else {
      html += '<button class="btn btn-danger" onclick="miniMapTrap()">⚠️ 尝试拆除陷阱</button>';
    }
  } else if (room.type === 'event') {
    html += '<button class="btn" onclick="miniMapEvent()">🔍 调查</button>';
  } else if (room.type === 'grass' || room.type === 'plain') {
    var _loc4 = LOCATIONS[G.location];
    html += '<button class="btn" onclick="miniMapLookAround()">🌿 观察四周</button>';
  } else if (room.type === 'stone') {
    html += '<button class="btn" onclick="miniMapStone()">🪨 调查石堆</button>';
  }
  html += '<button class="btn" onclick="miniMapLookAround()">🌿 观察四周</button>';
  html += '<button class="btn" onclick="_toggleMapMarker()">📌 标记</button>';
  html += '<button class="btn" onclick="leaveMiniMap()">🏰 返回城镇</button>';
  html += '<button class="btn" onclick="_goWorldMapFromMiniMap()">🗺️ 世界地图</button>';
  html += '<button class="btn" onclick="sceneInventoryFromExplore()">🎒 背包</button>';
  html += '<button class="btn" onclick="sceneEquipmentFromExplore()">⚔️ 装备</button>';  html += '<button class="btn" onclick="_showStatusFromExplore()">👤 状态</button>';
  html += '<button class="btn" onclick="_showQuestsFromExplore()">📜 任务</button>';
  html += '</div>';

  // === D2: Legend ===
  html += legendHtml;

  html += '</div>';
  render(html);
  // Camera-follow: center map on player position
  // On first entry (no _prevMapPos), snap instantly; on moves, animate
  if (G._prevMapPos && (G._prevMapPos.r !== G.miniMapPos.r || G._prevMapPos.c !== G.miniMapPos.c)) {
    centerMapOnPlayerAnimated();
  } else {
    centerMapOnPlayer();
    G._prevMapPos = { r: G.miniMapPos.r, c: G.miniMapPos.c };
  }
}

function renderGridMap(map, curR, curC) {
  var cols = map.cols;
  var rows = map.rows;
  var cellSize = 52; // P0-3: larger cells for touch/mobile
  var gap = 2;

  var totalW = cols * (cellSize + gap);
  var totalH = rows * (cellSize + gap);

  var html = '';
  html += '<svg viewBox="0 0 ' + totalW + ' ' + totalH + '" class="mini-svg" style="width:' + totalW + 'px;height:' + totalH + 'px;display:block;will-change:transform;-webkit-tap-highlight-color:transparent">';

  // SVG defs - terrain patterns
  html += '<defs>';
  // Water pattern - wave fill
  html += '<pattern id="pWater" width="12" height="12" patternUnits="userSpaceOnUse">';
  html += '<rect width="12" height="12" fill="#1a3a5c"/>';
  html += '<path d="M0 6 Q3 3 6 6 Q9 9 12 6" fill="none" stroke="#4488aa" stroke-width="1" opacity="0.7"/>';
  html += '<path d="M0 10 Q3 7 6 10 Q9 13 12 10" fill="none" stroke="#336688" stroke-width="0.6" opacity="0.4"/>';
  html += '</pattern>';
  // Grass pattern
  html += '<pattern id="pGrass" width="10" height="10" patternUnits="userSpaceOnUse">';
  html += '<rect width="10" height="10" fill="#1a2a1a"/>';
  html += '<line x1="2" y1="10" x2="2" y2="6" stroke="#2a4a2a" stroke-width="0.8"/>';
  html += '<line x1="5" y1="10" x2="5" y2="5" stroke="#2a4a2a" stroke-width="0.8"/>';
  html += '<line x1="8" y1="10" x2="8" y2="7" stroke="#2a4a2a" stroke-width="0.8"/>';
  html += '</pattern>';
  // Stone pattern
  html += '<pattern id="pStone" width="12" height="12" patternUnits="userSpaceOnUse">';
  html += '<rect width="12" height="12" fill="#1a1a1a"/>';
  html += '<rect x="1" y="1" width="4" height="4" fill="#252525" rx="1"/>';
  html += '<rect x="7" y="3" width="4" height="3" fill="#222" rx="1"/>';
  html += '<rect x="3" y="7" width="3" height="4" fill="#222" rx="1"/>';
  html += '</pattern>';
  html += '</defs>';

  for (var vr = 0; vr < rows; vr++) {
    for (var vc = 0; vc < cols; vc++) {
      var room = map.rooms[vr][vc];
      var x = vc * (cellSize + gap);
      var y = vr * (cellSize + gap);
      var isCurrent = (vr === curR && vc === curC);

      if (!room.revealed) {
        html += '<rect x="' + x + '" y="' + y + '" width="' + cellSize + '" height="' + cellSize + '" fill="#0a0a0a" stroke="#1a1a1a" stroke-width="0.5" rx="3"/>';
        continue;
      }

      if (room.type === 'wall') {
        html += '<rect x="' + x + '" y="' + y + '" width="' + cellSize + '" height="' + cellSize + '" fill="#050505" stroke="#111" stroke-width="0.5" rx="2"/>';
        html += '<rect x="' + (x+3) + '" y="' + (y+3) + '" width="' + (cellSize-6) + '" height="' + (cellSize-6) + '" fill="#0a0a0a" rx="1"/>';
        continue;
      }

      // ── Cell fill & decoration by type ──
      var fill, stroke, icon = '', isImpassable = false;
      var iconSize = 16; // icons for 44px cells
      var smallIconSize = 10; // terrain icons in corner

      // ── Special room types ──
      if (room.type === 'start') {
        fill = '#2a3a2a'; stroke = '#6b8'; icon = '🚪';
      } else if (room.type === 'boss') {
        fill = '#3a1a1a'; stroke = '#c44'; icon = '👑';
      } else if (room.type === 'elite') {
        fill = '#2a1a2a'; stroke = '#a4a'; icon = '💀';
      } else if (room.type === 'water') {
        // Full water cell - wave pattern fills entire cell
        fill = 'url(#pWater)'; stroke = '#4488aa'; isImpassable = true;
        // No emoji - the pattern IS the visual
      } else if (room.type === 'treasure') {
        if (room.visited) { fill = '#1a1a10'; stroke = '#3a3a30'; icon = '📦'; }
        else { fill = '#1a1a10'; stroke = '#d4a017'; icon = '📦'; }
      } else if (room.type === 'event') {
        fill = '#1a1a18'; stroke = '#555'; icon = '🔍';
      } else if (room.type === 'enemy') {
        fill = '#1a1a18'; stroke = '#444';
      } else if (room.type === 'trap') {
        fill = '#1a1a18'; stroke = '#444';
      } else {
        // ── Path/terrain rooms - full-cell terrain fill ──
        if (room.terrain === 'grass') {
          fill = 'url(#pGrass)'; stroke = '#2a4a2a';
        } else if (room.terrain === 'stone') {
          fill = 'url(#pStone)'; stroke = '#3a3a3a';
        } else if (room.terrain === 'water') {
          fill = 'url(#pWater)'; stroke = '#4488aa'; isImpassable = true;
        } else {
          // Plain path
          fill = '#1a1a18'; stroke = '#3a3a35';
        }
      }

      // Visited rooms slightly brighter
      if (room.visited && !isImpassable && room.type !== 'start' && room.type !== 'boss' && room.type !== 'elite') {
        if (room.terrain === 'grass') { fill = 'url(#pGrass)'; stroke = '#3a5a3a'; }
        else if (room.terrain === 'stone') { fill = 'url(#pStone)'; stroke = '#4a4a4a'; }
        else if (!room.terrain || room.terrain === 'plain') { fill = '#202018'; stroke = '#4a4a40'; }
      }

      // Draw connection lines
      for (var dir in room.connections) {
        var lx1 = x + cellSize / 2, ly1 = y + cellSize / 2;
        var lx2 = lx1, ly2 = ly1;
        if (dir === 'north') { ly2 = y - gap/2; }
        else if (dir === 'south') { ly2 = y + cellSize + gap/2; }
        else if (dir === 'west') { lx2 = x - gap/2; }
        else if (dir === 'east') { lx2 = x + cellSize + gap/2; }
        html += '<line x1="' + lx1 + '" y1="' + ly1 + '" x2="' + lx2 + '" y2="' + ly2 + '" stroke="#2a2a25" stroke-width="3" opacity="0.4"/>';
      }

      // Draw cell rect
      var clickAttr = isImpassable ? '' : ' onclick="clickGridCell(' + vr + ',' + vc + ')"';
      var cursorStyle = isImpassable ? 'cursor:not-allowed' : 'cursor:pointer';
      html += '<rect x="' + x + '" y="' + y + '" width="' + cellSize + '" height="' + cellSize + '" fill="' + fill + '" stroke="' + (isCurrent ? '#d4a017' : stroke) + '" stroke-width="' + (isCurrent ? 3 : 1.2) + '" rx="4" style="' + cursorStyle + '"' + clickAttr + '/>';

      // Icons - only for special rooms
      var showIcon = room.visited || isCurrent;
      if (room.type === 'elite' && room.revealed) showIcon = true;
      if (room.type === 'boss' && room.revealed) showIcon = true;
      if (room.type === 'start') showIcon = true;
      if (room.type === 'treasure' && room.revealed) showIcon = true;
      if (room.type === 'event' && room.revealed) showIcon = true;

      if (icon && showIcon) {
      // P0-3: Terrain SVG decorations
      var _td = '';
      var _terrain = room.terrain;
      if (_terrain === 'water') {
        var _wx = x+6, _wy = y+cellSize*0.7;
        _td = '<path d="M'+_wx+','+_wy+' Q'+(_wx+10)+','+(_wy-4)+' '+(_wx+20)+','+_wy+'" fill="none" stroke="#2980b9" stroke-width="1.5" opacity="0.5"/>';
      } else if (_terrain === 'grass') {
        var _gx = x+4, _gy = y+cellSize-8;
        _td = '<line x1="'+_gx+'" y1="'+(_gy+8)+'" x2="'+_gx+'" y2="'+_gy+'" stroke="#2ecc71" stroke-width="1.5" opacity="0.4"/>';
        _td += '<line x1="'+(_gx+14)+'" y1="'+(_gy+8)+'" x2="'+(_gx+14)+'" y2="'+(_gy+2)+'" stroke="#27ae60" stroke-width="1.5" opacity="0.4"/>';
      } else if (_terrain === 'stone') {
        _td = '<circle cx="'+(x+cellSize*0.3)+'" cy="'+(y+cellSize*0.6)+'" r="4" fill="#7f8c8d" opacity="0.3"/>';
      }
      html += _td;
        html += '<text x="' + (x + cellSize / 2) + '" y="' + (y + cellSize * 0.62) + '" text-anchor="middle" font-size="' + iconSize + '">' + icon + '</text>';
      }

      // Current position - pulsing golden border + player dot
      if (isCurrent) {
        html += '<rect x="' + (x - 2) + '" y="' + (y - 2) + '" width="' + (cellSize + 4) + '" height="' + (cellSize + 4) + '" fill="none" stroke="#d4a017" stroke-width="2.5" rx="5" stroke-dasharray="4,3">';
        html += '<animate attributeName="opacity" values="1;0.4;1" dur="2s" repeatCount="indefinite"/>';
        html += '</rect>';
        html += '<circle cx="' + (x + cellSize/2) + '" cy="' + (y + cellSize/2) + '" r="6" fill="#d4a017" opacity="0.85">';
        html += '<animate attributeName="r" values="5;7;5" dur="1.5s" repeatCount="indefinite"/>';
        html += '</circle>';
      }

      // D2: Visited footprint indicator (small dot in corner for visited rooms)
      if (room.visited && !isCurrent && room.type !== 'wall' && room.type !== 'water') {
        html += '<circle cx="' + (x + 5) + '" cy="' + (y + 5) + '" r="2" fill="#d4a017" opacity="0.3"/>';
      }

      // D2: Custom markers (player-placed pins)
      var _markers = G._mapMarkers || {};
      var _mKey = G.location + '_' + vr + '_' + vc;
      if (_markers[_mKey]) {
        html += '<text x="' + (x + cellSize - 8) + '" y="' + (y + 12) + '" font-size="10" text-anchor="middle">📌</text>';
      }
    }
  }

  html += '</svg>';
  return html;
}

function centerMapOnPlayer() {
  // Position the SVG so the player is centered in the viewport
  var viewport = document.getElementById('mapViewport');
  var layer = document.getElementById('mapLayer');
  if (!viewport || !layer || !G.miniMapPos) return;
  var cellTotal = 54; // cellSize(52) + gap(2)
  // Calculate where the player cell is in the SVG, then offset to center it
  var px = G.miniMapPos.c * cellTotal + cellTotal / 2;
  var py = G.miniMapPos.r * cellTotal + cellTotal / 2;
  var tx = viewport.clientWidth / 2 - px;
  var ty = viewport.clientHeight / 2 - py;
  // Snap instantly - disable transition to prevent flash from (0,0) → target
  layer.style.transition = 'none';
  layer.style.transform = 'translate(' + tx + 'px, ' + ty + 'px)';
  // Force reflow so the snap takes effect before any future transition
  layer.offsetHeight;
}

function centerMapOnPlayerAnimated() {
  // Animate from old position to new position - map slides, player stays center
  var viewport = document.getElementById('mapViewport');
  var layer = document.getElementById('mapLayer');
  if (!viewport || !layer || !G.miniMapPos) return;
  var cellTotal = 54; // cellSize(52) + gap(2)
  // First: instantly position at old location (no transition)
  var oldR = G._prevMapPos ? G._prevMapPos.r : G.miniMapPos.r;
  var oldC = G._prevMapPos ? G._prevMapPos.c : G.miniMapPos.c;
  layer.style.transition = 'none';
  var ox = viewport.clientWidth / 2 - (oldC * cellTotal + cellTotal / 2);
  var oy = viewport.clientHeight / 2 - (oldR * cellTotal + cellTotal / 2);
  layer.style.transform = 'translate(' + ox + 'px, ' + oy + 'px)';
  // Force reflow so the instant position takes effect
  layer.offsetHeight;
  // Now animate to new position
  layer.style.transition = 'transform 0.18s ease-out';
  var nx = viewport.clientWidth / 2 - (G.miniMapPos.c * cellTotal + cellTotal / 2);
  var ny = viewport.clientHeight / 2 - (G.miniMapPos.r * cellTotal + cellTotal / 2);
  layer.style.transform = 'translate(' + nx + 'px, ' + ny + 'px)';
  G._prevMapPos = { r: G.miniMapPos.r, c: G.miniMapPos.c };
}

function clickGridCell(r, c) {
  var map = getMapForLocation();
  var room = getRoom(map, r, c);
  if (!room || !room.revealed) return;

  // Can't step on water tiles
  if (room.type === 'water') {
    toast('💧 水域无法通行');
    return;
  }

  // Can only move to adjacent cells (N/S/E/W)
  var dr = Math.abs(r - G.miniMapPos.r);
  var dc = Math.abs(c - G.miniMapPos.c);
  if (!((dr === 1 && dc === 0) || (dr === 0 && dc === 1))) {
    toast('🔒 只能移动到相邻格子');
    return;
  }

  // Check connection exists (same as canMove logic)
  if (!canMove(map, r, c)) {
    toast('🚫 无法到达那里');
    return;
  }

  // Move there
  G.miniMapPos = { r: r, c: c };
  room.visited = true;

  // Random encounter check on any walkable tile (not elite/boss/stone/treasure/trap/event)
  var fixedRoom2 = (room.type === 'elite' || room.type === 'boss' || room.type === 'treasure' || room.type === 'trap' || room.type === 'event' || room.type === 'stone');
  if (!fixedRoom2 && !room._randomDone) {
    room._randomDone = true; // only trigger once per tile
    var encRate2 = (LOCATIONS[G.location].mapConfig || {}).enemyRate || 0.15;
    var roll2 = Math.random();
    if (roll2 < encRate2 * 0.5) {
      miniMapBattle();
      return;
    } else if (roll2 < encRate2 * 0.5 + 0.04) {
      // 4% chance: random treasure on empty tile
      room.type = 'treasure';
      miniMapTreasure();
      return;
    } else if (roll2 < encRate2 * 0.5 + 0.07) {
      // 3% chance: random event
      room.type = 'event';
      miniMapEvent();
      return;
    } else if (roll2 < encRate2 * 0.5 + 0.09) {
      // 2% chance: random trap (unless hunter)
      if (G.origin && G.origin.id === 'hunter') {
        toast('🕸️ 你发现了隐藏陷阱并避开了!');
      } else {
        var _trapDmg3 = 10 + Math.floor(Math.random() * 20);
        G.hp = Math.max(1, G.hp - _trapDmg3);
        updateStatus();
        toast('💥 踩到隐藏陷阱!受到 ' + _trapDmg3 + ' 点伤害!');
      }
    }
  }

  // Auto-trigger fixed room events on step
  if (room.type === 'boss') {
    var bossKey3 = G.location + '_' + r + '_' + c;
    if (G.bossDefeated[bossKey3]) {
      renderMiniMap('首领已被击败,巢穴空空荡荡...');
    } else {
      miniMapBoss();
    }
  } else if (room.type === 'trap') {
    // Auto-trigger trap on step unless hunter with 陷阱感知
    if (G.origin && G.origin.id === 'hunter') {
      renderMiniMap('🕸️ 陷阱感知!你发现并避开了陷阱');
    } else {
      // Step on trap - auto damage
      var _trapDmg = 10 + Math.floor(Math.random() * 20);
      G.hp = Math.max(1, G.hp - _trapDmg);
      room.type = 'path';
      room.name = '触发的陷阱';
      room.desc = '陷阱已经触发了,但区域现在是安全的。';
      if (G.hp <= 0) G.hp = 1;
      updateStatus();
      renderMiniMap('💥 陷阱!受到 ' + _trapDmg + ' 点伤害!');
      return;
    }
  } else if (room.type === 'elite') {
    renderMiniMap('💀 精锐敌人盘踞此处...');
  } else if (room.type === 'stone') {
    renderMiniMap('🪨 石堆似乎可以调查...');
  } else if (room.type === 'treasure') {
    renderMiniMap('📦 发现宝箱!');
  } else {
    renderMiniMap('前往 ' + room.name + '...');
  }
}

// === D2: Toggle map marker on current cell ===
function _toggleMapMarker() {
  if (!G._mapMarkers) G._mapMarkers = {};
  var key = G.location + '_' + G.miniMapPos.r + '_' + G.miniMapPos.c;
  if (G._mapMarkers[key]) {
    delete G._mapMarkers[key];
    toast('📌 已移除标记');
  } else {
    G._mapMarkers[key] = true;
    toast('📌 已标记此位置');
  }
  renderMiniMap();
}

function moveGrid(dr, dc) {
  var map = getMapForLocation();
  var nr = G.miniMapPos.r + parseInt(dr);
  var nc = G.miniMapPos.c + parseInt(dc);
  var room = getRoom(map, nr, nc);
  if (!room) {
    toast('那个方向没有路');
    return;
  }
  if (!canMove(map, nr, nc)) {
    if (room.type === 'water') toast('💧 水域无法通行');
    else toast('🚫 那个方向没有路');
    return;
  }
  G.miniMapPos = { r: nr, c: nc };
  room.visited = true;

  // Terrain flavor text on move
  var _terrainMsg = '';
  var _locTheme = ROOM_THEMES[G.location] || {};
  if (room.type === 'grass' || room.type === 'plain') {
    if (_locTheme.grassDesc) _terrainMsg = _locTheme.grassDesc[rand(0, _locTheme.grassDesc.length - 1)];
  } else if (room.type === 'stone') {
    if (_locTheme.stoneDesc) _terrainMsg = _locTheme.stoneDesc[rand(0, _locTheme.stoneDesc.length - 1)];
  }
  // Also check adjacent water for atmosphere
  if (!_terrainMsg) {
    var _nearWater = false;
    var _dirs4 = [{dr:-1,dc:0},{dr:1,dc:0},{dr:0,dc:-1},{dr:0,dc:1}];
    for (var _di = 0; _di < _dirs4.length; _di++) {
      var _adjR = getRoom(map, nr + _dirs4[_di].dr, nc + _dirs4[_di].dc);
      if (_adjR && _adjR.type === 'water') { _nearWater = true; break; }
    }
    if (_nearWater) {
      if (_locTheme.waterDesc) _terrainMsg = _locTheme.waterDesc[rand(0, _locTheme.waterDesc.length - 1)];
    }
  }
  if (_terrainMsg) toast('🍃 ' + _terrainMsg, 2500);

  // Random encounter check on any walkable tile (not elite/boss/stone/treasure/trap/event)
  var fixedRoom = (room.type === 'elite' || room.type === 'boss' || room.type === 'treasure' || room.type === 'trap' || room.type === 'event' || room.type === 'stone');
  if (!fixedRoom && !room._randomDone) {
    room._randomDone = true;
    var encRate = (LOCATIONS[G.location].mapConfig || {}).enemyRate || 0.15;
    var roll = Math.random();
    if (roll < encRate * 0.5) {
      miniMapBattle();
      return;
    } else if (roll < encRate * 0.5 + 0.04) {
      room.type = 'treasure';
      miniMapTreasure();
      return;
    } else if (roll < encRate * 0.5 + 0.07) {
      room.type = 'event';
      miniMapEvent();
      return;
    } else if (roll < encRate * 0.5 + 0.09) {
      if (G.origin && G.origin.id === 'hunter') {
        toast('🕸️ 你发现了隐藏陷阱并避开了!');
      } else {
        var _trapDmg4 = 10 + Math.floor(Math.random() * 20);
        G.hp = Math.max(1, G.hp - _trapDmg4);
        updateStatus();
        toast('💥 踩到隐藏陷阱!受到 ' + _trapDmg4 + ' 点伤害!');
      }
    }
  }

  // Auto-trigger fixed room events on step
  if (room.type === 'boss') {
    var bossKey2 = G.location + '_' + nr + '_' + nc;
    if (G.bossDefeated[bossKey2]) {
      renderMiniMap('首领已被击败,巢穴空空荡荡...');
    } else {
      miniMapBoss();
    }
  } else if (room.type === 'trap') {
    // Auto-trigger trap on step unless hunter with 陷阱感知
    if (G.origin && G.origin.id === 'hunter') {
      renderMiniMap('🕸️ 陷阱感知!你发现并避开了陷阱');
    } else {
      // Step on trap - auto damage
      var _trapDmg2 = 10 + Math.floor(Math.random() * 20);
      G.hp = Math.max(1, G.hp - _trapDmg2);
      room.type = 'path';
      room.name = '触发的陷阱';
      room.desc = '陷阱已经触发了,但区域现在是安全的。';
      if (G.hp <= 0) G.hp = 1;
      updateStatus();
      renderMiniMap('💥 陷阱!受到 ' + _trapDmg2 + ' 点伤害!');
      return;
    }
  } else if (room.type === 'elite') {
    renderMiniMap('💀 精锐敌人盘踞此处...');
  } else if (room.type === 'stone') {
    renderMiniMap('🪨 石堆似乎可以调查...');
  } else if (room.type === 'treasure') {
    renderMiniMap('📦 发现宝箱!');
  } else {
    renderMiniMap('你向' + (dr === '-1' ? '北' : dr === '1' ? '南' : dc === '-1' ? '西' : '东') + '前进...');
  }
}


function miniMapLookAround() {
  var map = getMapForLocation();
  var room = map.rooms[G.miniMapPos.r][G.miniMapPos.c];
  var loc = LOCATIONS[G.location];
  var html = '';
  html += '<div class="scene-title">🌿 观察四周</div>';
  
  // === D2: Mini compass visualization ===
  html += '<div class="mini-compass">';
  var _cDirs = [{dr:-1,dc:0,area:'n'},{dr:1,dc:0,area:'s'},{dr:0,dc:-1,area:'w'},{dr:0,dc:1,area:'e'}];
  var _compassCells = {n:'',s:'',w:'',e:'',c:'●'};
  for (var ci = 0; ci < _cDirs.length; ci++) {
    var _cRoom = getRoom(map, G.miniMapPos.r + _cDirs[ci].dr, G.miniMapPos.c + _cDirs[ci].dc);
    var _cArea = _cDirs[ci].area;
    if (!_cRoom || _cRoom.type === 'wall') _compassCells[_cArea] = '✕';
    else if (_cRoom.type === 'water') _compassCells[_cArea] = '💧';
    else if (_cRoom.type === 'boss') _compassCells[_cArea] = '👑';
    else if (_cRoom.type === 'elite') _compassCells[_cArea] = '💀';
    else if (_cRoom.type === 'treasure') _compassCells[_cArea] = '📦';
    else if (_cRoom.type === 'trap') _compassCells[_cArea] = '⚠️';
    else if (_cRoom.type === 'event') _compassCells[_cArea] = '🔍';
    else if (_cRoom.type === 'stone') _compassCells[_cArea] = '🪨';
    else if (_cRoom.revealed) _compassCells[_cArea] = '·';
    else _compassCells[_cArea] = '?';
  }
  html += '<div class="mini-compass-cell" style="grid-area:n">' + _compassCells.n + '</div>';
  html += '<div class="mini-compass-cell center" style="grid-area:c">' + _compassCells.c + '</div>';
  html += '<div class="mini-compass-cell" style="grid-area:s">' + _compassCells.s + '</div>';
  html += '<div class="mini-compass-cell" style="grid-area:w">' + _compassCells.w + '</div>';
  html += '<div class="mini-compass-cell" style="grid-area:e">' + _compassCells.e + '</div>';
  html += '</div>';
  
  // Terrain description
  var terrainDesc = '';
  if (loc) {
    if (room.type === 'grass' || room.type === 'plain') {
      var _theme = ROOM_THEMES[G.location]; if (_theme && _theme.grassDesc) terrainDesc = _theme.grassDesc[rand(0, _theme.grassDesc.length - 1)];
    } else if (room.type === 'stone') {
      if (_theme && _theme.stoneDesc) terrainDesc = _theme.stoneDesc[rand(0, _theme.stoneDesc.length - 1)];
    }
    // Check for nearby water
    var nearWater = false;
    var dirs4 = [{dr:-1,dc:0},{dr:1,dc:0},{dr:0,dc:-1},{dr:0,dc:1}];
    for (var di = 0; di < dirs4.length; di++) {
      var adjR = getRoom(map, G.miniMapPos.r + dirs4[di].dr, G.miniMapPos.c + dirs4[di].dc);
      if (adjR && adjR.type === 'water') { nearWater = true; break; }
    }
    if (nearWater && _theme && _theme.waterDesc) {
      terrainDesc += (terrainDesc ? '\n' : '') + _theme.waterDesc[rand(0, _theme.waterDesc.length - 1)];
    }
  }
  if (terrainDesc) {
    html += '<div style="padding:12px;background:#1a2a1a;border-radius:8px;border-left:3px solid #2ecc71;margin:8px 0">';
    html += '<div style="color:#2ecc71;font-style:italic;line-height:1.6">' + terrainDesc.replace(/\n/g, '<br>') + '</div>';
    html += '</div>';
  }
  
  // Scan for nearby points of interest
  var poiFound = [];
  var dirs8 = [{dr:-1,dc:0},{dr:1,dc:0},{dr:0,dc:-1},{dr:0,dc:1},{dr:-1,dc:-1},{dr:-1,dc:1},{dr:1,dc:-1},{dr:1,dc:1}];
  for (var pi = 0; pi < dirs8.length; pi++) {
    var adjRoom = getRoom(map, G.miniMapPos.r + dirs8[pi].dr, G.miniMapPos.c + dirs8[pi].dc);
    if (adjRoom && adjRoom.revealed && adjRoom.type !== 'wall') {
      var dirName = '';
      if (dirs8[pi].dr === -1 && dirs8[pi].dc === 0) dirName = '北';
      else if (dirs8[pi].dr === 1 && dirs8[pi].dc === 0) dirName = '南';
      else if (dirs8[pi].dr === 0 && dirs8[pi].dc === -1) dirName = '西';
      else if (dirs8[pi].dr === 0 && dirs8[pi].dc === 1) dirName = '东';
      else if (dirs8[pi].dr === -1 && dirs8[pi].dc === -1) dirName = '西北';
      else if (dirs8[pi].dr === -1 && dirs8[pi].dc === 1) dirName = '东北';
      else if (dirs8[pi].dr === 1 && dirs8[pi].dc === -1) dirName = '西南';
      else if (dirs8[pi].dr === 1 && dirs8[pi].dc === 1) dirName = '东南';
      
      var poiIcon = '';
      if (adjRoom.type === 'boss') poiIcon = '👑';
      else if (adjRoom.type === 'elite') poiIcon = '💀';
      else if (adjRoom.type === 'treasure') poiIcon = '📦';
      else if (adjRoom.type === 'event') poiIcon = '🔍';
      else if (adjRoom.type === 'water') poiIcon = '💧';
      else if (adjRoom.type === 'stone') poiIcon = '🪨';
      
      if (poiIcon) poiFound.push(dirName + '方' + poiIcon);
    }
  }
  // === D2: Extended range POI detection (up to 3 steps away) ===
  var farPoiFound = [];
  var farVisited = {};
  var farQueue = [{ r: G.miniMapPos.r, c: G.miniMapPos.c, dist: 0, path: '' }];
  farVisited[G.miniMapPos.r + ',' + G.miniMapPos.c] = true;
  var farDirs = [{dr:-1,dc:0,dir:'北'},{dr:1,dc:0,dir:'南'},{dr:0,dc:-1,dir:'西'},{dr:0,dc:1,dir:'东'}];
  while (farQueue.length > 0) {
    var fc = farQueue.shift();
    if (fc.dist > 3) break;
    var fcRoom = getRoom(map, fc.r, fc.c);
    if (!fcRoom || fcRoom.type === 'wall' || fcRoom.type === 'water') continue;
    if (fc.dist > 0 && fcRoom.revealed) {
      var farPoiIcon = '';
      if (fcRoom.type === 'boss') farPoiIcon = '👑';
      else if (fcRoom.type === 'elite') farPoiIcon = '💀';
      else if (fcRoom.type === 'treasure' && !fcRoom.visited) farPoiIcon = '📦';
      else if (fcRoom.type === 'event' && !fcRoom.visited) farPoiIcon = '🔍';
      if (farPoiIcon) farPoiFound.push(farPoiIcon + ' ' + fc.path + '(' + fc.dist + '步)');
    }
    for (var fd = 0; fd < farDirs.length; fd++) {
      var fnr = fc.r + farDirs[fd].dr, fnc = fc.c + farDirs[fd].dc;
      var fkey = fnr + ',' + fnc;
      if (farVisited[fkey]) continue;
      var fnRoom = getRoom(map, fnr, fnc);
      if (!fnRoom || fnRoom.type === 'wall' || fnRoom.type === 'water') continue;
      farVisited[fkey] = true;
      var fPath = fc.dist === 0 ? farDirs[fd].dir : fc.path;
      farQueue.push({ r: fnr, c: fnc, dist: fc.dist + 1, path: fPath });
    }
  }
  // Show nearby POIs (1 step)
  if (poiFound.length > 0) {
    html += '<div style="padding:8px;background:#1a1a2e;border-radius:6px;border:1px solid #333">';
    html += '<div style="color:#d4a017;font-size:0.9em;margin-bottom:4px">🔭 附近发现</div>';
    html += '<div style="color:#aaa;font-size:0.85em">' + poiFound.join(' · ') + '</div>';
    html += '</div>';
  }
  // Show distant POIs (2-3 steps)
  if (farPoiFound.length > 0) {
    html += '<div style="padding:8px;background:#1a1a18;border-radius:6px;border:1px solid #222;margin-top:6px">';
    html += '<div style="color:#8a8a4a;font-size:0.85em;margin-bottom:4px">🔭 远处感知</div>';
    html += '<div style="color:#777;font-size:0.8em">' + farPoiFound.join(' · ') + '</div>';
    html += '</div>';
  }
  
  // Small chance of random discovery
  if (Math.random() < 0.15) {
    var matKeys = Object.keys(MATERIALS);
    var commonMats = matKeys.filter(function(k) { return MATERIALS[k].rarity === 'common' || MATERIALS[k].rarity === 'uncommon'; });
    var mk = commonMats[rand(0, commonMats.length - 1)];
    var mat = MATERIALS[mk];
    G.inventory.push({ id: mat.id, name: mat.name, type: 'material', icon: mat.icon, category: mat.category, rarity: mat.rarity, sellPrice: mat.sellPrice, craftValue: mat.craftValue });
    html += '<div style="padding:8px;background:#2a1a0a;border-radius:6px;border:1px solid #d4a017;margin-top:8px">';
    html += '<div style="color:#d4a017">✨ 你在草丛中发现了什么!</div>';
    html += '<div style="color:#fff">' + mat.icon + ' ' + mat.name + '</div>';
    html += '</div>';
  }
  
  html += '<div style="margin-top:12px">';
  html += '<button class="btn" onclick="renderMiniMap()">↩️ 继续</button>';
  html += '</div>';
  render(html);
}

function miniMapStone() {
  var roll = Math.random();
  var html = '';
  html += '<div class="scene-title">🪨 石堆调查</div>';
  html += '<div class="event-text">你仔细翻检石堆...</div>';

  if (roll < 0.35) {
    // Find material instead of gold
    var matKeys = Object.keys(MATERIALS);
    var commonMats = matKeys.filter(function(k) { return MATERIALS[k].rarity === 'common'; });
    var mk = commonMats[rand(0, commonMats.length - 1)];
    var mat = MATERIALS[mk];
    G.inventory.push({ id: mat.id, name: mat.name, type: 'material', icon: mat.icon, category: mat.category, rarity: mat.rarity, sellPrice: mat.sellPrice, craftValue: mat.craftValue });
    html += '<div class="event-result good">' + mat.icon + ' 你在石头缝中发现了 ' + mat.name + '!</div>';
  } else if (roll < 0.55) {
    // Find item
    var items = [
      { name:'磨刀石', type:'material', atk:2, desc:'一块可以让武器更锋利的磨刀石' },
      { name:'护身符碎片', type:'material', def:2, desc:'刻有微弱符文的护身符碎片' },
      { name:'幸运石', type:'necklace', luk:2, desc:'据说能带来好运的圆润小石头' }
    ];
    var item = items[rand(0, items.length - 1)];
    G.inventory.push(item);
    html += '<div class="event-result good">✨ 你发现了一件物品:<strong>' + item.name + '</strong>' + (item.atk ? ' ⚔️+' + item.atk : '') + (item.def ? ' 🛡️+' + item.def : '') + (item.luk ? ' 🎲+' + item.luk : '') + '</div>';
  } else if (roll < 0.70) {
    // Find key
    G.keys = (G.keys || 0) + 1;
    html += '<div class="event-result good">🔑 你找到了一把宝箱钥匙!</div>';
  } else {
    // Nothing
    html += '<div class="event-result">除了碎石和尘土,什么也没发现。</div>';
  }

  // Mark stone as investigated (change to path)
  var map = getMapForLocation();
  var room = map.rooms[G.miniMapPos.r][G.miniMapPos.c];
  if (room.type === 'stone') room.type = 'path'; // Depleted

  html += '<button class="btn" onclick="renderMiniMap()">继续探索</button>';
  updateStatus();
  render(html);
}

// Universal battle entry — accepts an enemy object or array of enemy objects
function startBattleWith(enemyOrArray, opts) {
  var enemies = Array.isArray(enemyOrArray) ? enemyOrArray : [enemyOrArray];
  for (var i = 0; i < enemies.length; i++) {
    var e = enemies[i];
    if (!e.curHp) e.curHp = e.hp;
    if (!e.lv) e.lv = Math.max(1, Math.round((e.hp + e.atk * 3) / 50));
    // Ensure skills array exists on instance
    if (!e.skills) e.skills = [];
    // D1: Set initial enemy intent
    if (e.skills && e.skills.length > 0) {
      var initSk = ENEMY_SKILLS[e.skills[0]];
      e._intent = initSk ? (initSk.emoji || '🔮') + ' ' + initSk.name : '⚔️攻击';
    } else { e._intent = '⚔️攻击'; }
  }
  opts = opts || {};
  G.battle = {
    enemies: enemies,
    log: [], turn: 0, defending: false, warcry: 0, gamblerUsed: false,
    dungeon: true, isBoss: !!opts.isBoss, isElite: !!opts.isElite,
    bossKey: opts.bossKey || null, eliteKey: opts.eliteKey || null,
    // A3: Wave battle system
    wave: opts.wave || 0,
    totalWaves: opts.totalWaves || 0,
    waves: opts.waves || null
  };
  G.inBattle = true;
  G._tookDamageThisBattle = false;
  G.selectedTarget = 0;
  G.attackMode = null;
  G._comboCount = 0;
  // Reset skill cooldowns at start of new battle
  G._skillCooldowns = {};
  // Reset player debuffs at start of new battle
  G._stunned = false; G._stunTurns = 0;
  G._frozen = false; G._freezeTurns = 0;
  G._slowed = false; G._slowTurns = 0;
  renderBattle(opts.msg || '遭遇 ' + enemies.length + ' 只敌人!');
  // D1: Battle start flash effect
  var gameEl = document.getElementById('game');
  if (gameEl) {
    var flash = document.createElement('div');
    flash.style.cssText = 'position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(255,0,0,0.15);z-index:3000;pointer-events:none;animation:battleStartFlash 0.4s ease-out forwards;';
    document.body.appendChild(flash);
    setTimeout(function() { if (flash.parentNode) flash.parentNode.removeChild(flash); }, 500);
  }
  // Trigger tutorial for first battle
  _checkTutorial('battle_start');
}

function miniMapBattle() {
  var loc = LOCATIONS[G.location];
  var enemyIds = loc.enemies || ['goblin'];
  var count = rand(1, 2);
  var enemies = [];

  for (var i = 0; i < count; i++) {
    var eid = enemyIds[rand(0, enemyIds.length - 1)];
    var template = ENEMIES[eid];
    if (template) {
      var scaled = Object.assign({}, template);
      // Apply global difficulty scaling first
      scaleEnemy(scaled);
      // Apply location-specific difficulty scaling
      if (template.scale && template.scale[G.location]) {
        var s = template.scale[G.location];
        scaled.hp = Math.round(scaled.hp * s);
        scaled.atk = Math.round(scaled.atk * s);
        scaled.xp = Math.round(scaled.xp * s);
      }
      // 15% chance for rare spawn variant — stronger, better drops
      if (Math.random() < 0.15) {
        scaled.name = '异化' + scaled.name;
        scaled.hp = Math.round(scaled.hp * 1.5);
        scaled.atk = Math.round(scaled.atk * 1.3);
        scaled.xp = Math.round(scaled.xp * 2);
        scaled._rareSpawn = true;
        if (scaled.emoji && !scaled.emoji.startsWith('⭐')) scaled.emoji = '⭐' + scaled.emoji;
      }
      // Weather modifier: certain weathers buff enemies
      var w = getWeather(G.location);
      if (w && w.enemyAtkMod) scaled.atk = Math.round(scaled.atk * (1 + w.enemyAtkMod));
      if (w && w.enemyHpMod) scaled.hp = Math.round(scaled.hp * (1 + w.enemyHpMod));
      scaled.curHp = scaled.hp;
      // Q20: Derive enemy level from HP/ATK
      if (!scaled.lv) {
        scaled.lv = Math.max(1, Math.round((scaled.hp + scaled.atk * 3) / 50));
      }
      enemies.push(scaled);
    }
  }

  G.battle = { enemies: enemies, log: [], turn: 0, defending: false, warcry: 0, gamblerUsed: false, dungeon: true };
  G.inBattle = true;
  G._tookDamageThisBattle = false;
  G.selectedTarget = 0;
  G.attackMode = null;
  renderBattle('遭遇 ' + enemies.length + ' 只敌人!');
}

function miniMapBoss() {
  var bossKey = G.location + '_' + G.miniMapPos.r + '_' + G.miniMapPos.c;
  if (G.bossDefeated[bossKey]) {
    toast('👑 首领已被击败,需要离开区域后重新进入才会刷新');
    return;
  }
  // Show boss info screen first
  _showBossInfo();
}

function miniMapElite() {
  // Elite enemies: stronger than normal but weaker than boss, better drops
  var eliteKey = G.location + '_elite_' + G.miniMapPos.r + '_' + G.miniMapPos.c;
  if (G.eliteDefeated && G.eliteDefeated[eliteKey]) {
    toast('💀 精锐已被击败');
    renderMiniMap();
    return;
  }
  if (!G.eliteDefeated) G.eliteDefeated = {};

  // Generate elite stats based on location enemies + buff
  var locEnemies = LOCATIONS[G.location].enemies || ['goblin'];
  var baseEnemy = ENEMIES[locEnemies[Math.floor(Math.random() * locEnemies.length)]];
  if (!baseEnemy) baseEnemy = ENEMIES.goblin;

  // Elite = 3x HP, 2.5x ATK, 1.8x AGI of base enemy (then scaled by difficulty)
  var eliteEnemy = {
    name: '精锐' + baseEnemy.name,
    emoji: '💀',
    id: baseEnemy.id, // Inherit base enemy id for material drop lookup
    hp: Math.floor(baseEnemy.hp * 3 * DIFF_SCALE),
    atk: Math.floor(baseEnemy.atk * 2.5 * DIFF_SCALE),
    agi: Math.floor((baseEnemy.agi || 5) * 1.8),
    xp: Math.floor(baseEnemy.xp * 2.5),
    desc: '比普通同类更强壮、更凶猛的个体,浑身散发着危险的气息。'
  };

  // Start elite battle using G.battle (same as startBossFight/startBattle)
  G.battle = {
    enemies: [{
      name: eliteEnemy.name, emoji: eliteEnemy.emoji,
      id: eliteEnemy.id, // Critical: id for ENEMY_MAT_DROPS lookup
      hp: eliteEnemy.hp, curHp: eliteEnemy.hp,
      atk: eliteEnemy.atk, agi: eliteEnemy.agi,
      xp: eliteEnemy.xp, desc: eliteEnemy.desc,
      isElite: true, skills: baseEnemy.skills || [],
      lv: eliteEnemy.lv || Math.max(1, Math.round((eliteEnemy.hp + eliteEnemy.atk * 3) / 50))
    }],
    log: ['💀 精锐' + eliteEnemy.name + '发起了攻击!'],
    turn: 0, defending: false, warcry: 0, gamblerUsed: false,
    dungeon: true, isElite: true, eliteKey: eliteKey
  };
  G.inBattle = true;
  G._tookDamageThisBattle = false;
  G.selectedTarget = 0;
  G.attackMode = null;
  renderBattle();
}

function miniMapTrap() {
  // Trap room: AGI check to disarm, take damage if fail
  // Hunter's 陷阱感知: auto-avoid trap damage entirely
  var hasTrapSense = G.origin && G.origin.id === 'hunter';
  var agiCheck = G.agi * 3 + Math.floor(Math.random() * 40);
  var trapDmg = 10 + Math.floor(Math.random() * 20);
  var room = getMapForLocation().rooms[G.miniMapPos.r][G.miniMapPos.c];

  // Hunter auto-avoid
  if (hasTrapSense) {
    toast('🕸️ 陷阱感知!你轻松避开了陷阱');
    var goldReward = 15 + Math.floor(Math.random() * 25);
    G.gold += goldReward;
    toast('💰 从陷阱旁搜刮了 ' + goldReward + ' 金币');
    room.type = 'path';
    room.name = '拆解的陷阱';
    room.desc = '陷阱已被你巧妙避开,地上散落着零件。';
  } else if (agiCheck > 60) {
    // Success - disarm and find reward
    toast('✅ 成功拆除陷阱!');
    var goldReward2 = 15 + Math.floor(Math.random() * 25);
    G.gold += goldReward2;
    toast('💰 获得 ' + goldReward2 + ' 金币');
    room.type = 'path';
    room.name = '拆解的陷阱';
    room.desc = '陷阱已被拆除,地上散落着零件。';
  } else {
    // Fail - take damage
    G.hp = Math.max(1, G.hp - trapDmg);
    toast('💥 陷阱触发!受到 ' + trapDmg + ' 点伤害');
    room.type = 'path';
    room.name = '触发的陷阱';
    room.desc = '陷阱已经触发了,但区域现在是安全的。';
    if (G.hp <= 0) {
      G.hp = 1;
      toast('⚠️ 你勉强撑住了...');
    }
  }
  updateStatus();
  renderMiniMap();
}

function _showBossInfo() {
  var bossTemplateKey = null;
  var bossKeys = Object.keys(ENEMIES);
  for (var bki = 0; bki < bossKeys.length; bki++) {
    if (ENEMIES[bossKeys[bki]].isBoss && ENEMIES[bossKeys[bki]].region === G.location) { bossTemplateKey = bossKeys[bki]; break; }
  }
  if (!bossTemplateKey) bossTemplateKey = 'boss_goblin';
  var template = ENEMIES[bossTemplateKey];
  // Use boss data directly from ENEMIES
  var bossName = template.name;
  var bossDesc = template.desc;
  var bossEmoji = template.emoji;
  var bossHp = template.hp;
  var bossAtk = template.atk;
  var bossAgi = template.agi;
  var bossXp = template.xp;

  // Estimate difficulty relative to player
  var diffLabel = '';
  var diffColor = '';
  var playerPower = calcAtk() + calcDef() + G.maxHp / 5;
  var bossPower = bossAtk + bossHp / 4 + bossAgi;
  var ratio = playerPower / bossPower;
  if (ratio >= 1.5) { diffLabel = '轻松'; diffColor = '#1eff00'; }
  else if (ratio >= 1.0) { diffLabel = '有挑战'; diffColor = '#ffff00'; }
  else if (ratio >= 0.7) { diffLabel = '困难'; diffColor = '#ff8c00'; }
  else { diffLabel = '极危险'; diffColor = '#ff3333'; }

  var html = '';
  html += '<div class="scene-title">👑 首领情报</div>';
  html += '<div class="boss-info-panel">';
  html += '<div class="boss-info-emoji" style="font-size:3em;text-align:center;margin:10px 0">' + bossEmoji + '</div>';
  html += '<div class="boss-info-name" style="font-size:1.4em;font-weight:bold;text-align:center;color:#ff8c00">' + bossName + '</div>';
  html += '<div class="boss-info-desc" style="text-align:center;color:#aaa;margin:8px 0;font-style:italic">"' + bossDesc + '"</div>';
  html += '<div class="boss-info-stats" style="margin:12px 0">';
  html += '<div style="margin:4px 0">❤️ 生命值:约 ' + bossHp + '</div>';
  html += '<div style="margin:4px 0">⚔️ 攻击力:约 ' + bossAtk + '</div>';
  html += '<div style="margin:4px 0">🏃 敏捷:约 ' + bossAgi + '</div>';
  html += '<div style="margin:4px 0">⭐ 经验:约 ' + bossXp + '</div>';
  html += '</div>';
  html += '<div class="boss-difficulty" style="text-align:center;padding:8px;border:1px solid ' + diffColor + ';border-radius:6px;color:' + diffColor + '">难度评估:' + diffLabel + '</div>';
  html += '</div>';
  html += '<div class="btns">';
  html += '<button class="btn btn-danger" onclick="startBossFight()">⚔️ 挑战!</button>';
  html += '<button class="btn" onclick="renderMiniMap()">🏃 暂不挑战</button>';
  html += '</div>';
  render(html);
}

function startBossFight() {
  var bossKey = G.location + '_' + G.miniMapPos.r + '_' + G.miniMapPos.c;
  if (G.bossDefeated[bossKey]) {
    toast('👑 首领已被击败');
    renderMiniMap();
    return;
  }
  var bossTemplateKey2 = null;
  var bossKeys2 = Object.keys(ENEMIES);
  for (var bki2 = 0; bki2 < bossKeys2.length; bki2++) {
    if (ENEMIES[bossKeys2[bki2]].isBoss && ENEMIES[bossKeys2[bki2]].region === G.location) { bossTemplateKey2 = bossKeys2[bki2]; break; }
  }
  if (!bossTemplateKey2) bossTemplateKey2 = 'boss_goblin';
  var template = ENEMIES[bossTemplateKey2];
  var bossCopy = Object.assign({}, template);
  scaleEnemy(bossCopy);
  bossCopy.curHp = bossCopy.hp;
  if (!bossCopy.lv) bossCopy.lv = Math.max(1, Math.round((bossCopy.hp + bossCopy.atk * 3) / 50));

  // A3: Generate wave configuration for boss fight
  var waves = _generateBossWaves(bossCopy, bossKey);

  G.battle = {
    enemies: waves[0].enemies,
    log: [], turn: 0, defending: false, warcry: 0, gamblerUsed: false, dungeon: true, isBoss: true,
    bossKey: bossKey,
    wave: 0, totalWaves: waves.length, waves: waves
  };
  G.inBattle = true;
  G._tookDamageThisBattle = false;
  G._waveNoDamage = true; // Track per-wave no damage
  G.selectedTarget = 0;
  G.attackMode = null;

  // Boss pre-battle dialog - auto-match from NPC_DIALOGS using boss_<region> key
  var bossNpcId = 'boss_' + G.location;
  if (!NPC_DIALOGS[bossNpcId]) bossNpcId = null;

  if (bossNpcId) {
    G._pendingBossBattle = true;
    showDialog(bossNpcId, 0);
    return;
  }

  renderBattle('👑 第1波 / 共' + waves.length + '波 — ' + waves[0].label);
}

// === A3: Wave Battle System ===
function _generateBossWaves(bossTemplate, bossKey) {
  // Generate 3-5 wave configuration for boss fights
  // Wave composition: 1-2 minion waves -> 1-2 elite waves -> boss wave
  var region = bossTemplate.region || 'lake';
  var loc = LOCATIONS[region];
  var regionEnemies = loc && loc.enemies ? loc.enemies : ['goblin'];
  
  var waves = [];
  var bossLv = bossTemplate.lv || 10;
  var totalWaves = bossLv >= 50 ? 5 : bossLv >= 30 ? 4 : 3; // Boss level determines wave count
  
  // Wave 1-2: Minion waves (1-2 enemies each, scaled down)
  for (var w = 0; w < Math.min(2, totalWaves - 1); w++) {
    var numMinions = rand(1, 2);
    var minions = [];
    for (var m = 0; m < numMinions; m++) {
      var eid = regionEnemies[rand(0, regionEnemies.length - 1)];
      var template = ENEMIES[eid];
      if (!template || template.isBoss || template.isElite) { m--; continue; }
      var copy = Object.assign({}, template);
      scaleEnemy(copy);
      copy.curHp = copy.hp;
      if (!copy.lv) copy.lv = Math.max(1, Math.round((copy.hp + copy.atk * 3) / 50));
      minions.push(copy);
    }
    if (minions.length > 0) {
      waves.push({ type: 'minion', label: '小兵波次', enemies: minions });
    }
  }
  
  // Wave 3-4: Elite waves (1 elite each, scaled up)
  var numEliteWaves = Math.max(0, totalWaves - 3);
  for (var e = 0; e < numEliteWaves; e++) {
    var baseEnemy = ENEMIES[regionEnemies[rand(0, regionEnemies.length - 1)]];
    if (!baseEnemy || baseEnemy.isBoss) baseEnemy = ENEMIES.goblin;
    var elite = {
      name: '精锐' + baseEnemy.name,
      emoji: '💀',
      id: baseEnemy.id,
      hp: Math.floor(baseEnemy.hp * 2.5 * DIFF_SCALE),
      atk: Math.floor(baseEnemy.atk * 2 * DIFF_SCALE),
      agi: Math.floor((baseEnemy.agi || 5) * 1.5),
      xp: Math.floor(baseEnemy.xp * 2),
      isElite: true,
      skills: baseEnemy.skills || [],
      curHp: 0, lv: 0
    };
    scaleEnemy(elite);
    elite.curHp = elite.hp;
    elite.lv = Math.max(1, Math.round((elite.hp + elite.atk * 3) / 50));
    waves.push({ type: 'elite', label: '精锐波次', enemies: [elite] });
  }
  
  // Final wave: Boss
  waves.push({ type: 'boss', label: '👑 ' + bossTemplate.name, enemies: [bossTemplate] });
  
  return waves;
}

function _showWaveIntermission(waveIdx, totalWaves, nextWave) {
  // Show intermission screen between waves
  var html = '';
  html += '<div class="scene-title">⚔️ 波次休息</div>';
  html += '<div class="wave-progress" style="text-align:center;margin:12px 0;font-size:1.2em">';
  html += '第 <span style="color:var(--accent)">' + waveIdx + '</span> / ' + totalWaves + ' 波完成';
  html += '</div>';
  
  // Show player status
  var hpPct = Math.floor(G.hp / G.maxHp * 100);
  var mpPct = Math.floor(G.mp / G.maxMp * 100);
  html += '<div class="wave-status" style="margin:15px 0;padding:10px;border:1px solid var(--border);border-radius:6px">';
  html += '<div style="margin:6px 0">❤️ HP: <span style="color:' + (hpPct > 40 ? 'var(--hp)' : 'var(--danger)') + '">' + G.hp + '</span> / ' + G.maxHp + '</div>';
  html += '<div style="margin:6px 0">💧 MP: <span style="color:var(--mp)">' + G.mp + '</span> / ' + G.maxMp + '</div>';
  html += '</div>';
  
  // Next wave preview
  html += '<div class="wave-next" style="margin:12px 0;padding:10px;background:rgba(0,0,0,0.3);border-radius:6px">';
  html += '<div style="color:var(--accent);margin-bottom:8px">下一波: ' + nextWave.label + '</div>';
  var previewEnemies = nextWave.enemies;
  for (var i = 0; i < previewEnemies.length; i++) {
    var pe = previewEnemies[i];
    html += '<div style="margin:4px 0">' + (pe.emoji || '👹') + ' ' + pe.name + '</div>';
  }
  html += '</div>';
  
  // Options
  html += '<div class="btns">';
  // Heal option (if HP < 70% and has potions)
  var hasPotion = G.inventory && G.inventory.some(function(it) { return it.type === 'potion' && it.heal; });
  if (hpPct < 70 && hasPotion) {
    html += '<button class="btn" onclick="_usePotionInWave()">🧪 使用药水</button>';
  }
  // Buff option (costs MP)
  if (G.mp >= 20) {
    html += '<button class="btn" onclick="_buffBeforeWave()">✨ 强化祝福 (20 MP)</button>';
  }
  // Continue
  html += '<button class="btn btn-primary" onclick="_continueNextWave()">⚔️ 继续战斗</button>';
  html += '</div>';
  
  render(html);
}

function _usePotionInWave() {
  // Find and use a healing potion
  if (!G.inventory) return;
  var idx = G.inventory.findIndex(function(it) { return it.type === 'potion' && it.heal; });
  if (idx < 0) { toast('❌ 没有药水'); return; }
  var potion = G.inventory.splice(idx, 1)[0];
  G.hp = Math.min(G.maxHp, G.hp + potion.heal);
  toast('🧪 使用' + potion.name + '，恢复 ' + potion.heal + ' HP');
  // Re-render intermission
  var b = G.battle;
  if (b && b.waves && b.wave < b.totalWaves) {
    _showWaveIntermission(b.wave, b.totalWaves, b.waves[b.wave]);
  }
}

function _buffBeforeWave() {
  // Spend MP to get a temp buff for next wave
  if (G.mp < 20) { toast('❌ MP不足'); return; }
  G.mp -= 20;
  G._waveTempAtk = Math.floor(calcAtk() * 0.15);
  G._waveTempDef = Math.floor(calcDef() * 0.15);
  toast('✨ 获得临时攻击+15%、防御+15%（本波次有效）');
  var b = G.battle;
  if (b && b.waves && b.wave < b.totalWaves) {
    _showWaveIntermission(b.wave, b.totalWaves, b.waves[b.wave]);
  }
}

function _continueNextWave() {
  // Start next wave
  var b = G.battle;
  if (!b || !b.waves) return;
  b.wave++;
  if (b.wave >= b.totalWaves) {
    // Should not happen, but safety
    endBattle();
    return;
  }
  
  // Apply wave temp buffs if any
  if (G._waveTempAtk) { G._tempAtkBuff = (G._tempAtkBuff || 0) + G._waveTempAtk; delete G._waveTempAtk; }
  if (G._waveTempDef) { G._tempDefBuff = (G._tempDefBuff || 0) + G._waveTempDef; delete G._waveTempDef; }
  
  // Setup next wave enemies
  var nextWave = b.waves[b.wave];
  b.enemies = nextWave.enemies;
  b.turn = 0;
  b.defending = false;
  b.warcry = 0; // Reset warcry for new wave
  G.selectedTarget = 0;
  G._waveNoDamage = true;
  G._comboCount = 0; // Reset combo
  
  // Reset enemy intents
  for (var i = 0; i < b.enemies.length; i++) {
    var e = b.enemies[i];
    if (e.skills && e.skills.length > 0) {
      var sk = ENEMY_SKILLS[e.skills[0]];
      e._intent = sk ? (sk.emoji || '🔮') + ' ' + sk.name : '⚔️攻击';
    } else {
      e._intent = '⚔️攻击';
    }
  }
  
  var waveMsg = '⚔️ 第' + (b.wave + 1) + '波 / 共' + b.totalWaves + '波 — ' + nextWave.label;
  renderBattle(waveMsg);
}

function miniMapTreasure() {
  // Treasure chests drop materials + rare items + gold
  var loot = [];
  // Always drop some gold
  var goldAmt = rand(5, 15 + G.level * 2);
  G.gold += goldAmt;
  loot.push('💰' + goldAmt);
  // Always drop 1-2 materials
  var matKeys = Object.keys(MATERIALS);
  var uncommonMats = matKeys.filter(function(k) { return MATERIALS[k].rarity === 'uncommon' || MATERIALS[k].rarity === 'common'; });
  for (var i = 0; i < rand(1, 2); i++) {
    var mk = uncommonMats[rand(0, uncommonMats.length - 1)];
    var m = MATERIALS[mk];
    var item = { id: m.id, name: m.name, type: 'material', icon: m.icon, category: m.category, rarity: m.rarity, sellPrice: m.sellPrice, craftValue: m.craftValue };
    G.inventory.push(item);
    loot.push(m.icon + ' ' + m.name);
  }
  // 20% chance rare material
  if (Math.random() < 0.2) {
    var rareMats = matKeys.filter(function(k) { return MATERIALS[k].rarity === 'rare'; });
    var rm = MATERIALS[rareMats[rand(0, rareMats.length - 1)]];
    if (rm) { G.inventory.push({ id: rm.id, name: rm.name, type: 'material', icon: rm.icon, category: rm.category, rarity: rm.rarity, sellPrice: rm.sellPrice, craftValue: rm.craftValue }); loot.push(rm.icon + ' ' + rm.name); }
  }
  // 15% chance: random equipment drop
  if (Math.random() < 0.15) {
    var eqDrop = generateRandomDrop(false);
    G.inventory.push(eqDrop);
    loot.push(eqDrop.rarityColor ? '<span style="color:' + eqDrop.rarityColor + '">' + eqDrop.name + '</span>' : eqDrop.name);
  }
  // 5% chance: regional clue (if available)
  var clueMap = {
    lake:'clue_map_fragment', darkforest:'clue_forest_note', fortress:'clue_blackiron_letter', mine:'clue_tablet_mine',
    scholar_tower:'clue_dragon_scroll', north_pass:'clue_dragon_scale', dragontemple:'clue_dragon_blood',
    snowpeak:'clue_frostwing_feather', coastcave:'clue_tidal_chart', stormcape:'clue_storm_log',
    misthollow:'clue_mist_mirror', jademarsh:'clue_hydra_scale',
    ashplains:'clue_ash_crest', volcano:'clue_flame_prophecy',
    abyssgate:'clue_void_seal', shadowrealm:'clue_shadow_truth'
  };
  var locClue = clueMap[G.location];
  if (locClue && Math.random() < 0.05) {
    checkStoryTriggers('find_clue', locClue);
    if (!G._foundClues) G._foundClues = {};
    if (!G._foundClues[locClue]) {
      G._foundClues[locClue] = true;
      loot.push('📜 线索!');
    }
  }
  // Mark treasure as collected (change room type)
  var map = getMapForLocation();
  var room = map.rooms[G.miniMapPos.r][G.miniMapPos.c];
  room.type = 'path'; // treasure collected
  // Story trigger: found treasure
  checkStoryTriggers('find_treasure', 'treasure');
  _updateTreasureQuestProgress(G.location);
  updateStatus();
  toast('📦 发现宝箱!' + loot.join(' '));
  renderMiniMap('你在角落里发现了一个宝箱!');
}

function miniMapEvent() {
  // Random event outcomes - expanded pool
  var events = [
    { msg: '你发现了一面古老的石碑,上面刻着模糊的文字...', effect: function() { G.xp += 15; return '⭐ +15 XP'; } },
    { msg: '一位旅人向你分享了一些有用的信息。', effect: function() { G.xp += 10; return '⭐ +10 XP'; } },
    { msg: '你在地上发现了一些散落的材料。', effect: function() { var mk = Object.keys(MATERIALS).filter(function(k){return MATERIALS[k].rarity==='common';}); var m = MATERIALS[mk[rand(0,mk.length-1)]]; G.inventory.push({id:m.id,name:m.name,type:'material',icon:m.icon,category:m.category,rarity:m.rarity,sellPrice:m.sellPrice,craftValue:m.craftValue}); return m.icon + ' ' + m.name; } },
    { msg: '一股神秘的力量从地面涌出,你感觉精力恢复了。', effect: function() { G.hp = Math.min(G.maxHp, G.hp + 30); G.mp = Math.min(G.maxMp, G.mp + 20); return '❤️+30 💧+20'; } },
    { msg: '你发现了一个隐藏的补给箱!', effect: function() { var mk = Object.keys(MATERIALS).filter(function(k){return MATERIALS[k].rarity==='common'||MATERIALS[k].rarity==='uncommon';}); var m = MATERIALS[mk[rand(0,mk.length-1)]]; G.inventory.push({id:m.id,name:m.name,type:'material',icon:m.icon,category:m.category,rarity:m.rarity,sellPrice:m.sellPrice,craftValue:m.craftValue}); G.hp = Math.min(G.maxHp, G.hp + 20); return m.icon + ' ' + m.name + ' ❤️+20'; } },
    // === New events ===
    { msg: '你在岩壁上发现了一处矿脉!', effect: function() { var ores = ['iron_scrap','crystal_shard','moonstone']; var oid = ores[rand(0,ores.length-1)]; var m = MATERIALS[oid]; if(m) { G.inventory.push({id:m.id,name:m.name,type:'material',icon:m.icon,category:m.category,rarity:m.rarity,sellPrice:m.sellPrice,craftValue:m.craftValue}); return '⛏️ ' + m.icon + ' ' + m.name; } return '什么也没找到...'; } },
    { msg: '一座残破的祭坛散发着微弱的光芒...', effect: function() { G.hp = Math.min(G.maxHp, G.hp + Math.floor(G.maxHp * 0.25)); G.mp = Math.min(G.maxMp, G.mp + Math.floor(G.maxMp * 0.25)); return '✨ 恢复25% HP和MP'; } },
    { msg: '你听到了微弱的呼救声,发现了一个受伤的冒险者。', effect: function() { G.xp += 25; G.gold += 15; return '⭐ +25 XP 💰 +15 金币 (冒险者的谢礼)'; } },
    { msg: '一只小动物从草丛中蹿出,嘴里叼着什么东西!', effect: function() { G.gold += rand(5, 20); return '💰 获得金币'; } },
    { msg: '你发现了一本破旧的日志,记载着前人的冒险经验。', effect: function() { G.xp += 20; G.luk += 1; return '⭐ +20 XP 🍀 +1 幸运'; } },
    { msg: '地上有一个暗格,里面藏着某种东西...', effect: function() { var r = Math.random(); if(r < 0.5) { var mk = Object.keys(MATERIALS).filter(function(k){return MATERIALS[k].rarity==='uncommon'||MATERIALS[k].rarity==='rare';}); if(mk.length > 0) { var m = MATERIALS[mk[rand(0,mk.length-1)]]; G.inventory.push({id:m.id,name:m.name,type:'material',icon:m.icon,category:m.category,rarity:m.rarity,sellPrice:m.sellPrice,craftValue:m.craftValue}); return m.icon + ' ' + m.name + ' (稀有!)'; } } G.gold += rand(10, 30); return '💰 获得金币'; } },
    { msg: '你发现了一处温泉,热水蒸腾着雾气。', effect: function() { G.hp = Math.min(G.maxHp, G.hp + Math.floor(G.maxHp * 0.4)); return '♨️ 恢复40% HP'; } },
    { msg: '一颗流星划过天际,你觉得这是好运的征兆。', effect: function() { G.luk += 1; return '🍀 +1 幸运'; } },
    { msg: '你发现了一具冒险者的遗骸,身旁散落着装备...', effect: function() { G.gold += rand(15, 40); var mk = Object.keys(MATERIALS).filter(function(k){return MATERIALS[k].rarity==='common';}); var m = MATERIALS[mk[rand(0,mk.length-1)]]; if(m) G.inventory.push({id:m.id,name:m.name,type:'material',icon:m.icon,category:m.category,rarity:m.rarity,sellPrice:m.sellPrice,craftValue:m.craftValue}); return '💰 +金币 ' + (m ? m.icon + ' ' + m.name : ''); } },
    { msg: '你遇到了一位神秘商人,他愿意低价出售一些材料。', effect: function() { var cost = rand(5, 15); if(G.gold >= cost) { G.gold -= cost; var mk = Object.keys(MATERIALS).filter(function(k){return MATERIALS[k].rarity==='uncommon';}); var m = MATERIALS[mk[rand(0,mk.length-1)]]; if(m) { G.inventory.push({id:m.id,name:m.name,type:'material',icon:m.icon,category:m.category,rarity:m.rarity,sellPrice:m.sellPrice,craftValue:m.craftValue}); return '💰-' + cost + ' → ' + m.icon + ' ' + m.name; } G.gold += cost; } return '💰不够,商人离开了'; } },
    { msg: '一面古老的铜镜映出你的面容,你感觉有什么东西改变了...', effect: function() { G.xp += 35; return '⭐ +35 XP (铜镜的启示)'; } }
  ];
  // Regional flavor events (25% chance to replace generic)
  var regionalEvents = {
    lake: [
      { msg: '湖面泛起涟漪,一条银色的鱼跃出水面,鳞片反射着奇异的光芒。', effect: function() { G.xp += 10; G.gold += 8; return '⭐ +10 XP 💰 +8 (银鳞鱼换金)'; } },
      { msg: '你在湖底发现了一个半埋在泥中的古老容器。', effect: function() { var mk = Object.keys(MATERIALS).filter(function(k){return MATERIALS[k].rarity==='uncommon';}); var m = MATERIALS[mk[rand(0,mk.length-1)]]; if(m) { G.inventory.push({id:m.id,name:m.name,type:'material',icon:m.icon,category:m.category,rarity:m.rarity,sellPrice:m.sellPrice,craftValue:m.craftValue}); return m.icon + ' ' + m.name; } return '没什么有用的'; } }
    ],
    snowpeak: [
      { msg: '冰雪中你发现了一株发光的霜叶草,据说入药有奇效。', effect: function() { G.hp = Math.min(G.maxHp, G.hp + 50); return '❄️ 霜叶草 → ❤️+50'; } },
      { msg: '一只霜翼幼鸟冻僵在雪地里,你将它救起,它留下了一根闪光的羽毛。', effect: function() { G.luk += 1; return '🍀 +1 幸运 (霜翼的谢礼)'; } }
    ],
    volcano: [
      { msg: '岩浆缝隙中流淌着炽热的液态金属,你小心地收集了一些。', effect: function() { var m = MATERIALS['dragon_scale']; if(m) { G.inventory.push({id:m.id,name:m.name,type:'material',icon:m.icon,category:m.category,rarity:m.rarity,sellPrice:m.sellPrice,craftValue:m.craftValue}); return m.icon + ' ' + m.name; } G.gold += 20; return '💰 +20'; } },
      { msg: '火山灰中你发现了一个耐热的容器,里面是一瓶火焰精华。', effect: function() { G.mp = Math.min(G.maxMp, G.mp + 40); return '🔥 火焰精华 → 💧+40 MP'; } }
    ],
    abyssgate: [
      { msg: '深渊的边缘传来低沉的吟唱,你感到灵魂被拉扯......但你站稳了。', effect: function() { G.xp += 40; G.def += 1; return '⭐ +40 XP 🛡️ +1 防御 (深渊洗礼)'; } },
      { msg: '虚空中漂浮着一块暗物质,它散发着危险但强大的能量。', effect: function() { var m = MATERIALS['shadow_essence']; if(m) { G.inventory.push({id:m.id,name:m.name,type:'material',icon:m.icon,category:m.category,rarity:m.rarity,sellPrice:m.sellPrice,craftValue:m.craftValue}); return m.icon + ' ' + m.name; } G.xp += 30; return '⭐ +30 XP'; } }
    ],
    dragontemple: [
      { msg: '龙之神殿的墙壁上闪烁着古老符文,你感受到龙族力量的共鸣。', effect: function() { G.atk += 1; G.xp += 30; return '🐉 ⭐ +30 XP ⚔️ +1 攻击 (龙族共鸣)'; } },
      { msg: '你触碰了一块龙血石,灼热的力量涌入你的血脉。', effect: function() { G.hp = G.maxHp; G.mp = G.maxMp; return '🐉 龙血石 → 全回复!'; } }
    ],
    shadowrealm: [
      { msg: '暗影在你身边凝聚成一面镜子,映照出你内心深处的恐惧。', effect: function() { G.xp += 50; return '⭐ +50 XP (直面恐惧)'; } },
      { msg: '一个暗影信使递给你一封信,然后消散在空气中。信上写着: 「记住你是谁。」', effect: function() { G.luk += 1; G.def += 1; return '🍀 +1 幸运 🛡️ +1 防御 (自我确认)'; } }
    ],
    throneofages: [
      { msg: '时间在这里变得模糊,你同时看到了过去和未来的碎片。', effect: function() { G.xp += 60; G.luk += 1; return '⭐ +60 XP 🍀 +1 幸运 (时间碎片)'; } },
      { msg: '王座的回廊中回荡着千年前英雄的战歌,你的血液沸腾了。', effect: function() { G.atk += 2; return '⚔️ +2 攻击 (英雄战歌)'; } }
    ]
  };
  var regEvts = regionalEvents[G.location];
  var evt;
  if (regEvts && Math.random() < 0.25) {
    evt = regEvts[rand(0, regEvts.length - 1)];
  } else {
    evt = events[rand(0, events.length - 1)];
  }
  var reward = evt.effect();
  // Mark event as done
  var map = getMapForLocation();
  var room = map.rooms[G.miniMapPos.r][G.miniMapPos.c];
  room.type = 'path';
  updateStatus();
  toast('✨ ' + evt.msg);
  if (reward) toast('📦 获得: ' + reward);
  renderMiniMap(evt.msg);
}


// ═══════════════════════════════════════════════════════════
// SCENE: BATTLE (with SVG enemies and fixed HP bars)
// ═══════════════════════════════════════════════════════════

function renderBattle(msg) {
  if (!G || !G.battle) return;
  var b = G.battle;
  var html = '';

  // Weather display in battle
  html += renderWeatherBar(G.location);

  // Check win/loss
  var alive = b.enemies.filter(function(e) { return e.curHp > 0; });
  var isVictory = alive.length === 0;
  var isDefeat = G.hp <= 0;

  // === D1: Battle turn counter ===
  html += '<div class="battle-turn-counter">';
  html += '<span>回合 <span class="turn-num">' + (b.turn + 1) + '</span></span>';
  // A3: Wave progress indicator
  if (b.totalWaves > 0) {
    html += '<span>波次 <span style="color:var(--accent)">' + (b.wave + 1) + '</span>/' + b.totalWaves + '</span>';
  }
  if (G._comboCount && G._comboCount > 1) {
    html += '<span>连击 <span class="combo-num">🔥x' + G._comboCount + '</span></span>';
  }
  // D1: Battle speed toggle
  var speedLabel = G._battleSpeed === 2 ? '2x' : (G._battleSpeed === 3 ? '3x' : '1x');
  html += '<span style="cursor:pointer" onclick="toggleBattleSpeed()">⚡' + speedLabel + '</span>';
  html += '</div>';

  // === ENEMY AREA ===
  // D1: Boss frame detection
  var hasBoss = false;
  for (var bi2 = 0; bi2 < b.enemies.length; bi2++) { if (b.enemies[bi2].isBoss) { hasBoss = true; break; } }
  if (hasBoss) html += '<div class="battle-boss-frame">';
  html += '<div class="battle-enemies">';
  for (var i = 0; i < b.enemies.length; i++) {
    var e = b.enemies[i];
    var dead = e.curHp <= 0;
    var isSelected = (i === G.selectedTarget && !dead);
    var hpPct = Math.max(0, Math.floor(e.curHp / e.hp * 100));
    // D1: HP bar color class
    var hpClass = hpPct > 60 ? 'hp-high' : (hpPct > 30 ? 'hp-mid' : (hpPct > 10 ? 'hp-low' : 'hp-critical'));

    html += '<div class="enemy-card' + (dead ? ' enemy-dead' : '') + (isSelected ? ' enemy-selected' : '') + (e._charging ? ' enemy-charging' : '') + '"';
    if (!dead && !isVictory && !isDefeat) {
      html += ' onclick="selectTarget(' + i + ')" style="cursor:pointer"';
    }
    html += '>';
    html += '<div class="enemy-emoji">' + (e.emoji || (e.isBoss ? '👑' : '👹')) + (e._rareSpawn ? '⭐' : '') + '</div>';
    html += '<div class="enemy-info">';
    html += '<div class="enemy-name">' + (e.lv ? 'Lv.' + e.lv + ' ' : '') + e.name + (e.isBoss ? ' 👑' : '') + '</div>';
    // D1: Enemy intent indicator (deterministic per turn, stored on enemy object)
    var eIntent = e._intent || '';
    if (e._charging) { eIntent = '⚡蓄力中'; }
    else if (e._stunned || e.stunned) { eIntent = '💫眩晕'; }
    if (eIntent && !dead) html += '<div class="enemy-intent">意图: ' + eIntent + '</div>';
    // Enemy status icons
    var eStatus = [];
    if (e._buffed) eStatus.push('📈');
    if (e.stunned || e._stunned) eStatus.push('💫');
    if (e.poison && e.poison > 0) eStatus.push('🧪' + Math.floor(e.poison));
    if (e.burn && e.burn > 0) eStatus.push('🔥' + Math.floor(e.burn));
    if (e.bleed && e.bleed > 0) eStatus.push('🩸' + Math.floor(e.bleed));
    if (e._poisoned && e._poisoned > 0) eStatus.push('☠️');
    if (e._charging) eStatus.push('⚡蓄力');
    if (eStatus.length > 0) html += '<div class="enemy-status">' + eStatus.join(' ') + '</div>';
    html += '<div class="enemy-hp-bar"><div class="enemy-hp-fill ' + hpClass + '" style="width:' + hpPct + '%"></div></div>';
    html += '<div class="enemy-hp-text">' + e.curHp + '/' + e.hp + '</div>';
    html += '</div>';
    if (isSelected && !dead) html += '<div class="enemy-target-arrow">▼</div>';
    html += '</div>';
  }
  html += '</div>';
  if (hasBoss) html += '</div>'; // Close boss frame

  // === PLAYER STATUS ===
  var pHpPct = Math.max(0, Math.floor(G.hp / G.maxHp * 100));
  var pMpPct = Math.max(0, Math.floor(G.mp / G.maxMp * 100));
  var pHpClass = pHpPct > 60 ? 'hp-high' : (pHpPct > 30 ? 'hp-mid' : (pHpPct > 10 ? 'hp-low' : 'hp-critical'));
  var isDefending = b.defending;

  html += '<div class="battle-player' + (isDefending ? ' player-defending' : '') + (pHpPct <= 25 ? ' player-low-hp' : '') + '">';
  html += '<div class="player-name">Lv.' + G.level + ' ' + (G.name || '冒险者') + (isDefending ? ' 🛡️防御中' : '') + (pHpPct <= 25 ? ' ⚠️危险' : '') + '</div>';
  html += '<div class="player-bars">';
  html += '<div class="player-bar-row"><span class="bar-label">❤️</span><div class="player-hp-bar"><div class="player-hp-fill ' + pHpClass + '" style="width:' + pHpPct + '%"></div></div><span class="bar-val">' + G.hp + '/' + G.maxHp + '</span></div>';
  html += '<div class="player-bar-row"><span class="bar-label">💧</span><div class="player-mp-bar"><div class="player-mp-fill' + (pMpPct <= 20 ? ' player-mp-low' : '') + '" style="width:' + pMpPct + '%"></div></div><span class="bar-val">' + G.mp + '/' + G.maxMp + '</span></div>';
  html += '</div>';
  html += '<div class="player-stats-inline">⚔️<span>' + calcAtk() + '</span> 🔮<span>' + calcMagicAtk() + '</span> 🛡️<span>' + calcDef() + '</span> 🍀<span>' + (G.luk || 0) + '</span></div>';

  // === D1: Player status effects bar ===
  html += '<div class="player-status-bar">';
  if (b.warcry && b.warcry > 0) html += '<span class="status-icon buff">📢战吼 <span class="turns-left">' + b.warcry + '</span></span>';
  if (b.atkBuff && b.atkBuffTurns > 0) html += '<span class="status-icon buff">⬆️攻击+ <span class="turns-left">' + b.atkBuffTurns + '</span></span>';
  if (b.defBuff && b.defBuffTurns > 0) html += '<span class="status-icon buff">🛡️防御+ <span class="turns-left">' + b.defBuffTurns + '</span></span>';
  if (b.shield && b.shield > 0) html += '<span class="status-icon buff">🔰护盾 ' + b.shield + '</span>';
  if (G._tempAtkBuff && G._tempAtkBuffTurns > 0) html += '<span class="status-icon buff">💪临时攻击 <span class="turns-left">' + G._tempAtkBuffTurns + '</span></span>';
  if (G._stunned || G._stunTurns > 0) html += '<span class="status-icon debuff">💫眩晕 <span class="turns-left">' + G._stunTurns + '</span></span>';
  if (G._poisoned && G._poisoned > 0) html += '<span class="status-icon debuff">🧪中毒 ' + Math.floor(G._poisoned) + '</span>';
  if (G._burning && G._burning > 0) html += '<span class="status-icon debuff">🔥燃烧 ' + Math.floor(G._burning) + '</span>';
  if (G._bleeding && G._bleeding > 0) html += '<span class="status-icon debuff">🩸流血 ' + Math.floor(G._bleeding) + '</span>';
  if (G._frozen || G._freezeTurns > 0) html += '<span class="status-icon debuff">❄️冰冻 <span class="turns-left">' + G._freezeTurns + '</span></span>';
  if (G._slowed || G._slowTurns > 0) html += '<span class="status-icon debuff">🐌减速 <span class="turns-left">' + G._slowTurns + '</span></span>';
  // Set bonus indicators
  var sb = calcSetBonuses();
  if (sb.fireImmune) html += '<span class="status-icon buff">🔥火免疫</span>';
  if (sb.deathSaveCd) html += '<span class="status-icon buff">✨不死</span>';
  if (sb.mpCostReduct) html += '<span class="status-icon buff">💧省蓝</span>';
  if (sb.hpRegenPct) html += '<span class="status-icon buff">💚再生</span>';
  html += '</div>';

  html += '</div>';

  // === BATTLE LOG ===
  if (b.log && b.log.length > 0) {
    html += '<div class="battle-log">';
    // D1: Show only last 5 log entries to reduce clutter
    var logStart = Math.max(0, b.log.length - 5);
    for (var li = logStart; li < b.log.length; li++) {
      html += '<div class="log-entry">' + b.log[li] + '</div>';
    }
    html += '</div>';
  }

  // === VICTORY / DEFEAT ===
  if (isVictory) {
    html += '<div class="battle-result victory">';
    html += '<div class="result-title victory-title">🏆 胜利!</div>';
    var totalXp = 0;
    for (var vi = 0; vi < b.enemies.length; vi++) {
      totalXp += b.enemies[vi].xp || 0;
      // No gold from combat - must sell items or trade
    }
    html += '<div class="result-rewards result-anim">+' + totalXp + ' XP</div>';
    // Drops
    var drops = [];
    for (var di = 0; di < b.enemies.length; di++) {
      var e = b.enemies[di];
      var dropRoll = Math.random() * 100;
      var baseRate = e.isBoss ? 60 : 15;
      var lukBonus = G.luk * 1;
      if (dropRoll < Math.min(80, baseRate + lukBonus)) {
        var item = generateRandomDrop(e.isBoss);
        if (item) drops.push(item);
      }
      if (Math.random() * 100 < 30) drops.push({ name:'小型生命药水', type:'potion', heal:30, icon:'🧪', rarity:'common' });
      // Material drops
      var matDrops = ENEMY_MAT_DROPS[e.id];
      if (matDrops) {
        var mtiers = ['common', 'uncommon', 'rare', 'epic'];
        for (var mti = 0; mti < mtiers.length; mti++) {
          var mtier = mtiers[mti];
          var mtierDrops = matDrops[mtier];
          if (!mtierDrops) continue;
          for (var mmi = 0; mmi < mtierDrops.length; mmi++) {
            if (Math.random() < mtierDrops[mmi].rate) {
              var mmat = MATERIALS[mtierDrops[mmi].mid];
              if (mmat) drops.push({ id:mmat.id, name:mmat.name, type:'material', icon:mmat.icon, category:mmat.category, rarity:mmat.rarity, sellPrice:mmat.sellPrice, craftValue:mmat.craftValue });
            }
          }
        }
      }
    }
    if (drops.length > 0) {
      html += '<div class="result-drops">';
      for (var dk = 0; dk < drops.length; dk++) {
        var dr = drops[dk];
        var rarColor = dr.rarity === 'epic' ? '#a335ee' : dr.rarity === 'rare' ? '#0070dd' : dr.rarity === 'uncommon' ? '#1eff00' : '#9d9d9d';
        var rarGlow = dr.rarity === 'epic' ? 'text-shadow:0 0 8px #a335ee' : dr.rarity === 'rare' ? 'text-shadow:0 0 6px #0070dd' : '';
        html += '<div class="drop-item drop-anim" style="color:' + rarColor + ';' + rarGlow + ';animation-delay:' + (dk * 0.15) + 's">' + (dr.icon || '📦') + ' ' + dr.name + '</div>';
        G.inventory.push(dr);
      }
      html += '</div>';
    }
    G.xp += totalXp;
    G.totalBattlesWon++;
    // Boss flag
    for (var bi = 0; bi < b.enemies.length; bi++) {
      if (b.enemies[bi].isBoss) { G.bossDefeated[G.location] = true; _updateBossQuestProgress(G.location); }
    }
    // Level up check
    while (G.xp >= G.nextXp) {
      G.xp -= G.nextXp;
      G.level++;
      G.attrPts += 3;
      G.nextXp = calcNextXp(G.level);
      G.maxHp = calcMaxHp();
      G.maxMp = calcMaxMp();
      G.hp = G.maxHp;
      G.mp = G.maxMp;
      html += '<div class="level-up level-up-anim" style="animation-delay:0.3s">🎉 升级!Lv.' + G.level + ' | +3属性点</div>';
    }
    G.inBattle = false;
    G.battle = null;
    html += '<div class="btns">';
    html += '<button class="btn btn-primary" onclick="renderMiniMap()">继续探索</button>';
    html += '</div>';
    html += '</div>';
    updateStatus();
    render(html);
    return;
  }

  if (isDefeat) {
    html += '<div class="battle-result defeat result-anim">';
    html += '<div class="result-title defeat-title" style="color:var(--danger)">💀 战败...</div>';
    var lostGold = Math.floor(G.gold * 0.1);
    G.gold -= lostGold;
    G.hp = Math.floor(G.maxHp * 0.3);
    G.mp = Math.floor(G.maxMp * 0.3);
    G.totalBattlesLost++;
    G.inBattle = false;
    G.battle = null;
    // Deep Dive death
    if (G._inDeepDive) {
      html += '<div class="result-desc">你在深渊中倒下了......</div>';
      html += '<div class="btns">';
      html += '<button class="btn btn-primary" onclick="ddOnDeath()">💀 继续</button>';
      html += '</div>';
      html += '</div>';
      updateStatus();
      render(html);
      return;
    }
    html += '<div class="result-desc">你在旅店醒来,失去了 ' + lostGold + ' 金币</div>';
    html += '<div class="btns">';
    html += '<button class="btn btn-primary" onclick="sceneInn()">🔄 重新开始</button>';
    html += '</div>';
    html += '</div>';
    updateStatus();
    render(html);
    return;
  }

  // === BATTLE EFFECT LAYER ===
  html += '<div id="battleEffect" class="battle-effect-layer" style="display:none"></div>';

  // === ACTION BUTTONS ===
  html += '<div class="battle-actions">';
  html += '<button class="btn btn-atk" onclick="G._battleAction=\'attack\';toast(\'⚔️ 选择攻击目标\')">⚔️ 攻击</button>';
  // D1: Quick attack - auto-selects next alive enemy and attacks
  html += '<button class="btn btn-atk" style="font-size:0.85em" onclick="quickAttack()">⚔️⚡</button>';

  if (G.origin && G.origin.skill && G.origin.skill.type !== '被动') {
    html += '<button class="btn btn-skill" id="btn_skill" onclick="useOriginSkill()">' + G.origin.skill.emoji + ' ' + G.origin.skill.name + '</button>';
  }

  // Q21: Skills shown as expandable groups
  if (G.skills && G.skills.length > 0) {
    var spells = [];
    var combatSkills = [];
    for (var si = 0; si < G.skills.length; si++) {
      var sk = SKILLS.find(function(s) { return s.id === G.skills[si]; });
      if (sk) {
        if (sk.category === 'spell') spells.push(sk);
        else combatSkills.push(sk);
      }
    }
    if (spells.length > 0) {
      html += '<button class="btn btn-skill" onclick="G._showSpells=!G._showSpells;renderBattle()">🔮 法术 ' + (G._showSpells ? '▼' : '▶') + '</button>';
      if (G._showSpells) {
        for (var sp = 0; sp < spells.length; sp++) {
          var ssk = spells[sp];
          var canUse = G.mp >= ssk.cost;
          var onCd = G._skillCooldowns && G._skillCooldowns[ssk.id] && G._skillCooldowns[ssk.id] > 0;
          var targetIcon = ssk.target === '群攻' ? '🎯A' : ssk.target === '自身' ? '🛡️' : '🎯1';
          var cdLabel = onCd ? ' <span class="skill-cd">⏳' + G._skillCooldowns[ssk.id] + '</span>' : (ssk.cd > 0 ? ' <span class="skill-cd-hint">CD' + ssk.cd + '</span>' : '');
          html += '<button class="btn btn-skill' + (!canUse || onCd ? ' btn-disabled' : '') + '" style="margin-left:12px;font-size:0.9em"' + (onCd ? '' : ' onclick="G._battleAction=\'skill:\'' + ssk.id + '\';' + (ssk.target === '自身' ? 'playerSkill(\'' + ssk.id + '\')' : 'toast(\'选择施法目标\')') + '"') + '>' + ssk.emoji + ' ' + ssk.name + ' <span class="skill-meta-inline">' + targetIcon + '</span><span class="skill-cost">' + ssk.cost + '💧</span>' + cdLabel + '</button>';
        }
      }
    }
    if (combatSkills.length > 0) {
      html += '<button class="btn btn-skill" onclick="G._showCombatSkills=!G._showCombatSkills;renderBattle()">🥊 技能 ' + (G._showCombatSkills ? '▼' : '▶') + '</button>';
      if (G._showCombatSkills) {
        for (var cs = 0; cs < combatSkills.length; cs++) {
          var csk = combatSkills[cs];
          var canUse2 = G.mp >= csk.cost;
          var onCd2 = G._skillCooldowns && G._skillCooldowns[csk.id] && G._skillCooldowns[csk.id] > 0;
          var targetIcon2 = csk.target === '群攻' ? '🎯A' : csk.target === '自身' ? '🛡️' : '🎯1';
          var cdLabel2 = onCd2 ? ' <span class="skill-cd">⏳' + G._skillCooldowns[csk.id] + '</span>' : (csk.cd > 0 ? ' <span class="skill-cd-hint">CD' + csk.cd + '</span>' : '');
          html += '<button class="btn btn-skill' + (!canUse2 || onCd2 ? ' btn-disabled' : '') + '" style="margin-left:12px;font-size:0.9em"' + (onCd2 ? '' : ' onclick="G._battleAction=\'skill:\'' + csk.id + '\';' + (csk.target === '自身' ? 'playerSkill(\'' + csk.id + '\')' : 'toast(\'选择攻击目标\')') + '"') + '>' + csk.emoji + ' ' + csk.name + ' <span class="skill-meta-inline">' + targetIcon2 + '</span><span class="skill-cost">' + csk.cost + '💧</span>' + cdLabel2 + '</button>';
        }
      }
    }
  }

  html += '<button class="btn btn-flee" onclick="fleeBattle()">🏃 逃跑</button>';
  var defReduc = Math.floor(calcDef() * 0.6 * 0.5);
  html += '<button class="btn" onclick="doDefend()" title="减少约' + defReduc + '伤害">🛡️ 防御(-' + defReduc + ')</button>';
  html += '<button class="btn" onclick="sceneInventoryFromBattle()">🎒 背包</button>';
  // D1: Auto-battle toggle
  if (G._autoBattle) {
    html += '<button class="btn" style="background:#b71c1c;color:#fff" onclick="stopAutoBattle()">⏹️ 停止自动</button>';
  } else {
    html += '<button class="btn" style="background:#2e7d32;color:#fff" onclick="startAutoBattle()">▶️ 自动</button>';
  }
  html += '</div>';

  render(html);
  updateStatus();
}

// === D1: Quick attack - auto-select next alive enemy and attack ===
// === D1: Auto-battle system ===
var _autoBattleTimer = null;

function startAutoBattle() {
  if (!G.battle || !G.inBattle) return;
  G._autoBattle = true;
  toast('▶️ 自动战斗已开启');
  _runAutoBattle();
}

function stopAutoBattle() {
  G._autoBattle = false;
  if (_autoBattleTimer) { clearTimeout(_autoBattleTimer); _autoBattleTimer = null; }
  toast('⏹️ 自动战斗已关闭');
  if (G.inBattle && G.battle) renderBattle();
}

function _runAutoBattle() {
  if (!G._autoBattle || !G.inBattle || !G.battle) {
    G._autoBattle = false;
    return;
  }
  // Strategy: Attack if HP > 40%, defend if HP <= 40%, use skill if MP > 60%
  var hpPct = G.hp / G.maxHp;
  if (hpPct <= 0.25 && G.inventory) {
    // Try using a healing potion
    var potion = G.inventory.findIndex(function(it) { return it.type === 'potion' && it.heal; });
    if (potion >= 0) {
      var p = G.inventory.splice(potion, 1)[0];
      G.hp = Math.min(G.maxHp, G.hp + p.heal);
      G.battle.log.push('🧪 使用' + p.name + '恢复' + p.heal + ' HP');
      showHealPopup(p.heal);
      _autoBattleTimer = setTimeout(function() { _runAutoBattle(); }, 600);
      return;
    }
  }
  if (hpPct <= 0.35) {
    doDefend();
  } else if (G.mp > G.maxMp * 0.6 && G.skills && G.skills.length > 0) {
    // Use first available skill (not on cooldown)
    var usableSkill = null;
    for (var si = 0; si < G.skills.length; si++) {
      var sk = SKILLS.find(function(s) { return s.id === G.skills[si]; });
      if (sk && G.mp >= sk.cost && (!G._skillCooldowns || !G._skillCooldowns[sk.id] || G._skillCooldowns[sk.id] <= 0)) { usableSkill = sk; break; }
    }
    if (usableSkill) {
      if (usableSkill.target === '自身') { playerSkill(usableSkill.id); }
      else { playerSkill(usableSkill.id); }
    } else {
      quickAttack();
    }
  } else {
    quickAttack();
  }
  // Schedule next action
  var delay = Math.max(300, 800 / (G._battleSpeed || 1));
  _autoBattleTimer = setTimeout(function() { _runAutoBattle(); }, delay);
}

function quickAttack() {
  var b = G.battle;
  if (!b) return;
  // Find next alive enemy (prefer current target if alive, otherwise first alive)
  var targetIdx = -1;
  if (b.enemies[G.selectedTarget] && b.enemies[G.selectedTarget].curHp > 0) {
    targetIdx = G.selectedTarget;
  } else {
    for (var i = 0; i < b.enemies.length; i++) {
      if (b.enemies[i].curHp > 0) { targetIdx = i; break; }
    }
  }
  if (targetIdx >= 0) {
    G.selectedTarget = targetIdx;
    G._battleAction = null;
    playerAttack();
  }
}

function selectTarget(idx) {
  // D1: Auto-skip dead targets when clicking
  if (G.battle.enemies[idx] && G.battle.enemies[idx].curHp <= 0) {
    // Find next alive enemy
    for (var i = 0; i < G.battle.enemies.length; i++) {
      var ni = (idx + i) % G.battle.enemies.length;
      if (G.battle.enemies[ni].curHp > 0) { idx = ni; break; }
    }
  }
  G.selectedTarget = idx;
  // Q22: If a battle action was selected, execute it on this target
  if (G._battleAction === 'attack') {
    G._battleAction = null;
    playerAttack();
    return;
  }
  if (G._battleAction && G._battleAction.startsWith('skill:')) {
    var skillId = G._battleAction.substring(6);
    G._battleAction = null;
    playerSkill(skillId);
    return;
  }
  renderBattle('目标:' + (G.battle.enemies[idx] ? G.battle.enemies[idx].name : '?'));
}

// ═══════════════════════════════════════════════════════════
// BATTLE EFFECT SYSTEM - Visual effects for combat
// ═══════════════════════════════════════════════════════════
var BATTLE_EFFECTS = {
  fire:      { emoji:'🔥', anim:'burn', color:'#ff4444', particles:['🔥','💥','⚡'] },
  ice:       { emoji:'❄️', anim:'freeze', color:'#44ccff', particles:['❄️','✨','💎'] },
  lightning: { emoji:'⚡', anim:'zap', color:'#ffee44', particles:['⚡','✨','💥'] },
  explosion: { emoji:'💥', anim:'boom', color:'#ff8800', particles:['💥','🔥','☄️'] },
  missile:   { emoji:'✨', anim:'fly', color:'#cc44ff', particles:['✨','💫','⭐'] },
  blizzard:  { emoji:'🌨️', anim:'storm', color:'#aaddff', particles:['🌨️','❄️','💨'] },
  meteor:    { emoji:'☄️', anim:'crash', color:'#ff4400', particles:['☄️','💥','🔥','💀'] },
  heal:      { emoji:'💚', anim:'glow', color:'#44ff44', particles:['💚','✨','💖'] },
  shield:    { emoji:'🛡️', anim:'shield', color:'#4488ff', particles:['🛡️','✨','💎'] },
  slash:     { emoji:'⚔️', anim:'cut', color:'#ffcc44', particles:['⚔️','💥','🗡️'] },
  whirlwind: { emoji:'🌪️', anim:'spin', color:'#88ccff', particles:['🌪️','💨','⚔️'] },
  backstab:  { emoji:'🗡️', anim:'stab', color:'#aa44ff', particles:['🗡️','💥','🩸'] },
  shieldBash:{ emoji:'🛡️', anim:'bash', color:'#aaaaff', particles:['🛡️','💥','💫'] },
  rapid:     { emoji:'👊', anim:'multi', color:'#ffaa44', particles:['👊','💥','⚡'] },
  warcry:    { emoji:'📢', anim:'roar', color:'#ff8844', particles:['📢','⚡','🔥'] },
  steal:     { emoji:'🤚', anim:'sneak', color:'#aaffaa', particles:['🤚','💰','✨'] },
  attack:    { emoji:'⚔️', anim:'strike', color:'#ffcc44', particles:['⚔️','💥'] },
  crit:      { emoji:'💥', anim:'boom', color:'#ff4444', particles:['💥','🔥','⚡','💀'] },
  deadly:    { emoji:'⚡', anim:'fatal', color:'#ff0000', particles:['⚡','💀','💥','🔥'] }
};

function showBattleEffect(effectId) {
  var fx = BATTLE_EFFECTS[effectId];
  if (!fx) return;
  var el = document.getElementById('battleEffect');
  if (!el) return;
  // Build particle burst
  var html = '<div class="battle-fx battle-fx-' + fx.anim + '">';
  for (var i = 0; i < fx.particles.length; i++) {
    html += '<span class="fx-particle" style="animation-delay:' + (i * 0.08) + 's;color:' + fx.color + '">' + fx.particles[i] + '</span>';
  }
  html += '</div>';
  el.innerHTML = html;
  el.style.display = 'block';
  // Auto-hide after animation
  setTimeout(function() { el.style.display = 'none'; el.innerHTML = ''; }, 600);
}

function playerAttack() {
  var b = G.battle;
  // === Player stun check ===
  if (G._stunned && G._stunTurns > 0) {
    G._stunTurns--;
    if (G._stunTurns <= 0) { G._stunned = false; }
    b.log.push('💫 你处于眩晕状态,无法行动!');
    enemyTurn();
    renderBattle();
    return;
  }
  // === Player poison damage ===
  if (G._poisoned && G._poisoned > 0) {
    var ppDmg = Math.max(1, Math.floor(G._poisoned));
    G.hp = Math.max(0, G.hp - ppDmg);
    G._waveNoDamage = false; // A3
    G._poisoned = Math.floor(G._poisoned * 0.7);
    if (G._poisoned < 1) G._poisoned = 0;
    b.log.push('🧪 你中毒了!受到 ' + ppDmg + ' 伤害');
    if (G.hp <= 0) { endBattle(); return; }
  }
  // === Player burn damage ===
  if (G._burning && G._burning > 0) {
    var sbBurn = calcSetBonuses();
    if (sbBurn.fireImmune) {
      b.log.push('🔥 火焰领主：免疫燃烧伤害!');
      G._burning = 0;
    } else {
      var burnDmg = Math.max(1, Math.floor(G._burning));
      G.hp = Math.max(0, G.hp - burnDmg);
      G._waveNoDamage = false; // A3
      G._burning = Math.floor(G._burning * 0.6);
      if (G._burning < 1) G._burning = 0;
      b.log.push('🔥 你在燃烧!受到 ' + burnDmg + ' 伤害');
      if (G.hp <= 0) { endBattle(); return; }
    }
  }
  // === Player bleed damage ===
  if (G._bleeding && G._bleeding > 0) {
    var bleedDmg = Math.max(1, Math.floor(G._bleeding));
    G.hp = Math.max(0, G.hp - bleedDmg);
    G._waveNoDamage = false; // A3
    G._bleeding = Math.floor(G._bleeding * 0.5);
    if (G._bleeding < 1) G._bleeding = 0;
    b.log.push('🩸 你在流血!受到 ' + bleedDmg + ' 伤害');
    if (G.hp <= 0) { endBattle(); return; }
  }
  // === Player freeze check ===
  if (G._frozen && G._freezeTurns > 0) {
    G._freezeTurns--;
    if (G._freezeTurns <= 0) { G._frozen = false; }
    b.log.push('❄️ 你被冰冻了,无法行动!');
    enemyTurn();
    renderBattle();
    return;
  }

  var alive = b.enemies.filter(function(e) { return e.curHp > 0; });
  if (alive.length === 0) return;

  var targetIdx = G.selectedTarget;
  if (!b.enemies[targetIdx] || b.enemies[targetIdx].curHp <= 0) {
    for (var i = 0; i < b.enemies.length; i++) {
      if (b.enemies[i].curHp > 0) { targetIdx = i; break; }
    }
  }
  var target = b.enemies[targetIdx];

  var dmg = rand(Math.floor(calcAtk() * 0.8), Math.floor(calcAtk() * 1.2));
  if (b.warcry && b.warcry > 0) dmg = Math.floor(dmg * 1.2);
  // Apply temp buff
  if (G._tempAtkBuff && G._tempAtkBuffTurns > 0) { dmg = Math.floor(dmg * G._tempAtkBuff); G._tempAtkBuffTurns--; if (G._tempAtkBuffTurns <= 0) G._tempAtkBuff = 0; }
  // Apply battle atkBuff (from playerSkill)
  if (b.atkBuff && b.atkBuffTurns > 0) { dmg = Math.floor(dmg * (1 + b.atkBuff)); }
  // Slow debuff: reduce damage by 20%
  if (G._slowed && G._slowTurns > 0) { dmg = Math.floor(dmg * 0.8); }

  // Crit check
  var isCrit = G._nextCrit || (Math.random() * 100 < applyWeatherCrit(calcCrit(), G.location));
  G._nextCrit = false;
  if (isCrit) dmg = Math.floor(dmg * (1 + calcCritDmg()));

  // Deadly strike check (装备deadlyRate)
  var totalDeadly = 0;
  var eqKeys = ['weapon','helmet','armor','gloves','boots','belt','necklace','ring'];
  for (var di = 0; di < eqKeys.length; di++) {
    var dItem = G.equipment[eqKeys[di]];
    if (dItem && dItem.deadlyRate) totalDeadly += dItem.deadlyRate;
  }
  var isDeadly = Math.random() < totalDeadly;
  if (isDeadly) dmg = Math.floor(dmg * 2.5);

  // Apply weather modifier to damage
  dmg = applyWeatherToDamage(dmg, false, G.location);

  target.curHp = Math.max(0, target.curHp - dmg);
  var hitMsg = '⚔️ 攻击 ' + target.name + ',造成 ' + dmg + ' 伤害';
  if (isDeadly) { hitMsg += ' ⚡致命!'; showBattleEffect('deadly'); }
  else if (isCrit) { hitMsg += ' 💥会心!'; showBattleEffect('crit'); }
  else { showBattleEffect('attack'); }
  // D1: Combo counter
  if (!G._comboCount) G._comboCount = 0;
  G._comboCount++;
  if (G._comboCount >= 3) hitMsg += ' 🔥x' + G._comboCount;
  b.log.push(hitMsg);
  showDamagePopup('player-atk-dmg', dmg, isCrit || isDeadly);

  // Fire damage from equipment
  var totalFireDmg = 0;
  for (var fi = 0; fi < eqKeys.length; fi++) {
    var fItem = G.equipment[eqKeys[fi]];
    if (fItem && fItem.fireDmg) totalFireDmg += fItem.fireDmg;
  }
  // Set bonus fireDmgMult
  var sb = calcSetBonuses();
  if (sb.fireDmgMult) totalFireDmg = Math.floor(totalFireDmg * (1 + sb.fireDmgMult));
  if (totalFireDmg > 0 && target.curHp > 0) {
    target.curHp = Math.max(0, target.curHp - totalFireDmg);
    b.log.push('🔥 火焰灼烧 ' + target.name + ',造成 ' + totalFireDmg + ' 伤害');
  }

  // Poison damage from equipment
  var totalPoisonDmg = 0;
  for (var pi = 0; pi < eqKeys.length; pi++) {
    var pItem = G.equipment[eqKeys[pi]];
    if (pItem && pItem.poisonDmg) totalPoisonDmg += pItem.poisonDmg;
  }
  if (totalPoisonDmg > 0 && target.curHp > 0) {
    target.curHp = Math.max(0, target.curHp - totalPoisonDmg);
    b.log.push('🧪 毒素侵蚀 ' + target.name + ',造成 ' + totalPoisonDmg + ' 伤害');
    // 30% chance to poison enemy
    if (Math.random() < 0.3 && !target._poisoned) {
      target._poisoned = totalPoisonDmg;
      b.log.push('🧪 ' + target.name + ' 中毒了!');
    }
  }

  // Holy damage from equipment (bonus vs undead/boss)
  var totalHolyDmg = 0;
  for (var hi = 0; hi < eqKeys.length; hi++) {
    var hItem = G.equipment[eqKeys[hi]];
    if (hItem && hItem.holyDmg) totalHolyDmg += hItem.holyDmg;
  }
  if (totalHolyDmg > 0 && target.curHp > 0) {
    var holyMult = (target.isBoss || target.id.indexOf('skeleton') >= 0 || target.id.indexOf('wraith') >= 0 || target.id.indexOf('zombie') >= 0) ? 1.5 : 1.0;
    var holyFinal = Math.floor(totalHolyDmg * holyMult);
    target.curHp = Math.max(0, target.curHp - holyFinal);
    b.log.push('✨ 圣光打击 ' + target.name + ',造成 ' + holyFinal + ' 伤害' + (holyMult > 1 ? ' (亡灵特攻!)' : ''));
  }

  // Shadow damage from equipment
  var totalShadowDmg = 0;
  for (var si = 0; si < eqKeys.length; si++) {
    var sItem = G.equipment[eqKeys[si]];
    if (sItem && sItem.shadowDmg) totalShadowDmg += sItem.shadowDmg;
  }
  if (totalShadowDmg > 0 && target.curHp > 0) {
    target.curHp = Math.max(0, target.curHp - totalShadowDmg);
    b.log.push('👤 暗影侵蚀 ' + target.name + ',造成 ' + totalShadowDmg + ' 伤害');
  }

  // Storm damage from equipment
  var totalStormDmg = 0;
  for (var sti = 0; sti < eqKeys.length; sti++) {
    var stItem = G.equipment[eqKeys[sti]];
    if (stItem && stItem.stormDmg) totalStormDmg += stItem.stormDmg;
  }
  if (totalStormDmg > 0 && target.curHp > 0) {
    target.curHp = Math.max(0, target.curHp - totalStormDmg);
    b.log.push('⚡ 风暴轰击 ' + target.name + ',造成 ' + totalStormDmg + ' 伤害');
    // 15% chance to stun enemy
    if (Math.random() < 0.15 && !target._stunned) {
      target._stunned = true;
      target._stunTurns = 1;
      b.log.push('⚡ ' + target.name + ' 被击晕!');
    }
  }

  // Stun chance from equipment (on hit)
  var totalStunChance = 0;
  for (var sci = 0; sci < eqKeys.length; sci++) {
    var scItem = G.equipment[eqKeys[sci]];
    if (scItem && scItem.stunChance) totalStunChance += scItem.stunChance;
  }
  if (Math.random() < totalStunChance && target.curHp > 0 && !target._stunned) {
    target._stunned = true;
    target._stunTurns = 1;
    b.log.push('💫 ' + target.name + ' 被击晕!');
  }

  // Lifesteal
  var totalLifesteal = 0;
  for (var li = 0; li < eqKeys.length; li++) {
    var lItem = G.equipment[eqKeys[li]];
    if (lItem && lItem.lifesteal) totalLifesteal += lItem.lifesteal;
  }
  if (totalLifesteal > 0 && dmg > 0) {
    var heal = Math.floor(dmg * totalLifesteal);
    if (heal > 0) {
      G.hp = Math.min(G.maxHp, G.hp + heal);
      b.log.push('🩸 吸血恢复 ' + heal + ' HP');
      showHealPopup(heal);
    }
  }

  // Double attack
  var totalDoubleAtk = 0;
  for (var dai = 0; dai < eqKeys.length; dai++) {
    var daItem = G.equipment[eqKeys[dai]];
    if (daItem && daItem.doubleAtkRate) totalDoubleAtk += daItem.doubleAtkRate;
  }
  // Shadow blade set: crit double
  if (sb.critDouble && isCrit) totalDoubleAtk += sb.critDouble;
  if (Math.random() < totalDoubleAtk && target.curHp > 0) {
    var dmg2 = rand(Math.floor(calcAtk() * 0.6), Math.floor(calcAtk() * 0.9));
    target.curHp = Math.max(0, target.curHp - dmg2);
    b.log.push('⚔️⚔️ 连击!对 ' + target.name + ' 造成 ' + dmg2 + ' 伤害');
  }

  // Set bonus: shadow_blade firstStrikeMult (first attack in battle)
  if (sb.firstStrikeMult && !b._firstStrikeUsed) {
    b._firstStrikeUsed = true;
    var fsDmg = Math.floor(dmg * sb.firstStrikeMult);
    target.curHp = Math.max(0, target.curHp - fsDmg);
    b.log.push('🗡️ 背刺!额外 ' + fsDmg + ' 伤害');
  }

  if (b.warcry && b.warcry > 0) b.warcry--;
  G.attackMode = null;

  // Check if all enemies dead
  var allDead = b.enemies.filter(function(e) { return e.curHp > 0; }).length === 0;
  if (allDead) {
    setTimeout(function() { endBattle(); }, _battleDelay());
  } else {
    setTimeout(function() { enemyTurn(); }, _battleDelay());
  }
}

function useOriginSkill() {
  var o = G.origin;
  if (!o || !o.skill) return;

  if (o.id === 'warrior') {
    G.battle.warcry = 3;
    G.battle.log.push('📢 战吼!攻击力+20%持续3回合');
  } else if (o.id === 'gambler') {
    gamblerAttack();
    return;
  } else if (o.id === 'cleric') {
    var healAmt = Math.floor(G.maxHp * 0.1);
    G.hp = Math.min(G.maxHp, G.hp + healAmt);
    G.battle.log.push('✨ 祈祷,恢复 ' + healAmt + ' HP');
    showHealPopup(healAmt);
  } else if (o.id === 'mage') {
    var mAtk = calcMagicAtk();
    G.battle.log.push('👁️ 奥术感知激活,魔攻 ' + mAtk);
  } else if (o.id === 'hunter') {
    G.battle.log.push('🎯 鹰眼锁定,下次攻击必暴击');
    G._nextCrit = true;
  } else {
    G.battle.log.push('🔮 ' + o.skill.name + ':' + o.skill.desc);
  }

  G.attackMode = null;
  setTimeout(function() { enemyTurn(); }, _battleDelay());
}

function playerSkill(sid) {
  var sk = SKILLS.find(function(s) { return s.id === sid; });
  if (!sk) return;
  // D1: Cooldown check
  if (!G._skillCooldowns) G._skillCooldowns = {};
  if (G._skillCooldowns[sid] && G._skillCooldowns[sid] > 0) {
    toast('⏳ ' + sk.name + ' 冷却中!还需' + G._skillCooldowns[sid] + '回合');
    return;
  }
  // D1: Cast flash
  var _castEl = document.createElement('div');
  _castEl.style.cssText = 'position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(21,101,192,0.1);z-index:3000;pointer-events:none;animation:battleStartFlash 0.4s ease-out forwards;';
  document.body.appendChild(_castEl);
  setTimeout(function() { if (_castEl.parentNode) _castEl.parentNode.removeChild(_castEl); }, 500);
  var sb = calcSetBonuses();
  var actualCost = sk.cost;
  // Arcane Sage 4-piece: MP cost -25%
  if (sb.mpCostReduct) actualCost = Math.max(1, Math.floor(actualCost * (1 - sb.mpCostReduct)));
  // Arcane Sage 6-piece: 20% chance free cast
  var freeCast = sb.freeCast && Math.random() < sb.freeCast;
  if (G.mp < actualCost) { toast('💧 MP不足!'); return; }

  if (freeCast) {
    actualCost = 0;
  }
  G.mp -= actualCost;
  var b = G.battle;
  if (freeCast) {
    b.log.push('✨ 秘法贤者：免费施法!');
  }
  var b = G.battle;
  var alive = b.enemies.filter(function(e) { return e.curHp > 0; });
  var effectMsg = sk.effectDesc || '';

  if (sk.target === '自身' || sk.type === '治疗' || sk.type === '增益') {
    if (sk.healMin) {
      var heal = rand(sk.healMin, sk.healMax);
      G.hp = Math.min(G.maxHp, G.hp + heal);
      b.log.push((effectMsg ? effectMsg + ' ' : '') + sk.name + ' 恢复 ' + heal + ' HP');
      showHealPopup(heal);
      showBattleEffect(sk.effect || 'heal');
    }
    if (sk.shield) {
      G.battle.shield = (G.battle.shield || 0) + sk.shield;
      b.log.push((effectMsg ? effectMsg + ' ' : '') + sk.name + ' 获得 ' + sk.shield + ' 护盾');
      showBattleEffect(sk.effect || 'shield');
    }
    if (sk.atkBuff) {
      G.battle.atkBuff = (G.battle.atkBuff || 0) + sk.atkBuff;
      G.battle.atkBuffTurns = (G.battle.atkBuffTurns || 0) + (sk.buffTurns || 2);
      b.log.push((effectMsg ? effectMsg + ' ' : '') + sk.name + ' 攻击力+' + Math.floor(sk.atkBuff*100) + '% ' + (sk.buffTurns||2) + '回合');
      showBattleEffect(sk.effect || 'warcry');
    }
    if (sk.defBuff) {
      G.battle.defBuff = (G.battle.defBuff || 0) + sk.defBuff;
      G.battle.defBuffTurns = (G.battle.defBuffTurns || 0) + (sk.buffTurns || 2);
      b.log.push((effectMsg ? effectMsg + ' ' : '') + sk.name + ' 防御力+' + Math.floor(sk.defBuff*100) + '% ' + (sk.buffTurns||2) + '回合');
      showBattleEffect(sk.effect || 'shield');
    }
    // Poison clear (cure self poison)
    if (sk.id === 'poison_clear' || sk.poisonClear) {
      var cleared = [];
      if (G._poisoned && G._poisoned > 0) { cleared.push('🧪中毒' + G._poisoned); G._poisoned = 0; }
      if (G._burning && G._burning > 0) { cleared.push('🔥燃烧' + G._burning); G._burning = 0; }
      if (G._bleeding && G._bleeding > 0) { cleared.push('🩸流血' + G._bleeding); G._bleeding = 0; }
      if (G._slowed) { cleared.push('🐌减速'); G._slowed = false; G._slowTurns = 0; }
      if (cleared.length > 0) {
        b.log.push((effectMsg ? effectMsg + ' ' : '') + sk.name + ' 净化了: ' + cleared.join(' '));
      } else {
        b.log.push('你没有可净化的状态');
      }
      showBattleEffect(sk.effect || 'heal');
    }
  } else if (sk.aoe) {
    var total = 0;
    var baseDmg = calcSkillDmg(sk);
    var aoeDotMsg = '';
    for (var i = 0; i < alive.length; i++) {
      alive[i].curHp = Math.max(0, alive[i].curHp - baseDmg);
      total += baseDmg;
      if (sk.poison) { alive[i].poison = (alive[i].poison || 0) + sk.poison; aoeDotMsg = ' 🧪中毒!'; }
      if (sk.burn) { alive[i].burn = (alive[i].burn || 0) + sk.burn; aoeDotMsg = ' 🔥灼烧!'; }
      if (sk.freezeChance && Math.random() < sk.freezeChance) { alive[i].stunned = true; aoeDotMsg = ' ❄️冰冻!'; }
    }
    b.log.push((effectMsg ? effectMsg + ' ' : '') + sk.name + ' 群攻! ' + baseDmg + '×' + alive.length + '=' + total + ' 伤害' + aoeDotMsg);
    showBattleEffect(sk.effect || 'explosion');
  } else if (sk.missiles) {
    var total2 = 0;
    var targetIdx = G.selectedTarget;
    if (!b.enemies[targetIdx] || b.enemies[targetIdx].curHp <= 0) {
      for (var j = 0; j < b.enemies.length; j++) {
        if (b.enemies[j].curHp > 0) { targetIdx = j; break; }
      }
    }
    for (var m = 0; m < sk.missiles; m++) {
      total2 += calcSkillDmg(sk);
    }
    b.enemies[targetIdx].curHp = Math.max(0, b.enemies[targetIdx].curHp - total2);
    b.log.push((effectMsg ? effectMsg + ' ' : '') + sk.name + ' ' + sk.missiles + '枚命中 ' + b.enemies[targetIdx].name + ',造成 ' + total2 + ' 伤害');
    showBattleEffect(sk.effect || 'missile');
  } else if (sk.hits) {
    var total3 = 0;
    var targetIdx3 = G.selectedTarget;
    if (!b.enemies[targetIdx3] || b.enemies[targetIdx3].curHp <= 0) {
      for (var h = 0; h < b.enemies.length; h++) {
        if (b.enemies[h].curHp > 0) { targetIdx3 = h; break; }
      }
    }
    var hitDetails = [];
    for (var hi = 0; hi < sk.hits; hi++) {
      var hitDmg = calcSkillDmg(sk);
      var hitCrit = Math.random() * 100 < (calcCrit() + (sk.critBonus || 0));
      if (hitCrit) hitDmg = Math.floor(hitDmg * (1 + calcCritDmg()));
      total3 += hitDmg;
      hitDetails.push(hitDmg + (hitCrit ? '💥' : ''));
    }
    b.enemies[targetIdx3].curHp = Math.max(0, b.enemies[targetIdx3].curHp - total3);
    b.log.push((effectMsg ? effectMsg + ' ' : '') + sk.name + ' ' + sk.hits + '连击! ' + hitDetails.join('+') + '=' + total3);
    showBattleEffect(sk.effect || 'rapid');
  } else if (sk.stunChance) {
    var targetIdx4 = G.selectedTarget;
    if (!b.enemies[targetIdx4] || b.enemies[targetIdx4].curHp <= 0) {
      for (var s = 0; s < b.enemies.length; s++) {
        if (b.enemies[s].curHp > 0) { targetIdx4 = s; break; }
      }
    }
    var dmg4 = calcSkillDmg(sk);
    b.enemies[targetIdx4].curHp = Math.max(0, b.enemies[targetIdx4].curHp - dmg4);
    var stunned = Math.random() < sk.stunChance;
    if (stunned) b.enemies[targetIdx4].stunned = true;
    b.log.push((effectMsg ? effectMsg + ' ' : '') + sk.name + ' 对 ' + b.enemies[targetIdx4].name + ' 造成 ' + dmg4 + ' 伤害' + (stunned ? ' ☑️眩晕!' : ''));
    showBattleEffect(sk.effect || 'shieldBash');
  } else if (sk.agiCheck && sk.stealRate) {
    var targetIdx5 = G.selectedTarget;
    if (!b.enemies[targetIdx5] || b.enemies[targetIdx5].curHp <= 0) {
      for (var st = 0; st < b.enemies.length; st++) {
        if (b.enemies[st].curHp > 0) { targetIdx5 = st; break; }
      }
    }
    var agiBonus = (G.agi - 10) * 0.03;
    var stealChance = Math.min(0.85, sk.stealRate + agiBonus);
    if (Math.random() < stealChance) {
      var stolenGold = rand(5, 15 + G.level * 2);
      G.gold += stolenGold;
      var matStolen = null;
      if (Math.random() < 0.3) {
        var eMatDrops = ENEMY_MAT_DROPS[b.enemies[targetIdx5].id];
        if (eMatDrops && eMatDrops.common && eMatDrops.common.length > 0) {
          var pick = eMatDrops.common[Math.floor(Math.random() * eMatDrops.common.length)];
          var mat = MATERIALS[pick.mid];
          if (mat) {
            G.materials[pick.mid] = (G.materials[pick.mid] || 0) + 1;
            matStolen = mat.name;
          }
        }
      }
      b.log.push((effectMsg ? effectMsg + ' ' : '') + '偷窃成功!获得 ' + stolenGold + ' 金币' + (matStolen ? ' + ' + matStolen : ''));
    } else {
      b.log.push('🤚 偷窃失败!对方警觉了');
    }
    showBattleEffect('steal');
  } else {
    var targetIdx6 = G.selectedTarget;
    if (!b.enemies[targetIdx6] || b.enemies[targetIdx6].curHp <= 0) {
      for (var k = 0; k < b.enemies.length; k++) {
        if (b.enemies[k].curHp > 0) { targetIdx6 = k; break; }
      }
    }
    var dmg6 = calcSkillDmg(sk);
    var isCrit6 = G._nextCrit || Math.random() * 100 < (calcCrit() + (sk.critBonus || 0));
    if (isCrit6) dmg6 = Math.floor(dmg6 * (1 + calcCritDmg()));
    G._nextCrit = false;
    b.enemies[targetIdx6].curHp = Math.max(0, b.enemies[targetIdx6].curHp - dmg6);
    // Apply DoT effects from skill
    var dotMsg = '';
    if (sk.poison) { b.enemies[targetIdx6].poison = (b.enemies[targetIdx6].poison || 0) + sk.poison; dotMsg += ' 🧪中毒!'; }
    if (sk.burn) { b.enemies[targetIdx6].burn = (b.enemies[targetIdx6].burn || 0) + sk.burn; dotMsg += ' 🔥灼烧!'; }
    if (sk.bleed) { b.enemies[targetIdx6].bleed = (b.enemies[targetIdx6].bleed || 0) + sk.bleed; dotMsg += ' 🩸流血!'; }
    if (sk.freezeChance && Math.random() < sk.freezeChance) { b.enemies[targetIdx6].stunned = true; dotMsg += ' ❄️冰冻!'; }
    b.log.push((effectMsg ? effectMsg + ' ' : '') + sk.name + ' 对 ' + b.enemies[targetIdx6].name + ' 造成 ' + dmg6 + (isCrit6 ? ' 💥暴击!' : '') + ' 伤害' + dotMsg);
    showBattleEffect(sk.effect || 'slash');
  }

  G.attackMode = null;
  // D1: Set cooldown after skill use
  if (sk.cd && sk.cd > 0) {
    if (!G._skillCooldowns) G._skillCooldowns = {};
    G._skillCooldowns[sid] = sk.cd;
  }
  updateStatus();

  var allDead = b.enemies.filter(function(e) { return e.curHp > 0; }).length === 0;
  if (allDead) {
    setTimeout(function() { endBattle(); }, _battleDelay());
  } else {
    setTimeout(function() { enemyTurn(); }, _battleDelay());
  }
}


function gamblerAttack() {
  var b = G.battle;
  var winChance = 0.25 + G.luk * 0.02;
  if (Math.random() < winChance) {
    var targetIdx = G.selectedTarget;
    if (!b.enemies[targetIdx] || b.enemies[targetIdx].curHp <= 0) {
      for (var i = 0; i < b.enemies.length; i++) {
        if (b.enemies[i].curHp > 0) { targetIdx = i; break; }
      }
    }
    var dmg = Math.floor(calcAtk() * 2.5);
    b.enemies[targetIdx].curHp = Math.max(0, b.enemies[targetIdx].curHp - dmg);
    b.log.push('🎲 孤注一掷!大成功!造成 ' + dmg + ' 伤害!');
  } else {
    var selfDmg = Math.floor(G.hp * 0.3);
    G.hp = Math.max(1, G.hp - selfDmg);
    b.log.push('🎲 孤注一掷失败!自伤 ' + selfDmg);
    updateStatus();
  }
  b.gamblerUsed = true;
  G.attackMode = null;

  // Check if all enemies dead after gambler attack
  var allDead = b.enemies.filter(function(e) { return e.curHp > 0; }).length === 0;
  if (allDead) {
    setTimeout(function() { endBattle(); }, _battleDelay());
  } else {
    setTimeout(function() { enemyTurn(); }, _battleDelay());
  }
}

// D1: Battle speed toggle
function toggleBattleSpeed() {
  if (!G._battleSpeed || G._battleSpeed === 1) G._battleSpeed = 2;
  else if (G._battleSpeed === 2) G._battleSpeed = 3;
  else G._battleSpeed = 1;
  toast('战斗速度: ' + G._battleSpeed + 'x');
  renderBattle();
}
function _battleDelay(base) {
  return Math.max(50, Math.floor((base || 400) / (G._battleSpeed || 1)));
}

function doDefend() {
  var b = G.battle;
  if (!b) return;
  b.defending = true;
  b.log.push('🛡️ 你举起防御!本回合受到的伤害减半');
  // Small HP regen when defending
  var regen = Math.floor(G.maxHp * 0.03);
  if (regen > 0 && G.hp < G.maxHp) {
    G.hp = Math.min(G.maxHp, G.hp + regen);
    b.log.push('💚 防御中恢复 ' + regen + ' HP');
    showHealPopup(regen);
  }
  showBattleEffect('shield');
  enemyTurn();
  // Reset defending after enemy turn
  b.defending = false;
  renderBattle();
}

function fleeBattle() {
  tryFlee();
}

function enemyTurn() {
  var b = G.battle;
  var alive = b.enemies.filter(function(e) { return e.curHp > 0; });
  var eqKeys = ['weapon','helmet','armor','gloves','boots','belt','necklace','ring'];
  var sb = calcSetBonuses();

  // D1: Increment turn counter and reset combo on enemy turn
  b.turn++;
  G._comboCount = 0;
  // D1: Add turn marker to battle log
  b.log.push('━━ 第' + (b.turn + 1) + '回合 ━━');

  // D1: Reduce skill cooldowns
  if (G._skillCooldowns) {
    var cdKeys = Object.keys(G._skillCooldowns);
    for (var cdi = 0; cdi < cdKeys.length; cdi++) {
      if (G._skillCooldowns[cdKeys[cdi]] > 0) {
        G._skillCooldowns[cdKeys[cdi]]--;
        if (G._skillCooldowns[cdKeys[cdi]] <= 0) delete G._skillCooldowns[cdKeys[cdi]];
      }
    }
  }

  // === Process DoT effects on enemies ===
  for (var di = 0; di < alive.length; di++) {
    var ed = alive[di];
    if (ed.poison && ed.poison > 0) {
      var pDmg = Math.max(1, Math.floor(ed.poison));
      ed.curHp = Math.max(0, ed.curHp - pDmg);
      ed.poison = Math.floor(ed.poison * 0.7); // decay
      if (ed.poison < 1) ed.poison = 0;
      b.log.push('🧪 ' + ed.name + ' 中毒!受到 ' + pDmg + ' 伤害');
    }
    // Equipment-triggered poison
    if (ed._poisoned && ed._poisoned > 0) {
      var epDmg = Math.max(1, Math.floor(ed._poisoned));
      ed.curHp = Math.max(0, ed.curHp - epDmg);
      ed._poisoned = Math.floor(ed._poisoned * 0.7);
      if (ed._poisoned < 1) ed._poisoned = 0;
      b.log.push('🧪 ' + ed.name + ' 毒发!受到 ' + epDmg + ' 伤害');
    }
    if (ed.burn && ed.burn > 0) {
      var bDmg = Math.max(1, Math.floor(ed.burn));
      ed.curHp = Math.max(0, ed.curHp - bDmg);
      ed.burn = Math.floor(ed.burn * 0.6); // decay faster
      if (ed.burn < 1) ed.burn = 0;
      b.log.push('🔥 ' + ed.name + ' 灼烧!受到 ' + bDmg + ' 伤害');
    }
    if (ed.bleed && ed.bleed > 0) {
      var blDmg = Math.max(1, Math.floor(ed.bleed));
      ed.curHp = Math.max(0, ed.curHp - blDmg);
      ed.bleed = Math.floor(ed.bleed * 0.5);
      if (ed.bleed < 1) ed.bleed = 0;
      b.log.push('🩸 ' + ed.name + ' 流血!受到 ' + blDmg + ' 伤害');
    }
  }

  // Check if DoTs killed everything
  var stillAlive = alive.filter(function(e) { return e.curHp > 0; });
  if (stillAlive.length === 0) {
    b.turn++;
    setTimeout(function() { endBattle(); }, _battleDelay());
    return;
  }

  // === Guardian 6-piece: HP regen ===
  var sbRegen = calcSetBonuses();
  if (sbRegen.hpRegenPct && G.hp < G.maxHp && G.hp > 0) {
    if (!b._lastHpRegen) b._lastHpRegen = Date.now();
    if (Date.now() - b._lastHpRegen >= 5000) {
      var regenAmt = Math.max(1, Math.floor(G.maxHp * sbRegen.hpRegenPct));
      G.hp = Math.min(G.maxHp, G.hp + regenAmt);
      b._lastHpRegen = Date.now();
      b.log.push('💚 守护者回复：+' + regenAmt + ' HP');
    }
  }

  // === Process player buff durations ===
  if (b.atkBuffTurns && b.atkBuffTurns > 0) {
    b.atkBuffTurns--;
    if (b.atkBuffTurns <= 0) { b.atkBuff = 0; b.log.push('⬇️ 攻击增益消退'); }
  }
  if (b.defBuffTurns && b.defBuffTurns > 0) {
    b.defBuffTurns--;
    if (b.defBuffTurns <= 0) { b.defBuff = 0; b.log.push('⬇️ 防御增益消退'); }
  }
  // Slow decay
  if (G._slowed && G._slowTurns > 0) {
    G._slowTurns--;
    if (G._slowTurns <= 0) { G._slowed = false; b.log.push('🐌 减速效果消退'); }
  }

  // === D1: Pre-compute enemy intents for next turn ===
  for (var ii = 0; ii < stillAlive.length; ii++) {
    var ei = stillAlive[ii];
    if (ei._charging && ei._chargeSkill) {
      var csk = ENEMY_SKILLS[ei._chargeSkill];
      ei._intent = '⚡' + (csk ? (csk.emoji || '💥') + csk.name : '蓄力攻击');
    } else if (ei.skills && ei.skills.length > 0 && Math.random() < 0.4) {
      var nextSkill = ei.skills[Math.floor(Math.random() * ei.skills.length)];
      var nsDef = ENEMY_SKILLS[nextSkill];
      if (nsDef && nsDef.type === 'power_atk' && nsDef.mult >= 2.0) {
        ei._intent = '⚡' + (nsDef.emoji || '💥') + nsDef.name;
      } else {
        ei._intent = (nsDef ? (nsDef.emoji || '🔮') + ' ' + nsDef.name : '🔮技能');
      }
    } else {
      ei._intent = '⚔️攻击';
    }
  }

  // === Enemy Actions ===
  for (var i = 0; i < stillAlive.length; i++) {
    var e = stillAlive[i];
    // Check stun (from enemy skill or equipment stun)
    if (e.stunned || e._stunned) {
      e._intent = '💫眩晕';
      if (e.stunned) e.stunned = false;
      if (e._stunned) { e._stunTurns--; if (e._stunTurns <= 0) e._stunned = false; }
      b.log.push('☑️ ' + e.name + ' 处于眩晕状态,无法行动!');
      continue;
    }

    // === Enemy Skill AI ===
    var usedSkill = false;
    // D1: If enemy was charging, execute the charged skill now
    if (e._charging && e._chargeSkill) {
      usedSkill = _enemyUseSkill(e, e._chargeSkill, b, sb, eqKeys);
      e._charging = false;
      e._chargeSkill = null;
    } else if (e.skills && e.skills.length > 0 && Math.random() < 0.4) {
      var eskill = e.skills[Math.floor(Math.random() * e.skills.length)];
      var esDef = ENEMY_SKILLS[eskill];
      // D1: Power skills require charging (1 turn warn)
      if (esDef && esDef.type === 'power_atk' && esDef.mult >= 2.0 && !e._charging) {
        e._charging = true;
        e._chargeSkill = eskill;
        b.log.push('⚡ ' + e.name + ' 正在蓄力... ' + (esDef.emoji || '💪') + (esDef.name || '猛击') + '!');
        usedSkill = true;
      } else {
        usedSkill = _enemyUseSkill(e, eskill, b, sb, eqKeys);
      }
    }

    // Normal attack (if no skill used)
    if (!usedSkill) {
      if (Math.random() * 100 < applyWeatherDodge(calcDodge(), G.location)) {
        b.log.push('💨 你闪避了 ' + e.name + ' 的攻击!');
        flashPlayerStatus('#22c55e');
        continue;
      }
      var dmg = rand(Math.floor(e.atk * 0.8), Math.floor(e.atk * 1.2));
      var playerDef = calcDef();
      // Apply player defBuff
      if (b.defBuff && b.defBuff > 0) playerDef = Math.floor(playerDef * (1 + b.defBuff));
      // Apply weather defense modifier to player
      playerDef = applyWeatherToDef(playerDef, G.location);
      dmg = Math.max(1, dmg - Math.floor(playerDef * 0.6));
      if (b.defending) dmg = Math.floor(dmg * 0.5);

      // Shield absorbs damage first
      if (b.shield && b.shield > 0) {
        if (b.shield >= dmg) {
          b.shield -= dmg;
          b.log.push('🛡️ 护盾吸收了 ' + dmg + ' 伤害');
          dmg = 0;
        } else {
          dmg -= b.shield;
          b.log.push('🛡️ 护盾吸收了 ' + b.shield + ' 伤害后碎裂');
          b.shield = 0;
        }
      }

      if (dmg > 0) {
        // Set bonus: guardian deathSave
        if (G.hp - dmg <= 0 && sb.deathSave && Math.random() < sb.deathSave && (!b._deathSaveCdUntil || Date.now() > b._deathSaveCdUntil)) {
          G.hp = 1;
          b._deathSaveCdUntil = Date.now() + (sb.deathSaveCd || 120) * 1000;
          b.log.push('🛡️ 守护者之力!致命伤害被抵挡,保留1点生命!');
          flashPlayerStatus('#a855f7');
          continue;
        }
        // Equipment deathSave (unique items like 凤羽金冠)
        if (G.hp - dmg <= 0 && !b._equipDeathSaveUsed) {
          var hasDeathSave = false;
          for (var dsi = 0; dsi < eqKeys.length; dsi++) {
            var dsItem = G.equipment[eqKeys[dsi]];
            if (dsItem && dsItem.deathSave) { hasDeathSave = true; break; }
          }
          if (hasDeathSave) {
            G.hp = 1;
            b._equipDeathSaveUsed = true; // Once per battle
            b.log.push('⭐ 独特装备免死!致命伤害被抵挡,保留1点生命!');
            flashPlayerStatus('#ffd700');
            continue;
          }
        }
        G.hp = Math.max(0, G.hp - dmg);
        G._tookDamageThisBattle = true;
        G._waveNoDamage = false; // A3: Track per-wave damage
        b.log.push(e.name + ' 攻击命中,造成 <span class="dmg-player">' + dmg + '</span> 伤害');
        showDamagePopup('enemy-dmg', dmg, false);
        flashPlayerStatus('#ef4444');
      }

      // Counter attack from equipment
      var totalCounter = 0;
      for (var ci = 0; ci < eqKeys.length; ci++) {
        var cItem = G.equipment[eqKeys[ci]];
        if (cItem && cItem.counterRate) totalCounter += cItem.counterRate;
      }
      if (Math.random() < totalCounter && e.curHp > 0) {
        var counterDmg = Math.floor(calcAtk() * 0.5);
        e.curHp = Math.max(0, e.curHp - counterDmg);
        b.log.push('↩️ 反击!对 ' + e.name + ' 造成 ' + counterDmg + ' 伤害');
      }
    }
  }

  b.turn++;
  b.defending = false;
  updateStatus();

  // Check if counter killed everything
  var anyAlive = b.enemies.filter(function(e) { return e.curHp > 0; }).length > 0;
  if (!anyAlive) {
    setTimeout(function() { endBattle(); }, _battleDelay());
  } else {
    renderBattle('敌方回合');
  }
}

// Enemy skill AI executor
function _enemyUseSkill(e, skillId, b, sb, eqKeys) {
  var es = ENEMY_SKILLS[skillId];
  if (!es) return false;

  // HP threshold check (some skills only used when low HP)
  if (es.hpBelow && e.curHp > e.hp * es.hpBelow) return false;
  if (es.hpAbove && e.curHp < e.hp * es.hpAbove) return false;

  switch (es.type) {
    case 'power_atk': // Heavy hit
      var pdmg = rand(Math.floor(e.atk * es.mult), Math.floor(e.atk * es.mult * 1.3));
      var pDef = calcDef();
      if (b.defBuff && b.defBuff > 0) pDef = Math.floor(pDef * (1 + b.defBuff));
      pdmg = Math.max(1, pdmg - Math.floor(pDef * 0.4));
      if (b.shield && b.shield > 0) {
        if (b.shield >= pdmg) { b.shield -= pdmg; pdmg = 0; }
        else { pdmg -= b.shield; b.shield = 0; }
      }
      if (pdmg > 0) { G.hp = Math.max(0, G.hp - pdmg); flashPlayerStatus('#ef4444'); }
      b.log.push((es.emoji||'💪') + ' ' + e.name + ' ' + (es.name||'猛击') + '!造成 <span class="dmg-player">' + pdmg + '</span> 伤害');
      showBattleEffect(es.effect || 'slash');
      return true;

    case 'heal': // Enemy heals self
      var healAmt = Math.min(e.hp - e.curHp, Math.floor(e.hp * (es.pct || 0.3)));
      e.curHp += healAmt;
      b.log.push((es.emoji||'💚') + ' ' + e.name + ' ' + (es.name||'自愈') + '!恢复 ' + healAmt + ' HP');
      return true;

    case 'buff': // Enemy buffs self
      e.atk = Math.floor(e.atk * (1 + (es.atkMult || 0.3)));
      e._buffed = true;
      b.log.push((es.emoji||'📈') + ' ' + e.name + ' ' + (es.name||'强化') + '!攻击力提升!');
      return true;

    case 'poison_atk': // Poison attack
      if (Math.random() * 100 >= calcDodge()) {
        var poDmg = rand(Math.floor(e.atk * 0.6), Math.floor(e.atk * 0.9));
        var poDef = calcDef();
        poDmg = Math.max(1, poDmg - Math.floor(poDef * 0.4));
        if (b.shield && b.shield > 0) { if (b.shield >= poDmg) { b.shield -= poDmg; poDmg = 0; } else { poDmg -= b.shield; b.shield = 0; } }
        if (poDmg > 0) { G.hp = Math.max(0, G.hp - poDmg); flashPlayerStatus('#22c55e'); }
        G._poisoned = (G._poisoned || 0) + (es.poisonDmg || 3);
        b.log.push((es.emoji||'🧪') + ' ' + e.name + ' ' + (es.name||'毒击') + '!造成 ' + poDmg + ' 伤害+中毒!');
      } else {
        b.log.push('💨 你闪避了 ' + e.name + ' 的毒击!');
      }
      return true;

    case 'fire_atk': // Fire attack + burn
      var sbFire = calcSetBonuses();
      if (sbFire.fireImmune) {
        b.log.push('🔥 火焰领主：免疫火焰攻击!');
        showBattleEffect('shield');
        return true;
      }
      if (Math.random() * 100 >= calcDodge()) {
        var fiDmg = rand(Math.floor(e.atk * 0.8), Math.floor(e.atk * 1.1));
        var fiDef = calcDef();
        fiDmg = Math.max(1, fiDmg - Math.floor(fiDef * 0.4));
        if (b.shield && b.shield > 0) { if (b.shield >= fiDmg) { b.shield -= fiDmg; fiDmg = 0; } else { fiDmg -= b.shield; b.shield = 0; } }
        if (fiDmg > 0) { G.hp = Math.max(0, G.hp - fiDmg); flashPlayerStatus('#ff4444'); }
        // Apply burn DoT
        if (es.burnDmg) G._burning = (G._burning || 0) + es.burnDmg;
        else G._burning = (G._burning || 0) + Math.max(2, Math.floor(e.atk * 0.15));
        b.log.push((es.emoji||'🔥') + ' ' + e.name + ' ' + (es.name||'火焰吐息') + '!造成 ' + fiDmg + ' 伤害+灼烧!');
        showBattleEffect('fire');
      } else {
        b.log.push('💨 你闪避了 ' + e.name + ' 的火焰!');
      }
      return true;

    case 'ice_atk': // Ice attack + freeze/slow
      if (Math.random() * 100 >= calcDodge()) {
        var icDmg = rand(Math.floor(e.atk * 0.6), Math.floor(e.atk * 0.9));
        var icDef = calcDef();
        icDmg = Math.max(1, icDmg - Math.floor(icDef * 0.5));
        if (b.shield && b.shield > 0) { if (b.shield >= icDmg) { b.shield -= icDmg; icDmg = 0; } else { icDmg -= b.shield; b.shield = 0; } }
        if (icDmg > 0) { G.hp = Math.max(0, G.hp - icDmg); flashPlayerStatus('#44ccff'); }
        // Apply freeze: chance to skip turn, or slow (reduce atk)
        if (Math.random() < (es.freezeChance || 0.25)) {
          G._frozen = true; G._freezeTurns = (G._freezeTurns || 0) + 1;
          b.log.push((es.emoji||'❄️') + ' ' + e.name + ' ' + (es.name||'冰霜吐息') + '!造成 ' + icDmg + ' 伤害+冰冻!');
        } else {
          // Slow: reduce atk buff temporarily
          G._slowed = true; G._slowTurns = 2;
          b.log.push((es.emoji||'❄️') + ' ' + e.name + ' ' + (es.name||'冰霜吐息') + '!造成 ' + icDmg + ' 伤害+减速!');
        }
        showBattleEffect('ice');
      } else {
        b.log.push('💨 你闪避了 ' + e.name + ' 的冰霜!');
      }
      return true;

    case 'stun_atk': // Stun attack
      if (Math.random() * 100 >= calcDodge()) {
        var stDmg = rand(Math.floor(e.atk * 0.5), Math.floor(e.atk * 0.8));
        var stDef = calcDef();
        stDmg = Math.max(1, stDmg - Math.floor(stDef * 0.4));
      } else {
        b.log.push('💨 你闪避了 ' + e.name + ' 的重击!'); return true;
      }
      if (b.shield && b.shield > 0) { if (b.shield >= stDmg) { b.shield -= stDmg; stDmg = 0; } else { stDmg -= b.shield; b.shield = 0; } }
      if (stDmg > 0) { G.hp = Math.max(0, G.hp - stDmg); flashPlayerStatus('#ef4444'); }
      if (Math.random() < (es.stunChance || 0.3)) {
        G._stunned = true; G._stunTurns = (G._stunTurns || 0) + 1;
        b.log.push((es.emoji||'💫') + ' ' + e.name + ' ' + (es.name||'震荡') + '!造成 ' + stDmg + ' 伤害+眩晕!');
      } else {
        b.log.push((es.emoji||'💫') + ' ' + e.name + ' ' + (es.name||'重击') + '!造成 ' + stDmg + ' 伤害');
      }
      return true;

    case 'summon': // Summon minion
      if (alive.length >= 4) return false; // max 4 enemies
      var minion = Object.assign({}, ENEMIES[es.minionId || 'goblin']);
      if (minion) {
        scaleEnemy(minion);
        minion.curHp = minion.hp;
        b.enemies.push(minion);
        b.log.push((es.emoji||'👻') + ' ' + e.name + ' ' + (es.name||'召唤') + '!召唤了 ' + minion.name + '!');
      }
      return true;

    case 'aoe': // AoE damage to player
      var aoeDmg = rand(Math.floor(e.atk * es.mult * 0.7), Math.floor(e.atk * es.mult));
      var aoeDef = calcDef();
      aoeDmg = Math.max(1, aoeDmg - Math.floor(aoeDef * 0.3));
      if (b.shield && b.shield > 0) { if (b.shield >= aoeDmg) { b.shield -= aoeDmg; aoeDmg = 0; } else { aoeDmg -= b.shield; b.shield = 0; } }
      if (aoeDmg > 0) { G.hp = Math.max(0, G.hp - aoeDmg); flashPlayerStatus('#ff8800'); }
      b.log.push((es.emoji||'💥') + ' ' + e.name + ' ' + (es.name||'群体攻击') + '!造成 <span class="dmg-player">' + aoeDmg + '</span> 伤害!');
      showBattleEffect(es.effect || 'explosion');
      return true;

    case 'drain': // Drain life from player
      var drDmg = rand(Math.floor(e.atk * 0.6), Math.floor(e.atk * 0.9));
      var drDef = calcDef();
      drDmg = Math.max(1, drDmg - Math.floor(drDef * 0.4));
      if (b.shield && b.shield > 0) { if (b.shield >= drDmg) { b.shield -= drDmg; drDmg = 0; } else { drDmg -= b.shield; b.shield = 0; } }
      if (drDmg > 0) { G.hp = Math.max(0, G.hp - drDmg); flashPlayerStatus('#9b59b6'); }
      var drHeal = Math.floor(drDmg * (es.drainPct || 0.5));
      e.curHp = Math.min(e.hp, e.curHp + drHeal);
      b.log.push((es.emoji||'💜') + ' ' + e.name + ' ' + (es.name||'吸血') + '!造成 ' + drDmg + ' 伤害,恢复 ' + drHeal + ' HP');
      return true;

    case 'bleed_atk': // Bleed attack - physical + bleed DoT
      if (Math.random() * 100 >= calcDodge()) {
        var blDmg = rand(Math.floor(e.atk * 0.7), Math.floor(e.atk * 1.0));
        var blDef = calcDef();
        blDmg = Math.max(1, blDmg - Math.floor(blDef * 0.4));
        if (b.shield && b.shield > 0) { if (b.shield >= blDmg) { b.shield -= blDmg; blDmg = 0; } else { blDmg -= b.shield; b.shield = 0; } }
        if (blDmg > 0) { G.hp = Math.max(0, G.hp - blDmg); flashPlayerStatus('#cc0000'); }
        G._bleeding = (G._bleeding || 0) + (es.bleedDmg || Math.max(2, Math.floor(e.atk * 0.12)));
        b.log.push((es.emoji||'🩸') + ' ' + e.name + ' ' + (es.name||'撕裂') + '!造成 ' + blDmg + ' 伤害+流血!');
      } else {
        b.log.push('💨 你闪避了 ' + e.name + ' 的撕裂!');
      }
      return true;

    default:
      return false;
  }
}

// Visual effect helpers
function showDamagePopup(id, amount, isCrit) {
  var popup = document.createElement('div');
  popup.id = id;
  popup.className = 'dmg-popup' + (isCrit ? ' dmg-popup-crit' : '');
  popup.textContent = (isCrit ? '💥' : '') + '-' + amount;
  var gameEl = document.getElementById('game');
  if (gameEl) {
    gameEl.style.position = 'relative';
    popup.style.position = 'absolute';
    // D1: Better positioning with random horizontal offset
    var xJitter = Math.floor(Math.random() * 30) - 15;
    popup.style.left = (50 + xJitter) + '%';
    popup.style.top = id === 'player-atk-dmg' ? '20%' : '55%';
    gameEl.appendChild(popup);
    setTimeout(function() { if (popup.parentNode) popup.parentNode.removeChild(popup); }, 1000);
  }
}

function showDamagePopupOnEnemy(idx, amount, type) {
  // D1: Position damage on specific enemy card
  var popup = document.createElement('div');
  popup.className = 'dmg-popup' + (type === 'dot' ? ' dmg-popup-dot' : (type === 'miss' ? ' dmg-popup-miss' : ''));
  popup.textContent = (type === 'dot' ? '🧪' : (type === 'miss' ? 'MISS' : '-')) + amount;
  var gameEl = document.getElementById('game');
  if (gameEl) {
    gameEl.style.position = 'relative';
    popup.style.position = 'absolute';
    var xOff = 30 + (idx * 25) + Math.floor(Math.random() * 10) - 5;
    popup.style.left = xOff + '%';
    popup.style.top = '18%';
    gameEl.appendChild(popup);
    setTimeout(function() { if (popup.parentNode) popup.parentNode.removeChild(popup); }, 900);
  }
}

function showHealPopup(amount) {
  var popup = document.createElement('div');
  popup.className = 'dmg-popup heal-popup';
  popup.textContent = '💚+' + amount;
  var gameEl = document.getElementById('game');
  if (gameEl) {
    gameEl.style.position = 'relative';
    popup.style.position = 'absolute';
    popup.style.left = '50%';
    popup.style.top = '65%';
    gameEl.appendChild(popup);
    setTimeout(function() { if (popup.parentNode) popup.parentNode.removeChild(popup); }, 1000);
  }
}

function flashPlayerStatus(color) {
  var statusEl = document.getElementById('status');
  if (statusEl) {
    statusEl.style.transition = 'background 0.15s';
    statusEl.style.background = color;
    statusEl.style.borderRadius = '4px';
    setTimeout(function() { statusEl.style.background = ''; }, 300);
  }
}

// ═══════════════════════════════════════════════════════════
// FLEE FUNCTION - FIXED
// ═══════════════════════════════════════════════════════════

function tryFlee() {
  var b = G.battle;
  if (b.isBoss) {
    toast('👑 首领战中无法逃跑!');
    return;
  }

  // Flee chance based on AGI comparison
  // Average enemy AGI vs player AGI
  var totalEnemyAgi = 0;
  var alive = b.enemies.filter(function(e) { return e.curHp > 0; });
  for (var i = 0; i < alive.length; i++) {
    totalEnemyAgi += (alive[i].agi || 8); // default agi 8 if not set
  }
  var avgEnemyAgi = alive.length > 0 ? totalEnemyAgi / alive.length : 8;

  // If player AGI > enemy AGI: almost 100% flee (95%)
  // If player AGI == enemy AGI: ~70% flee
  // If player AGI < enemy AGI: ~30-50% flee
  var agiDiff = G.agi - avgEnemyAgi;
  var fleeChance;
  if (agiDiff > 0) {
    fleeChance = Math.min(98, 70 + agiDiff * 5); // Higher AGI = near guaranteed
  } else {
    fleeChance = Math.max(15, 70 + agiDiff * 5); // Lower AGI = harder
  }

  if (Math.random() * 100 < fleeChance) {
    toast('🏃 成功逃脱!(敏捷' + G.agi + ' vs 敌均' + Math.round(avgEnemyAgi) + ')');
    G.inBattle = false;
    G.battle = null;
    G.attackMode = null;
    // Stay on mini-map, don't go to world map
    if (G.miniMapPos && LOCATIONS[G.location] && LOCATIONS[G.location].mapConfig) {
      renderMiniMap('成功逃脱,继续探索...');
    } else {
      sceneWorldMap();
    }
  } else {
    b.log.push('🏃 逃跑失败!你的敏捷不足以甩开敌人');
    G.attackMode = null;
    setTimeout(function() { enemyTurn(); }, _battleDelay(600));
  }
}

