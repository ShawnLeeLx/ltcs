    enemies:['storm_elemental','sea_serpent','storm_bird'],
    townDesc:'闪电劈在崖壁上,照亮了整座海角要塞。士兵们在雷声中紧握长枪,海浪拍打城墙溅起数丈高的水花。暴风中的灯塔依然亮着,为迷航的船只指引方向。' },
  windisland: { id:'windisland', x:450, y:60, name:'风神岛', type:'dungeon', emoji:'🌀', unlocked:false, levelRange:[45,55],
    desc:'传说中风暴之神的居所,岛上的风永不停止',
    mapConfig:{ cols:22, rows:20, name:'风神岛', enemyRate:0.20, treasureRate:0.15, eventRate:0.10,
      desc:'狂风呼啸,几乎站不稳脚跟...', startPos:{r:18,c:1}, bossPos:{r:1,c:20} },
    enemies:['wind_guardian','harpy','cloud_golem'],
    townDesc:'狂风呼啸如雷,岛上的建筑都在风中摇曳。巨石被风削成奇形怪状,风车飞速旋转发出尖锐的啸声。岛民们早已习惯,系紧绳索照常生活,只有外乡人会在这天罗地网般的风中瑟瑟发抖。' },

