    id: 'ch2_fortress_boss',
    chapter: '第二章',
    title: '堡垒之下', next: 'ch3_mine_entrance', reward: {xp:200, gold:100},
    entry: '密信揭示了一个惊人的事实:黑铁兄弟会并不是在「守护」堡垒--他们在「挖掘」。他们要找的东西就在堡垒地下的封印室里,而封印已经在他们的持续破坏下接近崩溃。\n\n封印室的大门已经半开。门后的黑暗中,有什么东西在动。\n\n你听到了成千上万的低语声,汇聚成一个词:「......自由......」',
    objectives: [
      { id:'ch2_defeat_boss', desc:'击败被封印腐化的守卫者', type:'defeat_boss', location:'fortress' },
      { id:'ch2_seal_complete', desc:'用石板修复部分封印(需要智力≥12 或 找到修复卷轴)', type:'make_choice', choiceId:'ch2_seal' },
      { id:'ch2_reach_lv5', desc:'达到5级', type:'reach_level', level:5 }
    ],
    next: 'ch3_mine_entrance',
    reward: { xp:200, gold:100 }
  },
  // ─── 第三章:暗影矿洞 ───
  {
    id: 'ch3_mine_entrance',
