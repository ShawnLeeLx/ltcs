function calcSetBonuses() {
  var result = {};
  var counts = {};
  var eqKeys = ['weapon','helmet','armor','gloves','boots','belt','necklace','ring'];
  for (var i = 0; i < eqKeys.length; i++) {
    var item = G.equipment[eqKeys[i]];
    if (item && item.setId) {
      if (!counts[item.setId]) counts[item.setId] = 0;
      counts[item.setId]++;
    }
  }
  for (var sid in counts) {
    var set = EQUIP_SETS[sid];
    if (!set) continue;
    var n = counts[sid];
    if (n >= 2 && set.bonus2) {
      for (var k in set.bonus2) {
        if (k !== 'desc') result[k] = (result[k] || 0) + set.bonus2[k];
      }
    }
    if (n >= 4 && set.bonus4) {
      for (var k2 in set.bonus4) {
        if (k2 !== 'desc') result[k2] = (result[k2] || 0) + set.bonus4[k2];
        if (k2 === 'deathSave' || k2 === 'fireImmune') result[k2] = true;
      }
    }
    if (n >= 6 && set.bonus6) {
      for (var k3 in set.bonus6) {
        if (k3 !== 'desc') result[k3] = (result[k3] || 0) + set.bonus6[k3];
        if (k3 === 'fireImmune') result[k3] = true;
      }
    }
  }
  return result;
}

function getSetInfo() {
  var counts = {};
  var items = {};
  var eqKeys = ['weapon','helmet','armor','gloves','boots','belt','necklace','ring'];
  for (var i = 0; i < eqKeys.length; i++) {
    var item = G.equipment[eqKeys[i]];
    if (item && item.setId) {
      if (!counts[item.setId]) { counts[item.setId] = 0; items[item.setId] = []; }
      counts[item.setId]++;
      items[item.setId].push(item.name);
    }
  }
  var result = [];
  for (var sid in counts) {
    var set = EQUIP_SETS[sid];
    if (!set) continue;
    var n = counts[sid];
    result.push({ id:sid, name:set.name, count:n, max:6,
      b2:set.bonus2, b4:set.bonus4, b6:set.bonus6,
      active2:n>=2, active4:n>=4, active6:n>=6 });
  }
  return result;
}

