// ═══════════════════════════════════════════════════════════
// DATA: Locations with procedural grid maps
// Map sizes: early=50-80 rooms, mid=80-120, late=120-150 (cap)
// Grid: simple N/S/E/W movement, no diagonal
// ═══════════════════════════════════════════════════════════

// Location unlock progression:
// whitecity → always visible (starting town)
// lake → unlocked on ch1_arrival so new players can explore immediately
// darkforest → unlocked when ch1_boss_pre completes
// fortress → unlocked when ch2_fortress_discovery completes
// mine → unlocked when ch2_fortress_boss completes
// Achievement system - tracks player milestones across playthrough
var ACHIEVEMENTS = [
  // === Combat (8) ===
  { id:'first_blood', name:'初次阵血', emoji:'🗡️', cat:'combat', desc:'完成第一场战斗', reward:{gold:20}, check:function(){ return (G._battleCount||0) >= 1; } },
