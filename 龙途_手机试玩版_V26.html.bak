function generateGuildQuests() {
  // Generate 3-5 random guild quests
  var quests = [];
  var numQuests = 2 + Math.floor(Math.random() * 3);  // 2-4 quests per refresh (was 3-5)
  var unlockedWild = [];
  for (var k in LOCATIONS) {
    if (LOCATIONS[k].unlocked && (LOCATIONS[k].type === 'wild' || LOCATIONS[k].type === 'dungeon')) {
      unlockedWild.push(k);
    }
  }
  if (unlockedWild.length === 0) unlockedWild = ['lake'];

  var matNames = ['铁矿石','兽皮','草药','水晶碎片','暗影精华','海蓝石'];

  for (var i = 0; i < numQuests; i++) {
    var tmpl = GUILD_QUEST_TEMPLATES[Math.floor(Math.random() * GUILD_QUEST_TEMPLATES.length)];
    var loc = unlockedWild[Math.floor(Math.random() * unlockedWild.length)];
    var locName = LOCATIONS[loc].name;
    var count = 2 + Math.floor(Math.random() * 4);
    var mat = matNames[Math.floor(Math.random() * matNames.length)];

    var name = tmpl.nameFns[Math.floor(Math.random() * tmpl.nameFns.length)] + locName;
    var desc = tmpl.descFn.replace('{loc}',locName).replace('{n}',count).replace('{mat}',mat);
    var obj = tmpl.objFn.replace('{loc}',locName).replace('{n}',count).replace('{mat}',mat);

    var levelScale = G.level || 1;
    var gold = tmpl.goldBase * count + Math.floor(levelScale * 2);
    var xp = tmpl.xpBase * count + Math.floor(levelScale * 3);

    quests.push({
      id: 'guild_' + Date.now() + '_' + i,
      name: name, desc: desc, icon: tmpl.icon, type: tmpl.type,
      objective: obj,
      progressType: tmpl.progressType,
      progressTarget: loc,
      progressCount: count,
      reward: xp + ' XP + ' + gold + '金',
      rewardType: 'xp_gold', xp: xp, gold: gold,
      isGuild: true
    });
  }
  return quests;
}

