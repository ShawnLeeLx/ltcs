  }

  // Gambling options
  html += '<div class="quest-list-title" style="margin-top:12px">🎲 赌桌</div>';
  html += '<div style="color:#aaa;font-size:0.85em;margin-bottom:8px">手气好就赚,手气差就赔--赌徒起源自带优势</div>';

  // Dice game
  html += '<div class="loc-card" onclick="sceneDiceGame()" style="cursor:pointer">';
  html += '<div class="loc-emoji">🎲</div>';
  html += '<div class="loc-info">';
  html += '<div class="loc-name">掷骰比大</div>';
  html += '<div class="loc-desc">押10~200金,掷骰点数大者赢。赌徒起源:对手-2点</div>';
  html += '</div></div>';

  // Coin flip
  html += '<div class="loc-card" onclick="sceneCoinFlip()" style="cursor:pointer">';
  html += '<div class="loc-emoji">🪙</div>';
  html += '<div class="loc-info">';
  html += '<div class="loc-name">翻金币</div>';
  html += '<div class="loc-desc">押10~500金,猜正反。赌徒起源:赢+20%奖金</div>';
  html += '</div></div>';

  // Lucky wheel
  html += '<div class="loc-card" onclick="sceneLuckyWheel()" style="cursor:pointer">';
  html += '<div class="loc-emoji">🎡</div>';
  html += '<div class="loc-info">';
  html += '<div class="loc-name">命运转盘</div>';
  html += '<div class="loc-desc">花费100金,赢取稀有装备/材料/大量金币</div>';
  html += '</div></div>';

  html += '<div class="btns">';
  html += '<button class="btn" onclick="sceneTavern()">再听一个</button>';
  html += '<button class="btn" onclick="sceneTown()">↩️ 离开</button>';
  html += '</div>';
  render(html);
}

function _getTavernNpcs() {
  return {
    whitecity: [
      { name:'老赵', emoji:'👴', title:'退役佣兵', dialog:'我年轻时在坠星湖打过龙,信不信随你。给我买杯酒,我教你两招。', reward:{ type:'buff', stat:'atk', val:2, cost:30, desc:'攻击+2' } },
      { name:'莉娜', emoji:'👩', title:'流浪歌姬', dialog:'远方来的人啊,我唱一首歌给你听,也许能让你心情好些。', reward:{ type:'buff', stat:'cha', val:2, cost:20, desc:'魅力+2' } },
