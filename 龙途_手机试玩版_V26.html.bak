    ],
    icereef: [
      { name:'冰港老渔夫', emoji:'👴', title:'极地渔民', dialog:'冰海下面有东西在动,比任何鱼都大。小心点。', reward:{ type:'buff', stat:'agi', val:2, cost:25, desc:'敏捷+2' } },
      { name:'冻珠商人', emoji:'👩', title:'黑市珠宝商', dialog:'冻珠在南方能卖天价,但运出去才是问题。', reward:{ type:'gold', val:60, cost:0, desc:'获得60金珠宝线索' } },
      { name:'极地猎人', emoji:'🧔', title:'冰原追踪者', dialog:'我能在暴风雪里追踪三天三夜,这本事你想学?', reward:{ type:'buff', stat:'agi', val:3, cost:40, desc:'敏捷+3' } }
    ]
  };
}

function tavernNpcChat(locId, npcIdx) {
  var tavernNpcs = _getTavernNpcs();
  var npcs = tavernNpcs[locId] || tavernNpcs.whitecity;
  var npc = npcs[npcIdx];
  if (!npc) { sceneTavern(); return; }
  var npcKey = 'npc_talked_' + locId + '_' + npcIdx;
  var reward = npc.reward;
  var price = reward.cost || 0;

  // Already talked - just show dialog
  if (G[npcKey]) {
    var html0 = '';
    html0 += '<div class="scene-title">🍺 ' + npc.name + '</div>';
    html0 += '<div class="loc-card" style="margin-bottom:10px"><div class="loc-emoji">' + npc.emoji + '</div><div class="loc-info"><div class="loc-name">' + npc.title + '</div></div></div>';
    html0 += '<div style="background:#1a1a10;border:1px solid #3a3a2a;border-radius:8px;padding:12px;margin:10px 0;font-style:italic;color:#d4c8a8">"' + npc.dialog + '"</div>';
    html0 += '<div style="color:#888;font-size:0.85em;text-align:center">(已经获得过奖励)</div>';
    html0 += '<div class="btns"><button class="btn" onclick="sceneTavern()">↩️ 返回酒馆</button></div>';
    render(html0);
    return;
  }

  if (G.gold < price) { toast('💰 金币不足'); return; }
  G.gold -= price;
  G[npcKey] = true;
  updateStatus();

  var html2 = '';
  html2 += '<div class="scene-title">🍺 ' + npc.name + '</div>';
  html2 += '<div class="loc-card" style="margin-bottom:10px"><div class="loc-emoji">' + npc.emoji + '</div><div class="loc-info"><div class="loc-name">' + npc.title + '</div></div></div>';
  html2 += '<div style="background:#1a1a10;border:1px solid #3a3a2a;border-radius:8px;padding:12px;margin:10px 0;font-style:italic;color:#d4c8a8">"' + npc.dialog + '"</div>';

  if (reward.type === 'buff') {
    G[reward.stat] = (G[reward.stat] || 0) + reward.val;
    html2 += '<div style="color:#7ec8a4;padding:8px;background:#1a2a1a;border-radius:6px">✨ ' + npc.name + '传给了你一些经验, ' + reward.desc + '</div>';
  } else if (reward.type === 'heal') {
    var healed = Math.floor(G.maxHp * reward.val);
    G.hp = Math.min(G.maxHp, G.hp + healed);
    html2 += '<div style="color:#7ec8e3;padding:8px;background:#1a2a2a;border-radius:6px">💙 ' + npc.name + '为你祈祷,恢复 ' + healed + ' 生命</div>';
  } else if (reward.type === 'gold') {
    G.gold += reward.val;
    html2 += '<div style="color:#f0d060;padding:8px;background:#2a2a1a;border-radius:6px">💰 ' + npc.name + '给了你一条线索,获得 ' + reward.val + ' 金币</div>';
  } else if (reward.type === 'material') {
    var mats = MATERIALS || [];
    for (var mi = 0; mi < (reward.val||1); mi++) {
      var m = mats[rand(0, mats.length-1)];
      if (m) G.inventory.push({ id:m.id, name:m.name, type:'material', price:m.price||10 });
    }
    html2 += '<div style="color:#d4a017;padding:8px;background:#2a2a1a;border-radius:6px">🔧 ' + npc.name + '送了你一些东西</div>';
  } else if (reward.type === 'reveal') {
    html2 += '<div style="color:#9b59b6;padding:8px;background:#2a1a2a;border-radius:6px">🔍 ' + npc.name + '透露了一些商业情报</div>';
  } else if (reward.type === 'info') {
    var infoTexts = {
      ironridge: '矿洞深处有更强的怪物,但也有更好的矿石。三层以下开始出现精英怪。',
      sunspire: '日冕塔据说有一个隐藏的密室,入口在塔顶的星象仪后面。',
    };
    html2 += '<div style="color:#7ec8e3;padding:8px;background:#1a1a2a;border-radius:6px">📜 ' + npc.name + '分享了一些情报: ' + (infoTexts[G.location] || '据说这片区域还有很多秘密等待发现...') + '</div>';
  }

  html2 += '<div class="btns">';
  html2 += '<button class="btn" onclick="sceneTavern()">↩️ 返回酒馆</button>';
  html2 += '</div>';
  render(html2);
}

// ═══════════════════════════════════════════════════════════
// GAMBLING: Dice Game
// ═══════════════════════════════════════════════════════════
function sceneDiceGame() {
  var html = '';
  html += '<div class="scene-title">🎲 掷骰比大</div>';
  html += '<div class="tavern-desc">庄家:"来吧,比谁点数大!你先掷。"</div>';
  html += '<div style="color:#aaa;font-size:0.85em;margin:8px 0">你的金币: ' + G.gold + ' 🪙</div>';

  if (G._diceState === 'player_rolled') {
    html += '<div class="battle-info" style="background:#1a3a1a">🎲 你掷出了: <b>' + G._dicePlayer + '</b> 点</div>';
    html += '<div class="battle-info" style="background:#3a1a1a">🎲 庄家掷出了: <b>' + G._diceDealer + '</b> 点</div>';

    var gamblerBonus = G.origin && G.origin.id === 'gambler';
    var dealerFinal = gamblerBonus ? Math.max(1, G._diceDealer - 2) : G._diceDealer;
    if (gamblerBonus && G._diceDealer !== dealerFinal) {
      html += '<div style="color:#f1c40f;font-size:0.85em">🎲 赌徒天赋: 庄家点数 -2 → ' + dealerFinal + '</div>';
    }

    if (G._dicePlayer > dealerFinal) {
      var winnings = G._diceBet;
      html += '<div class="battle-victory" style="padding:10px;margin:8px 0">🎉 你赢了! +<b>' + winnings + '</b> 金币!</div>';
    } else if (G._dicePlayer < dealerFinal) {
      html += '<div class="battle-defeat" style="padding:10px;margin:8px 0">😢 你输了... -<b>' + G._diceBet + '</b> 金币</div>';
    } else {
      html += '<div style="padding:10px;margin:8px 0;color:#f39c12;border:1px solid #f39c12;border-radius:6px">🤝 平局! 金币退还</div>';
      G.gold += G._diceBet; // refund
    }
    G._diceState = null;
    html += '<button class="btn" onclick="sceneDiceGame()">🔄 再来一局</button>';
  } else {
    // Bet selection
    var bets = [10, 25, 50, 100, 200];
    html += '<div class="quest-list-title">选择赌注</div>';
    for (var i = 0; i < bets.length; i++) {
      var b = bets[i];
      var disabled = G.gold < b ? ' disabled style="opacity:0.4"' : '';
      html += '<button class="btn" onclick="rollDice(' + b + ')"' + disabled + '>🪙 ' + b + ' 金</button> ';
    }
  }

  html += '<div class="btns">';
  html += '<button class="btn" onclick="sceneTavern()">↩️ 返回酒馆</button>';
  html += '</div>';
  render(html);
}

function rollDice(bet) {
  if (G.gold < bet) return;
  G.gold -= bet;
  G._diceBet = bet;
  G._dicePlayer = rand(1, 6);
  G._diceDealer = rand(1, 6);
  G._diceState = 'player_rolled';
  sceneDiceGame();
}

// ═══════════════════════════════════════════════════════════
// GAMBLING: Coin Flip
// ═══════════════════════════════════════════════════════════
function sceneCoinFlip() {
  var html = '';
  html += '<div class="scene-title">🪙 翻金币</div>';
  html += '<div class="tavern-desc">庄家:"正面还是反面?猜对翻倍!"</div>';
  html += '<div style="color:#aaa;font-size:0.85em;margin:8px 0">你的金币: ' + G.gold + ' 🪙</div>';

  if (G._coinState === 'result') {
    var result = G._coinResult;
    var guess = G._coinGuess;
    var isWin = result === guess;
    html += '<div class="battle-info" style="background:#1a2a3a">🪙 结果: <b>' + (result === 'heads' ? '正 面☀️' : '反 面🌙') + '</b></div>';

    if (isWin) {
      var gamblerBonus = G.origin && G.origin.id === 'gambler';
      var winnings = gamblerBonus ? Math.floor(G._coinBet * 1.2) : G._coinBet;
      var bonusText = gamblerBonus ? ' (赌徒+20%!)' : '';
      html += '<div class="battle-victory" style="padding:10px;margin:8px 0">🎉 猜对了! +<b>' + winnings + '</b> 金币' + bonusText + '</div>';
    } else {
      html += '<div class="battle-defeat" style="padding:10px;margin:8px 0">😢 猜错了... -<b>' + G._coinBet + '</b> 金币</div>';
    }
    G._coinState = null;
    html += '<button class="btn" onclick="sceneCoinFlip()">🔄 再来一次</button>';
  } else {
    var bets = [10, 25, 50, 100, 200, 500];
    html += '<div class="quest-list-title">选择赌注</div>';
    for (var i = 0; i < bets.length; i++) {
      var b = bets[i];
      var disabled = G.gold < b ? ' disabled style="opacity:0.4"' : '';
      html += '<button class="btn" onclick="chooseCoinGuess(' + b + ')"' + disabled + '>🪙 ' + b + ' 金</button> ';
    }
  }

  html += '<div class="btns">';
  html += '<button class="btn" onclick="sceneTavern()">↩️ 返回酒馆</button>';
  html += '</div>';
  render(html);
}

function chooseCoinGuess(bet) {
  if (G.gold < bet) return;
  G._coinBet = bet;
  // Show guess choice
  var html = '';
  html += '<div class="scene-title">🪙 翻金币 - 赌注 ' + bet + ' 金</div>';
  html += '<div class="tavern-desc">猜正面还是反面?</div>';
  html += '<div class="btns">';
  html += '<button class="btn" onclick="flipCoin(\'heads\',' + bet + ')" style="font-size:1.5em;padding:15px 30px">☀️ 正面</button>';
  html += '<button class="btn" onclick="flipCoin(\'tails\',' + bet + ')" style="font-size:1.5em;padding:15px 30px">🌙 反面</button>';
  html += '</div>';
  html += '<button class="btn" onclick="sceneCoinFlip()">↩️ 返回</button>';
  render(html);
}

function flipCoin(guess, bet) {
  if (G.gold < bet) return;
  G.gold -= bet;
  G._coinGuess = guess;
  G._coinBet = bet;
  G._coinResult = Math.random() < 0.5 ? 'heads' : 'tails';
  G._coinState = 'result';
  sceneCoinFlip();
}

// ═══════════════════════════════════════════════════════════
// GAMBLING: Lucky Wheel
// ═══════════════════════════════════════════════════════════
var LUCKY_WHEEL_PRIZES = [
  { weight: 25, name: '少量金币', desc: '+150 金币', fn: function() { G.gold += 150; return '获得 150 金币!'; } },
  { weight: 20, name: '中量金币', desc: '+350 金币', fn: function() { G.gold += 350; return '获得 350 金币!'; } },
  { weight: 15, name: '大量金币', desc: '+800 金币', fn: function() { G.gold += 800; return '获得 800 金币!'; } },
  { weight: 15, name: '恢复药水', desc: '回复全部HP/MP', fn: function() { G.hp = calcMaxHp(); G.mp = calcMaxMp(); return 'HP/MP 完全恢复!'; } },
  { weight: 10, name: '材料宝袋', desc: '随机稀有材料×3', fn: function() {
    var matKeys = Object.keys(MATERIALS);
    for (var i = 0; i < 3; i++) {
      var mk = matKeys[rand(0, matKeys.length-1)];
      if (!G.materials[mk]) G.materials[mk] = 0;
      G.materials[mk] += rand(2,5);
    }
    return '获得3种稀有材料!';
  } },
  { weight: 8, name: '稀有装备', desc: '随机稀有品质装备', fn: function() {
    var item = generateRandomDrop(false);
    // Force at least rare
    if (RARITY_TABLE[item.rarity] && RARITY_TABLE[item.rarity].mult < RARITY_TABLE.rare.mult) {
      item.rarity = 'rare'; item.rarityColor = RARITY_TABLE.rare.color;
    }
    G.inventory.push(item);
    return '获得: ' + item.name + '!';
  } },
  { weight: 5, name: '史诗装备', desc: '随机史诗品质装备', fn: function() {
    var item = generateRandomDrop(false);
    item.rarity = 'epic'; item.rarityColor = RARITY_TABLE.epic.color;
    G.inventory.push(item);
    return '获得: ' + item.name + '!';
  } },
  { weight: 2, name: '💎 大奖', desc: '+2000 金币 + 史诗装备!', fn: function() {
    G.gold += 2000;
    var item = generateRandomDrop(false);
    item.rarity = 'epic'; item.rarityColor = RARITY_TABLE.epic.color;
    G.inventory.push(item);
    return '🏆 大奖! 2000金币 + ' + item.name + '!';
  } },
  { weight: 0, name: '💀 空奖', desc: '什么都没有...', fn: function() { return '转盘缓缓停下...什么也没有。'; } }
];

function sceneLuckyWheel() {
  var html = '';
  html += '<div class="scene-title">🎡 命运转盘</div>';
  html += '<div class="tavern-desc">转盘每次100金,奖品丰厚!</div>';
  html += '<div style="color:#aaa;font-size:0.85em;margin:8px 0">你的金币: ' + G.gold + ' 🪙</div>';

  if (G._wheelState === 'spun') {
    var prize = G._wheelPrize;
    html += '<div style="text-align:center;margin:15px 0">';
    html += '<div style="font-size:2em;margin-bottom:8px">🎡</div>';
    html += '<div style="font-size:1.3em;color:#f1c40f;font-weight:bold">' + prize.name + '</div>';
    html += '<div style="color:#ddd;margin:5px 0">' + G._wheelResult + '</div>';
    html += '</div>';
    G._wheelState = null;
    html += '<button class="btn" onclick="sceneLuckyWheel()">🔄 再转一次</button>';
  } else {
    // Show prize list
    html += '<div class="quest-list-title">奖池</div>';
    var totalWeight = 0;
    for (var i = 0; i < LUCKY_WHEEL_PRIZES.length; i++) totalWeight += LUCKY_WHEEL_PRIZES[i].weight;
    for (var j = 0; j < LUCKY_WHEEL_PRIZES.length; j++) {
      var p = LUCKY_WHEEL_PRIZES[j];
      if (p.weight === 0) continue;
      var pct = (p.weight / totalWeight * 100).toFixed(1);
      html += '<div style="display:flex;justify-content:space-between;padding:3px 0;color:#bbb;font-size:0.9em">';
      html += '<span>' + p.name + '</span><span>' + pct + '%</span>';
      html += '</div>';
    }
    html += '<div style="margin-top:12px">';
    var canSpin = G.gold >= 100;
    html += '<button class="btn" onclick="spinWheel()"' + (canSpin ? '' : ' disabled style="opacity:0.4"') + '>🎡 花费 100 金 转一次</button>';
    html += '</div>';
  }

  html += '<div class="btns">';
  html += '<button class="btn" onclick="sceneTavern()">↩️ 返回酒馆</button>';
  html += '</div>';
  render(html);
}

function spinWheel() {
  if (G.gold < 100) return;
  G.gold -= 100;

  // Lucky bonus: shift weights toward better prizes
  var lukShift = Math.floor(G.luk / 10); // every 10 luk = +1 shift tier
  var prizes = LUCKY_WHEEL_PRIZES.slice();
  var totalWeight = 0;
  for (var i = 0; i < prizes.length; i++) totalWeight += prizes[i].weight;

  // Weighted random selection
  var roll = Math.random() * totalWeight;
  var acc = 0;
  var selected = prizes[prizes.length - 1]; // default last (empty)
  for (var j = 0; j < prizes.length; j++) {
    acc += prizes[j].weight;
    if (roll < acc) { selected = prizes[j]; break; }
  }

  G._wheelPrize = selected;
  G._wheelResult = selected.fn();
  G._wheelState = 'spun';
  sceneLuckyWheel();
}

// ═══════════════════════════════════════════════════════════
// SCENE: GUILD (Quests)
// ═══════════════════════════════════════════════════════════

function sceneGuild() {
  G._currentScene = 'sceneGuild';
  checkStoryTriggers('visit_place', 'guild');
  var html = '';
  html += '<div class="scene-title">📜 冒险者公会</div>';
  html += '<div class="guild-desc">接待员:「冒险者,来看看有什么任务吧。」</div>';

  // Quest pacing system
  var MAX_GUILD_BOARD = 5;  // Max guild quests visible on board
  var MAX_ACTIVE_QUESTS_G = 8;  // Same as acceptQuest cap

  // Generate guild quests if none available
  if (!G.guildQuests || G.guildQuests.length === 0) {
    G.guildQuests = generateGuildQuests();
  }

  // Cap guild quests shown on board
  if (G.guildQuests.length > MAX_GUILD_BOARD) {
    // Keep only the first MAX_GUILD_BOARD (preserve accepted ones)
    var acceptedIds = G.quests || [];
    var acceptedGuild = G.guildQuests.filter(function(gq) { return acceptedIds.indexOf(gq.id) >= 0; });
    var unacceptedGuild = G.guildQuests.filter(function(gq) { return acceptedIds.indexOf(gq.id) < 0; });
    var keepUnaccepted = MAX_GUILD_BOARD - acceptedGuild.length;
    if (keepUnaccepted > 0) {
      G.guildQuests = acceptedGuild.concat(unacceptedGuild.slice(0, keepUnaccepted));
    } else {
      G.guildQuests = acceptedGuild;
    }
  }

  // Show active quest count
  var activeCount = G.quests ? G.quests.length : 0;
  html += '<div style="color:#d4a017;font-size:0.9em;margin-bottom:8px">📋 当前任务: ' + activeCount + '/' + MAX_ACTIVE_QUESTS_G + '</div>';

  // Merge story quests + guild quests for display
  var allAvailable = QUESTS.filter(function(q) { return !q.isGuild; }).concat(typeof SIDE_QUESTS !== 'undefined' ? SIDE_QUESTS : []).concat(G.guildQuests);

  // Accepted quests (active) - includes both story and guild
  var acceptedQuests = G.quests.filter(function(qid) { return qid; });
  var completableQuests = [];
  var inProgressQuests = [];
  for (var a = 0; a < acceptedQuests.length; a++) {
    var aq = _findQuestById(acceptedQuests[a]);
    if (aq) {
      var qp = G.questProgress[aq.id];
      if (qp && qp.done) completableQuests.push(aq);
      else inProgressQuests.push(aq);
    }
  }

  // Completable quests
  if (completableQuests.length > 0) {
    html += '<div class="quest-list-title" style="color:#4a4">✅ 可交付任务 (' + completableQuests.length + ')</div>';
    for (var c = 0; c < completableQuests.length; c++) {
      var cq = completableQuests[c];
      html += '<div class="quest-card" style="border-left:3px solid #4a4;cursor:pointer" onclick="showQuestDetail(\'' + cq.id + '\')">';
      html += '<div class="quest-header">' + cq.icon + ' ' + cq.name + ' <span class="quest-badge" style="color:#4a4">✅ 可交付</span></div>';
      html += '<div class="quest-desc">' + cq.desc + '</div>';
      html += '<div class="quest-reward">奖励:' + cq.reward + '</div>';
      html += '<div style="color:#4a4;font-size:0.85em;margin-top:4px">点击交付领取奖励</div>';
      html += '</div>';
    }
  }

  // In-progress quests
  if (inProgressQuests.length > 0) {
    html += '<div class="quest-list-title">进行中的任务 (' + inProgressQuests.length + ')</div>';
    for (var a2 = 0; a2 < inProgressQuests.length; a2++) {
      var aq2 = inProgressQuests[a2];
      html += '<div class="quest-card active-quest" onclick="showQuestDetail(\'' + aq2.id + '\')" style="cursor:pointer">';
      html += '<div class="quest-header">' + aq2.icon + ' ' + aq2.name + ' <span class="quest-badge active">进行中</span>';
      if (aq2.isGuild) html += ' <span style="color:#6fa8dc;font-size:0.8em">[公会]</span>';
      html += '</div>';
      html += '<div class="quest-desc">' + aq2.desc + '</div>';
      if (aq2.objective) {
        html += '<div style="color:#aaa;font-size:0.9em;margin-top:4px">🎯 ' + aq2.objective + '</div>';
        var qp2 = G.questProgress[aq2.id];
        var pCount2 = aq2.progressCount || 1;
        var cur2 = Math.min(qp2 ? (qp2.current || 0) : 0, pCount2);
        html += '<div style="color:#4a4;font-size:0.85em">进度:' + cur2 + '/' + pCount2 + '</div>';
      }
      html += '<div class="quest-reward">奖励:' + aq2.reward + '</div>';
      html += '</div>';
    }
  }

  // Available quests (story + guild) - filtered by unlocked locations
  html += '<div class="quest-list-title">📋 可接任务</div>';
  var hasAvailable = false;
  // Helper: check if quest's target location is unlocked
  function isQuestLocationUnlocked(q) {
    var loc = q.progressTarget;
    if (!loc) return true; // No location requirement
    if (loc === 'mine_entrance_clue') return true; // clue-based, no location lock
    if (LOCATIONS[loc]) return LOCATIONS[loc].unlocked;
    return true; // Unknown location, allow
  }
  for (var i = 0; i < allAvailable.length; i++) {
    var q = allAvailable[i];
    var isAccepted = G.quests.indexOf(q.id) >= 0;
    var isCompleted = G.questProgress[q.id] && G.questProgress[q.id].done;
    if (isAccepted || isCompleted) continue;
    // Q5: Skip quests for locked locations
    if (!isQuestLocationUnlocked(q)) continue;
    // Show requires-not-met quests as grayed out instead of hiding
    var requiresMet = !q.requires || (G.questProgress[q.requires] && G.questProgress[q.requires].done);
    hasAvailable = true;
    var questFull = G.quests.length >= 8;
    var blocked = questFull || !requiresMet;
    var cardStyle = blocked ? 'opacity:0.5;cursor:not-allowed' : '';
    var cardClick = blocked ? '' : ' onclick="showQuestDetail(\'' + q.id + '\')"';
    html += '<div class="quest-card"' + cardClick + ' style="' + cardStyle + '">';
    html += '<div class="quest-header">' + q.icon + ' ' + q.name;
    if (q.isGuild) html += ' <span style="color:#6fa8dc;font-size:0.8em">[公会]</span>';
    else if (q.isStory) html += ' <span style="color:#d4a017;font-size:0.8em">[主线]</span>';
    html += '</div>';
    html += '<div class="quest-desc">' + q.desc + '</div>';
    if (q.objective) html += '<div style="color:#aaa;font-size:0.9em;margin-top:4px">🎯 ' + q.objective + '</div>';
    html += '<div class="quest-reward">奖励:' + q.reward + '</div>';
    if (G.quests.length >= 8) {
      html += '<div style="color:#e74c3c;font-size:0.8em">📋 任务已满，请先完成一些任务</div>';
    } else {
      html += '<div class="quest-accept-hint">' + (!requiresMet ? '🔒 需先完成前置任务' : '点击接取') + '</div>';
    }
    html += '</div>';
  }
  if (!hasAvailable) {
    html += '<div class="inv-empty">所有任务已接取</div>';
  }

  // Show quest chain progress
  if (typeof QUEST_CHAINS !== 'undefined') {
    var activeChains = [];
    for (var qci = 0; qci < QUEST_CHAINS.length; qci++) {
      var chain = QUEST_CHAINS[qci];
      var chainDone = 0;
      var chainTotal = chain.quests.length;
      for (var cqi = 0; cqi < chain.quests.length; cqi++) {
        var cqp = G.questProgress[chain.quests[cqi]];
        if (cqp && cqp.done) chainDone++;
      }
      if (chainDone > 0 || chainTotal > 0) {
        activeChains.push({ name:chain.name, desc:chain.desc, done:chainDone, total:chainTotal, bonus:chain.bonusReward });
      }
    }
    if (activeChains.length > 0) {
      html += '<div style="margin-top:12px;padding:8px;border:1px solid #d4a017;border-radius:8px;background:#1a1a2e">';
      html += '<div style="color:#d4a017;font-weight:bold;margin-bottom:6px">🔗 任务链进度</div>';
      for (var aci = 0; aci < activeChains.length; aci++) {
        var ac = activeChains[aci];
        var pct = Math.round(ac.done / ac.total * 100);
        var barColor = pct === 100 ? '#2ecc71' : '#d4a017';
        html += '<div style="margin:4px 0;font-size:0.9em">';
        html += '<div style="color:#c0c0c0">' + ac.name + ' <span style="color:#888">(' + ac.done + '/' + ac.total + ')</span></div>';
        html += '<div style="background:#333;height:4px;border-radius:2px;margin:3px 0"><div style="background:' + barColor + ';width:' + pct + '%;height:4px;border-radius:2px"></div></div>';
        if (pct === 100) html += '<div style="color:#2ecc71;font-size:0.8em">✅ 已完成! 额外奖励已领取</div>';
        else html += '<div style="color:#888;font-size:0.8em">' + ac.desc + '</div>';
        html += '</div>';
      }
      html += '</div>';
    }
  }
  // Refresh guild quests button
  html += '<div class="btns">';
  html += '<button class="btn" onclick="refreshGuildQuests()">🔄 刷新公会任务 (50金)</button>';
  html += '<button class="btn" onclick="showGiftPanel(\'guild\')">🎁 送礼</button>';
  html += '<button class="btn" onclick="_goBackFromGuild()">↩️ 离开</button>';
  html += '</div>';

  render(html);
}

function refreshGuildQuests() {
  if (G.gold < 50) { toast('💰 金币不足(需要50金)'); return; }
  G.gold -= 50;
  // Preserve accepted guild quests (only refresh unaccepted ones)
  var acceptedIds = G.quests || [];
  var oldGuildQuests = G.guildQuests || [];
  var keptQuests = [];
  for (var kqi = 0; kqi < oldGuildQuests.length; kqi++) {
    if (acceptedIds.indexOf(oldGuildQuests[kqi].id) >= 0) keptQuests.push(oldGuildQuests[kqi]);
  }
  G.guildQuests = generateGuildQuests();
  // Re-add kept quests so progress is preserved
  for (var kqj = 0; kqj < keptQuests.length; kqj++) {
    G.guildQuests.push(keptQuests[kqj]);
  }
  toast('🔄 公会任务已刷新!(已接取任务保留)');
  sceneGuild();
}
function _goBackFromGuild() {
  var target = _questReturnTo || 'sceneTown';
  _questReturnTo = null;
  var fn = window[target];
  if (typeof fn === 'function') fn();
  else sceneTown();
}

// Quest progress tracking - unified search across all quest sources
function _findQuestById(qid) {
  var q = QUESTS.find(function(qx) { return qx.id === qid; });
  if (q) return q;
  if (G.guildQuests) { q = G.guildQuests.find(function(qx) { return qx.id === qid; }); if (q) return q; }
  if (typeof SIDE_QUESTS !== 'undefined') { q = SIDE_QUESTS.find(function(qx) { return qx.id === qid; }); if (q) return q; }
  if (typeof CHAIN_QUESTS !== 'undefined' && CHAIN_QUESTS[qid]) { return CHAIN_QUESTS[qid]; }
  return null;
}

function _initQuestProgress(qid) {
  if (!G.questProgress) G.questProgress = {};
  if (!G.questProgress[qid]) G.questProgress[qid] = { current: 0, done: false };
}

function _updateBattleQuestProgress() {
  if (!G.quests || G.quests.length === 0) return;
  for (var i = 0; i < G.quests.length; i++) {
    var qid = G.quests[i];
    var q = _findQuestById(qid);
    if (!q || !q.progressType) continue;
    _initQuestProgress(qid);

    // Battle wins at specific location
    if (q.progressType === 'win_battles_at' && q.progressTarget === G.location) {
      G.questProgress[qid].current++;
      if (G.questProgress[qid].current >= (q.progressCount || 1)) {
        G.questProgress[qid].done = true;
        toast('🎉 任务完成:' + q.name + '!');
      } else {
        toast('📜 ' + q.name + ': ' + G.questProgress[qid].current + '/' + (q.progressCount || 1));
      }
    }
    // Defeat boss at specific location
    if (q.progressType === 'defeat_boss_at' && q.progressTarget === G.location && G.bossDefeated[G.location]) {
      G.questProgress[qid].current = 1;
      G.questProgress[qid].done = true;
      toast('🎉 任务完成:' + q.name + '!');
    }
    // Kill elite at specific location
    if (q.progressType === 'kill_elite_at' && q.progressTarget === G.location && G.battle && G.battle.isElite) {
      G.questProgress[qid].current = (G.questProgress[qid].current || 0) + 1;
      if (G.questProgress[qid].current >= (q.progressCount || 1)) {
        G.questProgress[qid].done = true;
        toast('🎉 任务完成:' + q.name + '!');
      }
    }
    // Collect material
    if (q.progressType === 'collect_material' && q.progressTarget) {
      var matCount = 0;
      if (G.materials && G.materials[q.progressTarget]) matCount = G.materials[q.progressTarget];
      G.questProgress[qid].current = matCount;
      if (matCount >= (q.progressCount || 1)) {
        G.questProgress[qid].done = true;
        toast('🎉 任务完成:' + q.name + '!');
      }
    }
    // Side quest stages: battle-related stage auto-advance
    if (q.progressType === 'side_stages') {
      var _qp = G.questProgress[qid];
      if (_qp && !_qp.done) {
        var _si = _qp.current || 0;
        var _sd = (q.stageDescs || [])[_si];
        if (_sd && /击败|消灭|战斗|打败|杀|击杀/.test(_sd)) {
          _qp.current = (_qp.current || 0) + 1;
          toast('📋 ' + q.name + ' 阶段' + _qp.current + '/' + (q.stages || q.progressCount) + ' 完成!');
          if (_qp.current >= (q.progressCount || q.stages || 1)) { _qp.done = true; toast('🎉 支线任务完成:' + q.name + '!'); }
        } else if (_sd && /探索|前往|寻找|到达|搜索|采集/.test(_sd) && q.location === G.location) {
          _qp.current = (_qp.current || 0) + 1;
          toast('📋 ' + q.name + ' 阶段' + _qp.current + '/' + (q.stages || q.progressCount) + ' 完成!');
          if (_qp.current >= (q.progressCount || q.stages || 1)) { _qp.done = true; toast('🎉 支线任务完成:' + q.name + '!'); }
        }
      }
    }
  }
}

function _updateBossQuestProgress(locId) {
  if (!G.quests || G.quests.length === 0) return;
  for (var i = 0; i < G.quests.length; i++) {
    var qid = G.quests[i];
    var q = _findQuestById(qid);
    if (!q || !q.progressType) continue;
    _initQuestProgress(qid);
    if (q.progressType === 'defeat_boss_at' && q.progressTarget === locId) {
      G.questProgress[qid].current = 1;
      G.questProgress[qid].done = true;
      toast('🎉 任务完成:' + q.name + '!');
    }
    if (q.progressType === 'side_stages' && q.location === locId) {
      var _qp2 = G.questProgress[qid];
      if (_qp2 && !_qp2.done) {
        var _si2 = _qp2.current || 0;
        var _sd2 = (q.stageDescs || [])[_si2];
        if (_sd2 && /击败|打败|击杀|消灭|讨伐/.test(_sd2)) {
          _qp2.current = (_qp2.current || 0) + 1;
          toast('📋 ' + q.name + ' 阶段' + _qp2.current + '/' + (q.stages || q.progressCount) + ' 完成!');
          if (_qp2.current >= (q.progressCount || q.stages || 1)) { _qp2.done = true; toast('🎉 支线任务完成:' + q.name + '!'); }
        }
      }
    }
  }
}

function _updateVisitQuestProgress(locId) {
  if (!G.quests || G.quests.length === 0) return;
  for (var i = 0; i < G.quests.length; i++) {
    var qid = G.quests[i];
    var q = _findQuestById(qid);
    if (!q || !q.progressType) continue;
    _initQuestProgress(qid);

    if (q.progressType === 'visit_location') {
      if (q.progressTarget === locId) {
        G.questProgress[qid].current = (G.questProgress[qid].current || 0) + 1;
        if (G.questProgress[qid].current >= (q.progressCount || 1)) {
          G.questProgress[qid].done = true;
          toast('🎉 任务完成:' + q.name + '!');
        } else {
          toast('📜 ' + q.name + ': ' + G.questProgress[qid].current + '/' + (q.progressCount || 1));
        }
      }
    }
    // Side quest visit/return stages
    if (q.progressType === 'side_stages' && q.location === locId) {
      var _qp = G.questProgress[qid];
      if (_qp && !_qp.done) {
        var _si = _qp.current || 0;
        var _sd = (q.stageDescs || [])[_si];
        if (_sd && /前往|到达|回到|交给|带回|归还/.test(_sd)) {
          _qp.current = (_qp.current || 0) + 1;
          toast('📋 ' + q.name + ' 阶段' + _qp.current + '/' + (q.stages || q.progressCount) + ' 完成!');
          if (_qp.current >= (q.progressCount || q.stages || 1)) { _qp.done = true; toast('🎉 支线任务完成:' + q.name + '!'); }
        }
      }
    }
  }
}

function _updateTreasureQuestProgress(locId) {
  if (!G.quests || G.quests.length === 0) return;
  for (var i = 0; i < G.quests.length; i++) {
    var qid = G.quests[i];
    var q = _findQuestById(qid);
    if (!q || !q.progressType) continue;
    _initQuestProgress(qid);

    // find_treasure and find_treasure_at both match (unified)
    if ((q.progressType === 'find_treasure' || q.progressType === 'find_treasure_at') && q.progressTarget === locId) {
      G.questProgress[qid].current = (G.questProgress[qid].current || 0) + 1;
      if (G.questProgress[qid].current >= (q.progressCount || 1)) {
        G.questProgress[qid].done = true;
        toast('🎉 任务完成:' + q.name + '!');
      } else {
        toast('📜 ' + q.name + ': ' + G.questProgress[qid].current + '/' + (q.progressCount || 1));
      }
    }
    // Side quest treasure/collect stages
    if (q.progressType === 'side_stages' && q.location === locId) {
      var _qp = G.questProgress[qid];
      if (_qp && !_qp.done) {
        var _si = _qp.current || 0;
        var _sd = (q.stageDescs || [])[_si];
        if (_sd && /找到|收集|获取|寻|搜索|采集|拼凑/.test(_sd)) {
          _qp.current = (_qp.current || 0) + 1;
          toast('📋 ' + q.name + ' 阶段' + _qp.current + '/' + (q.stages || q.progressCount) + ' 完成!');
          if (_qp.current >= (q.progressCount || q.stages || 1)) { _qp.done = true; toast('🎉 支线任务完成:' + q.name + '!'); }
        }
      }
    }
  }
}

// ═══════════════════════════════════════════════════════════
// MAIN STORY SYSTEM - Guided questline
// ═══════════════════════════════════════════════════════════

function startStory() {
  G.storyProgress = { chapterId: STORY[0].id, completed: {} };
}

function getCurrentChapter() {
  if (!G.storyProgress) return null;
  return STORY.find(function(s) { return s.id === G.storyProgress.chapterId; });
}

function getChapterProgress() {
  var ch = getCurrentChapter();
  if (!ch) return null;
  var total = ch.objectives.length;
  var done = 0;
  for (var i = 0; i < ch.objectives.length; i++) {
    if (G.storyProgress.completed[ch.objectives[i].id]) done++;
  }
  return { total: total, done: done, allDone: done >= total && !ch.next };
}

function advanceStoryObj(objId) {
  if (!G.storyProgress) return;
  var ch = getCurrentChapter();
  if (!ch) return;
  // Check if this obj exists in current chapter
  var found = false;
  for (var i = 0; i < ch.objectives.length; i++) {
    if (ch.objectives[i].id === objId) { found = true; break; }
  }
  if (!found) return;
  if (G.storyProgress.completed[objId]) return; // already done
  G.storyProgress.completed[objId] = true;

  // Check if chapter complete
  var prog = getChapterProgress();
  if (prog.done >= prog.total) {
    completeStoryChapter();
  }
}

function _getChapterTransitionNarration(chapterId) {
  var narrations = {
    ch1_boss_pre: '湖面的涟漪渐渐平息,但远方暗影的轮廓愈发清晰。铁岭城的商队带来了不安的消息--北方的森林中,有什么东西正在苏醒。',
    ch2_fortress_boss: '森林深处的暗影暂时退去了,但你的直觉告诉你,这不过是暴风雨前的宁静。东方的海风中夹杂着血腥味,潮汐港的水手们谈论着海上出现的异象。',
    ch3_mine_boss: '海风凛冽,潮蚀海洞中的秘密令人不寒而栗。南方的学者们传来急信--日冕塔观测到了前所未见的星象异变,龙族的遗产正在苏醒。',
    ch4_mist_choice: '古文献中的记载令你心惊--龙神的封印正在瓦解。你感受到体内有一种力量在回应,仿佛命运之手正在将你推向更深的漩涡。',
    ch5_jade_choice: '跨过龙脊山脉的那一刻,空气变得沉重。北方龙域的天空永远笼罩着阴云,大地震颤不止。龙域边境的哨兵说--有什么东西在山脉深处移动。',
    ch6_sunspire_choice: '龙神的低语穿透了时空的壁障。你看到了不该看到的东西--那些关于龙族陨落的真相。而现在,那股力量正在寻找新的宿主。',
    ch7_dragon_choice: '灰烬平原上回荡着古老的战歌。曾经守护这片大地的龙骑士已经消逝,但他们的意志仍在燃烧。你必须找到他们留下的遗产,否则一切都将化为灰烬。',
    ch8_temple_boss: '火山口的熔岩中映照出世界的末日景象。这不是幻觉--你看到了。封印的最后一道裂缝即将崩塌,而你是唯一站在裂缝前的人。',
    ch9_ash_volcano: '深渊在注视着你。站在裂缝边缘,你感到一种奇异的熟悉感--仿佛你曾经来过这里,或者说,你注定要来。虚空的那一头,有什么在等待。',
    ch10_volcano_boss: '你的暗影镜像站在你面前,它拥有你的一切--记忆、力量、恐惧。但它的眼中没有光。击败它,你才能到达最终的真相。',
    ch11_abyss_choice: '万古王座在虚空中等待了千年。每一步都踩在时间的碎片上,每一息都吸入永恒的尘埃。终点就在眼前,但你的旅程还远未结束。',
    ch12_throne_final: '传说已经写就,而你是执笔之人。龙途的尽头不是终点,而是新的开始。你的名字将被铭刻在万古王座的基座上,与星辰同在。'
  };
  return narrations[chapterId] || '旅途仍在继续,前方的道路伸向未知的远方...';
}

function showGameEnding() {
  var endingType = 'destroy'; // default
  if (G._finalSacrifice) endingType = 'sacrifice';
  else if (G._finalAccept) endingType = 'accept';
  else if (G._finalDestroy) endingType = 'destroy';

  // Check if player qualified for accept ending (needed seek_mercy or understand_shadow)
  if (endingType === 'accept' && !G._seekMercy && !G._understandShadow) {
    endingType = 'destroy'; // fallback if not qualified
  }
  // Check if player qualified for sacrifice ending (needed altruist or purify_frost)
  if (endingType === 'sacrifice' && !G._altruistRoute && !G._purifyFrost) {
    endingType = 'destroy'; // fallback if not qualified
  }

  var endings = {
    destroy: {
      title: '☀️ 光明纪元',
      subtitle: '暗影消逝，世界重归光明',
      color: '#f0d060',
      narration: '你举起龙族之火，将它注入封印的核心。暗影龙王发出震天的怒吼，它的身躯在烈焰中崩解，化为无数黑色的碎片消散在风中。\n\n世界安静了。天空重新变得湛蓝，暗影的裂痕缓缓愈合。但你感到一丝空虚——那些消失的暗影，原本也是这个世界的一部分。\n\n人们欢呼着庆祝胜利，却没有人注意到，花不再开得那么鲜艳，夜空中的星星也不再那么明亮。光明纪元来临了，安全而苍凉。',
      epilogue: '多年后，诗人们传唱着一位冒险者的故事——他（她）用龙火焚尽了暗影，也焚去了世界的一半色彩。在光明的尽头，他（她）独自坐在湖畔，凝视着过于湛蓝的天空。'
    },
    accept: {
      title: '⚖️ 平衡纪元',
      subtitle: '光与暗共存，世界完整而危险',
      color: '#a0d0f0',
      narration: '你向暗影龙王伸出了手。它迟疑了很久——千年来，从没有人向它伸出手而非举起武器。\n\n「你......不怕我吗？」它的声音不再是咆哮，而是一个疲惫的老者。\n\n你告诉它，世界需要平衡。光需要暗，暗也需要光。它不必被消灭，只需要找到新的位置。\n\n暗影缓缓收缩，融入了大地。夜晚重新降临，但不再是可怕的黑暗——而是温柔的、孕育万物的暗。',
      epilogue: '在平衡纪元里，冒险者成为了暗影与光明的调停者。每当世界的天平倾斜，他们便踏上旅途，用智慧和勇气维持那份脆弱的平衡。危险依然存在，但这个世界，第一次完整了。'
    },
    sacrifice: {
      title: '💫 英雄纪元',
      subtitle: '你成为永恒的封印',
      color: '#ff8080',
      narration: '你闭上眼睛，将自己的生命力注入封印。龙族之火在你体内燃烧，你感到自己的存在正在化作光。\n\n暗影龙王看着你，第一次露出了敬畏的神情。「你......选择成为封印？永远？」\n\n你微笑着点头。光芒从你体内绽放，与暗影交织在一起，形成了一道永恒的屏障。你不再是人，但也不再是神——你成为了守护这个世界的誓约本身。',
      epilogue: '在英雄纪元的传说中，龙途的尽头不是王座，而是一道永恒的光。每当暗影试图挣脱，那道光便会亮起，温暖而坚定。人们不知道那光是什么，但孩子们会在睡前祈祷：\n\n「晚安，英雄。谢谢你还在。」'
    }
  };

  var e = endings[endingType];
  var html = '';
  html += '<div class="chapter-intro">';
  html += '<div class="chapter-intro-inner">';
  html += '<div style="color:' + e.color + ';font-size:1.6em;font-weight:bold;text-align:center;text-shadow:0 0 20px ' + e.color + ';margin-bottom:4px">' + e.title + '</div>';
  html += '<div style="color:' + e.color + ';text-align:center;font-size:0.95em;margin-bottom:16px">' + e.subtitle + '</div>';
  html += '<div class="chapter-divider">---- ✦ ----</div>';
  html += '<div class="chapter-narration" style="font-size:0.92em">' + e.narration.replace(/\n/g, '<br><br>') + '</div>';
  html += '<div class="chapter-divider">---- ✦ ----</div>';
  html += '<div style="font-style:italic;color:#888;font-size:0.88em;line-height:1.7">' + e.epilogue.replace(/\n/g, '<br><br>') + '</div>';
  // Stats summary
  html += '<div style="margin-top:20px;padding:12px;background:#111;border:1px solid #333;border-radius:8px;font-size:0.85em">';
  html += '<div style="color:#d4a017;font-weight:bold;margin-bottom:6px">📊 冒险统计</div>';
  html += '<div>⚔️ 战斗胜利: ' + (G.totalBattlesWon || 0) + ' | 💀 战败: ' + (G.totalBattlesLost || 0) + '</div>';
  html += '<div>⭐ 等级: ' + G.level + ' | 💰 金币: ' + G.gold + '</div>';
  html += '<div>🗺️ 探索区域: ' + Object.keys(LOCATIONS).filter(function(k){return LOCATIONS[k].unlocked;}).length + '/' + Object.keys(LOCATIONS).length + '</div>';
  html += '<div>👥 NPC好感: ' + Object.keys(G.npcRelations || {}).length + ' 位</div>';
  var storyChoiceCount = G.storyChoices ? Object.keys(G.storyChoices).length : 0;
  html += '<div>✦ 命运选择: ' + storyChoiceCount + ' 次</div>';
  html += '</div>';
  html += '<div style="margin-top:16px">';
  html += '<button class="btn btn-primary" onclick="sceneWorldMap()" style="width:100%">🗺️ 继续探索世界</button>';
  html += '</div>';
  html += '</div>';
  html += '</div>';
  render(html);
}

function completeStoryChapter() {
  var ch = getCurrentChapter();
  if (!ch) return;

  // Track completed chapters for achievements
  if (!G._completedChapters) G._completedChapters = [];
  var chNum = ch.id.replace(/ch(\d+).*/, '$1');
  if (G._completedChapters.indexOf(chNum) < 0) G._completedChapters.push(chNum);

  autoSave(); // Auto-save on chapter complete
  toast('💾 章节完成,已自动存档');

  // Mark reward as pending (must collect from Lord Hall)
  if (ch.reward) {
    if (!G.pendingChapterRewards) G.pendingChapterRewards = [];
    G.pendingChapterRewards.push({
      chapterId: ch.id,
      chapter: ch.chapter,
      title: ch.title,
      xp: ch.reward.xp || 0,
      gold: ch.reward.gold || 0
    });
  }

  // Unlock new locations based on chapter progression
  var newUnlocks = CHAPTER_UNLOCKS[ch.id] || [];
  var discoveredNames = [];
  for (var i = 0; i < newUnlocks.length; i++) {
    var locId = newUnlocks[i];
    if (LOCATIONS[locId] && !LOCATIONS[locId].unlocked) {
      LOCATIONS[locId].unlocked = true;
      discoveredNames.push(LOCATIONS[locId].emoji + ' ' + LOCATIONS[locId].name);
    }
  }

  // Show completion message
  var html = '';
  html += '<div class="scene-title">📖 章节完成!</div>';
  html += '<div class="chapter-complete">';
  html += '<div class="chapter-title">' + ch.chapter + ':' + ch.title + '</div>';
  // Transition narrative
  html += '<div style="margin:12px 0;padding:12px 14px;background:#0d1117;border:1px solid #2a3a4a;border-radius:8px;font-style:italic;line-height:1.6;color:#b0c0d0">';
  html += _getChapterTransitionNarration(ch.id);
  html += '</div>';
  html += '<div class="chapter-reward" style="color:#d4a017">🏛️ 前往城主厅领取奖赏</div>';
  if (ch.reward) {
    html += '<div class="chapter-reward-detail">待领取:⭐' + (ch.reward.xp || 0) + ' XP + 💰' + (ch.reward.gold || 0) + ' 金币</div>';
  }
  // Show newly discovered locations
  if (discoveredNames.length > 0) {
    html += '<div class="chapter-discover" style="color:#2ecc71;margin-top:12px;font-size:1.05em">🗺️ 发现新地点:' + discoveredNames.join('、') + '</div>';
  }
  if (ch.next) {
    var next = STORY.find(function(s) { return s.id === ch.next; });
    if (next) {
      html += '<div class="chapter-next">下一章:<strong>' + next.chapter + ':' + next.title + '</strong></div>';
    }
  } else {
    // Final chapter complete - show ending
    showGameEnding();
    return;
  }
  html += '</div>';

  // Advance to next chapter
  if (ch.next) {
    G.storyProgress.chapterId = ch.next;
    G.storyProgress.completed = {};
    // Re-check new chapter objectives against event log
    _checkCurrentChapterTriggers();
    // Show story choice for current chapter before intro
    if (showStoryChoice(ch.id)) return;
    // Also check make_choice objectives
    for (var _mci2 = 0; _mci2 < ch.objectives.length; _mci2++) {
      var _mcObj2 = ch.objectives[_mci2];
      if (_mcObj2.type === 'make_choice' && _mcObj2.choiceId) {
        if (showStoryChoice(_mcObj2.choiceId)) return;
      }
    }
    // Show next chapter intro cinematic
    var nextIntro = CHAPTER_INTROS[ch.next];
    if (nextIntro) {
      html = '';
      html += '<div class="scene-title">✨ 新篇章</div>';
      html += '<button class="btn btn-primary" onclick="showChapterIntro(\'' + ch.next + '\')" style="width:100%">查看下一章引言</button>';
      render(html);
      return;
    }
  }

  html += '<button class="btn btn-primary" onclick="sceneTown()">🏰 返回城镇</button>';
  render(html);
}

function showStory() {
  if (!_questReturnTo) _questReturnTo = G._currentScene || 'sceneTown';
  var ch = getCurrentChapter();
  if (!ch) {
    toast('暂无主线任务');
    _goBackFromQuest();
    return;
  }
  // Show story choice if available for this chapter (not yet chosen)
  if (showStoryChoice(ch.id)) return;
  // Also check make_choice objectives for linked story choices
  for (var _mci = 0; _mci < ch.objectives.length; _mci++) {
    var _mcObj = ch.objectives[_mci];
    if (_mcObj.type === 'make_choice' && _mcObj.choiceId && !G.storyProgress.completed[_mcObj.id]) {
      if (showStoryChoice(_mcObj.choiceId)) return;
    }
  }
  var prog = getChapterProgress();

  var html = '';
  html += '<div class="scene-title">📖 ' + ch.chapter + ':' + ch.title + '</div>';
  html += '<div class="story-entry">' + ch.entry + '</div>';
  html += '<div class="story-objectives">';
  html += '<div class="story-obj-title">任务目标 (' + prog.done + '/' + prog.total + ')</div>';
  for (var i = 0; i < ch.objectives.length; i++) {
    var obj = ch.objectives[i];
    var done = G.storyProgress.completed[obj.id];
    html += '<div class="story-obj' + (done ? ' obj-done' : '') + '">';
    html += (done ? '✅' : '⬜') + ' ' + obj.desc;
    html += '</div>';
  }
  html += '</div>';
  // Show chapter rewards
  if (ch.reward) {
    html += '<div style="margin-top:12px;padding:10px;background:#1a1a10;border:1px solid #3a3a2a;border-radius:8px">';
    html += '<div style="color:#d4a017;font-weight:bold">🎁 章节奖励</div>';
    if (ch.reward.xp) html += '<div style="color:#4a4;padding-left:8px">⭐ ' + ch.reward.xp + ' 经验值</div>';
    if (ch.reward.gold) html += '<div style="color:#d4a017;padding-left:8px">💰 ' + ch.reward.gold + ' 金币</div>';
    html += '<div style="color:#888;font-size:0.85em;padding-left:8px;margin-top:4px">(完成后前往城主厅领取)</div>';
    html += '</div>';
  }
  // Show location unlocks preview
  var nextUnlocks = CHAPTER_UNLOCKS[ch.id] || [];
  if (nextUnlocks.length > 0) {
    html += '<div style="margin-top:8px;color:#2ecc71;font-size:0.9em">🗺️ 完成后解锁:' + nextUnlocks.map(function(lid) { return LOCATIONS[lid] ? LOCATIONS[lid].name : lid; }).join('、') + '</div>';
  }
  // Show story choices made so far
  if (G.storyChoices && Object.keys(G.storyChoices).length > 0) {
    html += '<div style="margin-top:10px;padding:8px 12px;background:#2a1a0a;border:1px solid #d4a017;border-radius:6px;font-size:0.85em">';
    html += '<div style="color:#d4a017;font-weight:bold;margin-bottom:4px">✦ 命运的选择</div>';
    var _chKeys = Object.keys(G.storyChoices);
    for (var sci = 0; sci < _chKeys.length; sci++) {
      var _chKey = _chKeys[sci];
      var _chEffect = G.storyChoices[_chKey];
      var _chData = STORY_CHOICES[_chKey];
      var _chText = _chKey;
      if (_chData) {
        for (var _ci = 0; _ci < _chData.choices.length; _ci++) {
          if (_chData.choices[_ci].effect === _chEffect) { _chText = _chData.choices[_ci].text; break; }
        }
      }
      html += '<div style="color:#c0c0c0;padding-left:8px">• ' + _chText + '</div>';
    }
    html += '</div>';
  }
  html += '<button class="btn" onclick="_goBackFromQuest()">返回</button>';
  render(html);
}

function checkStoryTriggers(eventType, data) {
  if (!G.storyProgress) return;

  // Record this event in case it matches a future chapter's objectives
  if (!G._storyEventLog) G._storyEventLog = [];
  G._storyEventLog.push({ type: eventType, data: data, ts: Date.now() });

  // Track battle win count for story
  if (eventType === 'win_battles' && data === 'battle_won') {
    if (!G._storyBattleWins) G._storyBattleWins = 0;
    G._storyBattleWins++;
  }

  _checkCurrentChapterTriggers();
}

function _checkCurrentChapterTriggers() {
  if (!G.storyProgress) return;
  var ch = getCurrentChapter();
  if (!ch) return;
  for (var i = 0; i < ch.objectives.length; i++) {
    var obj = ch.objectives[i];
    if (G.storyProgress.completed[obj.id]) continue;

    // Check if any logged event matches this objective
    for (var e = 0; e < (G._storyEventLog || []).length; e++) {
      var evt = G._storyEventLog[e];
      if (obj.type !== evt.type) continue;

      if (obj.type === 'visit_place' && obj.place === evt.data) advanceStoryObj(obj.id);
      if (obj.type === 'visit_location' && obj.location === evt.data) advanceStoryObj(obj.id);
      if (obj.type === 'accept_any_quest') advanceStoryObj(obj.id);
      if (obj.type === 'find_treasure' && evt.data === 'treasure') advanceStoryObj(obj.id);
      if (obj.type === 'reach_level' && G.level >= obj.level) advanceStoryObj(obj.id);
      if (obj.type === 'defeat_boss' && evt.data === obj.location) advanceStoryObj(obj.id);
      if (obj.type === 'win_battles' && evt.data === 'battle_won') {
        if (!G._storyBattleWins) G._storyBattleWins = 0;
        if (G._storyBattleWins >= obj.count) advanceStoryObj(obj.id);
      }
      // ── New story objective types ──
      if (obj.type === 'talk_to_npc' && obj.npc === evt.data) advanceStoryObj(obj.id);
      if (obj.type === 'find_clue' && obj.clueId === evt.data) advanceStoryObj(obj.id);
      if (obj.type === 'collect_evidence' && obj.evidenceId === evt.data) {
        if (!G._storyEvidence) G._storyEvidence = {};
        G._storyEvidence[obj.evidenceId] = true;
        // Check if all required evidence collected
        var allCollected = true;
        for (var ei = 0; ei < (obj.evidenceList || []).length; ei++) {
          if (!G._storyEvidence[obj.evidenceList[ei]]) { allCollected = false; break; }
        }
        if (allCollected) advanceStoryObj(obj.id);
      }
      if (obj.type === 'make_choice' && G.storyChoices && G.storyChoices[obj.choiceId]) advanceStoryObj(obj.id);
      if (obj.type === 'gain_affection' && evt.type === 'gain_affection') {
        var npcAff = G.npcAffection && G.npcAffection[obj.npc] ? G.npcAffection[obj.npc] : 0;
        if (npcAff >= obj.amount) advanceStoryObj(obj.id);
      }
      if (obj.type === 'complete_quest' && evt.data === obj.questId) advanceStoryObj(obj.id);
      if (obj.type === 'buy_item' && obj.itemId === evt.data) advanceStoryObj(obj.id);
      if (obj.type === 'craft_item' && obj.itemId === evt.data) advanceStoryObj(obj.id);
      if (obj.type === 'rest_inn' && evt.data === 'rest_inn') advanceStoryObj(obj.id);
      if (obj.type === 'accept_quest_id' && evt.data === obj.questId) advanceStoryObj(obj.id);
      // Break if completed (advanceStoryObj may have changed chapter)
      if (G.storyProgress.completed[obj.id]) break;
    }
    // Also check reach_level independently
    if (obj.type === 'reach_level' && G.level >= obj.level && !G.storyProgress.completed[obj.id]) {
      advanceStoryObj(obj.id);
    }
    // Also check make_choice independently
    if (obj.type === 'make_choice' && G.storyChoices && G.storyChoices[obj.choiceId] && !G.storyProgress.completed[obj.id]) {
      advanceStoryObj(obj.id);
    }
    // Also check gain_affection independently
    if (obj.type === 'gain_affection' && !G.storyProgress.completed[obj.id]) {
      var npcAff2 = G.npcAffection && G.npcAffection[obj.npc] ? G.npcAffection[obj.npc] : 0;
      if (npcAff2 >= obj.amount) advanceStoryObj(obj.id);
    }
    // Also check complete_quest independently
    if (obj.type === 'complete_quest' && G.questProgress && G.questProgress[obj.questId] && G.questProgress[obj.questId].done && !G.storyProgress.completed[obj.id]) {
      advanceStoryObj(obj.id);
    }
  }
}



function showQuestDetail(qid) {
  var q = _findQuestById(qid);
  if (!q) return;
  G._currentDetailQuest = qid;
  var html = '';
  html += '<div class="scene-title">' + q.icon + ' ' + q.name + '</div>';
  html += '<div style="padding:12px;background:#1a1a2e;border-radius:8px;margin:8px 0">';
  html += '<div style="color:#aaa;line-height:1.6">' + q.desc + '</div>';
  html += '</div>';
  if (q.objective) {
    html += '<div style="padding:8px;background:#0a1a0a;border-radius:6px;margin:4px 0">';
    html += '<div style="color:#6fa8dc;font-size:0.9em">🎯 目标</div>';
    html += '<div style="color:#ddd">' + q.objective + '</div>';
    html += '</div>';
  }
  var isAccepted = G.quests && G.quests.indexOf(qid) >= 0;
  var qp = G.questProgress ? G.questProgress[qid] : null;
  if (isAccepted && qp) {
    var cur = qp.current || 0;
    var total = q.progressCount || 1;
    var pct = Math.min(100, Math.floor(cur / total * 100));
    html += '<div style="padding:8px;background:#1a2a1a;border-radius:6px;margin:4px 0">';
    html += '<div style="color:#4a8a4a;font-size:0.9em">📊 进度</div>';
    html += '<div style="background:#333;height:8px;border-radius:4px;margin:4px 0">';
    html += '<div style="background:#4a8a4a;height:100%;width:' + pct + '%;border-radius:4px"></div>';
    html += '</div>';
    html += '<div style="color:#aaa;font-size:0.85em">' + cur + '/' + total + ' (' + pct + '%)</div>';
    html += '</div>';
  }
  html += '<div style="padding:8px;background:#2a1a0a;border-radius:6px;margin:4px 0">';
  html += '<div style="color:#d4a017;font-size:0.9em">🎁 奖励</div>';
  html += '<div style="color:#ddd">' + q.reward + '</div>';
  if (q.affectionReward) {
    html += '<div style="color:#ff69b4;font-size:0.85em">❤️ 好感度+' + q.affectionReward + '</div>';
  }
  html += '</div>';
  if (q.stageDescs && q.stageDescs.length > 0) {
    html += '<div style="padding:8px;background:#1a1a2e;border-radius:6px;margin:4px 0">';
    html += '<div style="color:#d4a017;font-size:0.9em">📋 任务阶段</div>';
    var curStage = qp ? (qp.current || 0) : 0;
    for (var si = 0; si < q.stageDescs.length; si++) {
      var done = si < curStage;
      var active = si === curStage;
      html += '<div style="padding:2px 0;color:' + (done ? '#4a8a4a' : (active ? '#d4a017' : '#666')) + '">';
      html += (done ? '✅ ' : (active ? '▶️ ' : '⬜ ')) + q.stageDescs[si] + '</div>';
    }
    html += '</div>';
  }
  html += '<div style="margin-top:12px">';
  if (!isAccepted) {
    html += '<button class="btn btn-primary" onclick="acceptQuest(\'' + qid + '\')">✅ 接取任务</button>';
  } else if (qp && qp.done) {
    html += '<button class="btn btn-primary" onclick="completeQuest(\'' + qid + '\')">🎉 交付任务</button>';
  } else {
    html += '<button class="btn" onclick="failQuest(\'' + qid + '\')">📋 放弃任务</button>';
  }
  html += '<button class="btn" onclick="sceneGuild()">↩️ 返回</button>';
  html += '</div>';
  render(html);
}

function failQuest(qid) {
  var q = _findQuestById(qid);
  if (!q) return;
  if (!confirm('确定要放弃任务「' + q.name + '」？')) return;
  var idx = G.quests.indexOf(qid);
  if (idx >= 0) G.quests.splice(idx, 1);
  G.activeQuest = null;
  var penalty = Math.floor((q.xp || 0) * 0.3);
  G.xp = Math.max(0, G.xp - penalty);
  toast('📋 任务已放弃，损失 ' + penalty + ' XP');
  updateStatus();
  if (_questReturnTo === 'renderMiniMap') renderMiniMap();
  else if (_questReturnTo === 'sceneTown') sceneTown();
  else sceneGuild();
}

function acceptQuest(qid) {
  if (G.quests.indexOf(qid) >= 0) { toast('已接取过此任务'); return; }
  // Check requires (prerequisite quest must be completed)
  var q = _findQuestById(qid);
  if (q && q.requires) {
    var reqQ = G.questProgress[q.requires];
    if (!reqQ || !reqQ.done) {
      var reqDef = _findQuestById(q.requires);
      toast('🔒 需先完成: ' + (reqDef ? reqDef.name : q.requires));
      return;
    }
  }
  var MAX_ACTIVE_QUESTS = 8;
  if (G.quests.length >= MAX_ACTIVE_QUESTS) { toast('📋 任务已满(' + MAX_ACTIVE_QUESTS + '个上限)，请先完成一些任务'); return; }
  G.quests.push(qid);
  checkStoryTriggers('accept_any_quest', null);
  checkStoryTriggers('accept_quest_id', qid);
  toast('✅ 接取任务成功!');
  sceneGuild();
}

function abandonQuest() {
  if (!G.activeQuest) return;
  G.activeQuest = null;
  toast('已放弃当前任务');
  sceneGuild();
}

function _findQuest(qid) {
  return _findQuestById(qid);
}

function checkQuestProgress() {
  if (!G.activeQuest) return;
  var aq = QUESTS.find(function(q) { return q.id === G.activeQuest; });
  if (!aq) return;

  // Auto-complete conditions
  if (aq.id === 'forest_clear' && G.forestCleared) {
    completeQuest(aq.id);
  }
}

function completeQuest(qid) {
  var q = _findQuest(qid);
  if (!q) return;

  if (q.rewardType === 'xp_gold') {
    G.xp += (q.xp || 0);
    G.gold += (q.gold || 0);
    while (G.xp >= calcNextXp(G.level)) { doLevelUp(); }
  }

  // Handle gold_item reward type (gold + random rare material)
  if (q.rewardType === 'gold_item') {
    G.gold += (q.gold || 0);
    var matKeys = Object.keys(MATERIALS || {});
    if (matKeys.length > 0) {
      var rk = matKeys[Math.floor(Math.random() * matKeys.length)];
      if (!G.materials) G.materials = {};
      G.materials[rk] = (G.materials[rk] || 0) + 1;
      toast('📦 获得材料: ' + (MATERIALS[rk] ? MATERIALS[rk].name : rk));
    }
  }

  // Handle unique_item reward type (exclusive equip from SIDE_QUESTS/CHAIN_QUESTS)
  if (q.rewardType === 'unique_item' && q.uniqueItem) {
    G.inventory.push(Object.assign({}, q.uniqueItem));
    toast('🎁 获得专属装备: ' + q.uniqueItem.name);
  }

  // Handle unlock reward type
  if (q.rewardType === 'unlock' && q.rewardTarget && LOCATIONS[q.rewardTarget]) {
    LOCATIONS[q.rewardTarget].unlocked = true;
    toast('🔓 已解锁新区域: ' + LOCATIONS[q.rewardTarget].name + '!');
  }

  // Remove from active quests
  // Affection reward (for SIDE_QUESTS and CHAIN_QUESTS)
  if (q.affectionReward && q.npc) {
    var npcKey = q.npc;
    // Try to find NPC key from NPC_DEFS (object format)
    if (NPC_DEFS && !NPC_DEFS[npcKey]) {
      for (var _nk in NPC_DEFS) {
        if (NPC_DEFS[_nk].name === q.npc) { npcKey = _nk; break; }
      }
    }
    addNpcAffection(npcKey, q.affectionReward);
    toast('❤️ 好感度+' + q.affectionReward);
  }

  var idx = G.quests.indexOf(qid);
  if (idx >= 0) G.quests.splice(idx, 1);
  G.activeQuest = null;
  // Mark quest progress as done
  if (!G.questProgress) G.questProgress = {};
  G.questProgress[qid] = { current: q.progressCount || 1, done: true };
  G._questComplete = (G._questComplete || 0) + 1;
  updateStatus();
  autoSave(); // Auto-save on quest complete

  // Check quest chain progression
  checkQuestChainCompletion(qid);

  var html = '';
  html += '<div class="scene-title">🎉 任务完成!</div>';
  html += '<div class="victory-rewards">';
  html += '<div>' + q.icon + ' ' + q.name + '</div>';
  html += '<div>奖励:' + q.reward + '</div>';
  html += '</div>';
  html += '<button class="btn btn-primary" onclick="sceneGuild()">📜 返回公会</button>';
  html += '<button class="btn" onclick="sceneTown()">🏰 返回城镇</button>';
  render(html);
}

// ═══════════════════════════════════════════════════════════
// SCENE: INVENTORY
// ═══════════════════════════════════════════════════════════

// Track where inventory was opened from, so "返回" goes back to the right place
var _inventoryReturnTo = null; // 'sceneTown' | 'renderMiniMap' | 'renderBattle' | 'sceneShop' | 'sceneBlacksmith' | null
var _questReturnTo = null;     // Tracks where quest UI was opened from, so "返回" goes back correctly
var _playerInfoReturnTo = null; // Tracks where player info was opened from

function sceneInventoryFromExplore() {
  _inventoryReturnTo = 'renderMiniMap';
  sceneInventory();
}

function sceneInventoryFromBattle() {
  _inventoryReturnTo = 'renderBattle';
  sceneInventory();
}

function sceneInventoryFromShop() {
  _inventoryReturnTo = 'sceneShop';
  sceneInventory();
}

function sceneInventoryFromBlacksmith() {
  _inventoryReturnTo = 'sceneBlacksmith';
  sceneInventory();
}

function _inventoryGoBack() {
  var target = _inventoryReturnTo || 'sceneTown';
  _inventoryReturnTo = null;
  if (target === 'renderMiniMap') { renderMiniMap(); return; }
  if (target === 'renderBattle') { if (G.inBattle) renderBattle('查看背包'); else renderMiniMap(); return; }
  // For named scene functions
  var fn = window[target];
  if (typeof fn === 'function') fn();
  else sceneTown();
}

function _goBackFromQuest() {
  var target = _questReturnTo || 'sceneTown';
  _questReturnTo = null;
  if (target === 'renderMiniMap') { renderMiniMap(); return; }
  if (target === 'renderBattle') { if (G.inBattle) renderBattle(); else renderMiniMap(); return; }
  var fn = window[target];
  if (typeof fn === 'function') fn();
  else sceneTown();
}

function _showStatusFromExplore() {
  _questReturnTo = 'renderMiniMap';
  _inventoryReturnTo = 'renderMiniMap';
  _playerInfoReturnTo = 'renderMiniMap';
  scenePlayerInfo();
}

function _showQuestsFromTown() {
  _questReturnTo = 'sceneTown';
  var html = '';
  html += '<div class="scene-title">📜 冒险日志</div>';
  
  // ========= Main Story =========
  var ch = getCurrentChapter();
  if (ch) {
    var prog = getChapterProgress();
    html += '<div style="background:#1a1a2e;padding:10px;border-radius:8px;margin:8px 0;border-left:3px solid #d4a017">';
    html += '<div style="color:#d4a017;font-weight:bold;font-size:1.05em">📖 ' + ch.chapter + ':' + ch.title + '</div>';
    html += '<div style="color:#aaa;font-size:0.85em;margin:4px 0">' + ch.entry + '</div>';
    html += '<div style="background:#333;height:6px;border-radius:3px;margin:6px 0">';
    html += '<div style="background:#4a8a4a;height:100%;width:' + Math.floor(prog.done/prog.total*100) + '%;border-radius:3px"></div>';
    html += '</div>';
    html += '<div style="color:#aaa;font-size:0.8em">' + prog.done + '/' + prog.total + ' 目标完成</div>';
    for (var oi = 0; oi < ch.objectives.length; oi++) {
      var o = ch.objectives[oi];
      var odone = G.storyProgress.completed[o.id];
      html += '<div style="padding:2px 0;color:' + (odone?'#4a4':'#666') + '">' + (odone?'✅':'⬜') + ' ' + o.desc + '</div>';
    }
    html += '</div>';
  }

  // ========= Active Quests =========
  var acceptedQuests = G.quests || [];
  if (acceptedQuests.length > 0) {
    html += '<div style="color:#4a8a4a;font-weight:bold;margin:12px 0 6px">📋 进行中的任务 (' + acceptedQuests.length + '/' + (G.MAX_ACTIVE_QUESTS||8) + ')</div>';
    for (var i = 0; i < acceptedQuests.length; i++) {
      var aq = _findQuestById(acceptedQuests[i]);
      if (aq) {
        var qp = G.questProgress[aq.id];
        var isDone = qp && qp.done;
        var pCount = aq.progressCount || aq.stages || 1;
        var cur = Math.min(qp ? (qp.current||0) : 0, pCount);
        var pct = Math.min(100, Math.floor(cur/pCount*100));
        html += '<div style="padding:8px 10px;margin:4px 0;background:' + (isDone?'#0a2a0a':'#1a1a10') + ';border-radius:6px;border-left:3px solid ' + (isDone?'#4a4':'#6fa8dc') + ';cursor:pointer" onclick="showQuestDetail(\'' + aq.id + '\')">';
        html += '<div style="font-weight:bold">' + aq.icon + ' ' + aq.name + (isDone?' <span style="color:#4a4">✅可交付</span>':'') + '</div>';
        if (aq.objective) html += '<div style="color:#aaa;font-size:0.85em">🎯 ' + aq.objective + '</div>';
        html += '<div style="background:#222;height:5px;border-radius:2px;margin:4px 0">';
        html += '<div style="background:' + (isDone?'#4a4':'#6fa8dc') + ';height:100%;width:' + pct + '%;border-radius:2px"></div>';
        html += '</div>';
        html += '<div style="color:#888;font-size:0.8em">' + cur + '/' + pCount + ' (' + pct + '%)</div>';
        html += '</div>';
      }
    }
  } else {
    html += '<div style="color:#666;margin:8px 0">暂无进行中的任务，前往📜冒险公会接取任务</div>';
  }

  // ========= Side Quest Chains =========
  if (typeof CHAIN_QUESTS !== 'undefined') {
    var chainKeys = Object.keys(CHAIN_QUESTS);
    if (chainKeys.length > 0) {
      html += '<div style="color:#d4a017;font-weight:bold;margin:12px 0 6px">⛓️ 任务链</div>';
      for (var ck = 0; ck < chainKeys.length; ck++) {
        var cq = CHAIN_QUESTS[chainKeys[ck]];
        var cqp = G.questProgress[cq.id];
        if (cqp && cqp.done) { html += '<div style="color:#4a4;font-size:0.9em">✅ ' + cq.name + ' (已完成)</div>'; }
        else if (cqp) { html += '<div style="color:#d4a017;font-size:0.9em">▶️ ' + cq.name + ' (进行中)</div>'; }
      }
    }
  }

  html += '<div style="margin-top:12px">';
  html += '<button class="btn btn-primary" onclick="sceneGuild()">📜 冒险公会</button>';
  html += '<button class="btn" onclick="sceneTown()">↩️ 返回城镇</button>';
  html += '</div>';
  render(html);
}

function _showQuestsFromExplore() {
  _questReturnTo = 'renderMiniMap';
  var html = '';
  html += '<div class="scene-title">📜 任务</div>';
  // Active quests (includes QUESTS + GUILD + SIDE)
  var acceptedQuests = G.quests || [];
  if (acceptedQuests.length > 0) {
    html += '<div style="color:#4a4;font-weight:bold;margin-bottom:6px">进行中的任务</div>';
    for (var i = 0; i < acceptedQuests.length; i++) {
      var aq = _findQuestById(acceptedQuests[i]);
      if (aq) {
        var qp = G.questProgress[aq.id];
        var isDone = qp && qp.done;
        var pCount = aq.progressCount || 1;
        var cur = Math.min(qp ? (qp.current || 0) : 0, pCount);
        html += '<div style="padding:6px 8px;margin:4px 0;background:#1a1a10;border-radius:6px;border-left:3px solid ' + (isDone ? '#4a4' : '#6fa8dc') + '">';
        html += '<div>' + aq.icon + ' ' + aq.name + (isDone ? ' <span style="color:#4a4">✅</span>' : '') + '</div>';
        if (aq.objective) html += '<div style="color:#aaa;font-size:0.85em">🎯 ' + aq.objective + '</div>';
        html += '<div style="color:' + (isDone ? '#4a4' : '#6fa8dc') + ';font-size:0.85em">进度:' + cur + '/' + pCount + '</div>';
        html += '<div style="color:#d4a017;font-size:0.85em">奖励:' + aq.reward + '</div>';
        html += '</div>';
      }
    }
  } else {
    html += '<div style="color:#666">暂无进行中的任务</div>';
  }
  // Main story
  var ch = getCurrentChapter();
  if (ch) {
    var prog = getChapterProgress();
    html += '<div style="color:#d4a017;font-weight:bold;margin:12px 0 6px">📖 主线 - ' + ch.chapter + ':' + ch.title + '</div>';
    html += '<div style="color:#aaa;font-size:0.9em">' + ch.entry + '</div>';
    for (var j = 0; j < ch.objectives.length; j++) {
      var obj = ch.objectives[j];
      var done = G.storyProgress.completed[obj.id];
      html += '<div style="padding:2px 0">' + (done ? '✅' : '⬜') + ' ' + obj.desc + '</div>';
    }
    html += '<div style="color:#888;font-size:0.85em;margin-top:4px">进度:' + prog.done + '/' + prog.total + '</div>';
  }
  html += '<button class="btn" onclick="renderMiniMap()">返回探索</button>';
  render(html);
}

// ═══════════════════════════════════════════════════════════
// SCENE: EQUIPMENT (standalone character sheet)
// ═══════════════════════════════════════════════════════════

var _equipmentReturnTo = null;

function sceneEquipmentFromTown() { _equipmentReturnTo = 'sceneTown'; sceneEquipment(); }
function sceneEquipmentFromExplore() { _equipmentReturnTo = 'renderMiniMap'; sceneEquipment(); }
function sceneEquipmentFromBattle() { _equipmentReturnTo = 'renderBattle'; sceneEquipment(); }

function sceneEquipment() {
  G._currentScene = 'sceneEquipment';
  var baseStr = G.str || 0, baseAgi = G.agi || 0, baseInt = G.int || 0;
  var baseCha = G.cha || 0, baseLuk = G.luk || 0;
  var effStr = getEffStat('str'), effAgi = getEffStat('agi'), effInt = getEffStat('int');
  var effCha = getEffStat('cha'), effLuk = getEffStat('luk');
  var eqStr = effStr - baseStr, eqAgi = effAgi - baseAgi, eqInt = effInt - baseInt;
  var eqCha = effCha - baseCha, eqLuk = effLuk - baseLuk;

  var maxHp = calcMaxHp(), maxMp = calcMaxMp(), atk = calcAtk(), def = calcDef();
  var matk = calcMagicAtk(), crit = calcCrit(), dodge = calcDodge(), critDmg = calcCritDmg();

  var r = '#d4c8a8', rg = '#888', gol = '#d4a017', gre = '#7ec8a4', blu = '#7ec8e3', yel = '#f0d060';
  var _eq = function(v) { return v > 0 ? '<span style="color:' + gre + '">(+' + v + ')</span>' : ''; };
  var _val = function(v, unit) { return v + (unit || ''); };

  var html = '';
  html += '<div class="scene-title">⚔️ 装备</div>';

  // ── Character stats panel ──
  html += '<div class="equip-stats-panel" style="background:#1c1c12;border:2px solid #3a3a20;border-radius:10px;padding:10px;margin-bottom:10px">';
  html += '<div style="color:' + gol + ';font-weight:bold;margin-bottom:6px;text-align:center">📊 角色属性</div>';

  // Combat stats grid
  var stats = [
    ['❤️ HP', G.maxHp, maxHp, '', '#e74c3c'],
    ['💧 MP', G.maxMp, maxMp, '', '#3498db'],
    ['🗡️ 攻击', G.atk || 0, atk, '', '#f39c12'],
    ['🔰 防御', G.def || 0, def, '', '#95a5a6'],
    ['🔮 魔攻', G.matk || 0, matk, '', '#9b59b6'],
    ['🎯 暴击', calcCrit().toFixed(1) + '%', crit.toFixed(1) + '%', '', '#e67e22'],
    ['🌀 闪避', calcDodge().toFixed(1) + '%', dodge.toFixed(1) + '%', '', '#1abc9c'],
    ['💀 暴伤', (calcCritDmg()*100).toFixed(0) + '%', (critDmg*100).toFixed(0) + '%', '', '#e74c3c'],
  ];
  html += '<div style="display:grid;grid-template-columns:1fr 1fr 1fr 1fr;gap:4px;margin-bottom:8px">';
  for (var si = 0; si < stats.length; si++) {
    var s = stats[si];
    html += '<div style="background:#252515;padding:5px 4px;border-radius:6px;text-align:center">';
    html += '<div style="color:' + s[4] + ';font-size:0.75em">' + s[0] + '</div>';
    html += '<div style="color:' + gol + ';font-weight:bold;font-size:0.95em">' + s[2] + '</div>';
    html += '</div>';
  }
  html += '</div>';

  // Five attributes breakdown
  html += '<div style="text-align:center;color:' + gol + ';margin-bottom:4px">📈 五维属性</div>';
  var attrs = [
    ['体魄', baseStr, eqStr, '#e74c3c'],
    ['敏捷', baseAgi, eqAgi, '#2ecc71'],
    ['智力', baseInt, eqInt, '#3498db'],
    ['魅力', baseCha, eqCha, '#9b59b6'],
    ['幸运', baseLuk, eqLuk, '#f39c12']
  ];
  html += '<div style="display:flex;gap:6px;justify-content:center">';
  for (var ai = 0; ai < attrs.length; ai++) {
    var a = attrs[ai];
    html += '<div style="flex:1;background:#252515;padding:5px;border-radius:6px;text-align:center">';
    html += '<div style="color:' + a[3] + ';font-size:0.7em">' + a[0] + '</div>';
    html += '<div style="color:' + yel + ';font-weight:bold">' + a[1] + _eq(a[2]) + '</div>';
    html += '</div>';
  }
  html += '</div>';
  html += '<div style="text-align:center;margin-top:4px;font-size:0.7em;color:' + rg + '">括号内为装备加成</div>';
  html += '</div>';

  // ── Equipped items ──
  html += '<div style="color:' + gol + ';font-weight:bold;margin:6px 0 4px">🛡️ 已装备</div>';
  html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:6px">';
  var eqSlots = [
    { key:'weapon', name:'🗡️ 武器', emoji:'🗡️' },
    { key:'helmet', name:'🪖 头盔', emoji:'🪖' },
    { key:'armor', name:'🛡️ 铠甲', emoji:'🛡️' },
    { key:'gloves', name:'🧤 手套', emoji:'🧤' },
    { key:'boots', name:'👢 靴子', emoji:'👢' },
    { key:'belt', name:'🔗 腰带', emoji:'🔗' },
    { key:'necklace', name:'📿 项链', emoji:'📿' },
    { key:'ring', name:'💍 戒指', emoji:'💍' }
  ];
  for (var ei = 0; ei < eqSlots.length; ei++) {
    var es = eqSlots[ei];
    var eitem = G.equipment[es.key];
    html += '<div style="background:#1e1e10;border:1px solid #333;border-radius:8px;padding:7px">';
    html += '<div style="font-size:0.75em;color:' + rg + '">' + es.name + '</div>';
    if (eitem) {
      html += '<div style="color:' + (eitem.rarityColor||r) + ';font-weight:bold;font-size:0.9em">' + eitem.name + '</div>';
      html += '<div style="font-size:0.78em;color:#aaa;margin:2px 0">' + getItemStatString(eitem) + '</div>';
      html += '<button class="btn-small" style="margin-top:3px" onclick="unequipFromEquipment(\'' + es.key + '\')">卸下</button>';
    } else {
      html += '<div style="color:' + rg + ';font-size:0.85em">空</div>';
    }
    html += '</div>';
  }
  html += '</div>';

  // Set bonuses
  var setInfo = getSetInfo();
  if (setInfo.length > 0) {
    html += '<div style="color:' + gol + ';font-weight:bold;margin:8px 0 4px">✨ 套装效果</div>';
    html += '<div style="display:grid;gap:6px">';
    for (var ssi = 0; ssi < setInfo.length; ssi++) {
      var sset = setInfo[ssi];
      html += '<div style="background:#1e1e10;border:1px solid #333;border-radius:8px;padding:8px">';
      html += '<div style="color:' + (sset.active2 ? gre : rg) + '">🟢 ' + sset.name + ' (' + sset.count + '/' + sset.max + ')</div>';
      html += '<div style="font-size:0.8em;margin-top:2px;color:' + (sset.active2 ? gol : '#555') + '">' + sset.b2.desc + '</div>';
      html += '<div style="font-size:0.8em;color:' + (sset.active4 ? gre : '#555') + '">' + (sset.active4 ? '🟢 ' : '⚪ ') + sset.b4.desc + '</div>';
      if (sset.b6) html += '<div style="font-size:0.8em;color:' + (sset.active6 ? gre : '#555') + '">' + (sset.active6 ? '🟢 ' : '⚪ ') + sset.b6.desc + '</div>';
      html += '</div>';
    }
    html += '</div>';
  }

  // ── Set Collection Overview (all sets) ──
  html += '<div style="color:' + gol + ';font-weight:bold;margin:12px 0 6px">📋 套装图鉴</div>';
  html += '<div style="display:grid;gap:8px">';
  var setKeys = Object.keys(EQUIP_SETS);
  var eqKeysAll = ['weapon','helmet','armor','gloves','boots','belt','necklace','ring'];
  // Count owned pieces per set (from equipment + inventory)
  var ownedPieces = {};
  for (var oi = 0; oi < setKeys.length; oi++) {
    var osid = setKeys[oi];
    ownedPieces[osid] = { equipped: 0, inBag: 0, slots: {} };
  }
  // Check equipped
  for (var eqi = 0; eqi < eqKeysAll.length; eqi++) {
    var eqIt = G.equipment[eqKeysAll[eqi]];
    if (eqIt && eqIt.setId && ownedPieces[eqIt.setId]) {
      ownedPieces[eqIt.setId].equipped++;
      ownedPieces[eqIt.setId].slots[eqKeysAll[eqi]] = eqIt.name;
    }
  }
  // Check inventory
  if (G.inventory) {
    for (var ii = 0; ii < G.inventory.length; ii++) {
      var invIt = G.inventory[ii];
      if (invIt && invIt.setId && ownedPieces[invIt.setId]) {
        ownedPieces[invIt.setId].inBag++;
      }
    }
  }
  for (var si = 0; si < setKeys.length; si++) {
    var ssid = setKeys[si];
    var ssetData = EQUIP_SETS[ssid];
    var owned = ownedPieces[ssid];
    var total = owned.equipped + owned.inBag;
    var isActive = setInfo.some(function(x){ return x.id === ssid; });
    html += '<div style="background:#1a1a0f;border:1px solid ' + (isActive ? '#d4a017' : '#2a2a2a') + ';border-radius:8px;padding:10px">';
    html += '<div style="display:flex;justify-content:space-between;align-items:center">';
    html += '<span style="color:' + gol + ';font-weight:bold">' + ssetData.name + '</span>';
    html += '<span style="color:' + (total >= 6 ? gre : total >= 4 ? '#3b82f6' : total >= 2 ? '#d4a017' : '#555') + ';font-size:0.85em">' + total + '/8 件' + (owned.equipped > 0 ? ' (已装' + owned.equipped + ')' : '') + '</span>';
    html += '</div>';
    // Bonus lines
    var bonusLines = [
      { n: 2, b: ssetData.bonus2 },
      { n: 4, b: ssetData.bonus4 },
      { n: 6, b: ssetData.bonus6 }
    ];
    for (var bli = 0; bli < bonusLines.length; bli++) {
      var bl = bonusLines[bli];
      if (!bl.b) continue;
      var active = owned.equipped >= bl.n;
      html += '<div style="font-size:0.8em;margin-top:2px;padding-left:8px;color:' + (active ? gre : '#555') + '">' + (active ? '🟢 ' : '⚪ ') + bl.n + '件: ' + bl.b.desc + '</div>';
    }
    // Show equipped slot names
    if (owned.equipped > 0) {
      var slotNames = [];
      for (var sn in owned.slots) { slotNames.push(owned.slots[sn]); }
      html += '<div style="font-size:0.75em;margin-top:4px;color:#888;padding-left:8px">已装: ' + slotNames.join(', ') + '</div>';
    }
    html += '</div>';
  }
  html += '</div>';
  var bagEq = (G.inventory || []).filter(function(it) { return it.type === 'equipment' || it.slot || ['weapon','helmet','armor','gloves','boots','belt','necklace','ring'].indexOf(it.type) >= 0; });
  if (bagEq.length > 0) {
    // Q25: Add slot filter tabs
    if (!G._eqBagFilter) G._eqBagFilter = 'all';
    html += '<div style="color:' + gol + ';font-weight:bold;margin:8px 0 4px">🎒 背包装备 (' + bagEq.length + '件)</div>';
    html += '<div class="btns" style="margin-bottom:6px">';
    html += '<button class="btn' + (G._eqBagFilter==='all'?' btn-primary':'') + '" style="font-size:0.8em" onclick="G._eqBagFilter=\'all\';sceneEquipment()">全部</button>';
    var filterSlots = [{k:'weapon',n:'🗡️武器'},{k:'helmet',n:'🪖头盔'},{k:'armor',n:'🛡️铠甲'},{k:'gloves',n:'🧤手套'},{k:'boots',n:'👢靴子'},{k:'belt',n:'🔗腰带'},{k:'necklace',n:'📿项链'},{k:'ring',n:'💍戒指'}];
    for (var fi = 0; fi < filterSlots.length; fi++) {
      var hasType = bagEq.some(function(it){ return (it.slot||it.type)===filterSlots[fi].k; });
      if (hasType) {
        html += '<button class="btn' + (G._eqBagFilter===filterSlots[fi].k?' btn-primary':'') + '" style="font-size:0.8em" onclick="G._eqBagFilter=\'' + filterSlots[fi].k + '\';sceneEquipment()">' + filterSlots[fi].n + '</button>';
      }
    }
    html += '</div>';
    var filteredBag = G._eqBagFilter === 'all' ? bagEq : bagEq.filter(function(it){ return (it.slot||it.type)===G._eqBagFilter; });
    html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:6px">';
    for (var bi = 0; bi < filteredBag.length; bi++) {
      var be = filteredBag[bi];
      var bagIdx = G.inventory.indexOf(be);
      var slotKey = be.slot || be.type;
      var curItem = G.equipment[slotKey];
      var diffHtml = '';
      if (curItem) diffHtml = '<span style="color:#888;font-size:0.75em"> vs ' + curItem.name + '</span>';
      html += '<div style="background:#1e1e10;border:1px solid #333;border-radius:8px;padding:7px">';
      html += '<div style="color:' + (be.rarityColor||r) + ';font-size:0.88em;font-weight:bold">' + be.name + diffHtml + '</div>';
      html += '<div style="font-size:0.78em;color:#aaa;margin:2px 0">' + getItemStatString(be) + '</div>';
      html += '<button class="btn-small" style="margin-top:3px" onclick="previewEquip(' + bagIdx + ')">穿戴</button>';
      html += '</div>';
    }
    html += '</div>';
  }

  html += '<button class="btn" style="margin-top:12px" onclick="_equipmentGoBack()">↩️ 返回</button>';
  render(html);
}

function unequipFromEquipment(slot) {
  var item = G.equipment[slot];
  if (!item) return;
  G.equipment[slot] = null;
  G.inventory.push(item);
  G.maxHp = calcMaxHp();
  G.maxMp = calcMaxMp();
  G.hp = Math.min(G.hp, G.maxHp);
  G.mp = Math.min(G.mp, G.maxMp);
  updateStatus();
  toast('卸下 ' + item.name);
  sceneEquipment();
}

function _equipmentGoBack() {
  var target = _equipmentReturnTo || 'sceneTown';
  _equipmentReturnTo = null;
  var fn = window[target];
  if (typeof fn === 'function') fn();
  else sceneTown();
}

function sceneInventory() {
  var html = '';
  html += '<div class="scene-title">🎒 背包</div>';
  html += '<div class="money-display">💰 ' + G.gold + ' 金币</div>';

  // Equipped items (always show at top)
  html += '<div class="equip-section">';
  html += '<div class="equip-title">已穿戴</div>';
  html += '<div class="equip-grid">';

  var eqSlots = [
    { key:'weapon', name:'⚔️ 武器' },
    { key:'helmet', name:'🪖 头盔' },
    { key:'armor', name:'🛡️ 铠甲' },
    { key:'gloves', name:'🧤 手套' },
    { key:'boots', name:'👢 靴子' },
    { key:'belt', name:'🔗 腰带' },
    { key:'necklace', name:'📿 项链' }, { key:'ring', name:'💍 戒指' }
  ];

  for (var i = 0; i < eqSlots.length; i++) {
    var slot = eqSlots[i];
    var item = G.equipment[slot.key];
    html += '<div class="equip-slot">';
    html += '<div class="slot-name">' + slot.name + '</div>';
    if (item) {
      html += '<div class="equipped-item" style="color:' + (item.rarityColor || '#d4c8a8') + ';cursor:pointer" onclick="showEquippedDetail(\'' + slot.key + '\')">' + item.name + ' 📋</div>';
      html += '<div class="equipped-stats">' + getItemStatString(item) + '</div>';
      html += '<button class="btn-small" onclick="unequip(\'' + slot.key + '\')">卸下</button>';
    } else {
      html += '<div class="empty-slot">空</div>';
    }
    html += '</div>';
  }
  html += '</div>';
  html += '</div>';

  // Set bonuses
  var setInfo = getSetInfo();
  if (setInfo.length > 0) {
    html += '<div class="set-section">';
    html += '<div class="equip-title">套装效果</div>';
    for (var si = 0; si < setInfo.length; si++) {
      var s = setInfo[si];
      html += '<div class="set-item">';
      html += '<div class="set-name">' + s.name + ' (' + s.count + '/' + s.max + ')</div>';
      html += '<div class="set-bonus' + (s.active2 ? ' active' : '') + '">2件: ' + s.b2.desc + '</div>';
      html += '<div class="set-bonus' + (s.active4 ? ' active' : '') + '">4件: ' + s.b4.desc + '</div>';
      html += '<div class="set-bonus' + (s.active6 ? ' active' : '') + '">6件: ' + s.b6.desc + '</div>';
      html += '</div>';
    }
    html += '</div>';
  }

  // Category tabs - placed BETWEEN equipped section and item list
  var tab = G._invTab || 'equipment'; // Default to equipment tab
  var _tabStyle = 'flex:1;min-width:56px;padding:8px 4px;border-radius:8px;font-size:0.85em;text-align:center;cursor:pointer;border:2px solid #333;';
  var _tabOn = 'background:linear-gradient(135deg,#2a2a18,#3a3a28);border-color:#d4a017;color:#d4a017;font-weight:bold;box-shadow:0 0 8px rgba(212,160,23,0.3);';
  var _tabOff = 'background:#1a1a10;color:#888;';
  html += '<div class="inv-tabs" style="margin-top:10px">';
  html += '<button style="' + _tabStyle + (tab==='all'?_tabOn:_tabOff) + '" onclick="G._invTab=\'all\';sceneInventory()">全部</button>';
  html += '<button style="' + _tabStyle + (tab==='equipment'?_tabOn:_tabOff) + '" onclick="G._invTab=\'equipment\';sceneInventory()">⚔️装备</button>';
  html += '<button style="' + _tabStyle + (tab==='consumable'?_tabOn:_tabOff) + '" onclick="G._invTab=\'consumable\';sceneInventory()">🧪消耗</button>';
  html += '<button style="' + _tabStyle + (tab==='material'?_tabOn:_tabOff) + '" onclick="G._invTab=\'material\';sceneInventory()">🔧材料</button>';
  html += '<button style="' + _tabStyle + (tab==='trade'?_tabOn:_tabOff) + '" onclick="G._invTab=\'trade\';sceneInventory()">💰货物</button>';
  html += '</div>';

  // Stack & filter inventory
  var invItems = G.inventory || [];
  // Build stacked map: key = name+rarity, value = {item, count, indices}
  var stacked = [];
  var stackMap = {};
  for (var si2 = 0; si2 < invItems.length; si2++) {
    var inv = invItems[si2];
    var skey = inv.name + '|' + (inv.rarity || '') + '|' + (inv.type || '');
    // For equipment, don't stack (each is unique due to affixes)
    if (inv.type === 'equipment' || inv.slot || ['weapon','helmet','armor','gloves','boots','belt','necklace','ring'].indexOf(inv.type) >= 0) {
      stacked.push({ item: inv, count: 1, indices: [si2] });
    } else if (stackMap[skey]) {
      stackMap[skey].count++;
      stackMap[skey].indices.push(si2);
    } else {
      var entry = { item: inv, count: 1, indices: [si2] };
      stackMap[skey] = entry;
      stacked.push(entry);
    }
  }

  // Filter by tab
  var filtered = stacked;
  if (tab === 'equipment') filtered = stacked.filter(function(s) { return s.item.type === 'equipment' || s.item.slot || ['weapon','helmet','armor','gloves','boots','belt','necklace','ring'].indexOf(s.item.type) >= 0; });
  else if (tab === 'consumable') filtered = stacked.filter(function(s) { return s.item.type === 'consumable' || s.item.type === 'potion'; });
  else if (tab === 'material') filtered = stacked.filter(function(s) { return s.item.type === 'material'; });
  else if (tab === 'trade') filtered = stacked.filter(function(s) { return s.item.type === 'trade_good'; });

  // Inventory items
  html += '<div class="inv-section">';
  html += '<div class="inv-title">背包物品 (' + invItems.length + '件)</div>';
  if (filtered.length > 0) {
    html += '<div class="inv-list">';
    for (var fi = 0; fi < filtered.length; fi++) {
      var se = filtered[fi];
      var inv2 = se.item;
      var qtyLabel = se.count > 1 ? ' <span style="color:#7ec8e3;font-weight:normal">x' + se.count + '</span>' : '';
      var firstIdx = se.indices[0];
      html += '<div class="inv-item">';
      html += '<div class="inv-item-info">';
      html += '<span class="inv-item-name" style="color:' + (inv2.rarityColor || '#d4c8a8') + '">' + (inv2.icon ? inv2.icon + ' ' : '') + inv2.name + qtyLabel + '</span>';
      html += '<span class="inv-item-stats">' + getItemStatString(inv2) + '</span>';
      html += '</div>';
      if (inv2.type === 'consumable' || inv2.type === 'potion') {
        html += '<button class="btn-small" onclick="useItem(' + firstIdx + ')">使用</button>';
      }
      if (inv2.type !== 'material' && inv2.type !== 'trade_good' && inv2.type !== 'consumable' && inv2.type !== 'potion') {
        html += '<button class="btn-small" onclick="equipItem(' + firstIdx + ')">装备</button>';
      }
      html += '<button class="btn-small" onclick="showItemDetail(' + firstIdx + ')">详情</button>';
      var sellPrice = calcSellPrice(inv2);
      // Show sell value as text (not clickable) only in shop/blacksmith scenes
      var canSell = (_inventoryReturnTo === 'sceneShop' || _inventoryReturnTo === 'sceneBlacksmith');
      if (canSell) {
        html += '<button class="btn-small" style="color:' + (inv2.rarityColor || '#aaa') + '" onclick="sellItem(' + firstIdx + ')">出售 ' + sellPrice + '💰</button>';
      } else {
        html += '<span style="color:#888;font-size:0.8em">值' + sellPrice + '💰</span>';
      }
      html += '</div>';
    }
    html += '</div>';
  } else {
    html += '<div class="inv-empty">无物品</div>';
  }
  html += '</div>';

  // Keys
  html += '<div class="keys-display">🔑 宝箱钥匙:' + (G.keys || 0) + ' 把</div>';

  html += '<button class="btn" onclick="_inventoryGoBack()">返回</button>';
  render(html);
}

function getItemStatString(item) {
  var parts = [];
  if (item.type === 'consumable' || item.type === 'potion') {
    // Show consumable stats directly in list
    if (item.heal) parts.push('❤️+' + item.heal);
    if (item.restore) parts.push('💧+' + item.restore);
    if (item.cure) parts.push('🌿解毒');
    if (item.light) parts.push('🔥照亮暗区');
    if (item.tool) parts.push('🧗探索地形');
    return parts.join(' ');
  }
  if (item.type === 'material') {
    return '🔧 材料';
  }
  if (item.type === 'trade_good') {
    return '💰 货物';
  }
  if (item.atk) parts.push('⚔️' + item.atk);
  if (item.def) parts.push('🛡️' + item.def);
  if (item.hp) parts.push('❤️+' + item.hp);
  if (item.mp) parts.push('💧+' + item.mp);
  if (item.matk) parts.push('🧙+' + item.matk);
  if (item.luk) parts.push('🎲+' + item.luk);
  if (item.str) parts.push('💪+' + item.str);
  if (item.agi) parts.push('🏃+' + item.agi);
  if (item.int) parts.push('📖+' + item.int);
  if (item.critRate) parts.push('💥' + Math.round(item.critRate*100) + '%');
  if (item.dodge) parts.push('💨' + Math.round(item.dodge*100) + '%');
  if (item.fireDmg) parts.push('🔥+' + item.fireDmg);
  if (item.poisonDmg) parts.push('🧪+' + item.poisonDmg);
  if (item.holyDmg) parts.push('✨+' + item.holyDmg);
  if (item.shadowDmg) parts.push('👤+' + item.shadowDmg);
  if (item.stormDmg) parts.push('⚡+' + item.stormDmg);
  if (item.stunChance) parts.push('💫' + Math.round(item.stunChance*100) + '%');
  if (item.frostSlow) parts.push('❄️' + item.frostSlow + '%');
  if (item.deathSave) parts.push('🛡️免死');
  if (item.lifesteal) parts.push('🩸' + Math.round(item.lifesteal*100) + '%');
  if (item.deadlyRate) parts.push('⚡' + Math.round(item.deadlyRate*100) + '%');
  if (item.counterRate) parts.push('↩️' + Math.round(item.counterRate*100) + '%');
  if (item.doubleAtkRate) parts.push('⚔️⚔️' + Math.round(item.doubleAtkRate*100) + '%');
  if (item.setId) parts.push('📋' + EQUIP_SETS[item.setId].name);
  return parts.join(' ');
}

var _pendingEquipIdx = null;

function previewEquip(idx) {
  var item = G.inventory[idx];
  if (!item) return;
  if (item.type === 'material') { toast('⚠️ 材料无法装备,可在铁匠铺用于打造'); return; }
  if (item.type === 'trade_good') { toast('⚠️ 商贸货物无法装备'); return; }

  var slotKey = item.slot || (item.type === 'weapon' ? 'weapon' : item.type === 'helmet' ? 'helmet' : item.type === 'armor' ? 'armor' : item.type === 'gloves' ? 'gloves' : item.type === 'boots' ? 'boots' : item.type === 'belt' ? 'belt' : item.type === 'ring' ? 'ring' : item.type === 'necklace' ? 'necklace' : null);
  if (!slotKey) { toast('⚠️ 无法确定装备槽位'); return; }
  var oldItem = G.equipment[slotKey];

  // Snapshot current stats
  var before = { atk: calcAtk(), def: calcDef(), matk: calcMagicAtk(), maxHp: calcMaxHp(), maxMp: calcMaxMp(), crit: calcCrit(), dodge: calcDodge() };
  for (var sk in before) { if (isNaN(before[sk])) before[sk] = 0; }

  // Simulate equip: temporarily swap
  var simOld = G.equipment[slotKey];
  G.equipment[slotKey] = item;
  var after = { atk: calcAtk(), def: calcDef(), matk: calcMagicAtk(), maxHp: calcMaxHp(), maxMp: calcMaxMp(), crit: calcCrit(), dodge: calcDodge() };
  for (var sk2 in after) { if (isNaN(after[sk2])) after[sk2] = 0; }
  G.equipment[slotKey] = simOld; // restore

  var deltaLines = [];
  var statNames = [
    ['atk', '⚔️ 攻击'], ['def', '🛡️ 防御'], ['matk', '✨ 魔攻'],
    ['maxHp', '❤️ 生命'], ['maxMp', '💎 魔力'],
    ['crit', '💫 暴击'], ['dodge', '💨 闪避']
  ];
  for (var si = 0; si < statNames.length; si++) {
    var key = statNames[si][0], label = statNames[si][1];
    var bVal = before[key] || 0;
    var aVal = after[key] || 0;
    if (isNaN(bVal)) bVal = 0;
    if (isNaN(aVal)) aVal = 0;
    var diff = aVal - bVal;
    if (diff !== 0) {
      var sign = diff > 0 ? '▲' : '▼';
      var color = diff > 0 ? '#c44' : '#4a4';
      var val = key === 'crit' || key === 'dodge' ? diff.toFixed(1) + '%' : diff;
      var bDisp = key === 'crit' || key === 'dodge' ? bVal.toFixed(1) + '%' : bVal;
      var aDisp = key === 'crit' || key === 'dodge' ? aVal.toFixed(1) + '%' : aVal;
      deltaLines.push('<span style="color:' + color + '">' + label + ' ' + bDisp + ' → ' + aDisp + ' ' + sign + Math.abs(val) + '</span>');
    }
  }

  _pendingEquipIdx = idx;
  var html = '';
  html += '<div class="scene-title">⚔️ 装备预览</div>';
  html += '<div style="padding:12px;background:#1a1a10;border-radius:8px;margin:8px 0">';
  html += '<div style="color:' + (item.rarityColor || '#d4c8a8') + ';font-size:1.1em;font-weight:bold">' + (item.icon||'') + ' ' + item.name + '</div>';
  html += '<div style="color:#aaa;font-size:0.85em">装备至: ' + (SLOT_DEFS[slotKey] ? SLOT_DEFS[slotKey].name : slotKey) + '</div>';
  if (oldItem) {
    html += '<div style="color:#a44;font-size:0.9em;margin-top:6px">替换: ' + oldItem.name + '</div>';
  }
  if (deltaLines.length > 0) {
    html += '<div style="margin-top:8px;padding-top:8px;border-top:1px solid #333">';
    for (var di = 0; di < deltaLines.length; di++) {
      html += '<div style="font-size:0.9em">' + deltaLines[di] + '</div>';
    }
    html += '</div>';
  } else {
    html += '<div style="color:#888;margin-top:8px">无属性变化</div>';
  }
  html += '</div>';
  html += '<div style="display:flex;gap:8px">';
  html += '<button class="btn btn-primary" style="flex:1" onclick="confirmEquip()">✅ 确认装备</button>';
  html += '<button class="btn" style="flex:1" onclick="_cancelEquip()">❌ 取消</button>';
  html += '</div>';
  render(html);
}

function confirmEquip() {
  var idx = _pendingEquipIdx;
  _pendingEquipIdx = null;
  if (idx === null || idx === undefined) { sceneInventory(); return; }
  var item = G.inventory[idx];
  if (!item) { sceneInventory(); return; }

  var slotKey = item.slot || (item.type === 'weapon' ? 'weapon' : item.type === 'helmet' ? 'helmet' : item.type === 'armor' ? 'armor' : item.type === 'gloves' ? 'gloves' : item.type === 'boots' ? 'boots' : item.type === 'belt' ? 'belt' : item.type === 'ring' ? 'ring' : item.type === 'necklace' ? 'necklace' : null);
  if (!slotKey) { toast('⚠️ 无法确定装备槽位'); sceneInventory(); return; }
  var oldItem = G.equipment[slotKey];

  G.inventory.splice(idx, 1);
  if (oldItem) G.inventory.push(oldItem);
  G.equipment[slotKey] = item;

  G.maxHp = calcMaxHp();
  G.maxMp = calcMaxMp();
  G.hp = Math.min(G.hp, G.maxHp);
  G.mp = Math.min(G.mp, G.maxMp);
  updateStatus();
  toast('✅ 装备了 ' + item.name);
  if (G._currentScene === 'sceneEquipment') sceneEquipment();
  else sceneInventory();
}

function _cancelEquip() {
  if (G._currentScene === 'sceneEquipment') sceneEquipment();
  else sceneInventory();
}

function equipItem(idx) {
  // Redirect to preview flow
  previewEquip(idx);
}

function unequip(slot) {
  var item = G.equipment[slot];
  if (!item) return;
  G.equipment[slot] = null;
  G.inventory.push(item);
  G.maxHp = calcMaxHp();
  G.maxMp = calcMaxMp();
  G.hp = Math.min(G.hp, G.maxHp);
  G.mp = Math.min(G.mp, G.maxMp);
  updateStatus();
  toast('卸下 ' + item.name);
  if (G._currentScene === 'sceneEquipment') sceneEquipment();
  else sceneInventory();
}

// Use a consumable/potion from inventory
function useItem(idx) {
  var item = G.inventory[idx];
  if (!item) return;

  // Teleport scroll
  if (item.type === 'consumable' && item.useType === 'teleport') {
    showTeleportTarget(idx);
    return;
  }

  // Damage scroll - can only use in battle
  if (item.type === 'consumable' && item.dmgType) {
    if (!G.battle || !G.battle.active) { toast('⚔️ 攻击卷轴只能在战斗中使用'); return; }
    var dmgAmt = item.dmg || 30;
    var elementalMult = 1;
    // Check enemy weakness (future: element system)
    var enemy = G.battle.enemies[G.battle.currentEnemyIdx || 0];
    if (enemy) {
      enemy.hp -= dmgAmt;
      toast('🔥 ' + item.name + '! 造成' + dmgAmt + '点伤害!');
      showDamagePopup('enemy-dmg', dmgAmt, false);
      if (enemy.hp <= 0) { enemy.hp = 0; endBattle(); }
    }
    G.inventory.splice(idx, 1);
    updateStatus();
    return;
  }

  if (item.type !== 'consumable' && item.type !== 'potion') { toast('该物品无法使用'); return; }

  var used = false;
  if (item.heal && G.hp < G.maxHp) { G.hp = Math.min(G.maxHp, G.hp + item.heal); used = true; }
  if (item.restore && G.mp < G.maxMp) { G.mp = Math.min(G.maxMp, G.mp + item.restore); used = true; }
  if (item.cure) { used = true; } // antidote - future poison support
  // Buff items (whetstone etc)
  if (item.useType === 'buff_atk') { G._tempAtkBuff = 1.15; G._tempAtkBuffTurns = 3; used = true; }
  if (item.useType === 'buff_def') { G._tempDefBuff = 1.15; G._tempDefBuffTurns = 3; used = true; }
  if (item.useType === 'buff_crit') { G._tempCritBuff = 0.15; G._tempCritBuffTurns = 3; used = true; }

  if (used) {
    G.inventory.splice(idx, 1);
    updateStatus();
    var msg = '使用 ' + item.name;
    if (item.heal) msg += ' ❤️+' + item.heal;
    if (item.restore) msg += ' 💧+' + item.restore;
    toast(msg);
  } else {
    toast('现在不需要使用此物品');
  }
  sceneInventory();
}

function showTeleportTarget(idx) {
  var html = '';
  html += '<div class="scene-title">🌀 传送卷轴</div>';
  html += '<div style="color:#aaa;font-size:0.85em;margin-bottom:8px">选择目的地</div>';

  var townIds = Object.keys(LOCATIONS).filter(function(k) { return LOCATIONS[k].type === 'town' && LOCATIONS[k].unlocked && k !== G.location; });
  for (var i = 0; i < townIds.length; i++) {
    var t = townIds[i];
    html += '<button class="btn" style="margin:4px;display:block;width:100%" onclick="useTeleportScroll(' + idx + ',\'' + t + '\')">🏙️ → ' + LOCATIONS[t].name + '</button>';
  }
  html += '<button class="btn" onclick="sceneInventory()">↩️ 取消</button>';
  render(html);
}

function useTeleportScroll(idx, targetTown) {
  G.inventory.splice(idx, 1);
  G.location = targetTown;
  updateStatus();
  toast('🌀 传送至 ' + LOCATIONS[targetTown].name + '!');
  sceneTown();
}
function showItemDetail(idx) {
  var item = G.inventory[idx];
  if (!item) return;
  _showItemDetailPanel(item);
}

function showEquippedDetail(slot) {
  var item = G.equipment[slot];
  if (!item) return;
  _showItemDetailPanel(item);
}

function _showItemDetailPanel(item) {
  var html = '';
  html += '<div class="scene-title">📋 物品详情</div>';
  html += '<div class="item-detail-panel">';
  // Name with rarity color
  html += '<div class="item-detail-name" style="color:' + (item.rarityColor || '#d4c8a8') + ';font-size:1.3em;font-weight:bold">' + (item.icon ? item.icon + ' ' : '') + item.name + '</div>';
  // Rarity
  if (item.rarity) {
    var rarNames = {common:'普通',uncommon:'优秀',rare:'精良',epic:'史诗',legendary:'传说',mythic:'神话'};
    html += '<div style="color:' + (item.rarityColor || '#9d9d9d') + ';margin-bottom:8px">品质:' + (rarNames[item.rarity] || item.rarity) + '</div>';
  }
  // Slot
  if (item.slot) {
    var slotNames = {weapon:'⚔️ 武器',helmet:'🪖 头盔',armor:'🛡️ 铠甲',gloves:'🧤 手套',boots:'👢 靴子',belt:'🔗 腰带',necklace:'📿 项链',ring:'💍 戒指'};
    html += '<div style="margin-bottom:6px">槽位:' + (slotNames[item.slot] || item.slot) + '</div>';
  }
  // Type
  if (item.type) {
    var typeNames = {weapon:'武器',armor:'护甲',necklace:'项链',ring:'戒指',consumable:'消耗品',potion:'药剂',material:'材料',trade_good:'商贸货物',equipment:'装备'};
    var typeLabel = typeNames[item.type] || item.type;
    if (item.type === 'material') typeLabel = '材料 (可在铁匠铺打造)';
    html += '<div style="margin-bottom:8px">类型:' + typeLabel + '</div>';
  }
  // Core stats
  html += '<div class="item-detail-stats">';
  if (item.atk) html += '<div>⚔️ 物理攻击 +' + item.atk + '</div>';
  if (item.matk) html += '<div>🧙 魔法攻击 +' + item.matk + '</div>';
  if (item.def) html += '<div>🛡️ 防御 +' + item.def + '</div>';
  if (item.hp) html += '<div>❤️ 生命值 +' + item.hp + '</div>';
  if (item.mp) html += '<div>💧 魔法值 +' + item.mp + '</div>';
  if (item.str) html += '<div>💪 力量 +' + item.str + '</div>';
  if (item.agi) html += '<div>🏃 敏捷 +' + item.agi + '</div>';
  if (item.int) html += '<div>📖 智力 +' + item.int + '</div>';
  if (item.cha) html += '<div>🗣️ 魅力 +' + item.cha + '</div>';
  if (item.luk) html += '<div>🎲 幸运 +' + item.luk + '</div>';
  if (item.critRate) html += '<div>💥 暴击率 +' + Math.round(item.critRate * 100) + '%</div>';
  if (item.critDmg) html += '<div>💥 暴击伤害 +' + Math.round(item.critDmg * 100) + '%</div>';
  if (item.dodge) html += '<div>💨 闪避率 +' + Math.round(item.dodge * 100) + '%</div>';
  if (item.fireDmg) html += '<div>🔥 火焰伤害 +' + item.fireDmg + '</div>';
  if (item.poisonDmg) html += '<div>🧪 毒素伤害 +' + item.poisonDmg + '</div>';
  if (item.holyDmg) html += '<div>✨ 圣光伤害 +' + item.holyDmg + ' (亡灵+50%)</div>';
  if (item.shadowDmg) html += '<div>👤 暗影伤害 +' + item.shadowDmg + '</div>';
  if (item.stormDmg) html += '<div>⚡ 风暴伤害 +' + item.stormDmg + ' (15%击晕)</div>';
  if (item.stunChance) html += '<div>💫 击晕率 ' + Math.round(item.stunChance * 100) + '%</div>';
  if (item.frostSlow) html += '<div>❄️ 冰霜减速 ' + item.frostSlow + '%</div>';
  if (item.deathSave) html += '<div>🛡️ 免死：抵挡一次致命伤害</div>';
  if (item.isUnique) html += '<div style="color:#ffd700">⭐ 独特装备</div>';
  if (item.desc) html += '<div style="color:var(--text-dim);font-style:italic;font-size:0.9em">"' + item.desc + '"</div>';
  if (item.lifesteal) html += '<div>🩸 吸血 +' + Math.round(item.lifesteal * 100) + '%</div>';
  if (item.deadlyRate) html += '<div>⚡ 致命一击 ' + Math.round(item.deadlyRate * 100) + '%</div>';
  if (item.counterRate) html += '<div>↩️ 反击率 ' + Math.round(item.counterRate * 100) + '%</div>';
  if (item.doubleAtkRate) html += '<div>⚔️⚔️ 连击率 ' + Math.round(item.doubleAtkRate * 100) + '%</div>';
  if (item.heal) html += '<div>❤️ 恢复生命 ' + item.heal + '</div>';
  if (item.restore) html += '<div>💧 恢复魔法 ' + item.restore + '</div>';
  html += '</div>';
  // Prefix info
  if (item.prefix) {
    html += '<div style="margin-top:8px;color:#a335ee">前缀:' + item.prefix.name + '</div>';
  }
  if (item.effectPrefix) {
    html += '<div style="color:#ff8c00">效果:' + item.effectPrefix.name + '</div>';
  }
  // Affixes
  if (item.affixes && item.affixes.length > 0) {
    html += '<div style="margin-top:8px">附加词条:</div>';
    for (var ai = 0; ai < item.affixes.length; ai++) {
      var af = item.affixes[ai];
      var afLabel = af.label || af.name || af.stat || '未知';
      html += '<div style="color:#1eff00;padding-left:8px">• ' + afLabel + ': +' + af.value + '</div>';
    }
  }
  // Set info
  if (item.setId && EQUIP_SETS[item.setId]) {
    var set = EQUIP_SETS[item.setId];
    html += '<div style="margin-top:8px;color:#ffaa00">📋 套装:' + set.name + '</div>';
    html += '<div style="padding-left:8px;color:#888">2件:' + set.bonus2.desc + '</div>';
    html += '<div style="padding-left:8px;color:#888">4件:' + set.bonus4.desc + '</div>';
    html += '<div style="padding-left:8px;color:#888">6件:' + set.bonus6.desc + '</div>';
  }
  // Description
  if (item.desc) {
    html += '<div style="margin-top:10px;color:#aaa;font-style:italic">"' + item.desc + '"</div>';
  }
  // Sell value
  var sellPrice = Math.floor((item.price || 10) * 0.5);
  html += '<div style="margin-top:8px;color:#d4a017">💰 出售价:' + sellPrice + ' 金币</div>';
  // Comparison with currently equipped item in same slot
  if (item.slot && G.equipment[item.slot]) {
    var equipped = G.equipment[item.slot];
    html += '<div style="margin-top:10px;padding:8px;background:#16213e;border-radius:6px;border:1px solid #334">';
    html += '<div style="color:#d4a017;font-weight:bold;margin-bottom:4px">📊 与已装备对比</div>';
    html += '<div style="color:#888;font-size:0.85em">当前:' + equipped.name + '</div>';
    var compareStats = [
      ['atk', '⚔️ ATK'], ['matk', '✨ MATK'], ['def', '🛡️ DEF'],
      ['hp', '❤️ HP'], ['mp', '💎 MP'],
      ['str', '💪 体魄'], ['agi', '🏃 AGI'], ['int', '📖 INT'],
      ['cha', '🗣️ CHA'], ['luk', '🎲 LUK'],
      ['critRate', '💥 CRIT'], ['dodge', '💨 DODGE']
    ];
    var hasDiff = false;
    for (var ci = 0; ci < compareStats.length; ci++) {
      var ck = compareStats[ci][0], cl = compareStats[ci][1];
      var newVal = item[ck] || 0;
      var oldVal = equipped[ck] || 0;
      var cdiff = newVal - oldVal;
      if (cdiff !== 0) {
        hasDiff = true;
        var csign = cdiff > 0 ? '▲' : '▼';
        var ccolor = cdiff > 0 ? '#c44' : '#4a4'; // Red=up(better), Green=down(worse)
        var cunit = (ck === 'critRate' || ck === 'dodge') ? '%' : '';
        var cval = cunit ? Math.round(cdiff * 100) + cunit : cdiff;
        html += '<div style="color:' + ccolor + ';font-size:0.9em">' + cl + ' ' + csign + Math.abs(cval) + '</div>';
      }
    }
    if (!hasDiff) html += '<div style="color:#888;font-size:0.85em">无属性差异</div>';
    html += '</div>';
  }
  html += '</div>';
  html += '<button class="btn" onclick="sceneInventory()">返回背包</button>';
  render(html);
}

// ═══════════════════════════════════════════════════════════
// SCENE: PLAYER INFO with attr reallocation
// ═══════════════════════════════════════════════════════════

var _playerInfoDraft = null;

function scenePlayerInfo() {
  _playerInfoDraft = null;
  var html = '';
  html += '<div class="scene-title">👤 角色信息</div>';

  // Basic info
  html += '<div class="player-basic">';
  html += '<div class="basic-name">' + G.name + '</div>';
  html += '<div class="basic-origin">' + G.origin.emoji + ' ' + G.origin.name + '</div>';
  html += '<div class="basic-level">Lv.' + G.level + ' | ⭐ ' + G.xp + '/' + calcNextXp(G.level) + '</div>';
  html += '</div>';

  // HP / MP bars
  var hpPct = Math.min(100, Math.max(0, (G.hp / G.maxHp * 100))).toFixed(0);
  var mpPct = Math.min(100, Math.max(0, (G.mp / G.maxMp * 100))).toFixed(0);
  var hpColor = '#e74c3c';
  var mpColor = '#3498db';
  html += '<div style="margin:8px 0;padding:8px 10px;background:#111;border-radius:8px;border:1px solid #222">';
  // HP bar
  html += '<div style="display:flex;align-items:center;gap:6px;margin-bottom:6px">';
  html += '<span style="color:' + hpColor + ';font-size:0.9em;min-width:28px">❤️</span>';
  html += '<div style="flex:1;background:#1a1a1a;border-radius:4px;height:18px;overflow:hidden;position:relative">';
  html += '<div style="width:' + hpPct + '%;height:100%;background:' + hpColor + ';border-radius:4px;transition:width 0.3s"></div>';
  html += '<div style="position:absolute;top:0;left:0;width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:0.8em;color:#fff;text-shadow:0 0 3px #000">' + G.hp + '/' + G.maxHp + '</div>';
  html += '</div>';
  html += '</div>';
  // MP bar
  html += '<div style="display:flex;align-items:center;gap:6px">';
  html += '<span style="color:' + mpColor + ';font-size:0.9em;min-width:28px">💧</span>';
  html += '<div style="flex:1;background:#1a1a1a;border-radius:4px;height:18px;overflow:hidden;position:relative">';
  html += '<div style="width:' + mpPct + '%;height:100%;background:' + mpColor + ';border-radius:4px;transition:width 0.3s"></div>';
  html += '<div style="position:absolute;top:0;left:0;width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:0.8em;color:#fff;text-shadow:0 0 3px #000">' + G.mp + '/' + G.maxMp + '</div>';
  html += '</div>';
  html += '</div>';
  // Active status effects
  if (G.statusEffects && G.statusEffects.length > 0) {
    html += '<div style="margin-top:8px;display:flex;flex-wrap:wrap;gap:4px">';
    for (var sei = 0; sei < G.statusEffects.length; sei++) {
      var se = G.statusEffects[sei];
      var seColor = se.buff ? '#2ecc71' : '#e74c3c';
      var seLabel = se.emoji + ' ' + se.name + (se.turns ? '(' + se.turns + '回合)' : '');
      html += '<span style="padding:2px 8px;background:' + seColor + '22;border:1px solid ' + seColor + '44;border-radius:4px;font-size:0.8em;color:' + seColor + '">' + seLabel + '</span>';
    }
    html += '</div>';
  }
  html += '</div>';

  // Skills - detailed panel
  html += '<div class="skills-display">';
  html += '<div class="skills-title">📖 已学技能</div>';
  // Separate spells and combat skills
  var learnedSpells = [];
  var learnedCombat = [];
  var lockedSkills = [];
  if (G.skills && G.skills.length > 0) {
    for (var i = 0; i < G.skills.length; i++) {
      var sk = SKILLS.find(function(s) { return s.id === G.skills[i]; });
      if (sk) {
        if (sk.category === 'spell') learnedSpells.push(sk);
        else learnedCombat.push(sk);
      }
    }
  }
  // Check for learnable but not yet learned skills by level
  for (var li = 0; li < SKILLS.length; li++) {
    var lsk = SKILLS[li];
    if (lsk.reqLevel > 0 && G.level >= lsk.reqLevel && !G.skills.includes(lsk.id)) {
      lockedSkills.push(lsk);
    }
  }

  if (learnedSpells.length > 0) {
    html += '<div class="skill-category">🔮 法术</div>';
    html += '<div class="skill-detail-list">';
    for (var sp = 0; sp < learnedSpells.length; sp++) {
      var s = learnedSpells[sp];
      var tIcon = s.target === '群攻' ? '🎯群' : s.target === '自身' ? '🛡️' : '🎯单';
      var dmgType = s.damageType === 'magic' ? '🔮魔法' : s.damageType === 'physical' ? '⚔️物理' : '⚡混合';
      html += '<div class="skill-detail-card" onclick="showSkillDetail(\'' + s.id + '\')" style="cursor:pointer">';
      html += '<div class="sdc-header"><span class="sdc-emoji">' + s.emoji + '</span><span class="sdc-name">' + s.name + '</span><span class="sdc-target">' + tIcon + '</span></div>';
      html += '<div class="sdc-meta">' + dmgType + ' | 💧' + s.cost + (s.reqLevel ? ' | Lv.' + s.reqLevel : '') + '</div>';
      html += '<div class="sdc-desc">' + s.desc + '</div>';
      html += '</div>';
    }
    html += '</div>';
  }

  if (learnedCombat.length > 0) {
    html += '<div class="skill-category">⚔️ 战斗技能</div>';
    html += '<div class="skill-detail-list">';
    for (var cs = 0; cs < learnedCombat.length; cs++) {
      var c = learnedCombat[cs];
      var ctIcon = c.target === '群攻' ? '🎯群' : c.target === '自身' ? '🛡️' : '🎯单';
      var cdmgType = c.damageType === 'magic' ? '🔮魔法' : c.damageType === 'physical' ? '⚔️物理' : '⚡混合';
      html += '<div class="skill-detail-card" onclick="showSkillDetail(\'' + c.id + '\')" style="cursor:pointer">';
      html += '<div class="sdc-header"><span class="sdc-emoji">' + c.emoji + '</span><span class="sdc-name">' + c.name + '</span><span class="sdc-target">' + ctIcon + '</span></div>';
      html += '<div class="sdc-meta">' + cdmgType + ' | 💧' + c.cost + (c.reqLevel ? ' | Lv.' + c.reqLevel : '') + '</div>';
      html += '<div class="sdc-desc">' + c.desc + '</div>';
      html += '</div>';
    }
    html += '</div>';
  }

  if (lockedSkills.length > 0) {
    html += '<div class="skill-category" style="opacity:0.5">🔓 可学习 (Lv.' + G.level + ')</div>';
    html += '<div class="skill-detail-list" style="opacity:0.5">';
    for (var lk = 0; lk < lockedSkills.length; lk++) {
      var lsk2 = lockedSkills[lk];
      html += '<div class="skill-detail-card" style="border-color:#666">';
      html += '<div class="sdc-header"><span class="sdc-emoji">' + lsk2.emoji + '</span><span class="sdc-name">' + lsk2.name + '</span></div>';
      html += '<div class="sdc-desc">' + lsk2.desc + ' (需Lv.' + lsk2.reqLevel + ')</div>';
      html += '</div>';
    }
    html += '</div>';
  }

  if (learnedSpells.length === 0 && learnedCombat.length === 0) {
    html += '<div class="skills-empty">尚未学习任何技能</div>';
  }
  html += '</div>';

  // Skill detail tooltip
  html += '<div id="skillTooltip" class="attr-tooltip" style="display:none" data-key=""></div>';

  // Origin skill
  if (G.origin && G.origin.skill) {
    html += '<div class="origin-skill-display">';
    html += '<div class="origin-title">✨ 起源技能</div>';
    html += '<div class="origin-skill">' + G.origin.skill.emoji + ' ' + G.origin.skill.name + ' [' + G.origin.skill.type + ']</div>';
    html += '<div class="origin-desc">' + G.origin.skill.desc + '</div>';
    html += '</div>';
  }

  // Attribute points
  html += '<div class="attr-allocation">';
  html += '<div class="attr-header">';
  html += '<strong>自由属性点:' + G.attrPts + '</strong>';
  if (G.attrPts > 0) {
    html += ' <button class="btn-small" onclick="sceneAttrAllocation()">分配</button>';
  }
  html += '</div>';

  var akeys = ['str','agi','int','cha','luk'];
  html += '<div class="attr-grid">';
  for (var j = 0; j < akeys.length; j++) {
    var k = akeys[j];
    var ai = ATTR_INFO[k];
    html += '<div class="attr-block" onclick="showAttrInfo(\'' + k + '\')" style="cursor:pointer;border-left:3px solid ' + ai.color + '">';
    html += '<span class="attr-n">' + ai.icon + ' ' + ai.name + '</span>';
    var _eqBonus = getEffStat(k) - G[k];
            html += '<span class="attr-v">' + G[k] + ( _eqBonus > 0 ? '<span style="color:#7ec8a4;font-size:0.8em">(+' + _eqBonus + ')</span>' : '') + '</span>';
    html += '</div>';
  }
  html += '</div>';
  html += '</div>';

  // Derived stats
  html += '<div class="derived-stats">';
  html += '<div class="der-title">战斗属性</div>';
  html += '<div class="der-grid">';
  html += '<div class="der-item">⚔️ 物攻 ' + calcAtk() + '</div>';
  html += '<div class="der-item">🔮 魔攻 ' + calcMagicAtk() + '</div>';
  html += '<div class="der-item">🛡️ 防御 ' + calcDef() + '</div>';
  html += '<div class="der-item">💨 闪避 ' + calcDodge().toFixed(1) + '%</div>';
  html += '<div style="margin-top:12px;padding:10px;background:#111;border-radius:8px;border:1px solid #333">';
  html += '<div style="color:#d4a017;font-weight:bold;margin-bottom:6px">📋 属性换算表</div>';
  html += '<div style="font-size:0.78em;color:#aaa;line-height:1.6">';
  html += '⚔️ <b style="color:#e74c3c">体魄</b>: 物攻+2, 最大HP+5<br>';
  html += '🏹 <b style="color:#2ecc71">敏捷</b>: 闪避+0.8%, 先手+1<br>';
  html += '📖 <b style="color:#3498db">智力</b>: 魔攻+2, 最大MP+3<br>';
  html += '💬 <b style="color:#e67e22">魅力</b>: 商店价格-1%, 好感度+5%<br>';
  html += '🍀 <b style="color:#9b59b6">幸运</b>: 暴击+0.5%, 稀有掉落+1%<br>';
  html += '</div>';
  html += '</div>';
  html += '<div class="der-item">💥 会心 ' + calcCrit().toFixed(1) + '%</div>';
  html += '</div>';
  html += '</div>';

  // Re-select origin (only before game starts)
  if (!G.gameStarted) {
    html += '<div class="reselect-section">';
    html += '<button class="btn" onclick="sceneSelectOrigin()">🔄 重新选择起源</button>';
    html += '</div>';
  }

  var _returnTarget = _playerInfoReturnTo || 'sceneWorldMap';
  _playerInfoReturnTo = null;
  html += '<button class="btn" onclick="sceneAchievements()" style="margin-right:8px">🏆 成就</button>';
  html += '<button class="btn" onclick="' + _returnTarget + '()">返回</button>';
  render(html);
}

function sceneAttrAllocation() {
  if (G.attrPts <= 0) { toast('没有可分配的属性点'); return; }

  if (!_playerInfoDraft) {
    _playerInfoDraft = { str:G.str, agi:G.agi, int:G.int, cha:G.cha, luk:G.luk, pts:G.attrPts };
  }

  var html = '';
  html += '<div class="scene-title">分配属性点</div>';
  html += '<div class="pts-info">剩余:<strong>' + _playerInfoDraft.pts + '</strong> 点(点击属性名查看详情)</div>';

  var akeys = ['str','agi','int','cha','luk'];

  for (var i = 0; i < akeys.length; i++) {
    var k = akeys[i];
    var ai = ATTR_INFO[k];
    var cur = _playerInfoDraft[k];
    var baseVal = G[k];
    var delta = cur - baseVal;

    html += '<div class="attr-row-v5" style="border-left:3px solid ' + ai.color + '">';
    html += '<div class="attr-info">';
    html += '<span class="attr-name-v5" onclick="showAttrInfo(\'' + k + '\')" style="cursor:pointer;color:' + ai.color + '">' + ai.icon + ' ' + ai.name + '</span>';
    html += '<span class="attr-hint-v5">' + ai.brief + '</span>';
    html += '</div>';
    html += '<div class="attr-controls">';
    html += '<button class="attr-btn" onclick="adjAttr(\'' + k + '\', -1)" ' + (delta <= 0 ? 'disabled' : '') + '>-</button>';
    html += '<span class="attr-value' + (delta > 0 ? ' attr-boosted' : '') + '">' + cur + (delta > 0 ? ' (+' + delta + ')' : '') + '</span>';
    html += '<button class="attr-btn" onclick="adjAttr(\'' + k + '\', 1)" ' + (_playerInfoDraft.pts <= 0 ? 'disabled' : '') + '>+</button>';
    html += '</div>';
    html += '</div>';
  }

  // Attr info tooltip container
  html += '<div id="attrTooltip" class="attr-tooltip" style="display:none"></div>';

  html += '<div class="btns">';
  html += '<button class="btn btn-primary" onclick="confirmAttrAllocation()">✅ 确认分配</button>';
  html += '<button class="btn" onclick="skipAttrAlloc()">⏭️ 稍后再分配</button>';
  html += '</div>';
  render(html);
}

function adjAttr(key, delta) {
  if (delta > 0 && _playerInfoDraft.pts <= 0) return;
  var newVal = _playerInfoDraft[key] + delta;
  var baseVal = G[key];
  if (delta < 0 && newVal < baseVal) return;
  _playerInfoDraft[key] = newVal;
  _playerInfoDraft.pts -= delta;
  sceneAttrAllocation();
}

function confirmAttrAllocation() {
  G.str = _playerInfoDraft.str;
  G.agi = _playerInfoDraft.agi;
  G.int = _playerInfoDraft.int;
  G.cha = _playerInfoDraft.cha;
  G.luk = _playerInfoDraft.luk;
  G.attrPts = _playerInfoDraft.pts;
  _playerInfoDraft = null;
  G.maxHp = calcMaxHp();
  G.maxMp = calcMaxMp();
  G.hp = G.maxHp;
  G.mp = G.maxMp;
  toast('属性点分配成功!');
  afterBattleContinue();
}

function skipAttrAlloc() {
  _playerInfoDraft = null;
  afterBattleContinue();
}


