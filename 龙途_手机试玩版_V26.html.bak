    desc:'活火山口中的龙族圣地,岩浆在脚下流淌',
    mapConfig:{ cols:20, rows:18, name:'龙息火山', enemyRate:0.26, treasureRate:0.14, eventRate:0.06,
      desc:'脚下的岩石滚烫,岩浆在裂缝中涌动...', startPos:{r:16,c:1}, bossPos:{r:1,c:18} },
    enemies:['lava_titan','dragon_hatchling','magma_worm'],
    townDesc:'火焰与烟尘遮蔽了天空,熔岩从裂缝中涌出汇成溪流。地面的温度让金属靴底发烫,空气中充满了硫磺的刺鼻气味。岩石在高温下开裂,发出像骨骼断裂般的声响。' },

  // === Region 4: 禁忌深渊 (Lv 71-100) ===
  abyssgate: { id:'abyssgate', x:200, y:460, name:'深渊之门', type:'wild', emoji:'🕳️', unlocked:false, levelRange:[71,80],
    desc:'通往世界尽头的裂缝,暗影从这里涌出',
    mapConfig:{ cols:22, rows:20, name:'深渊之门', enemyRate:0.28, treasureRate:0.12, eventRate:0.05,
      desc:'地面上的裂缝中渗出紫黑色的暗影...', startPos:{r:18,c:1}, bossPos:{r:1,c:20} },
    enemies:['void_walker','shadow_lord','abyss_crawler'],
    townDesc:'深渊的呼吸清晰可闻,黑暗像活物一样吞噬光线。裂缝中渗出冰冷的雾气,偶有低频振动从地底传来,震得胸腔发麻。你的直觉在尖叫--这里不是人类该来的地方。' },
  shadowrealm: { id:'shadowrealm', x:150, y:480, name:'影界', type:'dungeon', emoji:'👤', unlocked:false, levelRange:[80,90],
    desc:'暗影的反转世界,一切都被扭曲和吞噬',
    mapConfig:{ cols:20, rows:18, name:'影界', enemyRate:0.26, treasureRate:0.14, eventRate:0.08,
      desc:'现实在这里扭曲,上下左右都失去了意义...', startPos:{r:16,c:1}, bossPos:{r:1,c:18} },
    enemies:['shadow_mirror','void_beast','nightmare'],
    townDesc:'你的影子在你身旁独立行走,它模仿你的每个动作,却总比你慢半拍。这个世界没有光,只有无尽的灰与黑。地面上映出无数个你的倒影,每一个表情都略有不同。' },
  throneofages: { id:'throneofages', x:250, y:490, name:'万古王座', type:'dungeon', emoji:'👑', unlocked:false, levelRange:[90,100],
    desc:'世界的最深处,初代龙神的王座所在',
    mapConfig:{ cols:22, rows:20, name:'万古王座', enemyRate:0.24, treasureRate:0.18, eventRate:0.10,
      desc:'巨龙的骸骨构成王座,远古的力量在这里沉睡...', startPos:{r:18,c:1}, bossPos:{r:1,c:20} },
    enemies:['ancient_guardian','primordial_wyrm','time_wraith'],
    townDesc:'万古的沉默笼罩一切,连心跳声都显得刺耳。王座悬浮在虚空之中,四周是无尽的星海。时间在这里失去了意义,过去、现在与未来同时映照在王座背后的镜面上。' }
};

