  },
  ashplains: {
    names: ['焦土','龙息痕','余烬路','灰烬丘','熔岩河','炭化林','龙骨堆','灼热平原','火石带','烬灭镇','龙爪印','龙息谷','灰烬祭坛','余火洞','岩浆池','炭化遗迹','灼热洼地','龙翼岭','焚风道','灰烬王庭'],
    desc: ['热浪扭曲了远方的地平线。','脚下的灰烬还带着温度。','龙息留下的痕迹随处可见。','空气中充满了硫磺的味道。','远处传来龙的咆哮和地面震动。'],
    waterDesc: ['熔岩河阻断了道路,任何触碰都是致命的。','沸腾的水坑冒着蒸汽。'],
    stoneDesc: ['龙息烧过的岩石中,有龙族遗留的宝物。','灰烬下的龙骨中卡着古代武器。'],
    grassDesc: ['只有最顽强的火焰花还在开放。','炭化的枯树像鬼影般矗立。']
  },
  volcano: {
    names: ['火山口','熔岩道','岩浆瀑布','龙息圣殿','火焰祭坛','火山深井','地心通道','龙蛋孵化室','熔炉大厅','龙焰核心'],
    desc: ['火焰与烟尘遮蔽了天空。','岩浆在脚下流淌,每一步都是生死。','空气如此灼热,连呼吸都困难。','远处传来龙的怒吼和火山的轰鸣。','地面的裂缝中喷出滚烫的蒸汽。'],
    waterDesc: ['熔岩就是这里的水,不可触碰。','岩浆瀑布从高处倾泻而下。'],
    stoneDesc: ['岩浆凝固的黑曜石中,嵌着龙族神器。','火山喷出的宝石散落在岩壁旁。'],
    grassDesc: ['没有任何生命能在这里存活。','只有火焰在永不熄灭地燃烧。']
  },
  // Region 4
  abyssgate: {
    names: ['裂缝边缘','暗影渗出点','虚空哨站','深渊阶梯','扭曲走廊','暗影大厅','灵魂之井','虚无回廊','深渊核心','万古之门'],
    desc: ['紫黑色的暗影从裂缝中涌出。','现实在这里开始崩塌。','你的影子独立于你行动。','时间在这里变得不确定。','深渊在呼吸,在低语,在等待。'],
    waterDesc: ['暗影凝成的液体中漂浮着破碎的现实碎片。','虚空之流吞噬一切。'],
    stoneDesc: ['暗影侵蚀的岩石中,有世界诞生时的碎片。','裂缝边缘的结晶体蕴含着禁忌的力量。'],
    grassDesc: ['暗影代替了植物,像黑色藤蔓般蔓延。','虚无中没有生长,只有消亡。']
  },
  shadowrealm: {
    names: ['镜像城','倒悬塔','无底阶梯','暗影王庭','虚无边境','时间裂缝','灵魂熔炉','影之回廊','虚空深渊','存在之核'],
    desc: ['上下左右都失去了意义。','你的镜像在对面做着相反的动作。','时间在这里同时前进和后退。','存在本身在这里受到质疑。','暗影之王从每个角落注视着你。'],
    waterDesc: ['流动的暗影如水般吞噬一切。','镜像世界中的河流倒流。'],
    stoneDesc: ['扭曲的空间中,宝物和陷阱同时存在。','暗影结晶中封存着被吞噬的灵魂。'],
    grassDesc: ['暗影化作枯萎的植物在风中摇曳。','这里没有自然,只有暗影的模仿。']
  },
  throneofages: {
    names: ['万古甬道','龙骨长廊','创世纪碑','初火祭坛','时间回廊','命运织机','永恒之厅','龙神寝殿','始源之座','万古王座'],
    desc: ['万古的沉默笼罩一切。','初代龙神的力量在这里沉睡。','时间和空间在这里汇聚。','世界最古老的故事在这里开始和结束。','王座在等待新的主人。'],
    waterDesc: ['时间凝成的琥珀之河,不可逾越。','创世的原始之水仍在流淌。'],
    stoneDesc: ['龙神遗骸中蕴含着改变世界的力量。','万古的宝藏就在王座之下。'],
    grassDesc: ['没有任何生命,只有永恒。','这里是万物的起点和终点。']
  }
};

// Procedural map generation
var _mapCache = {}; // cache generated maps per location

function generateMap(locId) {
  // Corridor+Room algorithm - irregular, branching maps with elite spawns
  if (_mapCache[locId]) return _mapCache[locId];

  var loc = LOCATIONS[locId];
  var cfg = loc.mapConfig;
  var theme = ROOM_THEMES[locId] || ROOM_THEMES.lake;

  // Use larger grid for irregular maps - most cells start as wall
  var gridW = cfg.cols;
  var gridH = cfg.rows;

  // Seeded RNG for consistency
  var seed = 0;
  for (var si = 0; si < locId.length; si++) seed += locId.charCodeAt(si) * (si + 1);
  var rng = function() { seed = (seed * 16807 + 0) % 2147483647; return (seed - 1) / 2147483646; };

  // Initialize all rooms as walls
  var rooms = [];
  for (var r = 0; r < gridH; r++) {
    rooms[r] = [];
    for (var c = 0; c < gridW; c++) {
      rooms[r][c] = {
        r: r, c: c, id: r + '_' + c,
        name: '', desc: '',
        type: 'wall', // wall = impassable, not carved yet
        visited: false, revealed: false,
        connections: {} // {north:true, south:true, east:true, west:true}
      };
    }
  }

  // ---- Corridor+Room generation ----
  // Start from bottom-left area
  var startR = gridH - 2;
  var startC = 1;
  var bossR = 1;
  var bossC = gridW - 2;

  // Carve rooms first (3-7 rooms of varying size)
  var numRooms = 4 + Math.floor(rng() * 4); // 4-7 rooms
  var carvedRooms = []; // {r, c, w, h} rectangles

  // Force start room
  var startRoomW = 2 + Math.floor(rng() * 2); // 2-3
  var startRoomH = 2 + Math.floor(rng() * 2);
  carvedRooms.push({r: startR - startRoomH + 1, c: startC, w: startRoomW, h: startRoomH});

  // Force boss room
  var bossRoomW = 2 + Math.floor(rng() * 2);
  var bossRoomH = 2 + Math.floor(rng() * 2);
  carvedRooms.push({r: bossR, c: bossC - bossRoomW + 1, w: bossRoomW, h: bossRoomH});

  // Generate additional rooms with random positions
  for (var ri = 2; ri < numRooms; ri++) {
    var rw = 2 + Math.floor(rng() * 3); // 2-4 wide
    var rh = 2 + Math.floor(rng() * 3); // 2-4 tall
    var rr = 1 + Math.floor(rng() * (gridH - rh - 2));
    var rc = 1 + Math.floor(rng() * (gridW - rw - 2));
    // Check overlap (allow 1 cell overlap for connectivity)
    var overlap = false;
    for (var oi = 0; oi < carvedRooms.length; oi++) {
      var o = carvedRooms[oi];
      if (rr < o.r + o.h + 1 && rr + rh + 1 > o.r && rc < o.c + o.w + 1 && rc + rw + 1 > o.c) {
        overlap = true; break;
      }
    }
    if (!overlap) carvedRooms.push({r: rr, c: rc, w: rw, h: rh});
  }

  // Carve rooms into grid
  for (var ci = 0; ci < carvedRooms.length; ci++) {
    var cr = carvedRooms[ci];
    for (var ry = cr.r; ry < cr.r + cr.h && ry < gridH; ry++) {
      for (var cx = cr.c; cx < cr.c + cr.w && cx < gridW; cx++) {
        if (rooms[ry][cx].type === 'wall') {
          rooms[ry][cx].type = 'path';
        }
      }
    }
  }

  // Connect rooms with L-shaped corridors
  for (var ci2 = 0; ci2 < carvedRooms.length - 1; ci2++) {
    var roomA = carvedRooms[ci2];
    var roomB = carvedRooms[ci2 + 1];
    var aCenterR = Math.floor(roomA.r + roomA.h / 2);
    var aCenterC = Math.floor(roomA.c + roomA.w / 2);
    var bCenterR = Math.floor(roomB.r + roomB.h / 2);
    var bCenterC = Math.floor(roomB.c + roomB.w / 2);

    // L-shaped corridor: horizontal first, then vertical (or random order)
    var horizontalFirst = rng() < 0.5;
    if (horizontalFirst) {
      // Horizontal segment
      var hStart = Math.min(aCenterC, bCenterC);
      var hEnd = Math.max(aCenterC, bCenterC);
      for (var hx = hStart; hx <= hEnd; hx++) {
        if (aCenterR >= 0 && aCenterR < gridH && hx >= 0 && hx < gridW && rooms[aCenterR][hx].type === 'wall') {
          rooms[aCenterR][hx].type = 'path';
        }
      }
      // Vertical segment
      var vStart = Math.min(aCenterR, bCenterR);
      var vEnd = Math.max(aCenterR, bCenterR);
      for (var vy = vStart; vy <= vEnd; vy++) {
        if (vy >= 0 && vy < gridH && bCenterC >= 0 && bCenterC < gridW && rooms[vy][bCenterC].type === 'wall') {
          rooms[vy][bCenterC].type = 'path';
        }
      }
    } else {
      // Vertical first, then horizontal
      var vStart2 = Math.min(aCenterR, bCenterR);
      var vEnd2 = Math.max(aCenterR, bCenterR);
      for (var vy2 = vStart2; vy2 <= vEnd2; vy2++) {
        if (vy2 >= 0 && vy2 < gridH && aCenterC >= 0 && aCenterC < gridW && rooms[vy2][aCenterC].type === 'wall') {
          rooms[vy2][aCenterC].type = 'path';
        }
      }
      var hStart2 = Math.min(aCenterC, bCenterC);
      var hEnd2 = Math.max(aCenterC, bCenterC);
      for (var hx2 = hStart2; hx2 <= hEnd2; hx2++) {
        if (bCenterR >= 0 && bCenterR < gridH && hx2 >= 0 && hx2 < gridW && rooms[bCenterR][hx2].type === 'wall') {
          rooms[bCenterR][hx2].type = 'path';
        }
      }
    }
  }

  // Add 1-2 dead-end branches for exploration surprise
  var numBranches = 1 + Math.floor(rng() * 2);
  for (var bi = 0; bi < numBranches; bi++) {
    // Pick a random carved cell and extend a corridor
    var attempts = 0;
    while (attempts < 20) {
      attempts++;
      var br = 1 + Math.floor(rng() * (gridH - 2));
      var bc = 1 + Math.floor(rng() * (gridW - 2));
      if (rooms[br][bc].type !== 'wall') {
        // Found a carved cell, extend in a random direction
        var branchDir = [{dr:-1,dc:0},{dr:1,dc:0},{dr:0,dc:-1},{dr:0,dc:1}][Math.floor(rng() * 4)];
        var len = 2 + Math.floor(rng() * 3); // 2-4 cells long
        for (var bl = 1; bl <= len; bl++) {
          var bnr = br + branchDir.dr * bl;
          var bnc = bc + branchDir.dc * bl;
          if (bnr >= 0 && bnr < gridH && bnc >= 0 && bnc < gridW) {
            rooms[bnr][bnc].type = 'path';
          }
        }
        break;
      }
    }
  }

  // Compute connections between adjacent non-wall cells
  var dirs4 = [{dr:-1,dc:0,key:'north'},{dr:1,dc:0,key:'south'},{dr:0,dc:-1,key:'west'},{dr:0,dc:1,key:'east'}];
  for (var cr2 = 0; cr2 < gridH; cr2++) {
    for (var cc = 0; cc < gridW; cc++) {
      if (rooms[cr2][cc].type === 'wall') continue;
      for (var di = 0; di < dirs4.length; di++) {
        var anr = cr2 + dirs4[di].dr, anc = cc + dirs4[di].dc;
        if (anr >= 0 && anr < gridH && anc >= 0 && anc < gridW && rooms[anr][anc].type !== 'wall') {
          rooms[cr2][cc].connections[dirs4[di].key] = true;
        }
      }
    }
  }

  // Mark start and boss
  rooms[startR][startC].type = 'start';
  rooms[startR][startC].name = '入口';
  rooms[startR][startC].desc = cfg.desc;
  rooms[startR][startC].revealed = true;
  rooms[startR][startC].visited = true;
  rooms[bossR][bossC].type = 'boss';
  rooms[bossR][bossC].name = '首领巢穴';
  rooms[bossR][bossC].desc = '空气中充满危险的气息...';

  // Reveal adjacent to start
  for (var di2 = 0; di2 < dirs4.length; di2++) {
    var nr2 = startR + dirs4[di2].dr, nc2 = startC + dirs4[di2].dc;
    if (nr2 >= 0 && nr2 < gridH && nc2 >= 0 && nc2 < gridW && rooms[nr2][nc2].type !== 'wall') {
      rooms[nr2][nc2].revealed = true;
    }
  }

  // Fill non-wall, non-start, non-boss rooms with content
  var nameIdx = 0;
  var eliteCount = 0;
  var maxElites = 2 + Math.floor(rng() * 2); // 2-3 elites per map

  for (var fr = 0; fr < gridH; fr++) {
    for (var fc = 0; fc < gridW; fc++) {
      var room = rooms[fr][fc];
      if (room.type === 'wall' || room.type === 'start' || room.type === 'boss') continue;

      var roll = rng();
      if (roll < cfg.enemyRate) {
        // Chance to be elite instead of regular enemy
        if (eliteCount < maxElites && rng() < 0.2) {
          room.type = 'elite';
          eliteCount++;
        } else {
          // Regular enemy rooms removed - enemies now spawn randomly on any walkable tile when stepping
          room.type = 'path';
        }
      } else if (roll < cfg.enemyRate + cfg.treasureRate) {
        room.type = 'treasure';
      } else if (roll < cfg.enemyRate + cfg.treasureRate + cfg.eventRate) {
        room.type = 'event';
      } else if (roll < cfg.enemyRate + cfg.treasureRate + cfg.eventRate + 0.05) {
        room.type = 'trap'; // new: trap room
      } else {
        room.type = 'path';
      }

      // Assign name and description
      room.name = theme.names[nameIdx % theme.names.length];
      nameIdx++;
      if (room.type === 'elite') {
        room.name = '精锐哨点';
        room.desc = '这里盘踞着比普通怪物更强的敌人...';
      } else {
        room.desc = theme.desc[Math.floor(rng() * theme.desc.length)];
      }
    }
  }

  // Place a treasure at the end of each dead-end branch
  for (var dr = 0; dr < gridH; dr++) {
    for (var dc = 0; dc < gridW; dc++) {
      var drm = rooms[dr][dc];
      if (drm.type === 'wall' || drm.type === 'start' || drm.type === 'boss') continue;
      var connCount = Object.keys(drm.connections).length;
      if (connCount === 1 && drm.type === 'path') {
        // Dead end - place treasure!
        drm.type = 'treasure';
        drm.name = '隐秘宝箱';
        drm.desc = '死胡同的尽头,一个被遗忘的宝箱...';
      }
    }
  }

  // ── Identify articulation points (choke points) before placing water ──
  // A cell is a choke point if removing it disconnects start↔boss
  function countNeighbors(r, c) {
    var cnt = 0;
    for (var di = 0; di < dirs4.length; di++) {
      var nr = r + dirs4[di].dr, nc = c + dirs4[di].dc;
      if (nr >= 0 && nr < gridH && nc >= 0 && nc < gridW && rooms[nr][nc].type !== 'wall') cnt++;
    }
    return cnt;
  }
  // Mark choke points: path cells with <=1 non-wall neighbor (dead ends) or
  // cells that are the only connection between two regions (simplified heuristic)
  var isChoke = [];
  for (var ckr = 0; ckr < gridH; ckr++) {
    isChoke[ckr] = [];
    for (var ckc = 0; ckc < gridW; ckc++) {
      isChoke[ckr][ckc] = false;
    }
  }
  // Simple choke detection: path cells with exactly 2 opposite-direction neighbors
  // (i.e. corridor cells that are the sole link between two halves)
  for (var ckr2 = 0; ckr2 < gridH; ckr2++) {
    for (var ckc2 = 0; ckc2 < gridW; ckc2++) {
      var ckRoom = rooms[ckr2][ckc2];
      if (ckRoom.type !== 'path') continue;
      var nn = countNeighbors(ckr2, ckc2);
      // Dead-end or corridor (2 neighbors) - likely a choke
      if (nn <= 2) isChoke[ckr2][ckc2] = true;
    }
  }

  // ── BFS connectivity check (ignoring water cells) ──
  function isConnected() {
    // Check if start can reach boss via non-wall, non-water cells
    var visited = [];
    for (var vr = 0; vr < gridH; vr++) { visited[vr] = []; for (var vc2 = 0; vc2 < gridW; vc2++) visited[vr][vc2] = false; }
    var queue = [{r: startR, c: startC}];
    visited[startR][startC] = true;
    while (queue.length > 0) {
      var cur = queue.shift();
      if (cur.r === bossR && cur.c === bossC) return true;
      for (var bdi = 0; bdi < dirs4.length; bdi++) {
        var bnr = cur.r + dirs4[bdi].dr, bnc = cur.c + dirs4[bdi].dc;
        if (bnr >= 0 && bnr < gridH && bnc >= 0 && bnc < gridW && !visited[bnr][bnc] && rooms[bnr][bnc].type !== 'wall' && rooms[bnr][bnc].type !== 'water') {
          visited[bnr][bnc] = true;
          queue.push({r: bnr, c: bnc});
        }
      }
    }
    return false;
  }

  // Assign terrain to non-wall rooms (grass/stone/water/plain)
  // Water = impassable (acts like wall but revealed)
  var waterRate = 0.08; // 8% of walkable tiles become water
  var stoneRate = 0.10; // 10% stone (investigatable)
  var grassRate = 0.15; // 15% grass (flavor text)
  var waterCandidates = []; // collect water placements for rollback
  for (var tr = 0; tr < gridH; tr++) {
    for (var tc = 0; tc < gridW; tc++) {
      var tRoom = rooms[tr][tc];
      if (tRoom.type === 'wall' || tRoom.type === 'start' || tRoom.type === 'boss' || tRoom.type === 'water') continue;
      // Only assign terrain to path-type rooms (not treasure/trap/event/elite)
      if (tRoom.type !== 'path') continue;
      // Skip choke points - never water a corridor that could block the path
      if (isChoke[tr][tc]) {
        tRoom.terrain = 'plain';
        continue;
      }
      var tRoll = rng();
      if (tRoll < waterRate) {
        // Tentatively place water
        var savedType = tRoom.type;
        var savedTerrain = tRoom.terrain;
        var savedDesc = tRoom.desc;
        tRoom.terrain = 'water';
        tRoom.type = 'water';
        // Check connectivity; if broken, rollback
        if (!isConnected()) {
          tRoom.type = savedType;
          tRoom.terrain = savedTerrain;
          tRoom.desc = savedDesc;
          tRoom.terrain = 'plain'; // safe fallback
          continue;
        }
        // Water descriptions are in LOCATIONS[locId].waterDesc
        var wd = loc.waterDesc || ['一片水域,无法通行。'];
        tRoom.desc = wd[Math.floor(rng() * wd.length)];
      } else if (tRoll < waterRate + stoneRate) {
        tRoom.terrain = 'stone';
        tRoom.desc = (loc.stoneDesc || ['巨石堆叠,缝隙间似乎有闪光。'])[Math.floor(rng() * (loc.stoneDesc || ['巨石堆叠']).length)];
      } else if (tRoll < waterRate + stoneRate + grassRate) {
        tRoom.terrain = 'grass';
        tRoom.desc = (loc.grassDesc || ['草丛沙沙作响。'])[Math.floor(rng() * (loc.grassDesc || ['草丛']).length)];
      } else {
        tRoom.terrain = 'plain';
      }
    }
  }
  // Recompute connections (water blocks movement)
  for (var cr3 = 0; cr3 < gridH; cr3++) {
    for (var cc3 = 0; cc3 < gridW; cc3++) {
      rooms[cr3][cc3].connections = {};
      if (rooms[cr3][cc3].type === 'wall' || rooms[cr3][cc3].type === 'water') continue;
      for (var di3 = 0; di3 < dirs4.length; di3++) {
        var anr3 = cr3 + dirs4[di3].dr, anc3 = cc3 + dirs4[di3].dc;
        if (anr3 >= 0 && anr3 < gridH && anc3 >= 0 && anc3 < gridW && rooms[anr3][anc3].type !== 'wall' && rooms[anr3][anc3].type !== 'water') {
          rooms[cr3][cc3].connections[dirs4[di3].key] = true;
        }
      }
    }
  }

  // ── Final connectivity check: ensure all non-wall/water rooms are reachable from start ──
  // If any rooms are isolated, convert them to water (they become decorative)
  var _allVisited = [];
  for (var avr = 0; avr < gridH; avr++) { _allVisited[avr] = []; for (var avc = 0; avc < gridW; avc++) _allVisited[avr][avc] = false; }
  var _bfsQueue = [{r: startR, c: startC}];
  _allVisited[startR][startC] = true;
  while (_bfsQueue.length > 0) {
    var _cur = _bfsQueue.shift();
    for (var _bdi = 0; _bdi < dirs4.length; _bdi++) {
      var _bnr = _cur.r + dirs4[_bdi].dr, _bnc = _cur.c + dirs4[_bdi].dc;
      if (_bnr >= 0 && _bnr < gridH && _bnc >= 0 && _bnc < gridW && !_allVisited[_bnr][_bnc] && rooms[_bnr][_bnc].type !== 'wall' && rooms[_bnr][_bnc].type !== 'water') {
        _allVisited[_bnr][_bnc] = true;
        _bfsQueue.push({r: _bnr, c: _bnc});
      }
    }
  }
  // Convert any unreachable non-wall rooms to water
  for (var irr = 0; irr < gridH; irr++) {
    for (var irc = 0; irc < gridW; irc++) {
      var _irm = rooms[irr][irc];
      if (_irm.type !== 'wall' && _irm.type !== 'water' && !_allVisited[irr][irc]) {
        _irm.type = 'water';
        _irm.terrain = 'water';
        _irm.name = '';
        _irm.desc = '一片水域,无法通行。';
        _irm.connections = {};
      }
    }
  }
  // Re-recompute connections after converting isolated rooms to water
  for (var cr4 = 0; cr4 < gridH; cr4++) {
    for (var cc4 = 0; cc4 < gridW; cc4++) {
      rooms[cr4][cc4].connections = {};
      if (rooms[cr4][cc4].type === 'wall' || rooms[cr4][cc4].type === 'water') continue;
      for (var di4 = 0; di4 < dirs4.length; di4++) {
        var anr4 = cr4 + dirs4[di4].dr, anc4 = cc4 + dirs4[di4].dc;
        if (anr4 >= 0 && anr4 < gridH && anc4 >= 0 && anc4 < gridW && rooms[anr4][anc4].type !== 'wall' && rooms[anr4][anc4].type !== 'water') {
          rooms[cr4][cc4].connections[dirs4[di4].key] = true;
        }
      }
    }
  }

  var map = { rows: gridH, cols: gridW, rooms: rooms, startR: startR, startC: startC, bossR: bossR, bossC: bossC, name: cfg.name };
  _mapCache[locId] = map;
  return map;
}

function getMapForLocation() {
  return generateMap(G.location);
}

function getRoom(map, r, c) {
  if (r < 0 || r >= map.rows || c < 0 || c >= map.cols) return null;
  return map.rooms[r][c];
}

function canMove(map, r, c) {
  var room = getRoom(map, r, c);
  if (!room) return false;
  if (room.type === 'wall' || room.type === 'water') return false;
  // Check if there's a connection from current position to target
  if (G.miniMapPos) {
    var curRoom = getRoom(map, G.miniMapPos.r, G.miniMapPos.c);
    if (curRoom) {
      var dr = r - G.miniMapPos.r, dc = c - G.miniMapPos.c;
      var dirKey = '';
      if (dr === -1 && dc === 0) dirKey = 'north';
      else if (dr === 1 && dc === 0) dirKey = 'south';
      else if (dr === 0 && dc === -1) dirKey = 'west';
      else if (dr === 0 && dc === 1) dirKey = 'east';
      if (dirKey && !curRoom.connections[dirKey]) return false;
    }
  }
  return true;
}

