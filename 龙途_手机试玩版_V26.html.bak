    objectives: [
      { id:'ch3_go_ironridge', desc:'前往铁岭城', type:'visit_location', location:'ironridge' },
      { id:'ch3_talk_lord_iron', desc:'与铁岭城主交谈', type:'talk_to_npc', npc:'lord_iron' },
      { id:'ch3_talk_hank', desc:'与瘸腿汉克交谈,了解矿洞情况', type:'talk_to_npc', npc:'hank' }
    ],
    next: 'ch3_mine_explore',
    reward: { xp:150, gold:80 }
  },
  {
