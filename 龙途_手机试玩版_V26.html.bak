    enemies:['dragon_cultist','shadow_drake','temple_golem'],
    townDesc:'殿堂深处传来低沉的龙吟,石柱上雕刻的龙纹仿佛在缓缓蠕动。祭司的诵经声回荡在高耸的穹顶下,烛火在无风中摇曳。每一块地砖都刻着古老的龙语铭文,踩上去隐约能感受到大地的震颤。' },
  ashplains: { id:'ashplains', x:350, y:400, name:'灰烬平原', type:'wild', emoji:'🔥', unlocked:false, levelRange:[65,75],
    desc:'龙息烧焦的荒原,地面上还冒着青烟',
    mapConfig:{ cols:22, rows:20, name:'灰烬平原', enemyRate:0.24, treasureRate:0.12, eventRate:0.08,
