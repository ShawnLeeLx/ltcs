// Check if tutorial should show for current scene/event
function _checkTutorial(trigger) {
  // null = existing save (pre-tutorial), treat as done
  if (!G._tutorial) return;
  if (G._tutorial.done || G._tutorial.skipped) return;
  var step = TUTORIAL_STEPS[G._tutorial.step];
  if (!step) return;
  if (step.trigger !== trigger) return;
  // Reset chain counter when trigger fires from scene event
  G._tutorial._chainCount = 0;
  // Show the tutorial overlay
  _showTutorialStep(G._tutorial.step);
}

function _showTutorialStep(stepIdx) {
  var step = TUTORIAL_STEPS[stepIdx];
  if (!step) return;

  var overlay = document.getElementById('tutorial_overlay');
  if (overlay) overlay.remove();

  var total = TUTORIAL_STEPS.length;
  var current = stepIdx + 1;

  // Create overlay
  var div = document.createElement('div');
  div.id = 'tutorial_overlay';
  div.style.cssText = 'position:fixed;top:0;left:0;right:0;bottom:0;z-index:10000;display:flex;align-items:center;justify-content:center;background:rgba(0,0,0,0.6);pointer-events:auto;';

  var box = '';
  box += '<div style="max-width:400px;width:90%;background:#1a1a2e;border:2px solid #7ec8e3;border-radius:12px;padding:20px;box-shadow:0 0 30px rgba(126,200,227,0.3)">';
  // Progress bar
  box += '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:12px">';
  box += '<span style="color:#7ec8e3;font-size:0.85em">' + current + '/' + total + '</span>';
  box += '<div style="flex:1;margin:0 8px;height:4px;background:#2a2a3e;border-radius:2px;overflow:hidden">';
  box += '<div style="width:' + Math.floor(current/total*100) + '%;height:100%;background:linear-gradient(90deg,#7ec8e3,#a78bfa);border-radius:2px"></div>';
  box += '</div>';
  box += '</div>';
  // Title
  box += '<div style="color:#7ec8e3;font-size:1.2em;font-weight:bold;margin-bottom:8px">' + step.title + '</div>';
  // Body
  box += '<div style="color:#c0c0c0;font-size:0.9em;line-height:1.6;margin-bottom:12px;white-space:pre-line">' + step.text + '</div>';
  // Tip
  if (step.tip) {
    box += '<div style="padding:8px 10px;background:#0d1520;border:1px solid #3a5a7a;border-radius:6px;font-size:0.8em;color:#7ec8e3;line-height:1.4;margin-bottom:12px">💡 ' + step.tip + '</div>';
  }
  // Buttons
  box += '<div style="display:flex;gap:8px">';
  if (stepIdx < total - 1) {
    box += '<button onclick="_tutorialNext()" style="flex:1;padding:8px;border:1px solid #7ec8e3;background:#1a2a3a;color:#7ec8e3;border-radius:6px;cursor:pointer;font-size:0.9em">下一步 ▶</button>';
  } else {
    box += '<button onclick="_tutorialFinish()" style="flex:1;padding:8px;border:1px solid #22c55e;background:#1a2a1a;color:#22c55e;border-radius:6px;cursor:pointer;font-size:0.9em">✅ 开始冒险!</button>';
  }
  box += '<button onclick="_tutorialSkip()" style="padding:8px 12px;border:1px solid #555;background:#1a1a1a;color:#888;border-radius:6px;cursor:pointer;font-size:0.8em">跳过</button>';
  box += '</div>';
  box += '</div>';

  div.innerHTML = box;
  document.body.appendChild(div);

  // Highlight element if specified
  if (step.highlight) {
    var target = document.getElementById(step.highlight);
    if (target) {
      target.style.outline = '2px solid #7ec8e3';
      target.style.outlineOffset = '2px';
      target.style.zIndex = '10001';
      target.style.position = 'relative';
    }
  }
}

function _tutorialNext() {
  if (!G._tutorial) return;
  var overlay = document.getElementById('tutorial_overlay');
  if (overlay) overlay.remove();
  // Clear highlights
  _tutorialClearHighlights();
  G._tutorial.step++;
  if (G._tutorial.step >= TUTORIAL_STEPS.length) {
    G._tutorial.done = true;
    toast('🎉 新手引导完成! 祝你冒险愉快!');
    return;
  }
  // Auto-chain up to 3 same-trigger steps, then wait for re-trigger
  if (!G._tutorial._chainCount) G._tutorial._chainCount = 0;
  G._tutorial._chainCount++;
  var nextStep = TUTORIAL_STEPS[G._tutorial.step];
  if (nextStep && nextStep.trigger === TUTORIAL_STEPS[G._tutorial.step - 1].trigger && G._tutorial._chainCount < 3) {
    _showTutorialStep(G._tutorial.step);
  } else {
    G._tutorial._chainCount = 0; // reset for next trigger group
  }
}

function _tutorialSkip() {
  if (!G._tutorial) return;
  G._tutorial.skipped = true;
  var overlay = document.getElementById('tutorial_overlay');
  if (overlay) overlay.remove();
  _tutorialClearHighlights();
  toast('⏩ 新手引导已跳过。可在设置中重新开启。');
}

function _tutorialFinish() {
  if (!G._tutorial) return;
  G._tutorial.done = true;
  var overlay = document.getElementById('tutorial_overlay');
  if (overlay) overlay.remove();
  _tutorialClearHighlights();
  toast('🎉 新手引导完成! 祝你冒险愉快!');
}

function _tutorialClearHighlights() {
  // Remove all tutorial highlights
  var highlighted = document.querySelectorAll('[style*="outline: 2px solid rgb(126, 200, 227)"]');
  for (var i = 0; i < highlighted.length; i++) {
    highlighted[i].style.outline = '';
    highlighted[i].style.outlineOffset = '';
    highlighted[i].style.zIndex = '';
  }
}

// Restart tutorial from settings
function restartTutorial() {
  G._tutorial = { step: 0, done: false, skipped: false };
  _showTutorialStep(0);
}

// ═══════════════════════════════════════════════════════════
// WEATHER SYSTEM - 天气系统
// ═══════════════════════════════════════════════════════════

// Weather type definitions
var WEATHER_TYPES = {
  sunny:    { id:'sunny',    name:'晴朗',   emoji:'☀️',  desc:'阳光明媚,万物可见。',     atkMod:0,    defMod:0,    matkMod:0,    dodgeMod:0,   critMod:0,   encounterMod:0,   priceMod:0,   enemyAtkMod:0,    enemyHpMod:0,    travelMsg:'阳光洒在路面上,旅途轻快。' },
  cloudy:   { id:'cloudy',   name:'多云',   emoji:'⛅',  desc:'云层遮日,光线柔和。',     atkMod:0,    defMod:0,    matkMod:0,    dodgeMod:0,   critMod:0,   encounterMod:-0.02, priceMod:0,   enemyAtkMod:0,    enemyHpMod:0,    travelMsg:'云朵飘过头顶,光影变幻。' },
  rainy:    { id:'rainy',    name:'雨天',   emoji:'🌧️', desc:'雨水淅沥,视野模糊。',     atkMod:-0.05,defMod:-0.03,matkMod:0,    dodgeMod:-0.05,critMod:-0.03,encounterMod:0.05, priceMod:0.05,enemyAtkMod:0,    enemyHpMod:0.05, travelMsg:'细雨湿了衣衫,道路泥泞难行。' },
  storm:    { id:'storm',    name:'暴风雨', emoji:'⛈️',  desc:'雷鸣电闪,风雨大作!',      atkMod:-0.10,defMod:-0.08,matkMod:0.05, dodgeMod:-0.10,critMod:0.05,encounterMod:0.15, priceMod:0.10,enemyAtkMod:0.10, enemyHpMod:0.05, travelMsg:'暴风骤雨,几乎看不清前方!' },
  foggy:    { id:'foggy',    name:'大雾',   emoji:'🌫️', desc:'浓雾弥漫,方向难辨。',     atkMod:-0.03,defMod:0.03, matkMod:-0.05,dodgeMod:0.05, critMod:0,   encounterMod:0.08, priceMod:0,   enemyAtkMod:0.05, enemyHpMod:0,    travelMsg:'雾气缭绕,四周一片朦胧。' },
  snowy:    { id:'snowy',    name:'降雪',   emoji:'❄️', desc:'雪花纷飞,天寒地冻。',     atkMod:-0.08,defMod:0.05, matkMod:-0.03,dodgeMod:-0.05,critMod:0,   encounterMod:0.03, priceMod:0.08,enemyAtkMod:0.03, enemyHpMod:0.05, travelMsg:'白雪覆盖了道路,寒风刺骨。' },
  blizzard: { id:'blizzard', name:'暴风雪', emoji:'🌨️', desc:'暴风雪肆虐,能见度极低!',  atkMod:-0.15,defMod:0.08, matkMod:-0.10,dodgeMod:-0.12,critMod:0.05,encounterMod:0.20, priceMod:0.15,enemyAtkMod:0.15, enemyHpMod:0.10, travelMsg:'暴风雪呼啸,寸步难行!' },
  heatwave: { id:'heatwave', name:'酷暑',   emoji:'🔥', desc:'热浪袭人,体力消耗加剧。', atkMod:-0.05,defMod:-0.05,matkMod:0.05, dodgeMod:0,    critMod:0.03,encounterMod:-0.05,priceMod:-0.05,enemyAtkMod:0.08, enemyHpMod:-0.05,travelMsg:'烈日当空,汗水浸透了衣衫。' }
};

// Region-based weather probability tables
var WEATHER_REGIONS = {
  north: {
    name: '北方冻土',
    base: { sunny:0.10, cloudy:0.20, rainy:0.10, storm:0.05, foggy:0.15, snowy:0.25, blizzard:0.10, heatwave:0.05 }
  },
  central: {
    name: '中原沃土',
    base: { sunny:0.25, cloudy:0.25, rainy:0.20, storm:0.08, foggy:0.10, snowy:0.05, blizzard:0.02, heatwave:0.05 }
  },
  south: {
    name: '南方龙域',
    base: { sunny:0.20, cloudy:0.15, rainy:0.15, storm:0.10, foggy:0.10, snowy:0.02, blizzard:0.01, heatwave:0.27 }
  }
};

// Location → region mapping
var WEATHER_LOC_REGION = {
  // Central (中原沃土)
  whitecity:'central', lake:'central', darkforest:'central', fortress:'central',
  sunspire:'central', misthollow:'central', dragontemple:'central',
  // North (北方冻土)
  ironridge:'north', mine:'north', icereef:'north', snowpeak:'north',
  coastcave:'north', windisland:'north',
  // South (南方龙域)
  tidport:'south', dragonreach:'south', jademarsh:'south',
  volcano:'south', stormcape:'south', ashplains:'south',
  // Deep/remote (深渊/边域 - 默认central)
  abyssgate:'north', shadowrealm:'south', throneofages:'central'
};

// Weather change interval: every N scene transitions
var WEATHER_CHANGE_INTERVAL = 5;

// Determine region for a location
function _getWeatherRegion(locId) {
  return WEATHER_LOC_REGION[locId] || 'central';
}

// Roll a new weather for a region based on probability table
function _rollWeather(regionId) {
  var region = WEATHER_REGIONS[regionId];
  if (!region) region = WEATHER_REGIONS.central;
  var probs = region.base;
  var r = Math.random();
  var cum = 0;
  for (var wid in probs) {
    cum += probs[wid];
    if (r < cum) return wid;
  }
  return 'sunny';
}

// Initialize weather state if needed
function _initWeather() {
  if (!G._weather) {
    G._weather = {
      north: 'snowy',
      central: 'sunny',
      south: 'sunny',
      _transitionCount: 0
    };
  }
}

// Called on every scene transition; may change weather
function tickWeather() {
  _initWeather();
  G._weather._transitionCount = (G._weather._transitionCount || 0) + 1;
  if (G._weather._transitionCount >= WEATHER_CHANGE_INTERVAL) {
    G._weather._transitionCount = 0;
    // Roll new weather for each region (with 40% chance to stay same)
    var regions = ['north', 'central', 'south'];
    for (var i = 0; i < regions.length; i++) {
      if (Math.random() < 0.6) { // 60% chance to change
        G._weather[regions[i]] = _rollWeather(regions[i]);
      }
    }
  }
}

// Get current weather for a location
function getWeather(locId) {
  _initWeather();
  var region = _getWeatherRegion(locId);
  var wId = G._weather[region] || 'sunny';
  return WEATHER_TYPES[wId];
}

// Get weather modifier object for combat
function getWeatherCombatMods(locId) {
  var w = getWeather(locId);
  return { atkMod:w.atkMod, defMod:w.defMod, matkMod:w.matkMod, dodgeMod:w.dodgeMod, critMod:w.critMod };
}

// Get encounter rate modifier from weather
function getWeatherEncounterMod(locId) {
  return getWeather(locId).encounterMod || 0;
}

// Get price modifier from weather (affects trade)
function getWeatherPriceMod(locId) {
  return getWeather(locId).priceMod || 0;
}

// Weather-themed colors
function _weatherBgColor(wId) {
  var c = { sunny:'#1a1a0d', cloudy:'#1a1a1e', rainy:'#0d1520', storm:'#0d0d1a', foggy:'#1a1a1a', snowy:'#1a2030', blizzard:'#0d1a2a', heatwave:'#2a1a0d' };
  return c[wId] || '#1a1a1e';
}
function _weatherBorderColor(wId) {
  var c = { sunny:'#8a8a2a', cloudy:'#4a4a5a', rainy:'#2a4a6a', storm:'#1a2a8a', foggy:'#3a3a3a', snowy:'#4a6a8a', blizzard:'#3a5a9a', heatwave:'#8a4a2a' };
  return c[wId] || '#4a4a5a';
}
function _weatherTextColor(wId) {
  var c = { sunny:'#f1c40f', cloudy:'#b0b0c0', rainy:'#6a9fd4', storm:'#7070e0', foggy:'#9a9a9a', snowy:'#a0c8e8', blizzard:'#80b0f0', heatwave:'#f08040' };
  return c[wId] || '#b0b0c0';
}

// Render weather status bar for display in scenes
function renderWeatherBar(locId) {
  var w = getWeather(locId);
  var html = '';
  html += '<div style="margin:6px 0;padding:6px 10px;background:' + _weatherBgColor(w.id) + ';border:1px solid ' + _weatherBorderColor(w.id) + ';border-radius:6px;font-size:0.85em;display:flex;align-items:center;gap:8px">';
  html += '<span style="font-size:1.2em">' + w.emoji + '</span>';
  html += '<div>';
  html += '<div style="font-weight:bold;color:' + _weatherTextColor(w.id) + '">' + w.name + '</div>';
  html += '<div style="color:#aaa;font-size:0.8em">' + w.desc + '</div>';
  html += '</div>';
  // Show combat modifiers if any
  var mods = [];
  if (w.atkMod !== 0) mods.push('⚔️' + (w.atkMod > 0 ? '+' : '') + Math.round(w.atkMod * 100) + '%');
  if (w.defMod !== 0) mods.push('🛡️' + (w.defMod > 0 ? '+' : '') + Math.round(w.defMod * 100) + '%');
  if (w.matkMod !== 0) mods.push('🔮' + (w.matkMod > 0 ? '+' : '') + Math.round(w.matkMod * 100) + '%');
  if (w.dodgeMod !== 0) mods.push('🏃' + (w.dodgeMod > 0 ? '+' : '') + Math.round(w.dodgeMod * 100) + '%');
  if (w.critMod !== 0) mods.push('💥' + (w.critMod > 0 ? '+' : '') + Math.round(w.critMod * 100) + '%');
  if (mods.length > 0) {
    html += '<div style="font-size:0.75em;color:#888;margin-left:auto">' + mods.join(' ') + '</div>';
  }
  html += '</div>';
  return html;
}

// Apply weather modifiers to battle damage
function applyWeatherToDamage(dmg, isMagic, locId) {
  var mods = getWeatherCombatMods(locId);
  var mod = isMagic ? mods.matkMod : mods.atkMod;
  return Math.max(1, Math.round(dmg * (1 + mod)));
}

// Apply weather defense modifier
function applyWeatherToDef(baseDef, locId) {
  var mods = getWeatherCombatMods(locId);
  return Math.max(0, Math.round(baseDef * (1 + mods.defMod)));
}

// Apply weather dodge modifier
function applyWeatherDodge(baseDodge, locId) {
  var mods = getWeatherCombatMods(locId);
  return Math.max(0, baseDodge + mods.dodgeMod * 100);
}

// Apply weather crit modifier
function applyWeatherCrit(baseCrit, locId) {
  var mods = getWeatherCombatMods(locId);
  return Math.max(0, baseCrit + mods.critMod * 100);
}

// Weather forecast panel (accessible from town/world map)
function sceneWeatherForecast() {
  G._currentScene = 'sceneWeatherForecast';
  G._weatherCheckCount = (G._weatherCheckCount || 0) + 1;
  checkAchievements();
  var html = '';
  html += '<div class="scene-title">🌤️ 天气预报</div>';
  html += '<div style="color:#aaa;font-size:0.85em;margin-bottom:8px">各地天气影响战斗、旅行和商贸。</div>';
  var regions = [
    { id:'north', name:'北方冻土', emoji:'❄️', locs:['ironridge','icereef','mine','frostpeak'] },
    { id:'central', name:'中原沃土', emoji:'🌿', locs:['whitecity','lake','darkforest','fortress','sunspire'] },
    { id:'south', name:'南方龙域', emoji:'🔥', locs:['tidport','dragonreach','swamp','volcano','dragonpeak'] }
  ];
  for (var r = 0; r < regions.length; r++) {
    var reg = regions[r];
    var w = getWeather(reg.locs[0] || 'whitecity');
    html += '<div style="margin:8px 0;padding:10px;background:' + _weatherBgColor(w.id) + ';border:1px solid ' + _weatherBorderColor(w.id) + ';border-radius:8px">';
    html += '<div style="display:flex;align-items:center;gap:8px;margin-bottom:6px">';
    html += '<span style="font-size:1.4em">' + w.emoji + '</span>';
    html += '<div>';
    html += '<div style="font-weight:bold;color:' + _weatherTextColor(w.id) + ';font-size:1.05em">' + reg.emoji + ' ' + reg.name + '</div>';
    html += '<div style="color:#c0c0c0">' + w.name + ' — ' + w.desc + '</div>';
    html += '</div></div>';
    // Effects breakdown
    html += '<div style="margin-top:6px;padding:6px;background:#0d1117;border-radius:4px;font-size:0.82em">';
    html += '<div style="color:#d4a017;margin-bottom:3px">⚡ 天气效果</div>';
    var effects = [];
    if (w.atkMod !== 0) effects.push('物攻' + (w.atkMod > 0 ? '+' : '') + Math.round(w.atkMod * 100) + '%');
    if (w.defMod !== 0) effects.push('防御' + (w.defMod > 0 ? '+' : '') + Math.round(w.defMod * 100) + '%');
    if (w.matkMod !== 0) effects.push('魔攻' + (w.matkMod > 0 ? '+' : '') + Math.round(w.matkMod * 100) + '%');
    if (w.dodgeMod !== 0) effects.push('闪避' + (w.dodgeMod > 0 ? '+' : '') + Math.round(w.dodgeMod * 100) + '%');
    if (w.critMod !== 0) effects.push('暴击' + (w.critMod > 0 ? '+' : '') + Math.round(w.critMod * 100) + '%');
    if (w.encounterMod !== 0) effects.push('遇敌率' + (w.encounterMod > 0 ? '+' : '') + Math.round(w.encounterMod * 100) + '%');
    if (w.priceMod !== 0) effects.push('物价' + (w.priceMod > 0 ? '+' : '') + Math.round(w.priceMod * 100) + '%');
    html += '<div style="color:#c0d0e0">' + (effects.length > 0 ? effects.join(' · ') : '无额外效果') + '</div>';
    html += '</div>';
    // Unlocked locations in this region
    var unlockedLocs = [];
    for (var li = 0; li < reg.locs.length; li++) {
      if (LOCATIONS[reg.locs[li]] && LOCATIONS[reg.locs[li]].unlocked) unlockedLocs.push(LOCATIONS[reg.locs[li]].name);
    }
    if (unlockedLocs.length > 0) {
      html += '<div style="margin-top:4px;font-size:0.8em;color:#888">📍 已解锁:' + unlockedLocs.join('、') + '</div>';
    }
    html += '</div>';
  }
  html += '<div style="margin:8px 0;padding:6px 10px;background:#0d1117;border-radius:4px;font-size:0.8em;color:#888">';
  html += '💡 天气每' + WEATHER_CHANGE_INTERVAL + '次场景切换后可能变化。不同区域天气独立。恶劣天气提高遇敌率但可能影响战斗属性。';
  html += '</div>';
  html += '<div class="btns">';
  html += '<button class="btn" onclick="sceneTown()">↩️ 返回城镇</button>';
  html += '</div>';
  render(html);
}

// Auto-start
window.onload = function() {
  initGame();
  sceneIntro();
};

// D3: Mobile touch helpers
(function() {
  // Prevent double-tap zoom on mobile
  var lastTouchEnd = 0;
  document.addEventListener('touchend', function(e) {
    var now = Date.now();
    if (now - lastTouchEnd <= 300) e.preventDefault();
    lastTouchEnd = now;
  }, { passive: false });

  // Swipe right = go back (edge gesture)
  var swipeStartX = 0, swipeStartY = 0, swipeInMap = false;
  document.addEventListener('touchstart', function(e) {
    swipeStartX = e.touches[0].clientX;
    swipeStartY = e.touches[0].clientY;
    // Check if touch is in the map viewport
    var vp = document.getElementById('mapViewport');
    swipeInMap = vp && vp.contains(e.target);
  }, { passive: true });
  document.addEventListener('touchend', function(e) {
    if (!G || G.inBattle) return;
    var dx = e.changedTouches[0].clientX - swipeStartX;
    var dy = e.changedTouches[0].clientY - swipeStartY;
    // Swipe from left edge = go back
    if (swipeStartX < 30 && dx > 100 && Math.abs(dy) < 60) {
      if (G._currentScene && G._currentScene !== 'sceneIntro') {
        if (G._lastSaveScene === 'sceneTown' || G.location) sceneTown();
      }
      return;
    }
    // Swipe on map = move in that direction
    if (swipeInMap && G.miniMapPos && Math.abs(dx) > 40 && Math.abs(dx) > Math.abs(dy)) {
      if (dx > 0) moveGrid('0', '1');   // swipe right = move east
      else moveGrid('0', '-1');          // swipe left = move west
    } else if (swipeInMap && G.miniMapPos && Math.abs(dy) > 40 && Math.abs(dy) > Math.abs(dx)) {
      if (dy > 0) moveGrid('1', '0');    // swipe down = move south
      else moveGrid('-1', '0');           // swipe up = move north
    }
  }, { passive: true });
})();

// PWA Service Worker registration
if ('serviceWorker' in navigator) {
  navigator.serviceWorker.register('pwa/sw.js').then(function(reg) {
    console.log('SW registered:', reg.scope);
    reg.addEventListener('updatefound', function() {
      var newWorker = reg.installing;
      newWorker.addEventListener('statechange', function() {
        if (newWorker.state === 'activated') {
          // New version available - could notify user
          console.log('New version activated');
        }
      });
    });
  }).catch(function(err) { console.log('SW registration failed:', err); });
}
</script></body></html>
