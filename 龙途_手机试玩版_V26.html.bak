    choices: [
      { id:'ch11c1_altruist', requiresFavor:{npc:'captain_storm',min:70}, text:'🌍 "为了拯救世界" - 利他路线', effect:'altruist', desc:'最终战获得NPC助战,但个人属性略低' },
      { id:'ch11c2_ego', text:'💪 "为了证明自己" - 利己路线', effect:'ego', desc:'最终战无NPC助战,但个人属性+10%' },
      { id:'ch11c3_balance', text:'⚖️ "为了平衡二者" - 平衡路线', effect:'balance', desc:'最终战获得一半NPC助战,属性+5%' }
    ]
  }
};

function applyStoryChoice(effect) {
  // P0-2: Check favor requirements
  var _ch = null;
  for (var _gk in STORY_CHOICES) {
    var _grp = STORY_CHOICES[_gk];
    if (_grp.choices) {
      for (var _cj = 0; _cj < _grp.choices.length; _cj++) {
        if (_grp.choices[_cj].effect === effect) { _ch = _grp.choices[_cj]; break; }
      }
    }
    if (_ch) break;
  }
  if (_ch && _ch.requiresFavor) {
    var _rf = _ch.requiresFavor;
    var _curLv = (G.npcRelations[_rf.npc] || {level:0}).level;
    if (_curLv < _rf.min) {
      var _nn = NPC_DEFS[_rf.npc] ? NPC_DEFS[_rf.npc].name : _rf.npc;
      toast('\ud83d\udd12 需要与' + _nn + '达到' + getNpcAffectionTierByMin(_rf.min) + '关系 (当前' + _curLv + '/需' + _rf.min + ')');
      return;
    }
  }
  if (!G.storyChoices) G.storyChoices = {};
  if (G.storyChoices[effect]) return;
  G.storyChoices[effect] = true;
  if (!G.permStats) G.permStats = {};
  switch(effect) {
    case 'combat_bonus': G.permStats.str = (G.permStats.str||0) + 2; break;
    case 'scout_bonus': G.permStats.agi = (G.permStats.agi||0) + 2; break;
    case 'social_bonus': G.permStats.cha = (G.permStats.cha||0) + 2; G._socialBonus = (G._socialBonus||0) + 0.1; break;
    case 'east_path': G._eastPath = true; G._lootBonus = (G._lootBonus||0) + 0.2; break;
    case 'west_path': G._westPath = true; break;
    case 'atk_bonus': G.permStats.str = (G.permStats.str||0) + 3; break;
    case 'int_bonus': G.permStats.int = (G.permStats.int||0) + 3; break;
    case 'luk_bonus': G.permStats.luk = (G.permStats.luk||0) + 3; G._lootBonus = (G._lootBonus||0) + 0.15; break;
    case 'dragon_ally': G._dragonAlly = true; break;
    case 'human_ally': G._humanAlly = true; break;
    case 'neutral_path': G._neutralPath = true; break;
    case 'altruist': G._altruistRoute = true; break;
    case 'ego': G._egoRoute = true; break;
    case 'balance': G._balanceRoute = true; break;
    // Ch2 seal choice
    case 'seal_chosen': G._sealChosen = true; G._shadowReduction = (G._shadowReduction||0) + 0.1; break;
    case 'keep_tablet': G.inventory.push({id:'rune_tablet',name:'古老符文石板',type:'equipment',slot:'necklace',rarity:'epic',rarityColor:'#a335ee',str:5,agi:5,int:5,cha:5,luk:5,atk:5,def:5,hp:50,sellPrice:0,icon:'🪨'}); break;
    // Ch3 aftermine choice
    case 'prepare_path': G.gold += 200; G.permStats.str = (G.permStats.str||0)+2; G.permStats.agi = (G.permStats.agi||0)+2; G.permStats.int = (G.permStats.int||0)+2; break;
    case 'rush_path': G._rushPath = true; break;
    case 'hank_path': G.inventory.push({id:'hank_pickaxe',name:'汉克的旧矿镐',type:'equipment',slot:'weapon',rarity:'legendary',rarityColor:'#ff8000',atk:25,str:8,critRate:0.15,sellPrice:0,icon:'⛏️'}); break;
    // Ch5 jade choice
    case 'return_heart': G._heartReturned = true; G._shadowReduction = (G._shadowReduction||0) + 0.15; break;
    case 'take_heart': G._heartTaken = true; G.inventory.push({id:'jade_heart',name:'翡翠之心',type:'equipment',slot:'necklace',rarity:'epic',rarityColor:'#00ff88',str:4,agi:4,int:4,cha:4,luk:4,atk:4,def:4,sellPrice:0,icon:'💎'}); break;
    case 'shard_heart': G._heartShard = true; G.inventory.push({id:'jade_shard',name:'翡翠碎片',type:'equipment',slot:'necklace',rarity:'rare',rarityColor:'#0070dd',str:2,agi:2,int:2,cha:2,luk:2,atk:2,def:2,sellPrice:0,icon:'💚'}); break;
    // Ch6 sunspire choice
    case 'seek_truth': G.permStats.int = (G.permStats.int||0) + 3; G._seekTruth = true; break;
    case 'do_duty': G.permStats.str = (G.permStats.str||0) + 3; G._critBonus = (G._critBonus||0) + 0.05; break;
    case 'seek_mercy': G.permStats.cha = (G.permStats.cha||0) + 3; G._seekMercy = true; break;
    // Ch8 temple choice
    case 'mercy_kill': G._mercyKill = true; G.inventory.push({id:'frost_armor',name:'龙鳞战甲',type:'equipment',slot:'armor',rarity:'epic',rarityColor:'#a335ee',def:10,hp:30,sellPrice:0,icon:'🛡️'}); break;
    case 'purify_frost': G._purifyFrost = true; break;
    case 'delay_frost': G._delayFrost = true; break;
    // Ch9 ash choice
    case 'destroy_shadow': G.permStats.str = (G.permStats.str||0) + 5; G._destroyShadow = true; break;
    case 'understand_shadow': G.permStats.int = (G.permStats.int||0) + 5; G._understandShadow = true; break;
    case 'ash_neutral': G.permStats.str = (G.permStats.str||0)+2; G.permStats.agi = (G.permStats.agi||0)+2; G.permStats.int = (G.permStats.int||0)+2; break;
    // Ch10 volcano choice
    case 'resist_whisper': G.permStats.int = (G.permStats.int||0) + 2; G._resistWhisper = true; break;
    case 'listen_whisper': G.permStats.str = (G.permStats.str||0) + 8; G._listenWhisper = true; break;
    case 'share_whisper': G.permStats.cha = (G.permStats.cha||0) + 3; G._shareWhisper = true; break;
    // Ch12 final choice
    case 'final_destroy': G._finalDestroy = true; break;
    case 'final_accept': G._finalAccept = true; break;
    case 'final_sacrifice': G._finalSacrifice = true; break;
  }
  if (!G.storyProgress.chosenEffects) G.storyProgress.chosenEffects = [];
  G.storyProgress.chosenEffects.push(effect);
  autoSave();
  toast('✦ 命运的分支已改变......');
}

function showStoryChoice(chapterId) {
  var choiceData = STORY_CHOICES[chapterId];
  if (!choiceData) return false;
  if (G.storyChoices && G.storyChoices[chapterId]) return false;
  var html = '';
  html += '<div class="scene-title">✦ 命运的选择</div>';
  html += '<div style="margin:8px 0;padding:10px;background:#1a1a2e;border-radius:8px;border:1px solid #d4a017;font-size:0.9em;line-height:1.5">';
  html += '<div style="color:#d4a017;font-weight:bold;margin-bottom:4px">' + choiceData.title + '</div>';
  html += '<div style="color:#c0c0c0">' + choiceData.desc + '</div>';
  html += '</div>';
  html += '<div style="margin:8px 0">';
  for (var ci = 0; ci < choiceData.choices.length; ci++) {
    var c = choiceData.choices[ci];
    // Check prerequisites for ch12 final choices
    var locked = false;
    var lockReason = '';
    if (c.effect === 'final_accept' && !G._seekMercy && !G._understandShadow) {
      locked = true; lockReason = '需要在之前选择过「寻求和解」或「理解暗影」';
    }
    if (c.effect === 'final_sacrifice' && !G._altruistRoute && !G._purifyFrost) {
      locked = true; lockReason = '需要在之前选择过「利他主义」或「净化霜翼」';
    }
    // P0-2: Favor requirement check
    if (c.requiresFavor) {
      var _rfc = c.requiresFavor;
      var _rfLv = (G.npcRelations[_rfc.npc] || {level:0}).level;
      if (_rfLv < _rfc.min) {
        locked = true;
        var _rfNpcName = NPC_DEFS[_rfc.npc] ? NPC_DEFS[_rfc.npc].name : _rfc.npc;
        lockReason = '需要与' + _rfNpcName + '达到' + getNpcAffectionTierByMin(_rfc.min) + '关系 (当前' + _rfLv + '/需' + _rfc.min + ')';
      }
    }
    var bgStyle = locked ? 'background:#111;opacity:0.5' : 'background:#16213e';
    var clickAction = locked ? '' : ' onclick="selectStoryChoice(\''+chapterId+'\',\''+c.effect+'\')"';
    var cursorStyle = locked ? 'cursor:not-allowed' : 'cursor:pointer';
    html += '<div style="margin:6px 0;padding:10px;'+bgStyle+';border-radius:8px;border:1px solid #333;'+cursorStyle+'"'+clickAction+'>';
    html += '<div style="font-weight:bold;margin-bottom:4px">' + (locked ? '🔒 ' : '') + c.text + '</div>';
    html += '<div style="font-size:0.8em;color:#888">' + c.desc + '</div>';
    if (locked) html += '<div style="font-size:0.75em;color:#c44;margin-top:4px">⚠️ ' + lockReason + '</div>';
    html += '</div>';
  }
  html += '</div>';
  render(html);
  return true;
}

function selectStoryChoice(chapterId, effect) {
  if (!G.storyChoices) G.storyChoices = {};
  G.storyChoices[chapterId] = effect;  // mark chapter as chosen
  applyStoryChoice(effect);
  // Advance any make_choice objectives matching this choiceId
  var ch = getCurrentChapter();
  if (ch) {
    for (var i = 0; i < ch.objectives.length; i++) {
      var obj = ch.objectives[i];
      if (obj.type === 'make_choice' && obj.choiceId === chapterId) {
        advanceStoryObj(obj.id);
      }
    }
  }
  // Return to previous scene instead of forcing showStory()
  var returnTo = G._currentScene || 'sceneWorldMap';
  // If we came from showStory, go back to story view
  if (_questReturnTo) returnTo = _questReturnTo;
  var fn = window[returnTo];
  if (typeof fn === 'function') fn();
  else sceneWorldMap();
}



// ═══════════════════════════════════════════════════════════
// CHAPTER INTROS & NPC DIALOGS - Story immersion system
// ═══════════════════════════════════════════════════════════

var CHAPTER_INTROS = {
  ch1_arrival: {
    title: '第一章', subtitle: '白城异乡客',
    quote: '"白城的城墙高百丈,据说用龙族的骨骸混合圣白石砌成。千年来,它挡住了兽潮、瘟疫和战争。但今天,它挡不住命运。"\n--《艾尔德兰编年史·卷一》',
    narration: '你踏入了白城的城门。城墙上的守卫漠然扫了你一眼——这种地方,每天都有陌生人来,也每天都有人消失。\n\n三天前在酒馆听到的传闻还在耳边回响：「坠星湖，夜里会发光。」而那张纸条上的字迹更令人不安：「去找旅店老板娘，她知道更多。」'
  },
  ch1_lake_mystery: {
    title: '第一章', subtitle: '湖底的光',
    quote: '"坠星湖的湖水永远不会结冰,即使在最冷的冬天。老人们说,那是因为湖底沉睡着一头龙的灵魂。"\n--白城老猎户',
    narration: '老板娘的讲述让你坐立不安。坠星湖的光芒已经持续七天七夜,公会的冒险者去了几个,都没回来。\n\n她递给你一把后门钥匙,低声说：「夜里可以绕过守卫直接出城。别说是我给的。」'
  },
  ch1_lake_explore: {
    title: '第一章', subtitle: '湖畔异变',
    quote: '"当哥布林开始崇拜龙的时候,就意味着有什么东西正在苏醒。"\n--法师塔首席学者艾琳娜',
    narration: '用老板娘的钥匙从后门溜出白城,坠星湖的轮廓在夜色中浮现。\n\n湖面确实在发光——从水底渗出的幽蓝色光芒。地面上有凌乱的哥布林脚印,而且……脚印是朝向湖心的。远处传来哥布林的尖叫声,夹杂着更低沉的嘶吼。'
  },
  ch1_boss_pre: {
    title: '第一章', subtitle: '湖底巨影',
    quote: '"有些东西被埋在湖底太久,久到它忘记了自己为什么被埋在这里。"\n--无名石碑铭文',
    narration: '地图碎片拼凑出一部分信息:坠星湖底有一个被淹没的古代建筑入口,哥布林们在守护它。\n\n水面突然剧烈翻涌——一个体型远超普通哥布林的巨型身影从湖心破水而出。那双发光的红眼清晰可见。\n\n「……退后……」一个低沉的声音在你脑海中响起。'
  },
  ch2_forest_warning: {
    title: '第二章', subtitle: '残片的线索',
    quote: '"幽暗森林的树木会说话——只要你愿意倾听。但大部分听到它们声音的人,再也没有走出来。"\n--失踪的游侠瓦恩',
    narration: '击败湖畔首领后,你找到了一块刻有符文的石板。石板上的文字不是任何你能辨识的语言——但奇怪的是,你居然能隐约理解它的意思:\n\n「……封印正在减弱……森林深处的东西快要出来了……」\n\n白城的学者艾琳娜或许能帮你翻译。但首先,你需要穿过幽暗森林。'
  },
  ch2_fortress_discovery: {
    title: '第二章', subtitle: '破碎堡垒',
    quote: '"破碎堡垒的城墙曾经是世界上最坚固的防线。直到他们从内部打开了那扇不该打开的门。"\n--佣兵工会编年史',
    narration: '艾琳娜的翻译指向「破碎堡垒」——古代封印的核心。\n\n但当你抵达堡垒外围,发现这里已经被一股武装力量占据——穿着黑色铠甲的黑铁兄弟会。他们在挖掘什么。\n\n堡垒门口的告示牌写着：「禁令：任何人不得入内。违者格杀勿论。——黑铁兄弟会」'
  },
  ch2_fortress_boss: {
    title: '第二章', subtitle: '堡垒之下',
    quote: '"封印不是用来关住恶魔的。它是用来保护恶魔的。因为一旦封印破碎,被释放的不仅是恶魔——还有它千年来积攒的愤怒。"\n--第一纪元封印铭文',
    narration: '密信揭示:黑铁兄弟会不是在守护堡垒,他们在挖掘封印室。封印接近崩溃。\n\n封印室的大门已经半开。门后的黑暗中,有什么东西在动。你听到了成千上万的低语声,汇聚成一个词:\n\n「……自由……」'
  },
  ch3_mine_entrance: {
    title: '第三章', subtitle: '铁岭的求救',
    quote: '"矿洞深处有一扇门。没有人知道门后面是什么,因为所有试图打开它的人,都再也没有回来。"\n--矿工老吴的最后遗言',
    narration: '修复了部分封印后,艾琳娜告诉你真相:坠星湖只是三个封印点之一。另外两个在铁岭城下方矿洞和龙域。\n\n她给了你一封推荐信,让你去铁岭城找矿王。只有他能让你进入矿井深处。'
  },
  ch3_mine_explore: {
    title: '第三章', subtitle: '地底黑潮',
    quote: '"不要相信城主说的话。矿洞底下确实有东西,但不是他在公告里说的「稀有矿脉」。那是……某种活的东西。它在动,而且它在生长。"\n--瘸腿汉克',
    narration: '汉克的警告在你脑中回响。你举着火把深入矿道。\n\n越往深处走,空气越稠密,带着甜腥味。然后你看到了——矿道壁面布满了暗紫色的脉络,像血管一样在跳动。'
  },
  ch3_mine_boss: {
    title: '第三章', subtitle: '矿洞之心',
    quote: '"第二封印点,守护者:铁岭。若汝至此,则三锁已开其二。最后一锁在龙域深处,而暗影已在前方等待。"\n--矿洞石碑铭文',
    narration: '脉络的尽头是一个巨大的地下空洞。空洞中央「生长」着一棵树——由暗影凝聚而成,枝干如同黑色水晶,叶片是暗紫色的薄雾。\n\n树根扎入地底,与更深处某种东西相连。它每一次脉动,都有一股暗影能量顺着脉络传向远方。\n\n「砍倒它。」那个低沉的声音又出现了,「它是封印的另一把钥匙——一把被扭曲了的钥匙。」'
  },
  ch4_mist_enter: {
    title: '第四章', subtitle: '迷雾深渊·入谷',
    quote: '"迷雾里有眼睛在看着你。你感觉得到吗?它们不是敌人,但也不是朋友。"\n--雾隐谷幸存者笔记',
    narration: '雾气从你踏入谷口的那一刻起就缠绕住了你。这不是普通的雾——它带着淡淡的甜味,像是某种花粉,又像是......记忆。\n\n你看到了一些碎片般的画面:精灵在树下歌唱,龙在云端盘旋,然后一切都被黑暗吞没了。\n\n「只有真诚之心,才能穿过迷雾。」日志上的话在你脑海中回响。'
  },
  ch4_mist_deep: {
    title: '第四章', subtitle: '迷雾深渊·精灵遗迹',
    quote: '"精灵不建造城市。他们种下种子,等待它长成殿堂。这些遗迹,是一千年的等待留下的残骸。"\n--雾中精灵',
    narration: '穿过迷雾,精灵遗迹出现在你面前。柱子上仍然爬满了银色的藤蔓,像流淌的月光。\n\n但遗迹中弥漫着不祥的气息——暗影在石柱间游走,侵蚀着古老的符文。曾经净化的力量,正在一点一点地被吞噬。'
  },
  ch4_mist_choice: {
    title: '第四章', subtitle: '迷雾深渊·符文抉择',
    quote: '"力量是火焰,烧尽一切。智慧是清水,润泽万物。自然是大地,承载生灭。三种道路,一种结局——你选哪种?"\n--精灵三圣铭文',
    narration: '三座符文石阵,三种光芒。红如血,蓝如星,绿如春。\n\n你伸出的手悬在空中。雾中精灵的声音从远处飘来:「无论你选择哪一条,都请记住——路不止一条。」'
  },
  ch5_jade_enter: {
    title: '第五章', subtitle: '翡翠沼泽·毒瘴',
    quote: '"翡翠沼泽曾经是精灵族的花园。现在?现在它只是一座华丽的坟墓。"\n--游侠迦伦的最后一封信',
    narration: '沼泽的毒气刺激着你的鼻腔。曾经清澈的水域如今泛着诡异的绿光,水面上漂浮着变异生物的尸体。\n\n远处,一座半沉没的精灵神庙露出了水面。你需要找到一种方法穿过毒气。'
  },
  ch5_jade_temple: {
    title: '第五章', subtitle: '翡翠沼泽·沉没神殿',
    quote: '"精灵不会让他们的珍宝沉入水中。除非......那颗心自己选择了沉没。"\n--沼泽巫医',
    narration: '水下,精灵神殿完好无损。绿色结界隔绝了毒水,殿中央,翡翠之心在跳动。\n\n它像一颗真正的心脏——绿色的光随着脉动扩散,每一次跳动都在净化周围的水。\n\n但当你靠近它时,神殿的结界开始出现裂痕。'
  },
  ch5_jade_choice: {
    title: '第五章', subtitle: '翡翠沼泽·心之抉择',
    quote: '"心不属于任何人。但每个人都需要一颗心。"\n--翡翠守护者遗言',
    narration: '翡翠之心在你手中跳动。它很温暖,比你想像的更温暖。\n\n神庙在崩塌,毒水在涌入。归还它,或许能拯救这片沼泽。带走它,你将有力量面对龙域的暗影。\n\n时间不多了。你必须在废墟中选择。'
  },
  ch6_sunspire_enter: {
    title: '第六章', subtitle: '日冕高塔·学术之都',
    quote: '"知识是最锋利的武器。但有时候,它也是最沉重的枷锁。"\n--大贤者伊兰',
    narration: '日冕塔的学者们用奇怪的眼神看着你。他们很少见到外来者,更少见识到翡翠之心这样的上古遗物。\n\n大贤者伊兰在最高的塔顶接见了你。她的眼睛是淡紫色的——那是长期使用奥术的痕迹。「你知道这是什么,对吗?」她轻声问。'
  },
  ch6_sunspire_research: {
    title: '第六章', subtitle: '日冕高塔·古代文献',
    quote: '"历史不是过去。它是未来的回声。"\n--日冕塔格言',
    narration: '禁书库的空气中弥漫着古老纸张的气味。伊兰翻开一本厚重的古籍,上面的文字在你眼前跳动。\n\n「暗影不是天灾,」伊兰合上书,「它是第一纪元的造物。一件失控的武器。」\n\n窗外,风暴角的方向电闪雷鸣。通往龙域的路,就在那风暴之后。'
  },
  ch6_sunspire_choice: {
    title: '第六章', subtitle: '日冕高塔·临行抉择',
    quote: '"出发前最重要的不是准备,而是知道自己为什么要出发。"\n--风暴船长的航海格言',
    narration: '伊兰的问题在你脑中回响:如果真相会毁掉你的信念呢?\n\n你站在日冕塔的门口,风暴角的风声从远处传来。明天,你将踏入龙域。今夜,你需要想清楚——你为什么而战?'
  },
  ch7_dragon_enter: {
    title: '第七章', subtitle: '龙之门槛·边境',
    quote: '"龙域不是被攻陷的,它是被放弃的。某种比战争更可怕的东西,让龙族选择了撤退。"\n--龙域边境守卫长卡尔',
    narration: '北方的天空是灰色的。龙域边境的城墙虽然还在,但城垛上已经长满了荒草。\n\n守卫长卡尔是个满脸伤疤的老兵。他看了你很久,才缓缓开口:「你就是那个拿回翡翠之心的人?孩子,你不知道自己打开了什么门。」'
  },
  ch7_dragon_choice: {
    title: '第七章', subtitle: '龙之门槛·阵营抉择',
    quote: '"龙族信任力量,人类信任纪律。但暗影不信任任何人。"\n--边境无名石碑',
    narration: '卡里斯的龙瞳和埃里克的铁灰色眼睛同时注视着你。\n\n翡翠之心在你胸口微微发烫,仿佛它也在等待你的选择。龙族的荣耀,还是人类的策略?或者......还有第三条路?'
  },
  ch8_temple_enter: {
    title: '第八章', subtitle: '龙神殿·废墟',
    quote: '"龙神殿是龙族信仰的心脏。当心脏停止跳动的时候,整个身体都会腐烂。"\n--冰礁港古老歌谣',
    narration: '龙神殿的巨门半开,黑暗从门缝中涌出。你点燃火把,踏入这座曾经辉煌的圣殿。\n\n墙上的龙形浮雕已经残缺不全,有些被砸碎了,有些被暗影覆盖。但最令你不安的是——你听到了呼吸声。巨大的、沉重的呼吸声,从神殿深处传来。'
  },
  ch8_temple_boss: {
    title: '第八章', subtitle: '龙神殿·霜翼',
    quote: '"不是所有的龙都值得拯救。但这一头......它值得。"\n--龙族后裔卡里斯',
    narration: '霜翼巨龙蜷缩在神殿最深处的殿堂。它的翅膀已经有一半变成了暗影的黑色,眼睛也只剩一只还保持着龙族的金色。\n\n「你来了,」它的声音直接在你的脑海中响起,「我等了很久了。那个拿翡翠之心的人......你终于来了。」'
  },
  ch9_ash_enter: {
    title: '第九章', subtitle: '灰烬平原·焦土',
    quote: '"第一纪元终结于一场大火。有人说那是龙族的陨落,有人说那是神的愤怒。真相?真相埋在灰烬之下。"\n--《灰烬编年史》',
    narration: '灰烬平原一望无际。地面上覆盖着厚厚的火山灰,每走一步都会扬起灰色的尘埃。\n\n霜翼留下的龙鳞在你胸口微微发烫。这片土地上曾经发生过什么?为什么龙族要离开?而暗影......暗影又是从哪里来的?'
  },
  ch9_ash_volcano: {
    title: '第九章', subtitle: '灰烬平原·火山口',
    quote: '"火山不是自然的产物。它是第一纪元大战的伤疤——至今未曾愈合。"\n--灰烬行者',
    narration: '你爬上火山口的边缘。岩浆的炽热让你汗流浃背。\n\n在火山口边缘,你看到了令人震惊的景象——岩浆之中,有什么东西在涌动。炽热的岩壁上刻满了你不认识的符文。\n\n灰烬行者的警告还在耳边:「有人在火山深处进行某种仪式。」'
  },
  ch10_volcano_deep: {
    title: '第十章', subtitle: '深渊火口·地底裂缝',
    quote: '"火山深处有一个声音。它不说话,但每个人都能听懂它在说什么:回来吧,回到火焰中去。"\n--火山探索队最后一份报告',
    narration: '岩壁上的符文告诉你一个惊人的真相:暗影不是天然存在的力量。它是被创造出来的。\n\n第一纪元,龙族和精灵族联合创造了一种力量,用来对抗一个更强大的敌人。那种力量就是暗影。但暗影失控了,它反噬了创造者。\n\n地面突然裂开。一条通往地底的裂缝出现在你面前。'
  },
  ch10_volcano_boss: {
    title: '第十章', subtitle: '深渊火口·守护者',
    quote: '"钥匙不是被藏起来的。它被守护着。因为用它打开的门,通向的不是希望,而是终结。"\n--炎先知',
    narration: '地底裂缝的尽头,石桥横跨在无底的深渊之上。\n\n石桥另一端,火山守护者用凝固的岩浆铸成的身体挡住了去路。它的眼睛是两团永不熄灭的火焰。\n\n「钥匙......」它的声音像岩浆翻涌,「你还没有资格拿走钥匙......」'
  },
  ch11_abyss_enter: {
    title: '第十一章', subtitle: '深渊之门·入口',
    quote: '"门后面是什么?我不知道。但我知道,那些进去的人......他们出来的时候,已经不是自己了。"\n--深渊之门守门人',
    narration: '裂缝比你想象的要小。只是一道在地底的裂口,通往更深的黑暗。但当你靠近它的时候,你感到一种奇异的......熟悉感。\n\n好像你曾经来过这里。好像这一切,你已经在梦中经历过无数次。'
  },
  ch11_abyss_choice: {
    title: '第十一章', subtitle: '深渊之门·动机抉择',
    quote: '"动机决定结局。你是猎人还是朝圣者,取决于你为什么走进黑暗。"\n--深渊守门人',
    narration: '深渊守门人没有面孔。它的声音从四面八方传来,像一个没有答案的回声。\n\n「你是为了拯救这个世界,还是为了证明自己?」\n\n你想起了这一路上的所有人——罗兰德、汉克、雾中精灵、伊兰......你是为了他们吗?还是为了你自己?'
  },
  ch12_throne_enter: {
    title: '第十二章', subtitle: '王者宝座·暗影领域',
    quote: '"暗影不是黑暗。它是被遗忘的光。"\n--暗影低语者',
    narration: '暗影领域比你想象的更加......美丽。\n\n这里没有你想象中的黑暗和恐怖。相反,这里是一片紫色的原野,天空中漂浮着暗影的光点,像萤火虫一样。远处,一座由黑色水晶筑成的王座矗立在平原中央。'
  },
  ch12_throne_final: {
    title: '第十二章', subtitle: '王者宝座·最终抉择',
    quote: '"暗影龙王不是敌人。它是伤口。你想要治愈它,还是想要杀死它?这是你最后的选择。"\n--霜翼的遗言',
    narration: '暗影领域的最深处,那座宝座就立在那里。黑色的水晶铺就了地面,空气中弥漫着紫色的薄雾。\n\n宝座上坐着一道高大的身影。你看不清它的脸,但你能感受到它的痛苦——千年的、沉重的、几乎要将世界压垮的痛苦。\n\n你举起武器,或者......你放下了武器。选择权在你手中。'
  }
};

