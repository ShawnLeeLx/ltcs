// When a side quest completes, check if it unlocks a chain quest
function checkQuestChainCompletion(questId) {
  // Check if completed quest is part of a chain
  for (var ci = 0; ci < QUEST_CHAINS.length; ci++) {
    var chain = QUEST_CHAINS[ci];
    var qIdx = chain.quests.indexOf(questId);
    if (qIdx >= 0 && qIdx < chain.quests.length - 1) {
      // Unlock next quest in chain
      var nextQId = chain.quests[qIdx + 1];
      if (!G.quests || G.quests.indexOf(nextQId) === -1) {
        if (!G.quests) G.quests = [];
        // Add the chain quest
        var chainQ = CHAIN_QUESTS[nextQId];
        if (chainQ) {
          SIDE_QUESTS.push(chainQ);
          G.quests.push(nextQId);
          G.questProgress[nextQId] = { current:0, done:false, stages:chainQ.stages||1 };
          toast('📜 任务链解锁: ' + chainQ.name);
        }
      }
    }
    // Check if entire chain is complete
    if (qIdx === chain.quests.length - 1) {
      var allDone = true;
      for (var qi = 0; qi < chain.quests.length; qi++) {
        var qp = G.questProgress[chain.quests[qi]];
        if (!qp || !qp.done) { allDone = false; break; }
      }
      if (allDone && !G._chainBonusClaimed) {
        if (!G._chainBonusClaimed) G._chainBonusClaimed = {};
        if (!G._chainBonusClaimed[chain.chainId]) {
          G._chainBonusClaimed[chain.chainId] = true;
          var br = chain.bonusReward;
          if (br.xp) { G.xp += br.xp; toast('🎊 任务链完成! ⭐+' + br.xp + 'XP'); }
          if (br.gold) { G.gold += br.gold; toast('💰+' + br.gold); }
          if (br.permStat) {
            if (!G.permStats) G.permStats = {};
            for (var stat in br.permStat) {
              G.permStats[stat] = (G.permStats[stat]||0) + br.permStat[stat];
              toast('✦ 永久+' + br.permStat[stat] + stat);
            }
          }
        }
      }
    }
  }
}

;

function getAvailableSideQuests() {
  var available = [];
  for (var i = 0; i < SIDE_QUESTS.length; i++) {
    var sq = SIDE_QUESTS[i];
    // Only show if at the right location, not already started, and location is unlocked
    if (G.location !== sq.location) continue;
    if (G.sideQuestProgress && G.sideQuestProgress[sq.id]) continue;
    if (!LOCATIONS[sq.location] || !LOCATIONS[sq.location].unlocked) continue;
    available.push(sq);
  }
  return available;
}

function acceptSideQuest(sqid) {
  if (!G.sideQuestProgress) G.sideQuestProgress = {};
  G.sideQuestProgress[sqid] = { current: 0, done: false };
  var sq = SIDE_QUESTS.find(function(s) { return s.id === sqid; });
  if (sq) toast('📋 接取支线任务:' + sq.name);
  sceneTown();
}

function advanceSideQuest(sqid) {
  if (!G.sideQuestProgress || !G.sideQuestProgress[sqid]) return;
  var sp = G.sideQuestProgress[sqid];
  if (sp.done) return;
  sp.current = (sp.current || 0) + 1;
  var sq = SIDE_QUESTS.find(function(s) { return s.id === sqid; });
  if (!sq) return;
  if (sp.current >= sq.stages) {
    sp.done = true;
    // Grant reward
    if (sq.rewardType === 'perm_buff' && sq.permBuff) {
      if (!G.permBuffs) G.permBuffs = {};
      G.permBuffs[sq.permBuff.stat] = (G.permBuffs[sq.permBuff.stat] || 0) + sq.permBuff.value;
      toast('🔮 ' + sq.permBuff.desc);
    } else if (sq.uniqueItem) {
      G.inventory.push(sq.uniqueItem);
      toast('🎁 获得专属装备:' + sq.uniqueItem.name);
    }
    if (sq.affectionReward) {
      // Determine NPC id from quest location
      var questNpcId = null;
      var npcDefKeys = Object.keys(NPC_DEFS);
      for (var ni = 0; ni < npcDefKeys.length; ni++) {
        if (NPC_DEFS[npcDefKeys[ni]].loc === sq.location && NPC_DEFS[npcDefKeys[ni]].role !== 'boss') {
          questNpcId = npcDefKeys[ni]; break;
        }
      }
      if (questNpcId) {
        var gained = addNpcAffection(questNpcId, sq.affectionReward);
        toast('❤️ ' + NPC_DEFS[questNpcId].name + ' 好感度+' + gained);
      } else {
        toast('❤️ 好感度 +' + sq.affectionReward);
      }
    }
    toast('🎉 支线任务完成:' + sq.name);
    // Check quest chain progression
    if (typeof checkQuestChainCompletion === 'function') checkQuestChainCompletion(sqid);
  } else {
    toast('📋 任务进展:' + sq.stageDescs[sp.current - 1] || '继续推进...');
  }
}

