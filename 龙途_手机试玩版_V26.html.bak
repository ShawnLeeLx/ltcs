  for (var ni = 0; ni < npcs.length; ni++) {
    var npc = npcs[ni];
    var npcKey = 'npc_talked_' + G.location + '_' + ni;
    var talked = G[npcKey];
    html += '<div class="loc-card" onclick="tavernNpcChat(\'' + G.location + '\',' + ni + ')" style="cursor:pointer">';
