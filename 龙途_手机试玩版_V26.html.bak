      { id:'ch10c2_listen', text:'👂 倾听低语 - 利用暗影的力量', effect:'listen_whisper', desc:'获得暗影之力(ATK+8),但深渊中暗影攻击+15%' },
      { id:'ch10c3_share', text:'🤝 与低语对话 - 试着理解它', effect:'share_whisper', desc:'解锁暗影领域和平对话选项,CHA+3' }
    ]
  },
  ch12_final: {
