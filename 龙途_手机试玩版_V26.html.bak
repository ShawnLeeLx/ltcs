    ],
    next: 'ch2_forest_warning',
    reward: { xp:120, gold:60 }
  },
  // ─── 第二章:幽暗森林的警告 ───
  {
    id: 'ch2_forest_warning',
    chapter: '第二章',
    title: '残片的线索', next: 'ch2_fortress_discovery',
    entry: '击败湖畔首领后,你在它身上找到了一块刻有符文的石板。石板上的文字不是任何一种你能辨识的语言--但奇怪的是,你居然能隐约理解它的意思:\n\n「......封印正在减弱......森林深处的东西快要出来了......」\n\n白城的学者艾琳娜或许能帮你翻译这块石板。但首先,你需要穿过幽暗森林--那条最近频传失踪事件的路。',
    objectives: [
      { id:'ch2_talk_elena', desc:'返回白城,与学者艾琳娜交谈', type:'talk_to_npc', npc:'elena' },
      { id:'ch2_visit_forest', desc:'前往幽暗森林边缘', type:'visit_location', location:'darkforest' },
      { id:'ch2_win5', desc:'在森林外围击败5只魔物', type:'win_battles', count:5 }
    ],
    next: 'ch2_fortress_discovery',
    reward: { xp:100, gold:50 }
  },
  {
    id: 'ch2_fortress_discovery',
    chapter: '第二章',
    title: '破碎堡垒', next: 'ch2_fortress_boss',
    entry: '艾琳娜的翻译让你心惊:「封印」、「森林深处」、「即将苏醒」--这些词组合在一起,指向一个她曾在古籍中读到的地方:幽暗森林深处的「破碎堡垒」,据说那里曾是古代封印的核心。\n\n但当你抵达堡垒外围时,发现这里已经被一股武装力量占据。不是魔物,而是人--穿着不属于任何已知势力的黑色铠甲。他们在挖掘什么。\n\n堡垒门口的告示牌上写着:「禁令:任何人不得入内。违者格杀勿论。--黑铁兄弟会」',
    objectives: [
      { id:'ch2_infiltrate', desc:'想办法混入堡垒(与堡垒外的流浪者交谈获取情报)', type:'talk_to_npc', npc:'forest_wanderer' },
      { id:'ch2_win_fortress', desc:'击败堡垒门口的守卫,深入探索', type:'win_battles', count:8 },
      { id:'ch2_find_letter', desc:'在堡垒中找到黑铁兄弟会的密信', type:'find_clue', clueId:'clue_blackiron_letter' }
    ],
    next: 'ch2_fortress_boss',
    reward: { xp:150, gold:80 }
