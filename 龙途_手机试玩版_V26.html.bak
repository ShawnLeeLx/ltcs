// ═══════════════════════════════════════════════════════════
// TRADE: Commerce Functions
// ═══════════════════════════════════════════════════════════

function getTradePrice(goodId, townId, isBuy) {
  var base = null;
  // Find base price from any town's tradeGoods
  var locs = Object.keys(LOCATIONS);
  for (var i = 0; i < locs.length; i++) {
    var tg = LOCATIONS[locs[i]].tradeGoods;
    if (tg) {
      for (var j = 0; j < tg.length; j++) {
        if (tg[j].id === goodId) { base = tg[j].price; break; }
      }
    }
    if (base) break;
  }
  if (!base) return 0;

  // Get town multiplier
  var tp = TRADE_PRICES[goodId];
  var mult = (tp && tp[townId]) ? tp[townId] : 1.0;

  // Apply market event modifier
  if (G.marketEvent && G.marketEvent.mods && G.marketEvent.mods[goodId]) {
    mult *= G.marketEvent.mods[goodId];
  }

  // CHA discount/markup: +5% sell per CHA above 10
  var chaBonus = 1.0;
  if (!isBuy && G.cha > 10) {
    chaBonus += (G.cha - 10) * 0.03;
  }
  // Lucky merchant set bonus: shopMarkup (sell) and shopDiscount (buy)
  if (!isBuy) {
    var setBonuses = calcSetBonuses();
    if (setBonuses.shopMarkup) chaBonus += setBonuses.shopMarkup;
  } else {
    var setBonusesBuy = calcSetBonuses();
    if (setBonusesBuy.shopDiscount) chaBonus = 1.0 - setBonusesBuy.shopDiscount;
  }

  // Buy price has small markup, sell has small discount
  var weatherMod = 1.0 + getWeatherPriceMod(townId);
  var price = Math.round(base * mult * (isBuy ? chaBonus : 0.7) * (isBuy ? 1.0 : chaBonus) * weatherMod);
  return Math.max(1, price);
}

function getTradeGoodsForTown(townId) {
  var loc = LOCATIONS[townId];
  if (!loc || !loc.tradeGoods) return [];
  return loc.tradeGoods;
}

function getAllTradeableGoods() {
  // Returns all goods the player can sell (from inventory)
  var goods = [];
  if (!G.inventory) return goods;
  for (var i = 0; i < G.inventory.length; i++) {
    var item = G.inventory[i];
    if (item.type === 'trade_good') {
      goods.push({ idx: i, item: item });
    }
  }
  return goods;
}

function rollMarketEvent() {
  // 30% chance of market event each time player enters trade scene
  if (Math.random() < 0.3) {
    var idx = rand(0, MARKET_EVENTS.length - 1);
    var evt = MARKET_EVENTS[idx];
    G.marketEvent = { id: evt.id, name: evt.name, desc: evt.desc, mods: evt.mods, turnsLeft: evt.duration };
    return evt;
  }
  G.marketEvent = null;
  return null;
}

function tickMarketEvent() {
  if (!G.marketEvent) return;
  G.marketEvent.turnsLeft--;
  if (G.marketEvent.turnsLeft <= 0) {
    G.marketEvent = null;
  }
}

// ═══════════════════════════════════════════════════════════
// SCENE: Trade Post (商贸站)
// ═══════════════════════════════════════════════════════════

function sceneTrade() {
  G._currentScene = 'sceneTrade';

  // Roll market event on first visit
  if (!G._tradeVisited) {
    G._tradeVisited = true;
    var evt = rollMarketEvent();
    if (evt) {
      toast('📢 市场消息:' + evt.name + ' - ' + evt.desc);
    }
  }

  var loc = LOCATIONS[G.location];
  var townGoods = getTradeGoodsForTown(G.location);
  var myGoods = getAllTradeableGoods();
  var tab = G._tradeTab || 'buy';

  var html = '';
  html += '<div class="scene-title">🏪 商贸站</div>';
  html += '<div class="trade-desc">' + (loc.name || '本城') + '的商贸站,各地货物在此集散。</div>';

  // Market event banner
  if (G.marketEvent) {
    html += '<div class="market-event" style="margin:8px 0;padding:8px 12px;background:#2a1a0a;border:1px solid #d4a017;border-radius:6px;font-size:0.85em">';
    html += '<div style="color:#d4a017;font-weight:bold">📢 ' + G.marketEvent.name + '</div>';
    html += '<div style="color:#c0c0c0">' + G.marketEvent.desc + '</div>';
    html += '<div style="color:#888;font-size:0.8em">剩余 ' + G.marketEvent.turnsLeft + ' 次交易</div>';
    html += '</div>';
  }

  // Tab buttons
  html += '<div class="trade-tabs" style="display:flex;gap:8px;margin:8px 0">';
  html += '<button class="btn ' + (tab === 'buy' ? 'btn-primary' : '') + '" onclick="G._tradeTab=\'buy\';sceneTrade()" style="flex:1">📋 进货</button>';
  html += '<button class="btn ' + (tab === 'sell' ? 'btn-primary' : '') + '" onclick="G._tradeTab=\'sell\';sceneTrade()" style="flex:1">💰 出货</button>';
  html += '<button class="btn ' + (tab === 'caravan' ? 'btn-primary' : '') + '" onclick="G._tradeTab=\'caravan\';sceneTrade()" style="flex:1">🐪 商队</button>';
  html += '<button class="btn ' + (tab === 'mission' ? 'btn-primary' : '') + '" onclick="G._tradeTab=\'mission\';sceneTrade()" style="flex:1">🚚 委托</button>';
  html += '</div>';

  if (tab === 'buy') {
    html += renderTradeBuy(townGoods);
  } else if (tab === 'sell') {
    html += renderTradeSell(myGoods);
  } else if (tab === 'caravan') {
    html += renderTradeCaravan();
  } else if (tab === 'mission') {
    sceneTradeMission(); return;
  }

  html += '<div class="btns">';
  html += '<button class="btn" onclick="sceneTown()">↩️ 返回城镇</button>';
  html += '</div>';
  render(html);
}

function renderTradeBuy(townGoods) {
  var html = '';
  html += '<div style="color:#aaa;font-size:0.85em;margin-bottom:8px">从本地进货,运到其他城镇出售赚差价</div>';

  if (townGoods.length === 0) {
    html += '<div style="color:#888;text-align:center;padding:20px">本城暂无商贸货物</div>';
    return html;
  }

  html += '<div class="trade-goods-list">';
  for (var i = 0; i < townGoods.length; i++) {
    var g = townGoods[i];
    var buyPrice = getTradePrice(g.id, G.location, true);
    var catEmoji = { common:'📦', metal:'⛏️', exotic:'🌺', luxury:'💎' };
    var catName = { common:'普通', metal:'金属', exotic:'异域', luxury:'奢侈' };
    var ce = catEmoji[g.category] || '📦';

    // Show estimated sell prices at other towns
    var sellInfo = '';
    var locs = ['whitecity','ironridge','tidport','sunspire','dragonreach','icereef'];
    for (var j = 0; j < locs.length; j++) {
      if (locs[j] === G.location) continue;
      if (!LOCATIONS[locs[j]].unlocked) continue;
      var sp = getTradePrice(g.id, locs[j], false);
      var profit = sp - buyPrice;
      var profitColor = profit > 0 ? '#22c55e' : '#ef4444';
      var townShort = { whitecity: '白城', ironridge: '铁岭', tidport: '潮汐', sunspire: '日冕', dragonreach: '龙域', icereef: '冰礁' };
      sellInfo += '<span style="color:' + profitColor + ';font-size:0.8em">' + townShort[locs[j]] + ':' + sp + '💰(' + (profit > 0 ? '+' : '') + profit + ')</span> ';
    }

    html += '<div class="trade-item" style="padding:8px;margin:6px 0;background:#16213e;border-radius:6px;border-left:3px solid ' + (profit > 0 ? '#22c55e' : '#ef4444') + '">';
    html += '<div style="display:flex;justify-content:space-between;align-items:center">';
    html += '<span>' + ce + ' ' + g.name + ' <span style="color:#888;font-size:0.8em">[' + (catName[g.category] || '普通') + ']</span></span>';
    html += '<span style="color:#d4a017">' + buyPrice + ' 💰</span>';
    html += '</div>';
    html += '<div style="margin-top:4px">' + sellInfo + '</div>';
    html += '<button class="btn" style="margin-top:4px;font-size:0.85em;padding:4px 12px" onclick="buyTradeGood(\'' + g.id + '\',' + buyPrice + ')" ' + (G.gold < buyPrice ? 'disabled' : '') + '>购入</button>';
    html += '</div>';
  }
  html += '</div>';

  html += '<div style="margin-top:8px;padding:6px;background:#0d1117;border-radius:4px;font-size:0.8em;color:#888">';
  html += '💡 提示:绿色数字表示在其他城镇出售可获利,红色表示亏本。行商起源额外+20%售价,CHA属性提升售价。';
  html += '</div>';
  return html;
}

function renderTradeSell(myGoods) {
  var html = '';
  html += '<div style="color:#aaa;font-size:0.85em;margin-bottom:8px">在本城出售货物</div>';

  if (myGoods.length === 0) {
    html += '<div style="color:#888;text-align:center;padding:20px">背包中没有商贸货物</div>';
    return html;
  }

  html += '<div class="trade-sell-list">';
  for (var i = 0; i < myGoods.length; i++) {
    var entry = myGoods[i];
    var g = entry.item;
    var sellPrice = getTradePrice(g.tradeId, G.location, false);
    var buyPrice = g.buyPrice || 0;
    var profit = sellPrice - buyPrice;
    var profitColor = profit > 0 ? '#22c55e' : '#ef4444';

    html += '<div class="trade-sell-item" style="padding:8px;margin:6px 0;background:#16213e;border-radius:6px">';
    html += '<div style="display:flex;justify-content:space-between;align-items:center">';
    html += '<span>' + g.name + '</span>';
    html += '<span><span style="color:#d4a017">' + sellPrice + ' 💰</span> <span style="color:' + profitColor + ';font-size:0.85em">(' + (profit > 0 ? '+' : '') + profit + ')</span></span>';
    html += '</div>';
    html += '<div style="font-size:0.8em;color:#888">买入价:' + buyPrice + ' 💰</div>';
    html += '<button class="btn" style="margin-top:4px;font-size:0.85em;padding:4px 12px" onclick="sellTradeGood(' + entry.idx + ')">出售</button>';
    html += '</div>';
  }
  html += '</div>';
  return html;
}

function renderTradeCaravan() {
  var html = '';
  html += '<div style="color:#aaa;font-size:0.85em;margin-bottom:8px">组织商队运输货物到其他城镇(自动卖出)</div>';

  // Count trade goods in inventory
  var myGoods = getAllTradeableGoods();
  if (myGoods.length === 0) {
    html += '<div style="color:#888;text-align:center;padding:20px">背包中没有商贸货物可运输</div>';
    return html;
  }

  // Destination selection
  var destinations = [];
  var locs = ['whitecity','ironridge','tidport','sunspire','dragonreach','icereef'];
  for (var i = 0; i < locs.length; i++) {
    if (locs[i] === G.location) continue;
    if (!LOCATIONS[locs[i]].unlocked) continue;
    // Calculate estimated total sell value
    var totalVal = 0;
    for (var j = 0; j < myGoods.length; j++) {
      totalVal += getTradePrice(myGoods[j].item.tradeId, locs[i], false);
    }
    destinations.push({ id: locs[i], name: LOCATIONS[locs[i]].name, estValue: totalVal });
  }

  if (destinations.length === 0) {
    html += '<div style="color:#888;text-align:center;padding:20px">没有已解锁的目的地城镇</div>';
    return html;
  }

  html += '<div style="margin-bottom:8px;padding:6px;background:#1a1a2e;border-radius:4px;font-size:0.85em;color:#c0c0c0">';
  html += '📦 背包中 ' + myGoods.length + ' 件商贸货物';
  html += '</div>';

  html += '<div class="caravan-dest-list">';
  for (var d = 0; d < destinations.length; d++) {
    var dest = destinations[d];
    html += '<div class="caravan-dest" style="padding:10px;margin:8px 0;background:#16213e;border-radius:6px;border:1px solid #333">';
    html += '<div style="font-weight:bold">🐪 → ' + dest.name + '</div>';
    html += '<div style="font-size:0.85em;color:#d4a017">预估收益:~' + dest.estValue + ' 💰</div>';
    html += '<div style="font-size:0.8em;color:#888">⚠️ 商队有风险:山贼伏击/暴风/重税</div>';
    html += '<button class="btn btn-primary" style="margin-top:6px" onclick="sendCaravan(\'' + dest.id + '\')">发车 → ' + dest.name + '</button>';
    html += '</div>';
  }
  html += '</div>';

  html += '<div style="margin-top:8px;padding:6px;background:#0d1117;border-radius:4px;font-size:0.8em;color:#888">';
  html += '⚠️ 商队将自动出售所有商贸货物,但可能遭遇:山贼伏击(-10~30%货物)、暴风(-5~15%)、关卡重税(-8~20%)。行商起源减少20%风险。';
  html += '</div>';
  return html;
}

function buyTradeGood(goodId, price) {
  if (G.gold < price) { toast('💰 金币不足'); return; }

  // Find good data
  var goodData = null;
  var locs = Object.keys(LOCATIONS);
  for (var i = 0; i < locs.length; i++) {
    var tg = LOCATIONS[locs[i]].tradeGoods;
    if (tg) {
      for (var j = 0; j < tg.length; j++) {
        if (tg[j].id === goodId) { goodData = tg[j]; break; }
      }
    }
    if (goodData) break;
  }
  if (!goodData) { toast('货物不存在'); return; }

  G.gold -= price;
  G._tradeCount = (G._tradeCount || 0) + 1;
  G.inventory.push({
    id: goodData.id,
    tradeId: goodData.id,
    name: goodData.name,
    type: 'trade_good',
    category: goodData.category,
    buyPrice: price,
    price: price  // for sellItem compatibility
  });
  updateStatus();
  tickMarketEvent();
  checkAchievements();
  toast('✅ 购入 ' + goodData.name + ' (-' + price + '💰)');
  _onTradeCompleted();
  sceneTrade();
}

function sellTradeGood(invIdx) {
  if (!G.inventory || !G.inventory[invIdx]) { toast('物品不存在'); return; }
  var item = G.inventory[invIdx];
  if (item.type !== 'trade_good') { toast('不是商贸货物'); return; }

  var sellPrice = getTradePrice(item.tradeId, G.location, false);
  var profit = sellPrice - (item.buyPrice || 0);

  G.gold += sellPrice;
  G.inventory.splice(invIdx, 1);
  G._tradeCount = (G._tradeCount || 0) + 1;
  updateStatus();
  tickMarketEvent();
  _onTradeCompleted();
  checkAchievements();

  var profitText = profit > 0 ? '📈 盈利 +' + profit : '📉 亏损 ' + profit;
  toast('💰 出售 ' + item.name + ' +' + sellPrice + '💰 ' + profitText);
  sceneTrade();
}

function sendCaravan(destId) {
  var myGoods = getAllTradeableGoods();
  if (myGoods.length === 0) { toast('没有货物可运输'); return; }

  // Calculate total sell value at destination
  var totalValue = 0;
  for (var i = 0; i < myGoods.length; i++) {
    totalValue += getTradePrice(myGoods[i].item.tradeId, destId, false);
  }

  // Roll caravan risk
  var riskRoll = Math.random();
  var cumulative = 0;
  var riskResult = CARAVAN_RISKS[CARAVAN_RISKS.length - 1]; // default: nothing
  for (var r = 0; r < CARAVAN_RISKS.length; r++) {
    cumulative += CARAVAN_RISKS[r].chance;
    if (riskRoll < cumulative) { riskResult = CARAVAN_RISKS[r]; break; }
  }

  // 行商起源: reduce risk
  var lossRate = 0;
  if (riskResult.id !== 'nothing') {
    lossRate = riskResult.minLoss + Math.random() * (riskResult.maxLoss - riskResult.minLoss);
    if (G.origin === 'merchant') lossRate *= 0.8; // 行商减少20%损失
  }

  var finalGold = Math.round(totalValue * (1 - lossRate));
  var lostGold = totalValue - finalGold;

  // Remove all trade goods from inventory (sold in reverse order to preserve indices)
  var soldNames = [];
  for (var s = myGoods.length - 1; s >= 0; s--) {
    soldNames.push(myGoods[s].item.name);
    G.inventory.splice(myGoods[s].idx, 1);
  }

  G.gold += finalGold;
  updateStatus();
  tickMarketEvent();
  _onTradeCompleted();

  // Show result
  var html = '';
  html += '<div class="scene-title">🐪 商队报告</div>';
  html += '<div style="text-align:center;margin:16px 0">';
  html += '<div style="font-size:1.2em;color:#e0e0e0">目的地:' + LOCATIONS[destId].name + '</div>';
  html += '<div style="font-size:1.1em;margin:8px 0">' + (riskResult.id === 'nothing' ? '✅' : '⚠️') + ' ' + riskResult.name + '</div>';
  html += '<div style="color:#888;font-size:0.9em">' + riskResult.desc + '</div>';
  html += '</div>';

  html += '<div style="margin:12px 0;padding:10px;background:#1a1a2e;border-radius:6px">';
  html += '<div style="color:#d4a017">货物:' + soldNames.reverse().join('、') + '</div>';
  html += '<div>预期收益:<span style="color:#888">' + totalValue + ' 💰</span></div>';
  if (lostGold > 0) {
    html += '<div style="color:#ef4444">损失:-' + lostGold + ' 💰 (' + Math.round(lossRate * 100) + '%)</div>';
  }
  html += '<div style="color:#22c55e;font-size:1.2em;font-weight:bold">实收:' + finalGold + ' 💰</div>';
  html += '</div>';

  html += '<div class="btns">';
  html += '<button class="btn btn-primary" onclick="sceneTrade()">↩️ 继续商贸</button>';
  html += '<button class="btn" onclick="sceneTown()">🏙️ 返回城镇</button>';
  html += '</div>';
  render(html);
}


// ═══════════════════════════════════════════════════════════
// TRADE MISSIONS - 行商委托系统
// ═══════════════════════════════════════════════════════════

function getAvailableTradeMissions() {
  var activeIds = (G._tradeMissions && G._tradeMissions.active) ? G._tradeMissions.active.map(function(m) { return m.missionId; }) : [];
  var avail = [];
  var chNum = _getCurrentChapterNum();
  for (var i = 0; i < TRADE_MISSIONS.length; i++) {
    var tm = TRADE_MISSIONS[i];
    var req = TM_TIER_UNLOCK[tm.tier];
    if (req) {
      var reqNum = parseInt(req.replace('ch',''));
      if (chNum < reqNum) continue;
    }
    if (activeIds.indexOf(tm.id) >= 0) continue;
    avail.push(tm);
  }
  // Shuffle and pick up to TM_AVAILABLE_SLOTS
  for (var s = avail.length - 1; s > 0; s--) {
    var j = Math.floor(Math.random() * (s + 1));
    var temp = avail[s]; avail[s] = avail[j]; avail[j] = temp;
  }
  return avail.slice(0, TM_AVAILABLE_SLOTS);
}

function _getCurrentChapterNum() {
  if (!G.storyProgress || !G.storyProgress.chapterId) return 1;
  var chId = G.storyProgress.chapterId;
  var m = chId.match(/ch(\d+)/);
  return m ? parseInt(m[1]) : 1;
}

function acceptTradeMission(missionId) {
  var mission = null;
  for (var i = 0; i < TRADE_MISSIONS.length; i++) {
    if (TRADE_MISSIONS[i].id === missionId) { mission = TRADE_MISSIONS[i]; break; }
  }
  if (!mission) { toast('委托不存在'); return; }
  if (!G._tradeMissions) {
    G._tradeMissions = { active: [], doneToday: [] };
  }
  if (G._tradeMissions.active.length >= TM_MAX_ACTIVE) {
    toast('⚠️ 最多同时接受 ' + TM_MAX_ACTIVE + ' 个行商委托');
    return;
  }
  for (var a = 0; a < G._tradeMissions.active.length; a++) {
    if (G._tradeMissions.active[a].missionId === missionId) {
      toast('⚠️ 已接受此委托'); return;
    }
  }
  var record = {
    missionId: missionId,
    acceptedAt: G.location,
    tradesLeft: mission.deadline,
    bonusEligible: true,
    hopsDone: mission.hops ? [] : null,
    acceptedChapter: G.storyProgress ? G.storyProgress.chapterId : null
  };
  G._tradeMissions.active.push(record);
  updateStatus();
  toast('✅ 已接受委托:' + mission.name);
  sceneTradeMission();
}

function abandonTradeMission(missionId) {
  if (!G._tradeMissions || !G._tradeMissions.active) return;
  var idx = -1;
  for (var i = 0; i < G._tradeMissions.active.length; i++) {
    if (G._tradeMissions.active[i].missionId === missionId) { idx = i; break; }
  }
  if (idx < 0) return;
  G._tradeMissions.active.splice(idx, 1);
  updateStatus();
  toast('🗑️ 已放弃委托');
  sceneTradeMission();
}

function tickTradeMissionDeadlines() {
  if (!G._tradeMissions || !G._tradeMissions.active) return;
  var stillActive = [];
  for (var i = 0; i < G._tradeMissions.active.length; i++) {
    var rec = G._tradeMissions.active[i];
    rec.tradesLeft--;
    // Check bonus eligibility
    var mission = null;
    for (var j = 0; j < TRADE_MISSIONS.length; j++) {
      if (TRADE_MISSIONS[j].id === rec.missionId) { mission = TRADE_MISSIONS[j]; break; }
    }
    if (mission && mission.bonusCond) {
      var bonusMax = parseInt(mission.bonusCond.replace('within',''));
      if (rec.tradesLeft < (mission.deadline - bonusMax)) {
        rec.bonusEligible = false;
      }
    }
    if (rec.tradesLeft <= 0) {
      toast('⏰ 委托失败:' + (mission ? mission.name : rec.missionId) + ' (期限已过)');
    } else {
      stillActive.push(rec);
    }
  }
  G._tradeMissions.active = stillActive;
}

function checkTradeMissionProgress() {
  if (!G._tradeMissions || !G._tradeMissions.active) return;
  for (var i = 0; i < G._tradeMissions.active.length; i++) {
    var rec = G._tradeMissions.active[i];
    var mission = null;
    for (var j = 0; j < TRADE_MISSIONS.length; j++) {
      if (TRADE_MISSIONS[j].id === rec.missionId) { mission = TRADE_MISSIONS[j]; break; }
    }
    if (!mission) continue;
    var completed = false;
    if (mission.hops) {
      var nextHopIdx = rec.hopsDone.length;
      if (nextHopIdx < mission.hops.length) {
        var hop = mission.hops[nextHopIdx];
        if (G.location === hop.to) {
          var hasGoods = countTradeGoodInInventory(hop.goods) >= hop.qty;
          if (hasGoods) {
            removeTradeGoodFromInventory(hop.goods, hop.qty);
            rec.hopsDone.push(hop.to);
            toast('✅ 行商委托进度:' + rec.hopsDone.length + '/' + mission.hops.length + ' 站完成');
          }
        }
      }
      if (rec.hopsDone.length >= mission.hops.length) completed = true;
    } else {
      if (G.location === mission.to) {
        var has = countTradeGoodInInventory(mission.goods) >= mission.qty;
        if (has) {
          removeTradeGoodFromInventory(mission.goods, mission.qty);
          completed = true;
        }
      }
    }
    if (completed) {
      completeTradeMission(rec.missionId);
      G._tradeMissions.active.splice(i, 1);
      i--;
    }
  }
}

function countTradeGoodInInventory(goodId) {
  var count = 0;
  for (var i = 0; i < G.inventory.length; i++) {
    var it = G.inventory[i];
    if (it.type === 'trade_good' && it.tradeId === goodId) count++;
  }
  return count;
}

function removeTradeGoodFromInventory(goodId, qty) {
  var removed = 0;
  for (var i = G.inventory.length - 1; i >= 0; i--) {
    var it = G.inventory[i];
    if (it.type === 'trade_good' && it.tradeId === goodId) {
      G.inventory.splice(i, 1);
      removed++;
      if (removed >= qty) break;
    }
  }
}

function completeTradeMission(missionId) {
  var mission = null;
  for (var i = 0; i < TRADE_MISSIONS.length; i++) {
    if (TRADE_MISSIONS[i].id === missionId) { mission = TRADE_MISSIONS[i]; break; }
  }
  if (!mission) return;
  var rec = null;
  if (G._tradeMissions && G._tradeMissions.active) {
    for (var a = 0; a < G._tradeMissions.active.length; a++) {
      if (G._tradeMissions.active[a].missionId === missionId) { rec = G._tradeMissions.active[a]; break; }
    }
  }
  var bonus = rec && rec.bonusEligible;
  var rewGold = mission.reward.gold + (bonus && mission.bonus ? mission.bonus.gold : 0);
  var rewXp = mission.reward.xp;
  G.gold += rewGold;
  G.xp += rewXp;
  // Level up check
  while (G.xp >= calcNextXp(G.level)) {
    G.level++; G.xp -= calcNextXp(G.level - 1); G.attrPts += 3; G.skillPts += 1;
    G.maxHp = calcMaxHp(); G.hp = G.maxHp; G.maxMp = calcMaxMp(); G.mp = G.maxMp;
  }
  if (!G._tradeMissions.doneToday) G._tradeMissions.doneToday = [];
  G._tradeMissions.doneToday.push(missionId);
  G._tmCompleteCount = (G._tmCompleteCount || 0) + 1;
  if (mission.id === 'tm_grand_tour' || mission.id === 'tm_northern_route') {
    G._tmGrandComplete = (G._tmGrandComplete || 0) + 1;
  }
  updateStatus();
  var html = '';
  html += '<div class="scene-title">📦 委托完成!</div>';
  html += '<div style="text-align:center;margin:16px 0">';
  html += '<div style="font-size:1.2em;color:#d4a017">' + mission.emoji + ' ' + mission.name + '</div>';
  html += '<div style="color:#22c55e;font-size:1.1em;margin:8px 0">✅ 委托完成!</div>';
  html += '</div>';
  html += '<div style="margin:12px 0;padding:10px;background:#1a1a2e;border-radius:6px">';
  html += '<div>💰 奖励:' + mission.reward.gold + ' 金币' + (bonus && mission.bonus ? ' + <span style="color:#d4a017">' + mission.bonus.gold + ' 额外奖励</span>' : '') + '</div>';
  html += '<div>⭐ 经验:' + rewXp + '</div>';
  if (bonus && mission.bonus) {
    html += '<div style="color:#22c55e;font-size:0.9em">📅 在规定交易次数内完成,获得额外奖励!</div>';
  }
  html += '</div>';
  html += '<div class="btns">';
  html += '<button class="btn btn-primary" onclick="sceneTradeMission()">↩️ 返回委托板</button>';
  html += '</div>';
  render(html);
  checkAchievements();
}

function refreshTradeMissionBoard() {
  if (G.gold < TM_REFRESH_COST) { toast('💰 金币不足 (' + TM_REFRESH_COST + ' 金币)'); return; }
  G.gold -= TM_REFRESH_COST;
  if (!G._tradeMissions) G._tradeMissions = { active: [], doneToday: [] };
  G._tradeMissions.doneToday = [];
  updateStatus();
  toast('🔄 委托板已刷新! (-' + TM_REFRESH_COST + '💰)');
  sceneTradeMission();
}

function sceneTradeMission() {
  G._currentScene = 'sceneTradeMission';
  var html = '';
  html += '<div class="scene-title">🚚 行商委托</div>';
  html += '<div style="color:#aaa;font-size:0.85em;margin-bottom:8px">接受委托,运输指定货物到目标城镇,赚取金币和经验!</div>';

  // Active missions
  var active = (G._tradeMissions && G._tradeMissions.active) || [];
  if (active.length > 0) {
    html += '<div style="margin:8px 0;padding:8px;background:#1a2a1a;border-radius:6px">';
    html += '<div style="color:#22c55e;font-weight:bold;margin-bottom:4px">📋 进行中的委托 (' + active.length + '/' + TM_MAX_ACTIVE + ')</div>';
    for (var a = 0; a < active.length; a++) {
      var rec = active[a];
      var mission = null;
      for (var m = 0; m < TRADE_MISSIONS.length; m++) {
        if (TRADE_MISSIONS[m].id === rec.missionId) { mission = TRADE_MISSIONS[m]; break; }
      }
      if (!mission) continue;
      html += '<div style="padding:8px;margin:4px 0;background:#0d1117;border-radius:4px;font-size:0.85em">';
      html += '<div style="font-weight:bold">' + mission.emoji + ' ' + mission.name + ' <span style="font-size:0.8em;color:#888">[T' + mission.tier + ']</span></div>';
      html += '<div style="color:#c0c0c0;font-size:0.85em">' + mission.desc + '</div>';
      if (mission.hops) {
        html += '<div style="color:#d4a017;font-size:0.85em">进度:' + rec.hopsDone.length + '/' + mission.hops.length + ' 站</div>';
        for (var h = 0; h < mission.hops.length; h++) {
          var hop = mission.hops[h];
          var hopDone = rec.hopsDone.indexOf(hop.to) >= 0;
          var hopName = LOCATIONS[hop.to] ? LOCATIONS[hop.to].name : hop.to;
          html += '<div style="font-size:0.8em;color:' + (hopDone ? '#22c55e' : '#888') + ';padding-left:12px">' + (hopDone ? '✅' : '⬜') + ' ' + hopName + ' (需' + hop.qty + '个' + hop.goods + ')</div>';
        }
      } else {
        var destName = LOCATIONS[mission.to] ? LOCATIONS[mission.to].name : mission.to;
        html += '<div style="color:#d4a017;font-size:0.85em">📍 目标:' + destName + ' | 需要:' + mission.qty + '个 ' + mission.goods + '</div>';
      }
      html += '<div style="color:#888;font-size:0.8em">⏰ 剩余 ' + rec.tradesLeft + ' 次交易' + (rec.bonusEligible ? ' | 🌟 可获额外奖励' : '') + '</div>';
      html += '<button class="btn" style="margin-top:4px;font-size:0.8em;padding:3px 8px" onclick="abandonTradeMission(\'' + rec.missionId + '\')">放弃委托</button>';
      html += '</div>';
    }
    html += '</div>';
  }

  // Available missions
  var avail = getAvailableTradeMissions();
  if (avail.length === 0 && active.length === 0) {
    html += '<div style="color:#888;text-align:center;padding:20px">暂无可用委托,提升章节进度解锁更多委托。</div>';
  } else if (avail.length > 0) {
    html += '<div style="margin:8px 0">';
    html += '<div style="color:#7ec8e3;font-weight:bold;margin-bottom:4px">📋 可用委托</div>';
    for (var i = 0; i < avail.length; i++) {
      var tm = avail[i];
      var canAccept = active.length < TM_MAX_ACTIVE;
      html += '<div style="padding:8px;margin:6px 0;background:#16213e;border-radius:6px;border-left:3px solid ' + (canAccept ? '#22c55e' : '#ef4444') + '">';
      html += '<div style="display:flex;justify-content:space-between;align-items:center">';
      html += '<span style="font-weight:bold">' + tm.emoji + ' ' + tm.name + ' <span style="font-size:0.8em;color:#888">[T' + tm.tier + ']</span></span>';
      html += '<span style="color:#d4a017;font-size:0.9em">' + tm.reward.gold + '💰 +' + tm.reward.xp + '⭐</span>';
      html += '</div>';
      html += '<div style="font-size:0.85em;color:#c0c0c0;margin:4px 0">' + tm.desc + '</div>';
      if (tm.hops) {
        html += '<div style="font-size:0.8em;color:#d4a017">路径:' + tm.hops.map(function(h) { return (LOCATIONS[h.to] ? LOCATIONS[h.to].name : h.to); }).join(' → ') + '</div>';
      } else {
        html += '<div style="font-size:0.8em;color:#888">📍 目标:' + (LOCATIONS[tm.to] ? LOCATIONS[tm.to].name : tm.to) + ' | 需要:' + tm.qty + '个 ' + tm.goods + '</div>';
      }
      html += '<div style="font-size:0.8em;color:#888">⏰ 期限:' + tm.deadline + '次交易 | 🌟 提前完成额外+' + (tm.bonus ? tm.bonus.gold : 0) + '💰</div>';
      if (canAccept) {
        html += '<button class="btn btn-primary" style="margin-top:4px;font-size:0.85em;padding:4px 12px" onclick="acceptTradeMission(\'' + tm.id + '\')">接受委托</button>';
      } else {
        html += '<button class="btn btn-disabled" style="margin-top:4px;font-size:0.85em;padding:4px 12px" disabled>进行中 (' + active.length + '/' + TM_MAX_ACTIVE + ')</button>';
      }
      html += '</div>';
    }
    html += '</div>';
  }

  html += '<div class="btns">';
  html += '<button class="btn" onclick="refreshTradeMissionBoard()" style="font-size:0.85em">🔄 刷新委托 (' + TM_REFRESH_COST + '💰)</button>';
  html += '<button class="btn" onclick="sceneTrade()">↩️ 返回商贸站</button>';
  html += '</div>';
  render(html);
}

// Hook: called after every trade action
function _onTradeCompleted() {
  tickTradeMissionDeadlines();
  checkTradeMissionProgress();
}

// ═══════════════════════════════════════════════════════════
// TRADE: Shop Refresh - 商店稀有商品轮换
// ═══════════════════════════════════════════════════════════

function getShopRareItems(scene) {
  if (scene === 'sceneShop') {
    if (!G._shopRareItems || !G._shopRareItems.shop || G._shopRareItems.shop.length === 0) {
      refreshShopStock('sceneShop');
    }
    return G._shopRareItems ? G._shopRareItems.shop : [];
  } else {
    if (!G._shopRareItems || !G._shopRareItems.smith || G._shopRareItems.smith.length === 0) {
      refreshShopStock('sceneBlacksmith');
    }
    return G._shopRareItems ? G._shopRareItems.smith : [];
  }
}

function refreshShopStock(scene) {
  if (!G._shopRareItems) G._shopRareItems = { shop: [], smith: [] };
  var poolKey = scene === 'sceneShop' ? 'consumable' : 'weapon';
  var pool = RARE_SHOP_POOL[poolKey] || [];
  var count = RARE_SHOP_SLOTS[scene === 'sceneShop' ? 'shop' : 'smith'];
  var idxs = [];
  var used = {};
  for (var c = 0; c < count && pool.length > 0; c++) {
    var ri;
    do { ri = rand(0, pool.length - 1); } while (used[ri] && Object.keys(used).length < pool.length);
    used[ri] = true;
    idxs.push(ri);
  }
  var items = idxs.map(function(i) { return pool[i]; });
  if (scene === 'sceneShop') {
    G._shopRareItems.shop = items;
  } else {
    G._shopRareItems.smith = items;
  }
}


// ═══════════════════════════════════════════════════════════
// TRADE: Material Trader - 材料商人（买卖材料）
// ═══════════════════════════════════════════════════════════

function getMatShopStock(townId) {
  var stock = MAT_SHOP_STOCK[townId] || MAT_SHOP_STOCK.whitecity;
  return stock.map(function(mid) {
    var m = MATERIALS[mid];
    if (!m) return null;
    return {
      id: mid,
      name: m.name,
      icon: m.icon,
      rarity: m.rarity,
      buyPrice: Math.floor(m.sellPrice * MAT_SHOP_BUY_MULT),
      sellPrice: m.sellPrice,
      owned: countMaterialInInventory(mid)
    };
  }).filter(function(x) { return x !== null; });
}

function sceneMaterialTrader() {
  G._currentScene = 'sceneMaterialTrader';
  var loc = LOCATIONS[G.location];
  var townStock = getMatShopStock(G.location);
  var myMats = [];
  if (G.inventory) {
    for (var i = 0; i < G.inventory.length; i++) {
      if (G.inventory[i].type === 'material' && MATERIALS[G.inventory[i].id]) {
        var m = MATERIALS[G.inventory[i].id];
        myMats.push({ idx: i, id: G.inventory[i].id, name: m.name, icon: m.icon, rarity: m.rarity, sellPrice: m.sellPrice, count: 1 });
      }
    }
  }

  var tab = G._matTraderTab || 'buy';
  var html = '';
  html += '<div class="scene-title">💎 材料商行</div>';
  html += '<div class="money-display">💰 ' + G.gold + ' 金币</div>';
  html += '<div style="color:#aaa;font-size:0.85em;margin-bottom:8px">当前城镇:' + loc.name + '</div>';
  html += '<div class="btns" style="margin-bottom:10px">';
  html += '<button class="btn ' + (tab==='buy'?'btn-primary':'') + '" onclick="G._matTraderTab=\'buy\';sceneMaterialTrader()" style="flex:1">📦 购买材料</button>';
  html += '<button class="btn ' + (tab==='sell'?'btn-primary':'') + '" onclick="G._matTraderTab=\'sell\';sceneMaterialTrader()" style="flex:1">💰 出售材料</button>';
  html += '</div>';

  if (tab === 'buy') {
    html += '<div style="color:#aaa;font-size:0.85em;margin-bottom:8px">📦 本店可购材料（下次刷新需离开商行）</div>';
    html += '<div class="shop-items">';
    for (var b = 0; b < townStock.length; b++) {
      var item = townStock[b];
      var rarColors = { common:'#9d9d9d', uncommon:'#1eff00', rare:'#0070dd', epic:'#a335ee', legendary:'#ff8000', mythic:'#e6cc80' };
      var col = rarColors[item.rarity] || '#9d9d9d';
      var npcDiscount = getNpcDiscount(null, 'mattrader') / 100;
      var finalPrice = Math.floor(item.buyPrice * (1 - npcDiscount));
      html += '<div class="shop-item" onclick="buyMaterial(\'' + item.id + '\')">';
      html += '<div class="item-name" style="color:' + col + '">' + item.icon + ' ' + item.name + (item.owned > 0 ? ' <span style="color:#7ec8a4;font-size:0.8em">(持有' + item.owned + ')</span>' : '') + '</div>';
      html += '<div class="item-stats"><span style="color:' + col + ';font-size:0.8em">[' + item.rarity + ']</span></div>';
      html += '<div class="item-price">' + finalPrice + ' 💰</div>';
      html += '</div>';
    }
    html += '</div>';
    html += '<div style="color:#888;font-size:0.8em;margin-top:6px">🔄 离开商行后再进入,商品将自动刷新</div>';
  } else {
    if (myMats.length === 0) {
      html += '<div style="color:#888;text-align:center;padding:20px">背包中没有材料可出售</div>';
    } else {
      html += '<div class="shop-items">';
      for (var s = 0; s < myMats.length; s++) {
        var sm = myMats[s];
        var smCol = { common:'#9d9d9d', uncommon:'#1eff00', rare:'#0070dd', epic:'#a335ee', legendary:'#ff8000', mythic:'#e6cc80' }[sm.rarity] || '#9d9d9d';
        html += '<div class="shop-item" style="position:relative">';
        html += '<div class="item-name" style="color:' + smCol + '">' + sm.icon + ' ' + sm.name + '</div>';
        html += '<div class="item-stats"><span style="color:' + smCol + ';font-size:0.8em">[' + sm.rarity + ']</span></div>';
        html += '<div class="item-price" style="color:#d4a017">+' + sm.sellPrice + ' 💰</div>';
        html += '<button class="btn-small" style="position:absolute;right:4px;top:4px;background:#4a2a1a;border:1px solid #a55;color:#d4a017" onclick="event.stopPropagation();sellMaterial(' + sm.idx + ')">💰出售</button>';
        html += '</div>';
      }
      html += '</div>';
    }
  }

  html += '<div class="btns" style="margin-top:10px">';
  html += '<button class="btn" onclick="sceneTown()">↩️ 返回城镇</button>';
  html += '</div>';
  render(html);
}

function buyMaterial(matId) {
  var townStock = getMatShopStock(G.location);
  var item = townStock.find(function(x) { return x.id === matId; });
  if (!item) { toast('该商品不存在'); return; }
  var npcDiscount = getNpcDiscount(null, 'mattrader') / 100;
  var price = Math.floor(item.buyPrice * (1 - npcDiscount));
  if (G.gold < price) { toast('💰 金币不足'); return; }
  G.gold -= price;
  G.inventory.push({
    id: matId, name: item.name, type: 'material',
    icon: item.icon, rarity: item.rarity,
    sellPrice: item.sellPrice, craftValue: MATERIALS[matId].craftValue || 1
  });
  updateStatus();
  toast('📦 购入 ' + item.icon + ' ' + item.name);
  sceneMaterialTrader();
}

function sellMaterial(invIdx) {
  if (!G.inventory || !G.inventory[invIdx]) return;
  var item = G.inventory[invIdx];
  if (item.type !== 'material') { toast('这不是材料'); return; }
  var m = MATERIALS[item.id];
  if (!m) return;
  G.gold += m.sellPrice;
  G.inventory.splice(invIdx, 1);
  updateStatus();
  toast('💰 出售 ' + item.icon + ' ' + item.name + ' +' + m.sellPrice + '💰');
  sceneMaterialTrader();
}

// NPC discount for material trader (maps to 'mattrader' type)
function getNpcDiscountMattrader() {
  return getNpcDiscount(null, 'mattrader');
}

// ═══════════════════════════════════════════════════════════
// ENHANCE: Equipment Enhancement - 装备强化
// ═══════════════════════════════════════════════════════════

function sceneEquipmentEnhance() {
  G._currentScene = 'sceneEquipmentEnhance';
  var tab = G._eqTab || 'enhance';
  var html = '';
  html += '<div class="scene-title">⚡ 装备强化</div>';
  html += '<div class="money-display">💰 ' + G.gold + ' 金币</div>';
  html += '<div class="btns" style="margin-bottom:10px">';
  html += '<button class="btn ' + (tab==='enhance'?'btn-primary':'') + '" onclick="G._eqTab=\'enhance\';sceneEquipmentEnhance()" style="flex:1">⬆️ 强化</button>';
  html += '<button class="btn ' + (tab==='disenchant'?'btn-primary':'') + '" onclick="G._eqTab=\'disenchant\';sceneEquipmentEnhance()" style="flex:1">💎 分解</button>';
  html += '</div>';

  if (tab === 'enhance') {
    html += '<div style="color:#aaa;font-size:0.85em;margin-bottom:8px">选择一件装备进行强化,最多强化到+10级</div>';
    var hasEq = false;
    html += '<div class="shop-items">';
    for (var i = 0; i < G.inventory.length; i++) {
      var item = G.inventory[i];
      if (!_isEnhanceable(item)) continue;
      hasEq = true;
      var rarity = item.rarity || 'common';
      var rarColors = { common:'#9d9d9d', uncommon:'#1eff00', rare:'#0070dd', epic:'#a335ee', legendary:'#ff8000', mythic:'#e6cc80' };
      var col = rarColors[rarity] || '#9d9d9d';
      var lvl = item.enhanceLevel || 0;
      var nextCost = ENHANCE_COSTS[rarity];
      var canEnhance = lvl < MAX_ENHANCE_LEVEL;
      html += '<div class="shop-item" style="' + (!canEnhance ? 'opacity:0.6' : '') + '">';
      html += '<div class="item-name" style="color:' + col + '">' + (item.icon||'') + ' ' + item.name + ' <span style="color:#d4a017">+' + lvl + '</span></div>';
      html += '<div class="item-stats">' + getItemStatString(item) + '</div>';
      if (canEnhance) {
        var costGold = Math.floor(nextCost.gold * Math.pow(1.3, lvl)); // C10: 1.5→1.3 gentler scaling
        var costMats = nextCost.mats.map(function(cm) {
          var have = countMaterialInInventory(cm.mid);
          var m = MATERIALS[cm.mid];
          var ok = have >= cm.qty;
          return m.icon + m.name + '×' + have + '/' + cm.qty + (ok ? '✅' : '❌');
        }).join(', ');
        html += '<div style="font-size:0.8em;color:#d4a017;margin-top:2px">消耗:' + costGold + '💰 + ' + costMats + '</div>';
        html += '<button class="btn-small" style="margin-top:4px;font-size:0.8em" onclick="showEnhanceConfirm(' + i + ')">⬆️ 强化+' + (lvl+1) + '</button>';
      } else {
        html += '<div style="font-size:0.8em;color:#ff8000;margin-top:2px">已达最大强化等级</div>';
      }
      html += '</div>';
    }
    html += '</div>';
    if (!hasEq) html += '<div style="color:#888;text-align:center;padding:20px">背包中没有可强化的装备</div>';
  } else {
    // Disenchant tab
    html += '<div style="color:#aaa;font-size:0.85em;margin-bottom:8px">分解装备回收材料（装备消失）</div>';
    var hasEq2 = false;
    html += '<div class="shop-items">';
    for (var j = 0; j < G.inventory.length; j++) {
      var item2 = G.inventory[j];
      if (!_isEnhanceable(item2)) continue;
      hasEq2 = true;
      var rarity2 = item2.rarity || 'common';
      var rar2Colors = { common:'#9d9d9d', uncommon:'#1eff00', rare:'#0070dd', epic:'#a335ee', legendary:'#ff8000', mythic:'#e6cc80' };
      var col2 = rar2Colors[rarity2] || '#9d9d9d';
      var yields = DISENCHANT_YIELD[rarity2] || [];
      var yieldStr = yields.map(function(y) {
        var m = MATERIALS[y.mid];
        return m ? m.icon + m.name + '×' + y.qty : y.mid + '×' + y.qty;
      }).join(', ');
      var goldRet = Math.floor((item2.price || 50) * DISENCHANT_GOLD_FRAC);
      html += '<div class="shop-item" style="position:relative">';
      html += '<div class="item-name" style="color:' + col2 + '">' + (item2.icon||'') + ' ' + item2.name + '</div>';
      html += '<div class="item-stats">' + getItemStatString(item2) + '</div>';
      html += '<div style="font-size:0.8em;color:#22c55e;margin-top:2px">分解获得:' + yieldStr + ' +' + goldRet + '💰</div>';
      html += '<button class="btn-small" style="position:absolute;right:4px;top:4px;background:#4a2a1a;border:1px solid #a55;color:#a335ee;font-size:0.75em" onclick="showDisenchantConfirm(' + j + ')">💎分解</button>';
      html += '</div>';
    }
    html += '</div>';
    if (!hasEq2) html += '<div style="color:#888;text-align:center;padding:20px">背包中没有可分解的装备</div>';
  }

  html += '<div class="btns" style="margin-top:10px">';
  html += '<button class="btn" onclick="sceneTown()">↩️ 返回城镇</button>';
  html += '</div>';
  render(html);
}

function showEnhanceConfirm(invIdx) {
  var item = G.inventory[invIdx];
  if (!item) return;
  var rarity = item.rarity || 'common';
  var lvl = item.enhanceLevel || 0;
  if (lvl >= MAX_ENHANCE_LEVEL) { toast('已达最大强化等级'); return; }
  var cost = ENHANCE_COSTS[rarity];
  var costGold = Math.floor(cost.gold * Math.pow(1.3, lvl)); // C10: 1.5→1.3 gentler scaling
  var costMatsStr = cost.mats.map(function(cm) {
    var have = countMaterialInInventory(cm.mid);
    var m = MATERIALS[cm.mid];
    return m.icon + m.name + '×' + have + '/' + cm.qty;
  }).join(', ');
  var html = '';
  html += '<div class="scene-title">⬆️ 确认强化 - ' + item.name + ' +' + lvl + '</div>';
  html += '<div style="padding:12px;background:#16213e;border-radius:8px;margin:8px 0">';
  html += '<div style="color:#d4a017;font-weight:bold">强化费用:</div>';
  html += '<div style="color:#aaa;margin-top:4px">💰 ' + costGold + ' 金币</div>';
  html += '<div style="color:#aaa;margin-top:2px">材料: ' + costMatsStr + '</div>';
  html += '<div style="color:#22c55e;font-size:0.85em;margin-top:4px">强化后属性提升:' + JSON.stringify(ENHANCE_BOOST) + '</div>';
  html += '</div>';
  html += '<div class="btns">';
  html += '<button class="btn btn-primary" onclick="enhanceEquipment(' + invIdx + ')">⬆️ 确认强化</button>';
  html += '<button class="btn" onclick="sceneEquipmentEnhance()">↩️ 取消</button>';
  html += '</div>';
  render(html);
}

function enhanceEquipment(invIdx) {
  var item = G.inventory[invIdx];
  if (!item) return;
  var rarity = item.rarity || 'common';
  var lvl = item.enhanceLevel || 0;
  if (lvl >= MAX_ENHANCE_LEVEL) { toast('已达最大强化等级'); return; }
  var cost = ENHANCE_COSTS[rarity];
  var costGold = Math.floor(cost.gold * Math.pow(1.3, lvl)); // C10: 1.5→1.3 gentler scaling
  if (G.gold < costGold) { toast('💰 金币不足'); sceneEquipmentEnhance(); return; }
  for (var ci = 0; ci < cost.mats.length; ci++) {
    if (countMaterialInInventory(cost.mats[ci].mid) < cost.mats[ci].qty) {
      toast('材料不足'); sceneEquipmentEnhance(); return;
    }
  }
  G.gold -= costGold;
  removeMaterialsFromInventory(cost.mats);
  item.enhanceLevel = lvl + 1;
  G._enhanceCount = (G._enhanceCount || 0) + 1;
  if (item.enhanceLevel >= MAX_ENHANCE_LEVEL) G._maxEnhanceCount = (G._maxEnhanceCount || 0) + 1;
  // Apply boost stats
  var boost = ENHANCE_BOOST;
  for (var stat in boost) {
    if (item[stat] !== undefined) item[stat] = (item[stat] || 0) + boost[stat];
    else if (boost[stat] > 0) item[stat] = boost[stat];
  }
  updateStatus();
  checkStoryTriggers('enhance_equipment', item.id);
  checkAchievements();
  autoSave(); // Auto-save on enhance
  toast('⬆️ 强化成功!' + item.name + ' → +' + item.enhanceLevel);
  sceneEquipmentEnhance();
}

function showDisenchantConfirm(invIdx) {
  var item = G.inventory[invIdx];
  if (!item) return;
  var rarity = item.rarity || 'common';
  var yields = DISENCHANT_YIELD[rarity] || [];
  var yieldStr = yields.map(function(y) {
    var m = MATERIALS[y.mid];
    return m ? m.icon + m.name + '×' + y.qty : y.mid + '×' + y.qty;
  }).join(', ');
  var goldRet = Math.floor((item.price || 50) * DISENCHANT_GOLD_FRAC);
  var html = '';
  html += '<div class="scene-title">💎 确认分解 - ' + item.name + '</div>';
  html += '<div style="padding:12px;background:#2a0a1a;border-radius:8px;margin:8px 0">';
  html += '<div style="color:#a335ee;font-weight:bold">⚠️ 分解后装备将消失!</div>';
  html += '<div style="color:#22c55e;margin-top:6px">分解获得:' + yieldStr + '</div>';
  html += '<div style="color:#d4a017;margin-top:2px">金币返还:+' + goldRet + ' 💰</div>';
  html += '</div>';
  html += '<div class="btns">';
  html += '<button class="btn btn-primary" onclick="disenchantEquipment(' + invIdx + ')">💎 确认分解</button>';
  html += '<button class="btn" onclick="sceneEquipmentEnhance()">↩️ 取消</button>';
  html += '</div>';
  render(html);
}

function disenchantEquipment(invIdx) {
  var item = G.inventory[invIdx];
  if (!item) return;
  var rarity = item.rarity || 'common';
  var yields = DISENCHANT_YIELD[rarity] || [];
  var goldRet = Math.floor((item.price || 50) * DISENCHANT_GOLD_FRAC);
  // Add materials to inventory
  for (var di = 0; di < yields.length; di++) {
    var y = yields[di];
    var m = MATERIALS[y.mid];
    if (m) {
      for (var k = 0; k < y.qty; k++) {
        G.inventory.push({
          id: y.mid, name: m.name, type: 'material',
          icon: m.icon, rarity: m.rarity,
          sellPrice: m.sellPrice, craftValue: m.craftValue || 1
        });
      }
    }
  }
  G.gold += goldRet;
  G.inventory.splice(invIdx, 1);
  G._disenchantCount = (G._disenchantCount || 0) + 1;
  updateStatus();
  checkStoryTriggers('disenchant_equipment', item.id);
  checkAchievements();
  autoSave(); // Auto-save on disenchant
  toast('💎 分解成功! +' + goldRet + '💰 + 材料');
  sceneEquipmentEnhance();
}

