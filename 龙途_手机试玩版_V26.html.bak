  { id:'dd_shop_heal', name:'生命药水', desc:'恢复50%最大HP', cost:30, effect:function(){ G.hp=Math.min(G.maxHp,G.hp+Math.floor(G.maxHp*0.5)); toast('❤️ 恢复50% HP'); } },
  { id:'dd_shop_mana', name:'魔力药水', desc:'恢复50%最大MP', cost:20, effect:function(){ G.mp=Math.min(G.maxMp,G.mp+Math.floor(G.maxMp*0.5)); toast('💧 恢复50% MP'); } },
  { id:'dd_shop_atk', name:'力量卷轴', desc:'本次深潜ATK+8', cost:50, effect:function(){ G._ddTempAtk=(G._ddTempAtk||0)+8; toast('⚔️ +8攻击力(本次深潜)'); } },
  { id:'dd_shop_def', name:'守护卷轴', desc:'本次深潜DEF+8', cost:50, effect:function(){ G._ddTempDef=(G._ddTempDef||0)+8; toast('🛡️ +8防御力(本次深潜)'); } },
  { id:'dd_shop_crit', name:'致命卷轴', desc:'本次深潜暴击+10%', cost:80, effect:function(){ G._ddTempCrit=(G._ddTempCrit||0)+0.1; toast('🎯 +10%暴击率(本次深潜)'); } },
  { id:'dd_shop_shield', name:'暗影护盾', desc:'获得一层护盾(抵扣30%最大HP伤害)', cost:100, effect:function(){ G._shield=(G._shield||0)+Math.floor(G.maxHp*0.3); toast('🛡️ 获得暗影护盾'); } },
  { id:'dd_shop_resurrect', name:'复活卷轴', desc:'本次深潜死亡时自动复活(50%HP)', cost:150, effect:function(){ G._ddResurrect=true; toast('💫 获得复活效果(死亡时自动触发)'); } },
  { id:'dd_shop_drop', name:'幸运符', desc:'本次深潜掉落率+20%', cost:60, effect:function(){ G._ddDropBonus=(G._ddDropBonus||0)+0.2; toast('🍀 +20%掉落率(本次深潜)'); } },
  { id:'dd_shop_perm_hp', name:'永久·生命精髓', desc:'永久+20最大HP', cost:200, once:true, effect:function(){ G.maxHp+=20; G.hp+=20; toast('❤️ 永久+20最大HP'); } },
  { id:'dd_shop_perm_atk', name:'永久·力量精髓', desc:'永久+3 ATK', cost:200, once:true, effect:function(){ G._permStats=G._permStats||{}; G._permStats.atk=(G._permStats.atk||0)+3; toast('⚔️ 永久+3 ATK'); } }
];

