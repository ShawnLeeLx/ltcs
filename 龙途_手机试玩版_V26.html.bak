  misthollow: { id:'misthollow', x:120, y:250, name:'雾隐谷', type:'wild', emoji:'🌫️', unlocked:false, levelRange:[26,35],
    desc:'常年被迷雾笼罩的山谷,传说是古代巫师的隐居之地',
    mapConfig:{ cols:20, rows:18, name:'雾隐谷', enemyRate:0.22, treasureRate:0.12, eventRate:0.08,
      desc:'浓雾中什么都看不清...', startPos:{r:16,c:1}, bossPos:{r:1,c:18} },
    enemies:['mist_wraith','shadow_spider','fog_crawler'],
    townDesc:'浓雾如纱帐笼罩山谷,远处的灯火在雾中忽明忽暗。脚下的石板路湿滑,空气中弥漫着草药与泥土的气息。偶尔传来不知名的低语,分不清是风声还是山中生灵的呼唤。' },
  jademarsh: { id:'jademarsh', x:200, y:340, name:'翠玉沼泽', type:'wild', emoji:'🌿', unlocked:false, levelRange:[30,40],
    desc:'翠绿色的沼泽中潜伏着毒物和古代遗迹',
    mapConfig:{ cols:20, rows:18, name:'翠玉沼泽', enemyRate:0.24, treasureRate:0.14, eventRate:0.06,
      desc:'沼泽水面上映出翡翠般的光...', startPos:{r:16,c:1}, bossPos:{r:1,c:18} },
    enemies:['swamp_beast','venom_snake','marsh_zombie'],
    townDesc:'翡翠色的水面泛着微光,气泡从深处缓缓升起。沼泽中的树木盘根错节,枝头挂着奇异的荧光菌。远处传来蛙鸣与蛇嘶,偶尔可见水面上划过的不明身影。' },
  sunspire: { id:'sunspire', x:460, y:200, name:'日冕塔', type:'town', emoji:'🕌', unlocked:false, levelRange:[35,45],
    desc:'南方的学术之都,高塔林立,学者们在此研究龙族历史',
