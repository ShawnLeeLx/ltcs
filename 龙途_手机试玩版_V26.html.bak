  // === Ch11-12 ===
  { id:'uniq_voidcloak', name:'虚空行者披风', slot:'armor', rarity:'legendary', level:40, icon:'🛡️',
    desc:'在虚空裂隙中飘荡的诡异披风，穿戴者能在影间穿梭',
    bossOnly:'boss_void_emperor',
    def:40, dodge:0.20, sellPrice:1800 },
  { id:'uniq_kingcrown', name:'万古王冠', slot:'helmet', rarity:'mythic', level:50, icon:'🪖',
    desc:'初代龙王的王冠，镶嵌着原初碎片',
    bossOnly:'boss_ancient_king',
    def:50, atk:25, matk:25, setId:'flame_lord', sellPrice:3000 }
];

// Regional themed drop pools - enemies in these zones have a chance to drop thematic random gear
var REGIONAL_DROP_POOL = {
  whispering_forest: { prefixes:['毒牙之','藤蔓之','森林之'], effects:['poison','lifesteal'], affixes:['agi','dodge'] },
  lake_breeze:       { prefixes:['湖光之','涟漪之'], effects:['lifesteal','frost'], affixes:['matk','mp'] },
  iron_hills:        { prefixes:['铁壁之','刚毅之'], effects:['counter'], affixes:['def','hp','str'] },
  ice_cape:          { prefixes:['霜寒之','冰封之'], effects:['frost'], affixes:['def','matk'] },
  dark_mine:         { prefixes:['暗矿之','晶石之'], effects:['shadow'], affixes:['atk','critRate'] },
  mist_marsh:        { prefixes:['迷雾之','沼泽之'], effects:['poison','lifesteal'], affixes:['agi','dodge'] },
  storm_plateau:     { prefixes:['雷鸣之','风暴之'], effects:['stun','storm'], affixes:['atk','agi','critRate'] },
  wind_song_forest:  { prefixes:['风歌之','龙风之'], effects:['storm','crit'], affixes:['agi','dodge','critRate'] },
  dragon_border:     { prefixes:['龙鳞之','龙血之'], effects:['fire','lifesteal'], affixes:['atk','str','hp'] },
  ash_wastes:        { prefixes:['灰烬之','凤凰之'], effects:['fire','holy'], affixes:['matk','mp','critRate'] },
  dragon_spine:      { prefixes:['龙骨之','熔岩之'], effects:['fire'], affixes:['atk','def','hp'] },
  void_rift:         { prefixes:['虚空之','暗影之'], effects:['shadow','stun'], affixes:['matk','agi'] },
  shadow_temple:     { prefixes:['暗影之','亡灵之'], effects:['shadow','lifesteal'], affixes:['matk','lifestealAff'] },
  ancient_throne:    { prefixes:['万古之','王者之'], effects:['holy','storm'], affixes:['critRate','lifestealAff'] }
};

// Helper: get regional drop theme for current location
function getRegionalDropTheme(locId) {
  var loc = LOCATIONS[locId];
  if (!loc) return null;
  if (REGIONAL_DROP_POOL[locId]) return REGIONAL_DROP_POOL[locId];
  if (loc.adjacent) {
    for (var ai = 0; ai < loc.adjacent.length; ai++) {
      var adj = REGIONAL_DROP_POOL[loc.adjacent[ai]];
      if (adj) return adj;
    }
  }
  return null;
}

// Boss Unique Item Drop
function tryUniqueItemDrop(bossId) {
  var firstKill = !G.bossDefeated[bossId];
  var dropChance = firstKill ? 0.80 : 0.30;
  if (Math.random() >= dropChance) return null;
  var uniq = UNIQUE_ITEMS.filter(function(u) { return u.bossOnly === bossId; });
  if (uniq.length === 0) return null;
  var item = JSON.parse(JSON.stringify(uniq[0]));
  item.type = 'equipment';
  item.isUnique = true;
  item.rarityColor = RARITY_TABLE[item.rarity].color;
  return item;
}

// Random equipment drop generator
function generateRandomDrop(isBoss, rarityOverride) {
  // isBoss: boolean or number (truthy = boss rates; number from DD = levelScale)
  // rarityOverride: optional string to force rarity (from DD drops)
  var allSlots = ['weapon','helmet','armor','gloves','boots','belt','necklace','ring'];
  var slot = allSlots[rand(0, allSlots.length - 1)];
  var sd = SLOT_DEFS[slot];

  // Determine rarity with LUCK tier bonus
  // Luck tiers: 0-9 = 普通, 10-19 = 吉运, 20-29 = 天选, 30+ = 神眷
  // Each tier shifts rarity probabilities upward
  var luckTier = G.luk < 10 ? 0 : (G.luk < 20 ? 1 : (G.luk < 30 ? 2 : 3));
  // dropTierBonus from set bonuses (幸运商人6件)
  var setBonus = 0;
  var setBonuses = calcSetBonuses();
  if (setBonuses.dropTierBonus) setBonus = setBonuses.dropTierBonus;
  luckTier += setBonus;

  // Base thresholds: [mythic, legendary, epic, rare, uncommon]
  // Normal:  [0.1, 1, 5, 15, 40]
  // Each luck tier shifts: +0.5% mythic, +2% legendary, +5% epic, +8% rare, +10% uncommon
  var tierShift = luckTier;
  // Story choice: 'luk_bonus' gives +15% loot drop rate
  if (G._lootBonus) tierShift += G._lootBonus * 5; // 0.15 * 5 = 0.75 extra tier shift
  var rarityRoll = Math.random() * 100;
  var rarity;
  if (isBoss) {
    // Boss: better base + luck shift
    var mythicCh = 2 + tierShift * 1;
    var legendCh = mythicCh + 18 + tierShift * 3;
    var epicCh = legendCh + 40 + tierShift * 5;
    var rareCh = epicCh + 30 + tierShift * 4;
    if (rarityRoll < mythicCh) rarity = 'mythic';
    else if (rarityRoll < legendCh) rarity = 'legendary';
    else if (rarityRoll < epicCh) rarity = 'epic';
    else if (rarityRoll < rareCh) rarity = 'rare';
    else rarity = 'uncommon';
  } else {
    // Normal mob
    var mythicCh = 0.1 + tierShift * 0.5;
    var legendCh = mythicCh + 0.9 + tierShift * 2;
    var epicCh = legendCh + 4 + tierShift * 5;
    var rareCh = epicCh + 10 + tierShift * 8;
    var uncomCh = rareCh + 25 + tierShift * 10;
    if (rarityRoll < mythicCh) rarity = 'mythic';
    else if (rarityRoll < legendCh) rarity = 'legendary';
    else if (rarityRoll < epicCh) rarity = 'epic';
    else if (rarityRoll < rareCh) rarity = 'rare';
    else if (rarityRoll < uncomCh) rarity = 'uncommon';
    else rarity = 'common';
  }
  // Apply rarity override from Deep Dive drops
  if (rarityOverride && RARITY_TABLE[rarityOverride]) rarity = rarityOverride;
  var rt = RARITY_TABLE[rarity];
  var levelScale = Math.max(1, G.level - rand(0, 2));

  // Stat prefix (1) - filtered by slot type for thematic consistency
  var validStatPfx = STAT_PREFIXES.filter(function(p) {
    if (slot === 'weapon') {
      var wName = sd.names[rand(0, sd.names.length - 1)];
      var isMagicWeapon = (wName.indexOf('法杖') >= 0 || wName.indexOf('魔杖') >= 0);
      if (isMagicWeapon) return p.stat === 'matk' || p.stat === 'maxHp' || p.stat === 'luk';
      else return p.stat === 'atk' || p.stat === 'dodge' || p.stat === 'maxHp' || p.stat === 'luk';
    }
    if (slot === 'helmet' || slot === 'armor') return p.stat === 'def' || p.stat === 'maxHp' || p.stat === 'matk';
    if (slot === 'boots') return p.stat === 'dodge' || p.stat === 'maxHp';
    if (slot === 'necklace' || slot === 'ring') return true; // accessories can have any prefix
    return true;
  });
  if (validStatPfx.length === 0) validStatPfx = STAT_PREFIXES;
  var statPfx = validStatPfx[rand(0, validStatPfx.length - 1)];
  var pfxObj = { name: statPfx.name, stat: statPfx.stat };
  if (statPfx.mult) pfxObj.mult = statPfx.mult;
  if (statPfx.flatMin) pfxObj.value = rand(statPfx.flatMin, statPfx.flatMax);

  // Effect prefixes (0 to max) - filtered by slot type
  var validEffectPfx = EFFECT_PREFIXES.filter(function(e) {
    if (slot === 'weapon') {
      var wName2 = sd.names[rand(0, sd.names.length - 1)];
      var isMagicW = (wName2.indexOf('法杖') >= 0 || wName2.indexOf('魔杖') >= 0);
      if (isMagicW) return e.type === 'fire' || e.type === 'frost' || e.type === 'lifesteal' || e.type === 'crit';
      else return e.type === 'fire' || e.type === 'crit' || e.type === 'counter' || e.type === 'doubleAtk' || e.type === 'deadly';
    }
    if (slot === 'helmet' || slot === 'armor') return e.type === 'frost' || e.type === 'counter' || e.type === 'lifesteal';
    if (slot === 'gloves') return e.type === 'crit' || e.type === 'doubleAtk' || e.type === 'counter';
    if (slot === 'boots') return e.type === 'frost' || e.type === 'lifesteal';
    return true;
  });
  if (validEffectPfx.length === 0) validEffectPfx = EFFECT_PREFIXES;

  var numEffectPfx = rand(rt.prefixMin - 1, rt.prefixMax - 1); // -1 because 1 stat prefix already used
  numEffectPfx = Math.max(0, numEffectPfx);
  var effects = [];
  var usedEffTypes = {};
  for (var ei = 0; ei < numEffectPfx; ei++) {
    var eff = validEffectPfx[rand(0, validEffectPfx.length - 1)];
    if (usedEffTypes[eff.type]) continue;
    usedEffTypes[eff.type] = true;
    var effObj = { name: eff.name, type: eff.type };
    if (eff.dmgMin !== undefined) effObj.dmg = rand(eff.dmgMin, eff.dmgMax);
    if (eff.slowPct !== undefined) effObj.slowPct = eff.slowPct;
    if (eff.valMin !== undefined) effObj.value = rand(eff.valMin, eff.valMax);
    effects.push(effObj);
  }

  // Random affixes - filtered by slot type
  var validAffixes = AFFIX_POOL.filter(function(a) {
    if (slot === 'weapon') {
      var wName3 = sd.names[rand(0, sd.names.length - 1)];
      var isMagicW2 = (wName3.indexOf('法杖') >= 0 || wName3.indexOf('魔杖') >= 0);
      if (isMagicW2) return a.stat === 'int' || a.stat === 'matk' || a.stat === 'mp' || a.stat === 'critRate' || a.stat === 'luk' || a.stat === 'cha';
      else return a.stat === 'str' || a.stat === 'agi' || a.stat === 'atk' || a.stat === 'critRate' || a.stat === 'dodge' || a.stat === 'luk';
    }
    if (slot === 'helmet' || slot === 'armor') return a.stat === 'def' || a.stat === 'hp' || a.stat === 'str' || a.stat === 'int' || a.stat === 'mp';
    if (slot === 'gloves') return a.stat === 'atk' || a.stat === 'agi' || a.stat === 'critRate' || a.stat === 'str';
    if (slot === 'boots') return a.stat === 'agi' || a.stat === 'dodge' || a.stat === 'hp';
    if (slot === 'belt') return a.stat === 'hp' || a.stat === 'str' || a.stat === 'def';
    return true;
  });
  if (validAffixes.length === 0) validAffixes = AFFIX_POOL;

  var numAffixes = rand(rt.affixMin, rt.affixMax);
  var affixes = [];
  var usedAffixStats = {};
  for (var ai = 0; ai < numAffixes; ai++) {
    var af = validAffixes[rand(0, validAffixes.length - 1)];
    if (usedAffixStats[af.stat]) continue;
    usedAffixStats[af.stat] = true;
    var val = rand(af.min, af.max);
    var pctScale = 0.6 + Math.random() * 0.7; // 60%~130%
    val = Math.floor(val * rt.mult * pctScale);
    // Level scale: reduce affix power for low-level items to prevent stat inflation
    // At level 1-5: 40-60% power; at level 10: 75%; at level 20+: 100%
    var lvlFactor = Math.min(1, 0.3 + (levelScale / 20) * 0.7);
    val = Math.max(1, Math.floor(val * lvlFactor));
    affixes.push({ stat: af.stat, value: val, label: af.label, isPct: !!af.isPct });
  }

  // Set assignment (rare+ only, 30% chance)
  var setId = null;
  if (rarity !== 'common' && rarity !== 'uncommon' && Math.random() < 0.3) {
    var setKeys = Object.keys(EQUIP_SETS);
    setId = setKeys[rand(0, setKeys.length - 1)];
  }

  // Build item name
  var baseName = sd.names[rand(0, sd.names.length - 1)];
  var fullName = pfxObj.name;
  for (var eni = 0; eni < effects.length; eni++) fullName += effects[eni].name;
  fullName += baseName;
  if (setId) fullName = '【' + EQUIP_SETS[setId].name + '】' + fullName;

  // Build item object
  var item = {
    name: fullName,
    type: 'equipment',
    slot: slot,
    level: levelScale,
    rarity: rarity,
    rarityColor: rt.color,
    icon: sd.icon,
    setId: setId,
    prefix: pfxObj,
    effects: effects,
    affixes: affixes,
    // Base stats (multiplier applied)
    atk: 0, def: 0, hp: 0, mp: 0, matk: 0,
    critRate: 0, dodge: 0, lifesteal: 0,
    fireDmg: 0, counterRate: 0, doubleAtkRate: 0, deadlyRate: 0
  };

  // Slot-specific base stats
  item.atk = Math.floor((sd.baseAtk + (sd.baseAtkPerLv || 0) * levelScale) * rt.mult);
  item.def = Math.floor((sd.baseDef + (sd.baseDefPerLv || 0) * levelScale) * rt.mult);
  item.hp  = Math.floor((sd.baseHp + (sd.baseHpPerLv || 0) * levelScale) * rt.mult);
  if (sd.baseMatk) item.matk = Math.floor(sd.baseMatk * levelScale * rt.mult);
  if (sd.baseDodge) item.dodge = sd.baseDodge * rt.mult;
  if (sd.baseLuk) item.luk = Math.floor(sd.baseLuk * rt.mult);

  // Apply stat prefix to base
  if (pfxObj.stat === 'atk' && pfxObj.mult) item.atk = Math.floor(item.atk * (1 + pfxObj.mult));
  if (pfxObj.stat === 'def' && pfxObj.mult) item.def = Math.floor(item.def * (1 + pfxObj.mult));
  if (pfxObj.stat === 'matk' && pfxObj.mult) item.matk = Math.floor(item.matk * (1 + pfxObj.mult));
  if (pfxObj.stat === 'maxHp' && pfxObj.mult) item.hp = Math.floor(item.hp * (1 + pfxObj.mult));
  if (pfxObj.stat === 'luk' && pfxObj.value) item.luk = (item.luk || 0) + pfxObj.value;

  // Apply effect prefixes
  for (var efi = 0; efi < effects.length; efi++) {
    var ef = effects[efi];
    if (ef.type === 'fire') item.fireDmg = ef.dmg;
    if (ef.type === 'lifesteal') item.lifesteal = ef.value / 100;
    if (ef.type === 'crit') item.critRate = ef.value / 100;
    if (ef.type === 'deadly') item.deadlyRate = ef.value / 100;
    if (ef.type === 'counter') item.counterRate = ef.value / 100;
    if (ef.type === 'doubleAtk') item.doubleAtkRate = ef.value / 100;
    if (ef.type === 'frost') item.frostSlow = ef.slowPct;
    if (ef.type === 'stun') item.stunChance = (ef.value || 15) / 100;
    if (ef.type === 'poison') item.poisonDmg = ef.value || rand(3, 8);
    if (ef.type === 'holy') item.holyDmg = ef.value || rand(5, 12);
    if (ef.type === 'shadow') item.shadowDmg = ef.value || rand(4, 10);
    if (ef.type === 'storm') item.stormDmg = ef.value || rand(6, 14);
  }

  // Apply affix bonuses to item
  for (var afi = 0; afi < affixes.length; afi++) {
    var a = affixes[afi];
    if (a.stat === 'atk') item.atk += a.value;
    if (a.stat === 'def') item.def += a.value;
    if (a.stat === 'hp') item.hp += a.value;
    if (a.stat === 'mp') item.mp += a.value;
    if (a.stat === 'matk') item.matk += a.value;
    if (a.stat === 'str') item.str = (item.str || 0) + a.value;
    if (a.stat === 'agi') item.agi = (item.agi || 0) + a.value;
    if (a.stat === 'int') item.int = (item.int || 0) + a.value;
    if (a.stat === 'cha') item.cha = (item.cha || 0) + a.value;
    if (a.stat === 'luk') item.luk = (item.luk || 0) + a.value;
    if (a.stat === 'critRate') item.critRate += a.value / 100;
    if (a.stat === 'dodge') item.dodge += a.value / 100;
    if (a.stat === 'lifestealAff') item.lifesteal = (item.lifesteal || 0) + a.value / 100;
    if (a.stat === 'counterAff') item.counterRate = (item.counterRate || 0) + a.value / 100;
  }

  // Calculate sell price based on rarity + stats + level
  var rarityPrice = { common:8, uncommon:20, rare:60, epic:150, legendary:400, mythic:1000 };
  var statValue = (item.atk || 0) * 3 + (item.matk || 0) * 3 + (item.def || 0) * 2 + (item.hp || 0) * 0.5 + (item.mp || 0) * 0.5;
  statValue += (item.critRate || 0) * 50 + (item.dodge || 0) * 50 + (item.lifesteal || 0) * 80;
  statValue += (item.fireDmg || 0) * 2 + (item.doubleAtkRate || 0) * 60 + (item.counterRate || 0) * 40 + (item.deadlyRate || 0) * 50;
  statValue += (item.poisonDmg || 0) * 2 + (item.holyDmg || 0) * 3 + (item.shadowDmg || 0) * 2.5 + (item.stormDmg || 0) * 2.5;
  statValue += (item.stunChance || 0) * 40 + (item.deathSave ? 200 : 0);
  if (item.luk) statValue += item.luk * 2;
  if (item.str) statValue += item.str * 2;
  if (item.agi) statValue += item.agi * 2;
  if (item.int) statValue += item.int * 2;
  if (item.cha) statValue += item.cha * 1.5;
  item.sellPrice = Math.floor((rarityPrice[rarity] || 10 + statValue * 0.5) + levelScale * 3);
  if (setId) item.sellPrice = Math.floor(item.sellPrice * 1.3);
  // Ensure minimum sell price
  if (item.sellPrice < 5) item.sellPrice = 5;

  return item;
}

function endBattle() {
  var b = G.battle;
  
  // A3: Wave battle — if more waves remain, show intermission instead of full victory
  if (b && b.waves && b.wave < b.totalWaves - 1) {
    G.inBattle = false;
    if (G._autoBattle) stopAutoBattle();
    
    // Partial rewards for current wave (gold + XP only, no full drops)
    var partialXp = 0;
    for (var wi = 0; wi < b.enemies.length; wi++) {
      partialXp += Math.floor((b.enemies[wi].xp || 0) * 0.3);
      var wGold = rand(2, 5) + Math.floor((b.enemies[wi].lv || 1) * 0.3);
      G.gold += wGold;
      if (b.enemies[wi].id) {
        if (!G._enemyKills) G._enemyKills = {};
        G._enemyKills[b.enemies[wi].id] = (G._enemyKills[b.enemies[wi].id] || 0) + 1;
      }
      if (b.enemies[wi]._rareSpawn) G._rareKills = (G._rareKills || 0) + 1;
    }
    G.xp += partialXp;
    while (G.xp >= calcNextXp(G.level)) { doLevelUp(); }
    
    // Small material drop chance per wave
    var waveMats = [];
    for (var wmi = 0; wmi < b.enemies.length; wmi++) {
      var we = b.enemies[wmi];
      var wMatDrops = ENEMY_MAT_DROPS[we.id];
      if (wMatDrops && Math.random() < 0.3) {
        var wmt = ['common', 'uncommon'];
        var wt = wmt[rand(0, wmt.length - 1)];
        if (wMatDrops[wt] && wMatDrops[wt].length > 0) {
          var wmd = wMatDrops[wt][rand(0, wMatDrops[wt].length - 1)];
          if (Math.random() < wmd.rate * 1.5) {
            var wmat = MATERIALS[wmd.mid];
            if (wmat) {
              waveMats.push({ id:wmat.id, name:wmat.name, type:'material', icon:wmat.icon, category:wmat.category, rarity:wmat.rarity, sellPrice:wmat.sellPrice, craftValue:wmat.craftValue });
              G.inventory.push(waveMats[waveMats.length - 1]);
            }
          }
        }
      }
    }
    
    // Wave no-damage tracking
    if (G._waveNoDamage && G.hp === G.maxHp) {
      G._wavePerfectCount = (G._wavePerfectCount || 0) + 1;
    }
    
    // Track battle won count (but not boss defeat)
    G.totalBattlesWon++;
    G._battleCount = (G._battleCount || 0) + 1;
    checkAchievements();
    updateStatus();
    
    // Show wave intermission
    G.inBattle = true; // Still in multi-wave battle
    _showWaveIntermission(b.wave + 1, b.totalWaves, b.waves[b.wave + 1]);
    
    // Toast partial rewards
    toast('+' + partialXp + ' XP | +' + (b.enemies.length > 0 ? '💰' : '') + ' | 波次完成!');
    if (waveMats.length > 0) {
      toast('获得: ' + waveMats.map(function(m) { return m.icon + m.name; }).join(' '));
    }
    return;
  }
  
  G.inBattle = false;
  if (G._autoBattle) stopAutoBattle();

  var totalXp = 0;
  var drops = []; // equipment/item/material drops
  for (var i = 0; i < b.enemies.length; i++) {
    var e = b.enemies[i];
    totalXp += Math.floor((e.xp || 0) * 0.5); // Halved XP from combat
    // C10: Small gold drops restored (5-15g per enemy, scaled by level)
    var goldDrop = rand(5, 10) + Math.floor((e.lv || 1) * 0.5);
    G.gold += goldDrop;
    totalXp += 0; // (already counted above)

    // Track enemy kills for bestiary achievements
    if (e.id) {
      if (!G._enemyKills) G._enemyKills = {};
      G._enemyKills[e.id] = (G._enemyKills[e.id] || 0) + 1;
    }
    // Track rare spawn kills
    if (e._rareSpawn) {
      G._rareKills = (G._rareKills || 0) + 1;
    }

    // Equipment drop chance
    var dropRoll = Math.random() * 100;
    var baseDropRate = e.isBoss ? 60 : (e.isElite ? 40 : 15);
    var lukBonus = G.luk * 1;
    var totalDropRate = Math.min(85, baseDropRate + lukBonus);

    if (dropRoll < totalDropRate) {
      // Boss: try unique item drop first
      var item = null;
      if (e.isBoss && b.bossKey) {
        item = tryUniqueItemDrop(b.bossKey);
      }
      if (!item) {
        item = generateRandomDrop(e.isBoss);
      }
      // Apply regional themed prefixes/affixes to non-unique items
      if (item && !item.isUnique) {
        var theme = getRegionalDropTheme(G.location);
        if (theme) {
          // 40% chance to apply a regional prefix
          if (Math.random() < 0.4 && theme.prefixes.length > 0) {
            var rpfx = theme.prefixes[rand(0, theme.prefixes.length - 1)];
            item.name = rpfx + item.name;
          }
        }
      }
      if (item) drops.push(item);
    }

    // Material drops (new!)
    var matDrops = ENEMY_MAT_DROPS[e.id];
    if (matDrops) {
      var tiers = ['common', 'uncommon', 'rare', 'epic'];
      for (var ti = 0; ti < tiers.length; ti++) {
        var tier = tiers[ti];
        var tierDrops = matDrops[tier];
        if (!tierDrops) continue;
        for (var mi = 0; mi < tierDrops.length; mi++) {
          if (Math.random() < tierDrops[mi].rate) {
            var mat = MATERIALS[tierDrops[mi].mid];
            if (mat) {
              drops.push({ id: mat.id, name: mat.name, type: 'material', icon: mat.icon,
                category: mat.category, rarity: mat.rarity, sellPrice: mat.sellPrice, craftValue: mat.craftValue });
            }
          }
        }
      }
    }

    // Potion drop chance (20%, reduced from 30%)
    if (Math.random() * 100 < 20) {
      drops.push({ name: '小型生命药水', type: 'potion', heal: 30, icon: '🧪' });
    }
    // Key drop chance (5%, bosses 20%)
    if (Math.random() * 100 < (e.isBoss ? 20 : 5)) {
      G.keys = (G.keys || 0) + 1;
    }
  }
  // West path bonus: +25% XP from STORY_CHOICES
  if (G._westPath) totalXp = Math.floor(totalXp * 1.25);

  // Mark boss as defeated
  if (b.isBoss && b.bossKey) {
    G.bossDefeated[b.bossKey] = true;
    checkStoryTriggers('defeat_boss', G.location);
    autoSave(); // Auto-save on boss defeat
    // A3: Wave battle achievement tracking
    if (b.totalWaves > 0) {
      G._waveBattlesCompleted = (G._waveBattlesCompleted || 0) + 1;
      if (G.hp === G.maxHp && !G._tookDamageThisBattle) G._wavePerfectClear = (G._wavePerfectClear || 0) + 1;
    }
  }
  // Mark elite as defeated
  if (b.isElite) {
    var ek = G.location + '_elite_' + G.miniMapPos.r + '_' + G.miniMapPos.c;
    if (!G.eliteDefeated) G.eliteDefeated = {};
    G.eliteDefeated[ek] = true;
  }

  G.xp += totalXp;
  G.totalBattlesWon++;
  G._battleCount = (G._battleCount || 0) + 1;
  if (b.isBoss || b.isElite) G._bossKills = (G._bossKills || 0) + 1;
  if (G.hp === G.maxHp && !G._tookDamageThisBattle) G._perfectBattles = (G._perfectBattles || 0) + 1;
  // Weather battle tracking
  var curWeather = getWeather(G.location);
  if (curWeather.id === 'storm') G._stormBattlesWon = (G._stormBattlesWon || 0) + 1;
  if (curWeather.id === 'blizzard') G._blizzardBattlesWon = (G._blizzardBattlesWon || 0) + 1;
  checkAchievements();
  checkStoryTriggers('win_battles', 'battle_won');

  // Random clue discovery in battle (12% chance per win)
  var _battleLoc = G.battle && G.battle.location ? G.battle.location : G.location;
  if (Math.random() < 0.12) {
    var _clueMap = {
      lake:'clue_map_fragment', darkforest:'clue_forest_note', fortress:'clue_blackiron_letter', mine:'clue_tablet_mine',
      scholar_tower:'clue_dragon_scroll', north_pass:'clue_dragon_scale', dragontemple:'clue_dragon_blood',
      snowpeak:'clue_frostwing_feather', coastcave:'clue_tidal_chart', stormcape:'clue_storm_log',
      misthollow:'clue_mist_mirror', jademarsh:'clue_hydra_scale',
      ashplains:'clue_ash_crest', volcano:'clue_flame_prophecy',
      abyssgate:'clue_void_seal', shadowrealm:'clue_shadow_truth'
    };
    // Lake also gives mine_entrance_clue for mine_unlock quest (if not yet found)
    if (_battleLoc === 'lake') { checkStoryTriggers('find_clue', 'mine_entrance_clue'); }
    if (_clueMap[_battleLoc]) {
      checkStoryTriggers('find_clue', _clueMap[_battleLoc]);
      if (!G._foundClues) G._foundClues = {};
      if (!G._foundClues[_clueMap[_battleLoc]]) {
        G._foundClues[_clueMap[_battleLoc]] = true;
        toast('📜 你在战利品中发现了一条线索!');
      }
    }
  }

  // Track quest progress for battle-related quests
  _updateBattleQuestProgress();

  // Add drops to inventory
  for (var d = 0; d < drops.length; d++) {
    G.inventory.push(drops[d]);
    // Track unique equipment
    if (drops[d].isUnique) {
      G._uniqueCount = (G._uniqueCount || 0) + 1;
    }
  }

  // Level up check
  var levelUps = 0;
  while (G.xp >= calcNextXp(G.level)) {
    G.level++;
    G.xp -= calcNextXp(G.level - 1);
    G.attrPts += 3;
    G.skillPts += 1;
    G.maxHp = calcMaxHp();
    G.hp = G.maxHp;
    G.maxMp = calcMaxMp();
    G.mp = G.maxMp;
    levelUps++;
    // Skills must be learned at Training Ground (paid), no auto-learn
  }

  G.battle = null;
  G.attackMode = null;
  // D1: Reset all battle-specific state
  G._comboCount = 0;
  G._skillCooldowns = {};
  G._autoBattle = false;
  G._stunned = false; G._stunTurns = 0;
  G._frozen = false; G._freezeTurns = 0;
  G._slowed = false; G._slowTurns = 0;
  G._poisoned = 0;
  G._burning = 0;
  G._bleeding = 0;
  G._battleAction = null;
  G._showSpells = false;
  G._showCombatSkills = false;
  updateStatus();

  // Deep Dive battle win hook
  if (G._inDeepDive && ddOnBattleWin()) {
    checkAchievements();
    return; // DD handles its own post-battle flow
  }

  checkAchievements();

  // If leveled up, show level-up screen with attr allocation
  if (levelUps > 0) {
    var html = '';
    html += '<div class="scene-title">🎉 升级!</div>';
    html += '<div class="level-up-info">';
    html += '<div class="level-up-level">Lv.' + G.level + '</div>';
    if (levelUps > 1) html += '<div class="level-up-multi">连续升了 ' + levelUps + ' 级!</div>';
    html += '<div class="level-up-rewards">';
    html += '<div>⭐ +' + totalXp + ' 经验值</div>';
    html += '<div>📝 +3 自由属性点</div>';
    // Show newly available skills for learning (not auto-learned)
    var newAvailable = [];
    for (var nsi = 0; nsi < SKILLS.length; nsi++) {
      var nsk = SKILLS[nsi];
      var oldLevel = G.level - levelUps;
      if (nsk.reqLevel > oldLevel && nsk.reqLevel <= G.level && !G.skills.includes(nsk.id)) {
        newAvailable.push(nsk);
      }
    }
    if (newAvailable.length > 0) {
      html += '<div class="new-skills-title">📖 可学新技能!</div>';
      for (var nsk2 = 0; nsk2 < newAvailable.length; nsk2++) {
        var learnCost = 30 + (newAvailable[nsk2].reqLevel || 1) * 15;
        html += '<div class="drop-item" style="color:#d4a017">' + newAvailable[nsk2].emoji + ' ' + newAvailable[nsk2].name + ' (' + learnCost + '💰 训练场学习)</div>';
      }
    }
    if (drops.length > 0) {
      for (var dd = 0; dd < drops.length; dd++) {
        html += '<div class="drop-item">' + (drops[dd].icon || '⚔️') + ' ' + drops[dd].name + '</div>';
      }
    }
    html += '</div>';
    html += '</div>';
    html += '<button class="btn btn-primary" onclick="goToAttrAlloc()">✨ 分配属性点</button>';
    render(html);
    return;
  }

  var html = '';
  html += '<div class="scene-title result-anim">战斗胜利</div>';
  html += '<div class="victory-rewards">';
  html += '<div>⭐ ' + totalXp + ' 经验值</div>';
  // D1: Battle stats summary
  html += '<div style="font-size:0.8em;color:#888;margin:4px 0">';
  html += '回合数: ' + b.turn + ' | ';
  html += '剩余HP: ' + G.hp + '/' + G.maxHp;
  if (G.hp === G.maxHp) html += ' ✨无伤!';
  html += '</div>';
  if (drops.length > 0) {
    html += '<div class="drop-list">📦 战利品:</div>';
    for (var dd = 0; dd < drops.length; dd++) {
      var drop = drops[dd];
      var rarity = drop.rarity || 'common';
      html += '<div class="drop-item drop-' + rarity + '">' + (drop.icon || '⚔️') + ' ' + drop.name + '</div>';
    }
  }
  html += '</div>';
  // Show quest progress update if applicable
  var questUpdates = [];
  if (G.quests && G.quests.length > 0) {
    for (var qi = 0; qi < G.quests.length; qi++) {
      var qid = G.quests[qi];
      var q = QUESTS.find(function(qx) { return qx.id === qid; });
      var qp = G.questProgress[qid];
      if (q && qp && (q.progressType === 'win_battles_at' || q.progressType === 'defeat_boss_at') && q.progressTarget === G.location) {
        if (q.progressCount) {
          questUpdates.push('📜 ' + q.name + ':' + Math.min(qp.current || 0, q.progressCount) + '/' + q.progressCount + (qp.done ? ' ✅' : ''));
        } else if (qp.done) {
          questUpdates.push('📜 ' + q.name + ':✅ 可交付');
        }
      }
    }
  }
  if (questUpdates.length > 0) {
    html += '<div style="margin-top:8px;padding:8px;background:#16213e;border-radius:6px;border:1px solid #334">';
    for (var qu = 0; qu < questUpdates.length; qu++) {
      html += '<div style="font-size:0.9em">' + questUpdates[qu] + '</div>';
    }
    html += '</div>';
  }
  html += '<button class="btn btn-primary" onclick="_checkTutorial(\'battle_end\');afterBattleContinue()">继续</button>';
  render(html);
}

function goToAttrAlloc() {
  if (G.attrPts > 0) {
    _playerInfoDraft = null;
    sceneAttrAllocation();
  } else {
    afterBattleContinue();
  }
}

function afterBattleContinue() {
  // A3: Clear wave temp buffs
  if (G._waveTempAtk) delete G._waveTempAtk;
  if (G._waveTempDef) delete G._waveTempDef;
  if (G._wavePerfectCount) {
    if (G._wavePerfectCount >= 3) checkAchievements(); // Potential achievement
    delete G._wavePerfectCount;
  }
  // Deep Dive: return to DD floor
  if (G._ddFloor && G._ddFloor > 0 && !G._inDeepDive) {
    renderDDFloor();
    return;
  }
  var loc = LOCATIONS[G.location];
  if (loc && loc.mapConfig && G.miniMapPos) {
    renderMiniMap('战斗结束,继续探索...');
  } else {
    sceneWorldMap();
  }
}

function doLevelUp() {
  G.level++;
  G.xp -= calcNextXp(G.level - 1);
  G.attrPts += 3;
  G.skillPts += 1;
  G.maxHp = calcMaxHp();
  G.hp = G.maxHp;
  G.maxMp = calcMaxMp();
  G.mp = G.maxMp;
  // Story trigger: check level objectives
  checkStoryTriggers('reach_level', G.level);
  checkAchievements();
}

function sceneDeath() {
  G.totalBattlesLost++;
  var lossGold = Math.floor(G.gold * 0.1);
  var lossXp = Math.floor(G.xp * 0.2);
  G.gold -= lossGold;
  G.xp = Math.max(0, G.xp - lossXp);

  var html = '';
  html += '<div class="scene-title">战斗失败</div>';
  html += '<div class="death-msg">你被送回最近的城镇...</div>';
  html += '<div class="loss-info">损失:💰' + lossGold + ' | ⭐' + lossXp + ' EXP</div>';
  html += '<button class="btn btn-primary" onclick="sceneRespawn()">继续</button>';
  render(html);
}

function sceneRespawn() {
  G.hp = Math.floor(G.maxHp * 0.5);
  G.mp = Math.floor(G.maxMp * 0.5);
  G.location = 'whitecity';
  updateStatus();
  sceneTown();
}


// ═══════════════════════════════════════════════════════════
// SCENE: TOWN
// ═══════════════════════════════════════════════════════════

function _getTownAtmosphere(locId) {
  var events = {
    whitecity: [
      '📢 集市上的商人正在打折促销:"今日特价!生命药水买二送一!"',
      '🐕 一只流浪狗蹲在城门口,用湿漉漉的眼睛望着每一个进出的人。',
      '🎶 酒馆里传出一阵欢快的琴声,有人在里面唱歌。',
      '🌧️ 天空飘起细雨,路人纷纷撑起油纸伞,街面泛起涟漪。',
      '⚔️ 几个满身伤痕的冒险者从城外走来,脸上带着劫后余生的庆幸。',
      '📦 一支商队刚从铁岭城抵达,货物堆满了半条街。'
    ],
    ironridge: [
      '🔥 铁匠铺的炉火烧得正旺,叮当声此起彼伏。',
      '💨 一股热浪从锻造区涌来,空气中弥漫着金属的气味。',
      '⚒️ 铁匠赫尔曼正在展示新打造的宝剑,围观的人群发出赞叹。',
      '⛏️ 矿工们从山间归来,推着满载矿石的小车。',
      '🍺 下班的铁匠们聚在酒馆里,大声争论着哪种矿石最坚硬。'
    ],
    tidport: [
      '⛵ 一艘远洋商船刚刚靠岸,水手们忙着卸货。',
      '🐟 渔夫们在码头上叫卖着新鲜的海鱼,海鸥在头顶盘旋。',
      '🧭 老船长坐在码头边抽着烟斗,望着远方的海平线出神。',
      '🎪 一个异域商人支起了帐篷,展示着来自远方的奇珍异宝。',
      '🌊 一阵巨浪拍上码头,溅湿了几个在岸边闲聊的水手。'
    ],
    sunspire: [
      '📖 学者们抱着厚重的书卷在塔间穿行,偶尔停下来讨论某个古文献的解读。',
      '✨ 一个年轻的学徒失手打翻了药瓶,彩色的烟雾在走廊里弥漫。',
      '🔭 塔顶的天文台传来惊呼--他们观测到了一颗从未记录的星辰。',
      '🔮 大贤者伊兰从高塔走下,他的眼中映着某种深远的忧虑。'
    ],
    dragonreach: [
      '🐉 一块龙鳞碎片从城墙上脱落,守卫们紧张地检查着墙体。',
      '🗡️ 老兵卡尔在城门口擦拭着他那把跟了他三十年的旧剑。',
      '🔥 远处的火山又亮了一些,空气中多了些硫磺味。',
      '📯 哨兵吹响了换岗号,沉闷的号声在山间回荡。'
    ],
    icereef: [
      '❄️ 又一场暴风雪刚刚过去,街道上的积雪没过膝盖。',
      '🧊 港口的冰又厚了一寸,渔船彻底出不去了。',
      '🍲 酒馆里飘出炖肉的香气,这是冰港人御寒的秘方。',
      '🦭 一群海豹趴在浮冰上,用圆溜溜的眼睛打量着城里的人。'
    ]
  };
  var pool = events[locId];
  if (!pool || pool.length === 0) return null;
  return pool[Math.floor(Math.random() * pool.length)];
}


function sceneStory() {
  G._currentScene = 'sceneStory';
  var html = '';
  html += '<div class="scene-title">📖 龙途传说</div>';
  var ch = getCurrentChapter();
  if (!ch) {
    html += '<div style="color:#888;padding:20px;text-align:center">尚未开始冒险</div>';
  } else {
    var prog = getChapterProgress();
    html += '<div style="padding:12px;background:#1a1a2e;border-radius:8px;border:1px solid #d4a017">';
    html += '<div style="color:#d4a017;font-size:1.1em;font-weight:bold">' + ch.chapter + ': ' + ch.title + '</div>';
    var entryPreview = ch.entry ? ch.entry.substring(0, 80) : '';
    if (entryPreview) html += '<div style="color:#888;font-size:0.9em;margin:4px 0">' + entryPreview + '…</div>';
    var pct = prog ? Math.floor(prog.done / prog.total * 100) : 0;
    html += '<div style="margin:8px 0;background:#333;border-radius:4px;height:8px;overflow:hidden"><div style="width:' + pct + '%;height:100%;background:linear-gradient(90deg,#d4a017,#f1c40f);border-radius:4px"></div></div>';
    html += '<div style="font-size:0.85em;color:#aaa">' + (prog ? prog.done : 0) + '/' + (prog ? prog.total : 0) + ' 目标完成 (' + pct + '%)</div>';
    html += '</div>';
    html += '<div style="margin-top:12px">';
    for (var i = 0; i < ch.objectives.length; i++) {
      var obj = ch.objectives[i];
      var done = G.storyProgress.completed[obj.id];
      html += '<div style="padding:8px;margin:4px 0;background:' + (done ? '#1a2e1a' : '#1a1a2e') + ';border-radius:6px;border-left:3px solid ' + (done ? '#2ecc71' : '#555') + '">';
      html += '<span style="color:' + (done ? '#2ecc71' : '#c0c0c0') + '">' + (done ? '✅' : '⬜') + ' ' + obj.desc + '</span>';
      html += '</div>';
    }
    html += '</div>';
    if (G._completedChapters && G._completedChapters.length > 0) {
      html += '<div style="margin-top:12px;padding:8px;background:#0d1117;border-radius:8px">';
      html += '<div style="color:#d4a017;font-size:0.9em;margin-bottom:6px">📜 已完成章节</div>';
      var chNames = ['', '第一章', '第二章', '第三章', '第四章', '第五章', '第六章', '第七章', '第八章', '第九章', '第十章', '第十一章', '第十二章'];
      for (var ci = 0; ci < G._completedChapters.length; ci++) {
        var cn = parseInt(G._completedChapters[ci]);
        if (cn > 0 && cn < chNames.length) {
          var doneTitle = '';
          var doneCh = STORY.find(function(s) { return s.id && s.id.indexOf('ch' + cn + '_') === 0; });
          if (doneCh) doneTitle = ' ' + doneCh.title;
          html += '<div style="color:#2ecc71;font-size:0.85em">✅ ' + chNames[cn] + doneTitle + '</div>';
        }
      }
      html += '</div>';
    }
    // Story choices recap
    if (G.storyChoices) {
      var choiceKeys = Object.keys(G.storyChoices);
      if (choiceKeys.length > 0) {
        html += '<div style="margin-top:12px;padding:8px;background:#0d1117;border-radius:8px">';
        html += '<div style="color:#d4a017;font-size:0.9em;margin-bottom:6px">✦ 命运抉择</div>';
        for (var cki = 0; cki < choiceKeys.length; cki++) {
          var scData = STORY_CHOICES[choiceKeys[cki]];
          if (scData) {
            var chosenEffect = G.storyChoices[choiceKeys[cki]];
            var chosenLabel = '';
            for (var sci = 0; sci < scData.choices.length; sci++) {
              if (scData.choices[sci].effect === chosenEffect) {
                chosenLabel = scData.choices[sci].label;
                break;
              }
            }
            html += '<div style="color:#b0c0d0;font-size:0.85em">✦ ' + (scData.title || keyKeys[cki]) + ' → <span style="color:#d4a017">' + (chosenLabel || chosenEffect) + '</span></div>';
          }
        }
        html += '</div>';
      }
    }
  }
  html += '<div style="margin-top:16px">';
  html += '<button class="btn" onclick="sceneTown()" style="width:100%">↩️ 返回城镇</button>';
  html += '</div>';
  render(html);
}

function sceneTown() {
  G._currentScene = 'sceneTown';
  G._lastSaveScene = 'sceneTown';
  tickWeather();
  checkStoryTriggers('visit_location', G.location);
  updateStatus();
  var loc = LOCATIONS[G.location];
  var html = '';
  html += '<div class="scene-title">🏰 ' + loc.name + '</div>';
  html += '<div class="town-desc">' + (loc.townDesc || '商路交汇的喧嚣城镇,冒险者的补给站') + '</div>';
  // Weather display
  html += renderWeatherBar(G.location);
  // Random atmosphere event - different each visit
  var atmEvent = _getTownAtmosphere(G.location);
  if (atmEvent) {
    html += '<div style="margin:8px 0;padding:8px 12px;background:#111820;border:1px solid #2a3a4a;border-radius:6px;font-size:0.85em;line-height:1.4">';
    html += atmEvent;
    html += '</div>';
  }
  // First-time tutorial hint
  if (!G._townTutorialDone) {
    G._townTutorialDone = true;
    html += '<div style="margin:10px 0;padding:10px 12px;background:#1a2a3a;border:1px solid #3a5a7a;border-radius:8px;font-size:0.85em;line-height:1.5">';
    html += '<div style="color:#7ec8e3;font-weight:bold;margin-bottom:4px">📖 新手指引</div>';
    html += '<div>🏛️ <b>城主厅</b>领取主线奖励 · 🛏️ <b>旅店</b>休息回血 · 🏪 <b>商店</b>买药水</div>';
    html += '<div>⚔️ <b>公会</b>接任务 · ⚒️ <b>铁匠</b>打造装备 · 💎 <b>材料商行</b>买卖材料</div>';
    html += '<div>⚡ <b>强化工坊</b>强化/分解装备 · 🚛 <b>商贸站</b>跨城赚差价</div>';
    html += '<div style="margin-top:4px;color:#aaa">点击任意建筑进入 · 点左下🗺️离开城镇探索</div>';
    html += '</div>';
  }
  // Story progress hint - always visible in town
  var ch = getCurrentChapter();
  if (ch) {
    var prog = getChapterProgress();
    html += '<div style="margin:8px 0;padding:10px 12px;background:#1a1a10;border:1px solid #3a3a2a;border-radius:8px;cursor:pointer" id="story_progress" onclick="showStory()">';
    html += '<div style="display:flex;justify-content:space-between;align-items:center">';
    html += '<div style="color:#d4a017;font-weight:bold;font-size:0.95em">📖 ' + ch.chapter + ':' + ch.title + '</div>';
    html += '<div style="color:#888;font-size:0.8em">' + prog.done + '/' + prog.total + '</div>';
    html += '</div>';
    // Show incomplete objectives
    for (var oi = 0; oi < ch.objectives.length; oi++) {
      var o = ch.objectives[oi];
      var odone = G.storyProgress.completed[o.id];
      html += '<div style="font-size:0.82em;color:' + (odone ? '#4a4' : '#aaa') + ';padding-left:8px;margin-top:2px">' + (odone ? '✅' : '⬜') + ' ' + o.desc + '</div>';
    }
    var nextUnlocks = CHAPTER_UNLOCKS[ch.id] || [];
    if (nextUnlocks.length > 0) {
      html += '<div style="color:#2ecc71;font-size:0.8em;margin-top:6px;padding-left:8px">🗺️ 完成后解锁:' + nextUnlocks.map(function(lid) { return LOCATIONS[lid] ? LOCATIONS[lid].name : lid; }).join('、') + '</div>';
    }
    html += '</div>';
  }

  if (loc.specialty) {
    html += '<div class="town-specialty" style="text-align:center;color:var(--accent);margin:4px 0;font-size:0.85em">✦ 特产:' + loc.specialty + '</div>';
  }

  // Building list - icon + text, click to enter
  var buildings = [
    { id:'lord_hall', name:'城主厅', emoji:'🏛️', desc:'觐见城主,领取章节奖励', action:'sceneLordHall()' },
    { id:'inn', name:'旅店', emoji:'🛏️', desc:'休息恢复,听旅店老板讲故事', action:'sceneInn()' },
    { id:'shop', name:'杂货商店', emoji:'🧴', desc:'购买药水和日用品', action:'sceneShop()' },
    { id:'guild', name:'冒险公会', emoji:'📜', desc:'接取任务,了解冒险情报', action:'sceneGuild()' },
    { id:'blacksmith', name:'铁匠铺', emoji:'⚒️', desc:'购买装备,强化武器', action:'sceneBlacksmith()' },
    { id:'tavern', name:'酒馆', emoji:'🍺', desc:'打探消息,赌博试试手气', action:'sceneTavern()' },
    { id:'story', name:'故事', emoji:'📖', desc:'查看故事进度与命运抉择', action:'sceneStory()' },
    { id:'relations', name:'人际关系', emoji:'👥', desc:'查看NPC好感度,送礼提升关系', action:'sceneNpcRelations()' },
    { id:'trade', name:'商贸站', emoji:'🚛', desc:'买卖货物,跨城倒卖赚差价', action:'sceneTrade()' },
    { id:'mattrader', name:'材料商行', emoji:'💎', desc:'买卖材料,打造装备必备', action:'sceneMaterialTrader()' },
    { id:'enhance', name:'强化工坊', emoji:'⚡', desc:'装备强化与分解', action:'sceneEquipmentEnhance()' },
    { id:'deep_dive', name:'深渊入口', emoji:'🌀', desc:'挑战无尽深渊,获取稀有奖励', action:'sceneDeepDive()' },
    { id:'training', name:'训练场', emoji:'🏋️', desc:'花费金币训练属性,提升实力', action:'sceneTraining()' }
  ];

  // Pre-calculate badge info for buildings
  var badgeInfo = {};
  // 城主厅: pending chapter rewards
  var pendingRewards = G.pendingChapterRewards || [];
  if (pendingRewards.length > 0) badgeInfo.lord_hall = '🎁' + pendingRewards.length;
  // 冒险公会: completable quests
  var completableCount = 0;
  if (G.quests && G.questProgress) {
    for (var qi2 = 0; qi2 < G.quests.length; qi2++) {
      var qp2 = G.questProgress[G.quests[qi2]];
      if (qp2 && qp2.done) completableCount++;
    }
  }
  if (completableCount > 0) badgeInfo.guild = '✅' + completableCount;

  html += '<div class="building-list">';
  for (var i = 0; i < buildings.length; i++) {
    var bld = buildings[i];
    var badge = badgeInfo[bld.id] ? '<span class="bld-badge">' + badgeInfo[bld.id] + '</span>' : '';
    html += '<div class="bld-card" id="btn_town_' + bld.id + '" onclick="' + bld.action + '">';
    html += '<div class="bld-emoji">' + bld.emoji + '</div>';
    html += '<div class="bld-info">';
    html += '<div class="bld-name">' + bld.name + '</div>';
    html += '<div class="bld-desc">' + bld.desc + '</div>';
    html += '</div>';
    html += '<div class="bld-right">' + badge + '<span class="bld-arrow">›</span></div>';
    html += '</div>';
  }
  html += '</div>';

  // Active quest indicator with progress
  if (G.quests && G.quests.length > 0) {
    var activeNames = [];
    for (var qi = 0; qi < G.quests.length; qi++) {
      var aq = _findQuestById(G.quests[qi]);
      if (aq) {
        var qp = G.questProgress[aq.id];
        var pC = aq.progressCount || 1;
        var cV = Math.min(qp ? (qp.current || 0) : 0, pC);
        activeNames.push(aq.icon + ' ' + aq.name + '(' + cV + '/' + pC + ')');
      }
    }
    html += '<div class="active-quest-banner" style="cursor:pointer" onclick="_showQuestsFromTown()">📜 任务(' + activeNames.length + '):' + activeNames.join(' / ') + '</div>';
  }

  html += '<div class="btns">';
  html += '<button class="btn" id="btn_town_explore" onclick="sceneWorldMap()">🗺️ 城镇出口</button>';
  html += '<button class="btn" id="btn_town_inventory" onclick="sceneInventory()">🎒 背包</button>';
  html += '<button class="btn" onclick="_playerInfoReturnTo=\'sceneTown\';scenePlayerInfo()">👤 角色</button>';
  html += '<button class="btn" onclick="sceneEquipmentFromTown()">⚔️ 装备</button>';
  html += '<button class="btn" onclick="showStory()">📖 主线</button>';
  html += '<button class="btn" onclick="sceneSaveLoad()">💾 存档</button>';
  html += '<button class="btn" onclick="sceneWeatherForecast()">🌤️ 天气</button>';
  html += '</div>';

  render(html);
  // Trigger tutorial for town scene
  _checkTutorial('sceneTown');
}


// ═══════════════════════════════════════════════════════════
// SCENE: LORD HALL (城主厅)
// ═══════════════════════════════════════════════════════════

function sceneLordHall() {
  G._currentScene = 'sceneLordHall';

  // Town-specific lord hall flavor
  var lordTitles = {
    whitecity: '🏛️ 城主厅',
    ironridge: '🏛️ 铁岭长官厅',
    tidport: '🏛️ 港务官署',
    sunspire: '🏛️ 日冕塔大殿',
    dragonreach: '🏛️ 龙域军议厅',
    icereef: '🏛️ 冰礁镇政厅'
  };
  var lordDescs = {
    whitecity: '庄严肃穆的大厅,城主坐镇高位',
    ironridge: '铁与火的味道弥漫在厅堂,长官的铁拳统治着这座城',
    tidport: '海风吹进敞开的大门,港务官正在翻阅账本',
    sunspire: '高塔顶端的圆形大厅,水晶穹顶折射着永恒的日光',
    dragonreach: '粗糙的石刻大厅,墙上龙族壁画诉说着往昔荣光',
    icereef: '冰块与鲸骨搭建的议事厅,炉火在中央噼啪作响'
  };
  var lordNames = {
    whitecity: '城主李承安',
    ironridge: '矿王巴克',
    tidport: '港主银鳍夫人',
    sunspire: '塔主贤者伊兰',
    dragonreach: '守将卡尔',
    icereef: '镇长老约根'
  };
  var lordEmoji = {
    whitecity: '👑',
    ironridge: '🦾',
    tidport: '🐚',
    sunspire: '📖',
    dragonreach: '🐉',
    icereef: '🧊'
  };

  var locId = G.location;
  var title = lordTitles[locId] || lordTitles.whitecity;
  var desc = lordDescs[locId] || lordDescs.whitecity;
  var lordName = lordNames[locId] || lordNames.whitecity;
  var emoji = lordEmoji[locId] || lordEmoji.whitecity;

  var html = '';
  html += '<div class="scene-title">' + title + '</div>';
  html += '<div class="town-desc">' + desc + '</div>';

  // Check for pending chapter rewards
  var pending = G.pendingChapterRewards || [];
  if (pending.length > 0) {
    html += '<div class="lord-greeting" style="margin:12px 0;padding:10px;background:#1a1a2e;border-radius:8px;border:1px solid #d4a017">';
    html += '<div style="color:#d4a017;font-weight:bold">' + emoji + ' ' + lordName + ':「冒险者,你立下了功勋。这是你的奖赏。」</div>';
    for (var i = 0; i < pending.length; i++) {
      var p = pending[i];
      html += '<div class="chapter-reward-item" style="margin:8px 0;padding:6px 8px;background:#16213e;border-radius:4px">';
      html += '<div style="color:#e0e0e0">📖 ' + p.chapter + ':' + p.title + '</div>';
      html += '<div style="color:#22c55e">⭐ +' + p.xp + ' XP &nbsp; 💰 +' + p.gold + ' 金币</div>';
      html += '</div>';
    }
    html += '<button class="btn btn-primary" onclick="collectChapterReward()" style="width:100%;margin-top:8px">🎁 领取全部奖赏</button>';
    html += '</div>';
  } else {
    // Dynamic dialogue based on chapter progress
    var ch = getCurrentChapter();
    var lordMsg = emoji + ' ' + lordName + ':「继续你的冒险吧,这片土地需要勇者。」';
    if (!ch) {
      lordMsg = emoji + ' ' + lordName + ':「你已完成所有已知使命,传奇仍在继续。」';
    } else if (ch.id === 'ch1_arrival' || ch.id === 'ch1_lake_mystery') {
      lordMsg = emoji + ' ' + lordName + ':「新来的?先把公会的事办妥再说。」';
    } else if (ch.id.indexOf('ch1_') === 0) {
      lordMsg = emoji + ' ' + lordName + ':「矿洞的事我听说了,注意安全。」';
    } else if (ch.id.indexOf('ch2_') === 0) {
      lordMsg = emoji + ' ' + lordName + ':「商路的麻烦越来越多了...」';
    } else if (ch.id.indexOf('ch3_') === 0) {
      lordMsg = emoji + ' ' + lordName + ':「暗流涌动,你需要更强大的力量。」';
    }
    html += '<div class="lord-greeting" style="margin:12px 0;padding:10px;background:#1a1a2e;border-radius:8px;border:1px solid #555">';
    html += '<div style="color:#e0e0e0">' + lordMsg + '</div>';
    html += '</div>';
  }

  // Lord NPC dialog
  var lordNpcMap = {
    whitecity: 'lord_white',
    ironridge: 'lord_iron',
    tidport: 'lord_tid',
    sunspire: 'lord_sun',
    dragonreach: 'lord_dragon',
    icereef: 'lord_ice'
  };
  if (lordNpcMap[locId] && NPC_DIALOGS[lordNpcMap[locId]]) {
    html += '<button class="btn" onclick="showDialog(\''+lordNpcMap[locId]+'\',0)" style="margin:8px 0;width:100%">💬 与' + lordName + '深入交谈</button>';
  }

  html += '<div class="btns">';
  html += '<button class="btn" onclick="sceneTown()">↩️ 返回城镇</button>';
  html += '</div>';
  render(html);
}

function collectChapterReward() {
  var pending = G.pendingChapterRewards || [];
  if (pending.length === 0) { toast('没有待领取的奖赏'); return; }

  var totalXp = 0, totalGold = 0;
  for (var i = 0; i < pending.length; i++) {
    totalXp += pending[i].xp;
    totalGold += pending[i].gold;
  }

  G.xp += totalXp;
  G.gold += totalGold;

  // Level up check
  var levelUps = 0;
  while (G.xp >= calcNextXp(G.level)) {
    G.level++;
    G.xp -= calcNextXp(G.level - 1);
    G.attrPts += 3;
    G.skillPts += 1;
    G.maxHp = calcMaxHp();
    G.hp = G.maxHp;
    G.maxMp = calcMaxMp();
    G.mp = G.maxMp;
    levelUps++;
    // Skills must be learned at Training Ground (paid), no auto-learn
  }

  G.pendingChapterRewards = [];
  updateStatus();

  var html = '';
  html += '<div class="scene-title">🎁 奖赏已领取</div>';
  html += '<div class="victory-rewards">';
  html += '<div>⭐ +' + totalXp + ' 经验值</div>';
  html += '<div>💰 +' + totalGold + ' 金币</div>';
  if (levelUps > 0) {
    html += '<div style="color:#d4a017;font-weight:bold">🎉 升至 Lv.' + G.level + '!</div>';
  }
  html += '</div>';

  if (levelUps > 0 && G.attrPts > 0) {
    html += '<button class="btn btn-primary" onclick="goToAttrAlloc()">✨ 分配属性点</button>';
  } else {
    html += '<button class="btn btn-primary" onclick="sceneLordHall()">🏛️ 继续</button>';
  }
  render(html);
}

function sceneInn() {
  G._currentScene = 'sceneInn';
  // Story trigger: visited inn
  checkStoryTriggers('visit_place', 'inn');

  // Town-specific inn pricing and flavor
  var innPrices = { whitecity: 10, ironridge: 15, tidport: 12, sunspire: 40, dragonreach: 60, icereef: 70 };
  var innDescs = {
    whitecity: '温暖的壁炉,舒适的床铺,冒险者的港湾',
    ironridge: '石头砌成的火炕,炉火烧得通红,铁匠们收工后的最爱',
    tidport: '海风从窗缝溜进来,墙上挂着船舵和渔网,水手们在这里安睡',
    sunspire: '高塔中的修士宿舍,安静得只听见翻书声和远处的钟鸣',
    dragonreach: '粗犷的石屋,墙上挂着龙牙,守卫们轮流值班不敢深睡',
    icereef: '冰屋里的火炉是唯一的温暖,皮毛被褥厚得像另一层城墙'
  };
  var cost = innPrices[G.location] || 20;
  var npcDiscount = getNpcDiscount(null, 'inn') / 100;
  cost = Math.floor(cost * (1 - npcDiscount));
  var desc = innDescs[G.location] || '一间简朴的旅店';

  var html = '';
  html += '<div class="scene-title">🏨 旅店</div>';
  html += '<div class="inn-desc">' + desc + '</div>';

  // NPC dialog triggers based on story progress and location
  var npcAvailable = [];
  var chapterId = G.storyProgress ? G.storyProgress.chapterId : '';
  // Inn NPCs: innkeeper + lord only (smith moved to blacksmith scene)
  var townNpcMap = {
    whitecity:  [{ id:'innkeep_white', label:'☕ 与旅店老板娘闲聊' }, { id:'lord_white', label:'🏛️ 求见城主' }],
    ironridge:  [{ id:'innkeep_iron', label:'🍺 与旅店老板闲聊' }, { id:'lord_iron', label:'⛏️ 求见矿王' }],
    tidport:    [{ id:'innkeep_tid', label:'⚓ 与旅店老板听航海故事' }, { id:'innkeep_tid_port', label:'🌊 与海风驿老板聊天' }, { id:'lord_tid', label:'🐚 求见港主' }],
    sunspire:   [{ id:'innkeep_sun', label:'🕌 听学者们讨论' }, { id:'innkeep_sun_full', label:'☀️ 与日晷轩老板闲聊' }, { id:'lord_sun', label:'📖 求见塔主' }],
    dragonreach:[{ id:'innkeep_dragon', label:'🔥 龙息酒馆闲聊' }, { id:'lord_dragon', label:'🐉 求见守将' }],
    icereef:    [{ id:'innkeep_ice', label:'❄️ 与暖炉小屋老板聊天' }, { id:'lord_ice', label:'🧊 求见镇长' }]
  };
  // Add town NPCs (avoid duplicates)
  var existingIds = {};
  for (var ei = 0; ei < npcAvailable.length; ei++) existingIds[npcAvailable[ei].id] = true;
  var townNpcs = townNpcMap[G.location];
  if (townNpcs) {
    for (var ti = 0; ti < townNpcs.length; ti++) {
      if (!existingIds[townNpcs[ti].id]) npcAvailable.push(townNpcs[ti]);
    }
  }

  if (G.location === 'whitecity') {
    if (chapterId && chapterId.indexOf('ch1_') === 0) npcAvailable.push({ id: 'roland', label: '🛡️ 与守卫队长罗兰德交谈' });
    if (chapterId === 'ch1_lake_mystery' || chapterId === 'ch1_lake_explore') {
      npcAvailable.push({ id: 'hank', label: '⚒️ 与瘸腿汉克交谈' });
      npcAvailable.push({ id: 'elena', label: '📖 与学者艾琳娜交谈' });
    }
    if (chapterId && chapterId.indexOf('ch2_') === 0) npcAvailable.push({ id: 'elena', label: '📖 与学者艾琳娜交谈' });
  }
  if (G.location === 'ironridge') {
    npcAvailable.push({ id: 'hank', label: '⚒️ 与瘸腿汉克交谈' });
    if (chapterId && chapterId.indexOf('ch3_') === 0) npcAvailable.push({ id: 'innkeep_iron', label: '⛏️ 与旅店老板闲聊矿洞' });
    if (chapterId === 'ch2_fortress_discovery' || chapterId === 'ch2_fortress_boss') npcAvailable.push({ id: 'forest_wanderer', label: '🌲 与森林流浪者交谈' });
  }
  if (G.location === 'tidport') {
    npcAvailable.push({ id: 'mystic_wu', label: '🎭 与神秘人老吴交谈' });
  }
  // forest_wanderer appears near darkforest/fortress in ironridge
  // (moved to ironridge section above)
  if (G.location === 'sunspire') {
    npcAvailable.push({ id: 'elena', label: '📖 与学者艾琳娜深入交谈' });
    npcAvailable.push({ id: 'sage_ilan', label: '🔮 与大贤者伊兰交谈' });
    if (chapterId === 'ch6_sunspire') npcAvailable.push({ id: 'innkeep_sun', label: '🕌 听学者们讨论龙族历史' });
  }
  if (G.location === 'dragonreach') {
    npcAvailable.push({ id: 'guard_karl', label: '🗡️ 与龙卫统领卡尔交谈' });
    npcAvailable.push({ id: 'smithkeep_drag', label: '🐉 与龙域铁匠讨论龙族锻造' });
    if (chapterId === 'ch7_dragon') npcAvailable.push({ id: 'xuanming', label: '🐉 与玄冥的幻影交谈' });
  }
  if (G.location === 'icereef') {
    npcAvailable.push({ id: 'frostwing_echo', label: '🐲 感受霜翼的低语' });
    npcAvailable.push({ id: 'smithkeep_ice', label: '❄️ 与冰礁铁匠聊冰炼技术' });
  }

  if (npcAvailable.length > 0) {
    html += '<div class="npc-list">';
    for (var n = 0; n < npcAvailable.length; n++) {
      html += '<button class="btn" onclick="showDialog(\'' + npcAvailable[n].id + '\',0)">' + npcAvailable[n].label + '</button>';
    }
    html += '</div>';
  }

  html += '<div class="inn-service">';
  html += '<p>恢复状态:<strong>' + cost + ' 金币</strong></p>';
  html += '<p>当前HP:' + G.hp + '/' + G.maxHp + '</p>';
  html += '<p>当前MP:' + G.mp + '/' + G.maxMp + '</p>';
  html += '</div>';

  html += '<div class="btns">';
  // Chapter 1 free stay: first inn rest is free if on ch1_arrival
  var ch1FreeStay = G.storyProgress && G.storyProgress.chapterId === 'ch1_arrival' && !G._ch1InnRestDone;
  if (ch1FreeStay) {
    html += '<div style="color:#2ecc71;font-size:0.9em;margin:4px 0">🎁 老板娘:「新来的?今晚免费住!」</div>';
    html += '<button class="btn btn-primary" onclick="restAtInn()">💤 免费住宿</button>';
  } else {
    // Mercy: if broke and low HP, offer a free rest (once per location)
    var mercyKey = '_mercyRest_' + G.location;
    var needMercy = G.gold < cost && G.hp < G.maxHp * 0.3 && !G[mercyKey];
    if (needMercy) {
      html += '<div style="color:#e67e22;font-size:0.9em;margin:4px 0">😔 老板娘看你伤痕累累……</div>';
      html += '<button class="btn" onclick="mercyRest()">🆓 请求收留</button>';
    }
    html += '<button class="btn btn-primary" onclick="restAtInn()" ' + (G.gold < cost ? 'disabled' : '') + '>💤 住宿恢复 (' + cost + '金)</button>';
  }
    // P0-2: Gift button
  if (npcAvailable.length > 0 && Object.keys(G.materials || {}).length > 0) { html += '<button class="btn" style="background:#8e44ad" onclick="showGiftPanel(\x27inn\x27)">🎁 送礼</button>'; }
  html += '<button class="btn" onclick="sceneTown()">↩️ 离开</button>';
  html += '</div>';
  render(html);
}

function restAtInn() {
  // Free first stay for ch1_arrival
  var ch1FreeStay = G.storyProgress && G.storyProgress.chapterId === 'ch1_arrival' && !G._ch1InnRestDone;
  var innPrices2 = { whitecity: 10, ironridge: 15, tidport: 12, sunspire: 40, dragonreach: 60, icereef: 70 };
  var cost = innPrices2[G.location] || 20;
  var npcDiscount2 = getNpcDiscount(null, 'inn') / 100;
  cost = Math.floor(cost * (1 - npcDiscount2));
  if (ch1FreeStay) {
    G._ch1InnRestDone = true;
    cost = 0;
  } else if (G.gold < cost) {
    toast('💰 金币不足');
    return;
  }
  G.gold -= cost;
  G.hp = G.maxHp;
  G.mp = G.maxMp;
  G._trainingSessions = 0; // Reset daily training
  updateStatus();
  if (ch1FreeStay) {
    toast('💤 老板娘收留你住了一晚，HP/MP已恢复!');
  } else {
    toast('💤 休息完毕!HP/MP已恢复 训练次数已重置 (-' + cost + '💰)');
  }
  checkStoryTriggers('rest_inn', 'rest_inn');
  sceneTown();
}

function mercyRest() {
  var mercyKey = '_mercyRest_' + G.location;
  G[mercyKey] = true;
  G.hp = G.maxHp;
  G.mp = G.maxMp;
  G._trainingSessions = 0;
  updateStatus();
  toast('🛏️ 老板娘叹了口气，收留了你一晚。HP/MP已恢复!');
  checkStoryTriggers('rest_inn', 'rest_inn');
  sceneTown();
}

var _shopItems = null;

function sceneShop() {
  G._currentScene = 'sceneShop';
  var loc = LOCATIONS[G.location];
  var items = (loc && loc.shopItems) ? loc.shopItems : [
    { id:'health_potion', name:'生命药水', type:'consumable', heal:30, price:15 },
    { id:'mana_potion', name:'魔法药水', type:'consumable', restore:20, price:20 },
    { id:'elixir', name:'高级药剂', type:'consumable', heal:80, restore:50, price:60 },
    { id:'antidote', name:'解毒剂', type:'consumable', cure:true, price:25 },
    { id:'torch', name:'火把', type:'consumable', light:true, price:5 },
    { id:'rope', name:'绳索', type:'consumable', tool:true, price:10 }
  ];
  _shopItems = items;

  var html = '';
  html += '<div class="scene-title">🏪 商店</div>';
  html += '<div class="money-display">💰 ' + G.gold + ' 金币</div>';
  html += '<div class="btns" style="margin-bottom:10px">';
  html += '<button class="btn btn-primary" onclick="_shopBuyTab(\'sceneShop\')">购买</button>';
  html += '<button class="btn" onclick="_shopSellTab(\'sceneShop\')">出售</button>';
  html += '</div>';

  html += '<div class="shop-items">';
  for (var i = 0; i < items.length; i++) {
    var it = items[i];
    var discount = (G.origin && G.origin.id === 'trader') ? 0.85 : 1;
    var npcDiscount = getNpcDiscount(null, 'shop') / 100;
    discount = discount * (1 - npcDiscount);
    var finalPrice = Math.floor(it.price * discount);
    html += '<div class="shop-item" onclick="buyItem(' + i + ')">';
    // Q18: Show how many player already owns
    var owned = 0;
    for (var oi = 0; oi < G.inventory.length; oi++) { if (G.inventory[oi].id === it.id || G.inventory[oi].name === it.name) owned++; }
    html += '<div class="item-name">' + it.name + (owned > 0 ? ' <span style="color:#7ec8a4;font-size:0.8em">(已有' + owned + ')</span>' : '') + '</div>';
    html += '<div class="item-stats">' + (it.atk ? '⚔️' + it.atk + ' ' : '') + (it.def ? '🛡️' + it.def + ' ' : '') + (it.heal ? '❤️+' + it.heal + ' ' : '') + (it.restore ? '💧+' + it.restore + ' ' : '') + (it.luk ? '🎲+' + it.luk + ' ' : '') + (it.int ? '🧙+' + it.int + ' ' : '') + (it.light ? '🔥照亮黑暗区域 ' : '') + (it.tool ? '🧗探索特殊地形 ' : '') + (it.cure ? '💊解除中毒 ' : '') + '</div>';
    html += '<div class="item-price">' + finalPrice + ' 💰</div>';
    html += '</div>';
  }
  html += '</div>';

  // Rare rotating stock
  var rareItems = getShopRareItems('sceneShop');
  if (rareItems.length > 0) {
    html += '<div style="margin:8px 0 4px;color:#d4a017;font-weight:bold;font-size:0.95em">🌟 限时特供（离开后刷新）</div>';
    html += '<div class="shop-items">';
    for (var ri = 0; ri < rareItems.length; ri++) {
      var rit = rareItems[ri];
      var ritDiscount = (G.origin && G.origin.id === 'trader') ? 0.85 : 1;
      var ritNpcDiscount = getNpcDiscount(null, 'shop') / 100;
      ritDiscount = ritDiscount * (1 - ritNpcDiscount);
      var ritPrice = Math.floor(rit.price * ritDiscount);
      var ritCol = {common:'#9d9d9d',uncommon:'#1eff00',rare:'#0070dd',epic:'#a335ee',legendary:'#ff8000',mythic:'#e6cc80'};
      html += '<div class="shop-item" onclick="buyRareShopItem(' + ri + ',\'sceneShop\')" style="border-left:3px solid ' + (ritCol[rit.rarity]||'#9d9d9d') + '">';
      html += '<div class="item-name" style="color:' + (ritCol[rit.rarity]||'#9d9d9d') + '">' + rit.name + ' <span style="font-size:0.8em">[' + rit.rarity + ']</span></div>';
      html += '<div class="item-stats">' + (rit.heal ? '❤️+' + rit.heal + ' ' : '') + (rit.restore ? '💧+' + rit.restore + ' ' : '') + (rit.desc ? rit.desc + ' ' : '') + (rit.atk ? '⚔️' + rit.atk + ' ' : '') + (rit.luk ? '🎲+' + rit.luk + ' ' : '') + '</div>';
      html += '<div class="item-price">' + ritPrice + ' 💰</div>';
      html += '</div>';
    }
    html += '</div>';
  }

  html += '<div class="btns" style="margin-top:8px">';
  html += '<button class="btn" onclick="showGiftPanel(\'shop\')">🎁 送礼</button>';
  html += '<button class="btn" onclick="sceneTown()">↩️ 离开</button>';
  html += '</div>';
  render(html);
}

function buyRareShopItem(idx, scene) {
  var items = getShopRareItems(scene);
  var it = items[idx];
  if (!it) { toast('商品不存在'); return; }
  var discount = (G.origin && G.origin.id === 'trader') ? 0.85 : 1;
  var npcDiscount = getNpcDiscount(null, 'shop') / 100;
  discount = discount * (1 - npcDiscount);
  var price = Math.floor(it.price * discount);
  if (G.gold < price) { toast('💰 金币不足'); return; }
  G.gold -= price;
  // Clone item into inventory
  var newItem = JSON.parse(JSON.stringify(it));
  delete newItem.rarity;
  G.inventory.push(newItem);
  // Remove from rare stock
  items.splice(idx, 1);
  updateStatus();
  toast('✅ 购入 ' + it.name + ' (-' + price + '💰)');
  sceneShop();
}

function buyItem(idx) {
  var it = _shopItems[idx];
  var discount = (G.origin && G.origin.id === 'trader') ? 0.85 : 1;
  var npcDiscount = getNpcDiscount(null, 'shop') / 100;
  discount = discount * (1 - npcDiscount);
  var price = Math.floor(it.price * discount);

  if (G.gold < price) { toast('💰 金币不足'); return; }

  if (it.type === 'consumable') {
    // Teleport scrolls and damage scrolls go to inventory, not instant use
    if (it.useType === 'teleport' || it.dmgType) {
      G.gold -= price;
      G.inventory.push({ id:it.id, name:it.name, type:it.type, useType:it.useType||null, dmgType:it.dmgType||null, dmg:it.dmg||0, heal:it.heal||0, restore:it.restore||0, cure:it.cure||false, light:it.light||false, tool:it.tool||false, price:it.price, desc:it.desc||'' });
      toast('购买 ' + it.name + ',已放入背包');
      sceneShop();
      return;
    }
    G.gold -= price;
    var useMsg = it.name;
    if (it.heal) { G.hp = Math.min(G.maxHp, G.hp + it.heal); useMsg += ' ❤️+' + it.heal; }
    if (it.restore) { G.mp = Math.min(G.maxMp, G.mp + it.restore); useMsg += ' 💧+' + it.restore; }
    if (it.cure) useMsg += ' 🌿解毒';
    updateStatus();
    toast(useMsg);
    sceneShop();
    return;
  }

  // Put in inventory instead of auto-equipping
  G.gold -= price;
  var invItem = { id:it.id, name:it.name, type:'equipment', slot:it.slot||it.type, atk:it.atk||0, def:it.def||0, hp:it.hp||0, mp:it.mp||0, matk:it.matk||0, luk:it.luk||0, int:it.int||0, agi:it.agi||0, str:it.str||0, cha:it.cha||0, heal:it.heal||0, restore:it.restore||0, price:it.price, rarity:it.rarity||'common', rarityColor:it.rarityColor||'#9ca3af', icon:it.icon||'', affixes:it.affixes||[], effects:it.effects||[] };
  G.inventory.push(invItem);
  toast('购买 ' + it.name + ',已放入背包');
  checkStoryTriggers('buy_item', it.id);
  sceneShop();
}

// === SHOP SELL/BUY TAB SYSTEM ===

function _shopBuyTab(returnScene) {
  // Just re-render the shop/blacksmith
  var fn = window[returnScene];
  if (typeof fn === 'function') fn();
}

function _shopSellTab(returnScene) {
  var title = returnScene === 'sceneBlacksmith' ? '⚒️ 铁匠铺 - 出售' : '🏪 商店 - 出售';
  if (!G._sellTab) G._sellTab = 'equipment';
  var html = '';
  html += '<div class="scene-title">' + title + '</div>';
  html += '<div class="money-display">💰 ' + G.gold + ' 金币</div>';
  html += '<div class="btns" style="margin-bottom:10px">';
  html += '<button class="btn" onclick="_shopBuyTab(\'' + returnScene + '\')">购买</button>';
  html += '<button class="btn btn-primary" onclick="_shopSellTab(\'' + returnScene + '\')">出售</button>';
  html += '</div>';

  // Sell category tabs
  html += '<div class="btns" style="margin-bottom:8px">';
  html += '<button class="btn' + (G._sellTab === 'equipment' ? ' btn-primary' : '') + '" onclick="G._sellTab=\'equipment\';_shopSellTab(\'' + returnScene + '\')">⚔️ 装备</button>';
  html += '<button class="btn' + (G._sellTab === 'material' ? ' btn-primary' : '') + '" onclick="G._sellTab=\'material\';_shopSellTab(\'' + returnScene + '\')">🧪 材料</button>';
  html += '<button class="btn' + (G._sellTab === 'all' ? ' btn-primary' : '') + '" onclick="G._sellTab=\'all\';_shopSellTab(\'' + returnScene + '\')">📦 全部</button>';
  html += '</div>';

  // Show sellable items from inventory, filtered by tab - with stacking (Q17)
  html += '<div class="shop-items">';
  var hasItems = false;
  if (G.inventory && G.inventory.length > 0) {
    // Group identical items for stacking display
    var sellGroups = {};  // key: name+type -> {item, indices:[]}
    var sellOrder = [];
    for (var i = 0; i < G.inventory.length; i++) {
      var item = G.inventory[i];
      // Filter by tab
      if (G._sellTab === 'equipment' && item.type !== 'weapon' && item.type !== 'helmet' && item.type !== 'armor' && item.type !== 'gloves' && item.type !== 'boots' && item.type !== 'belt' && item.type !== 'necklace' && item.type !== 'ring' && item.type !== 'equipment') continue;
      if (G._sellTab === 'material' && item.type !== 'material' && item.type !== 'trade_good') continue;
      var gkey = item.name + '|' + item.type;
      if (!sellGroups[gkey]) { sellGroups[gkey] = {item: item, indices: []}; sellOrder.push(gkey); }
      sellGroups[gkey].indices.push(i);
    }
    for (var gi = 0; gi < sellOrder.length; gi++) {
      var group = sellGroups[sellOrder[gi]];
      var item = group.item;
      var count = group.indices.length;
      var sellPrice = calcSellPrice(item);
      hasItems = true;
      html += '<div class="shop-item" style="position:relative">';
      html += '<div class="item-name" style="color:' + (item.rarityColor || '#d4c8a8') + '">' + (item.icon ? item.icon + ' ' : '') + item.name + (count > 1 ? ' <span style="color:#d4a017">x' + count + '</span>' : '') + '</div>';
      html += '<div class="item-stats">' + getItemStatString(item) + '</div>';
      html += '<div class="item-price" style="color:#d4a017">+' + sellPrice + ' 💰</div>';
      html += '</div>';
      html += '<button class="btn-small" style="position:absolute;right:4px;top:4px;background:#4a2a1a;border:1px solid #a55;color:#d4a017" onclick="sellItem(' + group.indices[0] + ',\'' + returnScene + '\')">💰出售</button>';
    }
  }
  if (!hasItems) {
    html += '<div style="color:#888;text-align:center;padding:20px">该分类下没有可出售的物品</div>';
  }
  html += '</div>';

  var backFn = returnScene === 'sceneBlacksmith' ? 'sceneBlacksmith' : 'sceneShop';
  html += '<button class="btn" onclick="' + backFn + '()">↩️ 返回</button>';
  render(html);
}

function calcSellPrice(item) {
  var base = Math.floor((item.sellPrice || item.price || 10) * 0.5);
  if (G.origin && G.origin.id === 'trader') base = Math.floor(base * 1.2);
  return base;
}

function sellItem(idx, returnScene) {
  var item = G.inventory[idx];
  if (!item) return;
  var sellPrice = calcSellPrice(item);
  // Q16: Two-step sell confirmation
  if (!G._sellConfirmIdx || G._sellConfirmIdx !== idx) {
    G._sellConfirmIdx = idx;
    toast('⚠️ 再次点击确认出售 ' + item.name + ' (' + sellPrice + '💰)');
    return;
  }
  G._sellConfirmIdx = null;

  G.gold += sellPrice;
  G.inventory.splice(idx, 1);
  updateStatus();
  toast('💰 出售 ' + item.name + ',获得 ' + sellPrice + ' 金币');
  if (returnScene === 'sceneBlacksmith') { sceneBlacksmith(); }
  else { _shopSellTab(returnScene); }
}


// ─── talkToNpc(): redirect to showDialog (with quest offer support) ───
var _npcQuestMap = {
  // Blacksmith NPCs
  smith_white: ['mine_unlock'],
  smith_iron: ['ironridge_supply', 'boss_fortress'],
  smithkeep_drag: ['q_dragonreach_patrol'],
  smithkeep_ice: ['q_stormcape_lighthouse'],
  // Inn NPCs
  innkeep_white: ['q_lake_patrol'],
  innkeep_iron: ['forest_clear'],
  innkeep_tid: ['tidport_escort'],
  innkeep_sun: ['q_sunspire_climb'],
  innkeep_dragon: ['q_dragontemple_depths'],
  innkeep_ice: ['q_windisland_trial'],
  // Special NPCs
  mist_spirit: ['q_misthollow_visit'],
  jade_guardian: ['q_jademarsh_clear'],
  captain_storm: ['q_windisland_trial'],
  ash_wanderer: ['q_ashplains_survey'],
  flame_seer: ['q_volcano_expedition'],
  gatekeeper_abyss: ['q_abyssgate_visit'],
  shadow_whisperer: ['q_shadowrealm_explore'],
  lord_white: ['mine_unlock'],
  lord_iron: ['boss_fortress'],
  lord_tid: ['tidport_escort'],
  sage_ilan: ['q_sunspire_climb']
};

function talkToNpc(npcKey) {
  showDialog(npcKey, 0);
}


function sceneBlacksmith() {
  G._currentScene = 'sceneBlacksmith';
  var loc = LOCATIONS[G.location];
  var items = (loc && loc.smithItems) ? loc.smithItems : [
    { id:'wooden_sword', name:'木剑', type:'weapon', atk:5, matk:0, price:30 },
    { id:'iron_sword', name:'铁剑', type:'weapon', atk:12, matk:0, price:80 },
    { id:'steel_blade', name:'钢刃', type:'weapon', atk:22, matk:0, price:200 },
    { id:'apprentice_staff', name:'学徒法杖', type:'weapon', atk:2, matk:14, price:60 },
    { id:'leather_armor', name:'皮甲', type:'armor', def:5, hp:20, price:40 },
    { id:'ring', name:'戒指', type:'ring', slot:'ring', luk:2, price:50 },
    { id:'amulet', name:'护身符', type:'necklace', slot:'necklace', int:3, price:70 }
  ];
  _shopItems = items;
  var tab = G._smithTab || 'buy';

  var html = '';
  html += '<div class="scene-title">⚒️ 铁匠铺</div>';
  html += '<div style="color:#d4a017;text-align:right;font-weight:bold;margin-bottom:8px">💰 ' + G.gold + ' 金币</div>';
  // Blacksmith NPCs
  var smithNpcMap = {
    whitecity:  [{ id:'smith_white', label:'🔨 与铁匠老赵聊天' }],
    ironridge:  [{ id:'smith_iron', label:'⚒️ 与铁匠赫尔曼交谈' }],
    dragonreach:[{ id:'smithkeep_drag', label:'🐉 与龙域铁匠交谈' }],
    icereef:    [{ id:'smithkeep_ice', label:'🧊 与冰礁铁匠交谈' }]
  };
  var smithNpcs = smithNpcMap[G.location];
  if (smithNpcs) {
    html += '<div class="npc-list" style="margin-bottom:8px">';
    for (var sni = 0; sni < smithNpcs.length; sni++) {
      html += '<button class="btn" style="margin:2px" onclick="talkToNpc(\''+smithNpcs[sni].id+'\')">'+smithNpcs[sni].label+'</button>';
    }
    html += '</div>';
  }

  var smithDescs = {
    whitecity: '「好钢要千锤百炼。」铁匠擦拭着额头',
    ironridge: '「这里的火从不断绝。」铁匠拿起一把赤红的铁钳',
    tidport: '「船需要钉子,人需要刀。」铁匠从盐渍的工作台上抬起头',
    sunspire: '「魔法和钢铁可以共存。」工匠轻轻擦拭着附魔的刀刃',
    dragonreach: '「龙骨比任何金属都硬,但我们可以锻造它。」铁匠指着墙上的龙牙锤',
    icereef: '「冰不会融化,如果你锻造得够快。」铁匠吐出一口白气'
  };
  html += '<div class="smith-desc">' + (smithDescs[G.location] || smithDescs.whitecity) + '</div>';
  html += '<div class="money-display">💰 ' + G.gold + ' 金币</div>';

  // Tabs: Buy / Sell / Craft
  html += '<div class="btns" style="margin-bottom:10px">';
  html += '<button class="btn ' + (tab==='buy'?'btn-primary':'') + '" onclick="G._smithTab=\'buy\';sceneBlacksmith()" style="flex:1">购买</button>';
  html += '<button class="btn ' + (tab==='sell'?'btn-primary':'') + '" onclick="G._smithTab=\'sell\';sceneBlacksmith()" style="flex:1">出售</button>';
  html += '<button class="btn ' + (tab==='craft'?'btn-primary':'') + '" onclick="G._smithTab=\'craft\';sceneBlacksmith()" style="flex:1">🔨 打造</button>';
  html += '<button class="btn ' + (tab==='sets'?'btn-primary':'') + '" onclick="G._smithTab=\'sets\';sceneBlacksmith()" style="flex:1">📋 套装</button>';
  html += '</div>';

  if (tab === 'buy') {
    html += renderSmithBuy(items);
  } else if (tab === 'sell') {
    html += renderSmithSell();
  } else if (tab === 'craft') {
    html += renderSmithCraft();
  } else if (tab === 'sets') {
    html += renderSetCollection();
  }

  // P0-2: Gift button
  if (Object.keys(G.materials || {}).length > 0) { html += '<button class="btn" style="background:#8e44ad" onclick="showGiftPanel(\x27blacksmith\x27)">🎁 送礼</button>'; }
  html += '<button class="btn" onclick="sceneTown()">↩️ 离开</button>';
  render(html);
}

function renderSmithBuy(items) {
  var html = '';
  html += '<div class="shop-items">';
  for (var i = 0; i < items.length; i++) {
    var it = items[i];
    var discount = (G.origin && G.origin.id === 'trader') ? 0.85 : 1;
    var npcDiscount = getNpcDiscount(null, 'smith') / 100;
    discount = discount * (1 - npcDiscount);
    var finalPrice = Math.floor(it.price * discount);
    html += '<div class="shop-item" onclick="buyItem(' + i + ')">';
    var owned = 0;
    for (var oi = 0; oi < G.inventory.length; oi++) { if (G.inventory[oi].id === it.id || G.inventory[oi].name === it.name) owned++; }
    html += '<div class="item-name">' + it.name + (owned > 0 ? ' <span style="color:#7ec8a4;font-size:0.8em">(已有' + owned + ')</span>' : '');
    if (it.type === 'weapon') html += ' ⚔️';
    else if (it.type === 'armor') html += ' 🛡️';
    else if (it.type === 'necklace') html += ' 📿'; else if (it.type === 'ring') html += ' 💍';
    html += '</div>';
    html += '<div class="item-stats">';
    if (it.atk) html += '物攻+' + it.atk + ' ';
    if (it.matk) html += '魔攻+' + it.matk + ' ';
    if (it.def) html += '防御+' + it.def + ' ';
    if (it.hp) html += 'HP+' + it.hp + ' ';
    if (it.luk) html += '幸运+' + it.luk + ' ';
    if (it.int) html += '智力+' + it.int + ' ';
    if (it.str) html += '体魄+' + it.str + ' ';
    if (it.agi) html += '敏捷+' + it.agi + ' ';
    if (it.cha) html += '魅力+' + it.cha + ' ';
    html += '</div>';
    html += '<div class="item-price">' + finalPrice + ' 💰</div>';
    html += '</div>';
  }
  // Rare rotating stock
  var rareSmithItems = getShopRareItems('sceneBlacksmith');
  if (rareSmithItems.length > 0) {
    html += '<div style="margin:8px 0 4px;color:#d4a017;font-weight:bold;font-size:0.95em">🌟 限时特供（离开后刷新）</div>';
    for (var rsi = 0; rsi < rareSmithItems.length; rsi++) {
      var rit = rareSmithItems[rsi];
      var ritDiscount = (G.origin && G.origin.id === 'trader') ? 0.85 : 1;
      var ritNpcDiscount = getNpcDiscount(null, 'smith') / 100;
      ritDiscount = ritDiscount * (1 - ritNpcDiscount);
      var ritPrice = Math.floor(rit.price * ritDiscount);
      var ritCol = {common:'#9d9d9d',uncommon:'#1eff00',rare:'#0070dd',epic:'#a335ee',legendary:'#ff8000',mythic:'#e6cc80'};
      html += '<div class="shop-item" onclick="buyRareSmithItem(' + rsi + ')" style="border-left:3px solid ' + (ritCol[rit.rarity]||'#9d9d9d') + '">';
      html += '<div class="item-name" style="color:' + (ritCol[rit.rarity]||'#9d9d9d') + '">' + rit.name + ' <span style="font-size:0.8em">[' + rit.rarity + ']</span> ⚔️</div>';
      html += '<div class="item-stats">' + (rit.atk ? '物攻+' + rit.atk + ' ' : '') + (rit.matk ? '魔攻+' + rit.matk + ' ' : '') + (rit.luk ? '幸运+' + rit.luk + ' ' : '') + (rit.agi ? '敏捷+' + rit.agi + ' ' : '') + '</div>';
      html += '<div class="item-price">' + ritPrice + ' 💰</div>';
      html += '</div>';
    }
  }
  html += '</div>';
  return html;
}

function renderSmithCraft() {
  var html = '';
  html += '<div style="color:#aaa;font-size:0.85em;margin-bottom:8px">用材料+金币打造定制装备,可指定词条!</div>';

  var available = [];
  var locked = [];
  for (var i = 0; i < CRAFT_RECIPES.length; i++) {
    var r = CRAFT_RECIPES[i];
    var canCraft = true;
    var missingMats = [];
    // Check materials
    for (var mi = 0; mi < r.mats.length; mi++) {
      var need = r.mats[mi];
      var have = countMaterialInInventory(need.mid);
      if (have < need.qty) {
        canCraft = false;
        missingMats.push(MATERIALS[need.mid].name + '(' + (need.qty - have) + ')');
      }
    }
    // Check gold
    if (G.gold < r.goldCost) canCraft = false;

    if (canCraft) {
      available.push({ recipe: r, idx: i });
    } else {
      locked.push({ recipe: r, idx: i, missingMats: missingMats });
    }
  }

  // Available recipes
  if (available.length > 0) {
    html += '<div style="color:#22c55e;font-weight:bold;margin:8px 0">✅ 可打造</div>';
    for (var a = 0; a < available.length; a++) {
      var rec = available[a].recipe;
      var rarColors = { common:'#9d9d9d', uncommon:'#1eff00', rare:'#0070dd', epic:'#a335ee', legendary:'#ff8000', mythic:'#e6cc80' };
      html += '<div class="craft-item" style="padding:10px;margin:6px 0;background:#16213e;border-radius:6px;border-left:3px solid ' + (rarColors[rec.rarity]||'#9d9d9d') + '">';
      html += '<div style="display:flex;justify-content:space-between;align-items:center">';
      html += '<span style="color:' + (rarColors[rec.rarity]||'#e0e0e0') + ';font-weight:bold">' + rec.name + '</span>';
      html += '<span style="color:#d4a017">' + rec.goldCost + ' 💰</span>';
      html += '</div>';
      if (rec.setId && EQUIP_SETS[rec.setId]) {
        html += '<div style="font-size:0.75em;color:#ffaa00;margin-top:1px">📋 ' + EQUIP_SETS[rec.setId].name + '套装</div>';
      }
      html += '<div style="font-size:0.85em;color:#c0c0c0;margin-top:4px">';
      if (rec.atk) html += '物攻+' + rec.atk + ' ';
      if (rec.matk) html += '魔攻+' + rec.matk + ' ';
      if (rec.def) html += '防御+' + rec.def + ' ';
      if (rec.hp) html += 'HP+' + rec.hp + ' ';
      if (rec.agi) html += '敏捷+' + rec.agi + ' ';
      if (rec.luk) html += '幸运+' + rec.luk + ' ';
      html += '</div>';
      html += '<div style="font-size:0.8em;color:#888;margin-top:2px">材料:';
      for (var cm = 0; cm < rec.mats.length; cm++) {
        html += MATERIALS[rec.mats[cm].mid].name + '×' + rec.mats[cm].qty + ' ';
      }
      html += '</div>';
      if (rec.fixedAffix === 'chosen') {
        html += '<div style="font-size:0.8em;color:#d4a017;margin-top:2px">⭐ 可选择1个词条</div>';
      } else if (rec.fixedAffix) {
        html += '<div style="font-size:0.8em;color:#a335ee;margin-top:2px">附魔:' + rec.fixedAffix + '</div>';
      }
      html += '<button class="btn" style="margin-top:6px;font-size:0.85em" onclick="startCraft(' + available[a].idx + ')">🔨 打造</button>';
      html += '</div>';
    }
  }

  // Locked recipes (grayed out)
  if (locked.length > 0) {
    html += '<div style="color:#888;font-weight:bold;margin:12px 0 8px">🔒 缺材料</div>';
    for (var l = 0; l < locked.length; l++) {
      var lr = locked[l].recipe;
      html += '<div class="craft-item" style="padding:8px;margin:4px 0;background:#0d1117;border-radius:6px;opacity:0.6">';
      html += '<div style="color:#888">' + lr.name + (lr.setId && EQUIP_SETS[lr.setId] ? ' <span style="color:#ffaa00;font-size:0.8em">📋' + EQUIP_SETS[lr.setId].name + '</span>' : '') + ' <span style="font-size:0.8em">(' + locked[l].missingMats.join(', ') + ')</span></div>';
      html += '<div style="font-size:0.8em;color:#666">' + lr.goldCost + ' 💰</div>';
      html += '</div>';
    }
  }

  // Material inventory summary
  html += '<div style="margin-top:12px;padding:8px;background:#0d1117;border-radius:6px;font-size:0.85em">';
  html += '<div style="color:#aaa;font-weight:bold;margin-bottom:4px">📦 材料背包</div>';
  var matCount = {};
  if (G.inventory) {
    for (var ii = 0; ii < G.inventory.length; ii++) {
      if (G.inventory[ii].type === 'material') {
        var mid = G.inventory[ii].id;
        matCount[mid] = (matCount[mid] || 0) + 1;
      }
    }
  }
  var hasMats = false;
  for (var mk in matCount) {
    var mm = MATERIALS[mk];
    if (mm) {
      html += '<span style="margin-right:8px">' + mm.icon + ' ' + mm.name + '×' + matCount[mk] + '</span>';
      hasMats = true;
    }
  }
  if (!hasMats) html += '<span style="color:#666">暂无材料,去野外打怪获取</span>';
  html += '</div>';

  return html;
}

function renderSetCollection() {
  var html = '';
  var gol = '#d4a017';
  var gre = '#22c55e';
  var setKeys = Object.keys(EQUIP_SETS);
  var eqKeysAll = ['weapon','helmet','armor','gloves','boots','belt','necklace','ring'];
  var slotNames = { weapon:'⚔️武器', helmet:'🪖头盔', armor:'🛡️铠甲', gloves:'🧤手套', boots:'👢靴子', belt:'🔗腰带', necklace:'📿项链', ring:'💍戒指' };

  // Count owned pieces per set
  var ownedPieces = {};
  for (var oi = 0; oi < setKeys.length; oi++) {
    var osid = setKeys[oi];
    ownedPieces[osid] = { equipped: 0, inBag: 0, slots: {} };
  }
  for (var eqi = 0; eqi < eqKeysAll.length; eqi++) {
    var eqIt = G.equipment[eqKeysAll[eqi]];
    if (eqIt && eqIt.setId && ownedPieces[eqIt.setId]) {
      ownedPieces[eqIt.setId].equipped++;
      ownedPieces[eqIt.setId].slots[eqKeysAll[eqi]] = eqIt.name;
    }
  }
  if (G.inventory) {
    for (var ii = 0; ii < G.inventory.length; ii++) {
      var invIt = G.inventory[ii];
      if (invIt && invIt.setId && ownedPieces[invIt.setId]) {
        ownedPieces[invIt.setId].inBag++;
      }
    }
  }

  html += '<div style="color:' + gol + ';font-weight:bold;margin-bottom:8px;font-size:1.1em">📋 套装图鉴</div>';
  html += '<div style="color:#888;font-size:0.85em;margin-bottom:10px">收集同套装备激活套装效果，2/4/6件分别解锁加成</div>';

  html += '<div style="display:grid;gap:10px">';
  for (var si = 0; si < setKeys.length; si++) {
    var ssid = setKeys[si];
    var ssetData = EQUIP_SETS[ssid];
    var owned = ownedPieces[ssid];
    var total = owned.equipped + owned.inBag;
    html += '<div style="background:#1a1a0f;border:1px solid ' + (total >= 2 ? '#d4a017' : '#2a2a2a') + ';border-radius:10px;padding:12px">';
    // Header
    html += '<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">';
    html += '<span style="color:' + gol + ';font-weight:bold;font-size:1.05em">' + ssetData.name + '</span>';
    html += '<span style="color:' + (total >= 6 ? gre : total >= 4 ? '#3b82f6' : total >= 2 ? '#d4a017' : '#555') + ';font-size:0.9em">' + total + '/8 件' + (owned.equipped > 0 ? ' (装' + owned.equipped + ')' : '') + '</span>';
    html += '</div>';
    // Progress bar
    var pct = Math.round(total / 8 * 100);
    html += '<div style="background:#1a1a0a;border-radius:4px;height:6px;margin-bottom:8px;overflow:hidden">';
    html += '<div style="width:' + pct + '%;height:100%;background:linear-gradient(90deg,#d4a017,#ff8c00);border-radius:4px"></div>';
    html += '</div>';
    // Bonus lines
    var bonusLines = [
      { n: 2, b: ssetData.bonus2 },
      { n: 4, b: ssetData.bonus4 },
      { n: 6, b: ssetData.bonus6 }
    ];
    for (var bli = 0; bli < bonusLines.length; bli++) {
      var bl = bonusLines[bli];
      if (!bl.b) continue;
      var active = owned.equipped >= bl.n;
      html += '<div style="font-size:0.85em;margin-top:3px;padding-left:10px;color:' + (active ? gre : '#555') + ';border-left:2px solid ' + (active ? gre : '#333') + '">' + (active ? '🟢 ' : '⚪ ') + bl.n + '件: ' + bl.b.desc + '</div>';
    }
    // Show equipped slot items
    if (owned.equipped > 0) {
      html += '<div style="margin-top:6px;padding-left:10px;font-size:0.8em;color:#aaa">';
      for (var sn in owned.slots) {
        html += '<span style="margin-right:8px">' + (slotNames[sn] || sn) + ': ' + owned.slots[sn] + '</span>';
      }
      html += '</div>';
    }
    // Show set piece list from CRAFT_RECIPES
    var setRecipes = CRAFT_RECIPES.filter(function(r){ return r.setId === ssid; });
    if (setRecipes.length > 0) {
      html += '<div style="margin-top:6px;padding-left:10px;font-size:0.8em;color:#666">配方: ';
      for (var ri = 0; ri < setRecipes.length; ri++) {
        html += setRecipes[ri].name + ' ';
      }
      html += '</div>';
    }
    html += '</div>';
  }
  html += '</div>';
  return html;
}

function countMaterialInInventory(matId) {
  var count = 0;
  if (!G.inventory) return 0;
  for (var i = 0; i < G.inventory.length; i++) {
    if (G.inventory[i].type === 'material' && G.inventory[i].id === matId) count++;
  }
  return count;
}

function buyRareSmithItem(idx) {
  var items = getShopRareItems('sceneBlacksmith');
  var it = items[idx];
  if (!it) { toast('商品不存在'); return; }
  var discount = (G.origin && G.origin.id === 'trader') ? 0.85 : 1;
  var npcDiscount = getNpcDiscount(null, 'smith') / 100;
  discount = discount * (1 - npcDiscount);
  var price = Math.floor(it.price * discount);
  if (G.gold < price) { toast('💰 金币不足'); return; }
  G.gold -= price;
  var newItem = JSON.parse(JSON.stringify(it));
  delete newItem.rarity;
  G.inventory.push(newItem);
  items.splice(idx, 1);
  updateStatus();
  toast('✅ 购入 ' + it.name + ' (-' + price + '💰)');
  sceneBlacksmith();
}

function renderSmithSell() {
  var html = '';
  html += '<div class="shop-items">';
  if (G.inventory && G.inventory.length > 0) {
    for (var i = 0; i < G.inventory.length; i++) {
      var item = G.inventory[i];
      var sellPrice = Math.floor((item.sellPrice || item.price || 10) * 0.5);
      if (G.origin && G.origin.id === 'trader') sellPrice = Math.floor(sellPrice * 1.2);
      html += '<div class="shop-item" style="position:relative">';
      html += '<div class="item-name">' + (item.icon ? item.icon + ' ' : '') + item.name + '</div>';
      html += '<div class="item-stats">' + getItemStatString(item) + '</div>';
      html += '<div class="item-price" style="color:#d4a017">+' + sellPrice + ' 💰</div>';
      html += '</div>';
      html += '<button class="btn-small" style="position:absolute;right:4px;top:4px;background:#4a2a1a;border:1px solid #a55;color:#d4a017" onclick="sellItem(' + i + ',\'sceneBlacksmith\')">💰出售</button>';    }
  } else {
    html += '<div style="color:#888;text-align:center;padding:20px">背包中没有可出售的物品</div>';
  }
  html += '</div>';
  return html;
}

function removeMaterialsFromInventory(matList) {
  for (var i = 0; i < matList.length; i++) {
    var need = matList[i];
    var removed = 0;
    for (var j = G.inventory.length - 1; j >= 0 && removed < need.qty; j--) {
      if (G.inventory[j].type === 'material' && G.inventory[j].id === need.mid) {
        G.inventory.splice(j, 1);
        removed++;
      }
    }
  }
}

function startCraft(recipeIdx) {
  var recipe = CRAFT_RECIPES[recipeIdx];
  if (!recipe) return;

  // Verify materials
  for (var i = 0; i < recipe.mats.length; i++) {
    if (countMaterialInInventory(recipe.mats[i].mid) < recipe.mats[i].qty) {
      toast('材料不足'); return;
    }
  }
  if (G.gold < recipe.goldCost) { toast('金币不足'); return; }

  // If recipe allows choosing an affix, show selection
  if (recipe.fixedAffix === 'chosen') {
    showCraftAffixPicker(recipeIdx);
    return;
  }

  // Otherwise craft directly
  finishCraft(recipeIdx, null);
}

function showCraftAffixPicker(recipeIdx) {
  var recipe = CRAFT_RECIPES[recipeIdx];
  var html = '';
  html += '<div class="scene-title">🔨 选择词条 - ' + recipe.name + '</div>';
  html += '<div style="color:#aaa;font-size:0.85em;margin-bottom:8px">选择1个属性词条附加到装备上</div>';

  var affixChoices = [
    { id:'str', name:'💪 体魄 +5', stat:'str', val:5 },
    { id:'agi', name:'🏃 敏捷 +5', stat:'agi', val:5 },
    { id:'int', name:'🧠 智力 +5', stat:'int', val:5 },
    { id:'cha', name:'🗣️ 魅力 +5', stat:'cha', val:5 },
    { id:'luk', name:'🍀 幸运 +5', stat:'luk', val:5 },
    { id:'atk', name:'⚔️ 攻击 +8', stat:'atk', val:8 },
    { id:'def', name:'🛡️ 防御 +8', stat:'def', val:8 },
    { id:'hp', name:'❤️ 生命 +40', stat:'hp', val:40 },
    { id:'crit', name:'💥 暴击率 +5%', stat:'critRate', val:0.05 },
    { id:'dodge', name:'💫 闪避率 +5%', stat:'dodge', val:0.05 },
    { id:'lifesteal', name:'🧛 吸血 +5%', stat:'lifesteal', val:0.05 }
  ];

  for (var i = 0; i < affixChoices.length; i++) {
    var af = affixChoices[i];
    html += '<button class="btn" style="margin:4px;display:inline-block;min-width:120px" onclick="finishCraft(' + recipeIdx + ',' + i + ')">' + af.name + '</button>';
  }

  html += '<div class="btns" style="margin-top:12px">';
  html += '<button class="btn" onclick="sceneBlacksmith()">↩️ 取消</button>';
  html += '</div>';
  render(html);
}

function finishCraft(recipeIdx, affixChoiceIdx) {
  var recipe = CRAFT_RECIPES[recipeIdx];
  if (!recipe) return;

  // Verify again
  for (var i = 0; i < recipe.mats.length; i++) {
    if (countMaterialInInventory(recipe.mats[i].mid) < recipe.mats[i].qty) {
      toast('材料不足'); return;
    }
  }
  if (G.gold < recipe.goldCost) { toast('金币不足'); return; }

  // Deduct gold and materials
  G.gold -= recipe.goldCost;
  removeMaterialsFromInventory(recipe.mats);

  // Create item
  var item = {
    name: recipe.name,
    type: recipe.type,
    slot: recipe.slot,
    rarity: recipe.rarity,
    price: recipe.goldCost
  };
  if (recipe.setId) item.setId = recipe.setId;
  if (recipe.rarity) item.rarityColor = RARITY_TABLE[recipe.rarity] ? RARITY_TABLE[recipe.rarity].color : '#9ca3af';
  // Slot-based icon
  var slotIcons = { weapon:'⚔️', helmet:'🪖', armor:'🛡️', gloves:'🧤', boots:'👢', belt:'🔗', necklace:'📿', ring:'💍', shield:'🛡️' };
  item.icon = slotIcons[recipe.slot] || '📦';
  if (recipe.atk) item.atk = recipe.atk;
  if (recipe.matk) item.matk = recipe.matk;
  if (recipe.def) item.def = recipe.def;
  if (recipe.hp) item.hp = recipe.hp;
  if (recipe.agi) item.agi = recipe.agi;
  if (recipe.luk) item.luk = recipe.luk;

  // Apply chosen affix
  if (recipe.fixedAffix === 'chosen' && affixChoiceIdx !== null && affixChoiceIdx !== undefined) {
    var affixChoices = [
      { stat:'str', val:5 }, { stat:'agi', val:5 }, { stat:'int', val:5 },
      { stat:'cha', val:5 }, { stat:'luk', val:5 }, { stat:'atk', val:8 },
      { stat:'def', val:8 }, { stat:'hp', val:40 }, { stat:'critRate', val:0.05 },
      { stat:'dodge', val:0.05 }, { stat:'lifesteal', val:0.05 }
    ];
    var chosen = affixChoices[affixChoiceIdx];
    if (chosen) {
      item[chosen.stat] = (item[chosen.stat] || 0) + chosen.val;
      item.chosenAffix = chosen.stat;
    }
  } else if (recipe.fixedAffix && recipe.fixedAffix !== 'chosen') {
    item.craftAffix = recipe.fixedAffix;
  }

  G.inventory.push(item);
  updateStatus();
  G._craftCount = (G._craftCount || 0) + 1;

  var rarNames = { common:'普通', uncommon:'优秀', rare:'精良', epic:'史诗', legendary:'传说' };
  toast('🔨 打造成功!' + (rarNames[recipe.rarity]||'') + ' ' + recipe.name);
  checkStoryTriggers('craft_item', recipe.id);
  checkAchievements();
  sceneBlacksmith();
}

function sceneTraining() {
  G._currentScene = 'sceneTraining';
  var html = '';
  html += '<div class="scene-title">🏋️ 训练场</div>';
  html += '<div style="color:#d4a017;text-align:right;font-weight:bold;margin-bottom:8px">💰 ' + G.gold + ' 金币</div>';  html += '<div style="color:#aaa;font-size:0.85em;margin-bottom:8px">挥洒汗水,突破极限!</div>';
  html += '<div class="money-display">💰 ' + G.gold + ' 金币 | 📊 可用属性点: ' + (G.attrPts || 0) + '</div>';

  // Tab switch
  var tab = G._trainingTab || 'attr';
  var _tTabStyle = 'flex:1;padding:8px 4px;border-radius:8px;font-size:0.9em;text-align:center;cursor:pointer;border:2px solid #333;';
  var _tTabOn = 'background:linear-gradient(135deg,#2a2a18,#3a3a28);border-color:#d4a017;color:#d4a017;font-weight:bold;box-shadow:0 0 8px rgba(212,160,23,0.3);';
  var _tTabOff = 'background:#1a1a10;color:#888;';
  html += '<div style="display:flex;gap:4px;margin:8px 0">';
  html += '<div style="' + _tTabStyle + (tab === 'attr' ? _tTabOn : _tTabOff) + '" onclick="G._trainingTab=\'attr\';sceneTraining()">💪 属性训练</div>';
  html += '<div style="' + _tTabStyle + (tab === 'skill' ? _tTabOn : _tTabOff) + '" onclick="G._trainingTab=\'skill\';sceneTraining()">📖 技能学习</div>';
  html += '<div style="' + _tTabStyle + (tab === 'dragon' ? _tTabOn : _tTabOff) + '" onclick="G._trainingTab=\'dragon\';sceneTraining()">🐉 龙祭</div>';
  html += '</div>';

  if (tab === 'attr') {
    html += renderAttrTraining();
  } else if (tab === 'skill') {
    html += renderSkillTraining();
  } else {
    html += renderDragonOffering();
  }

  html += '<button class="btn" onclick="sceneTown()">↩️ 离开</button>';
  render(html);
}

function renderAttrTraining() {
  var html = '';
  html += '<div style="color:#aaa;font-size:0.85em;margin-bottom:8px">花费金币获得属性点。</div>';

  // Training options - cost scales with total trained
  var trained = G._totalTrained || 0;
  var baseCost = 50;
  var costPerPoint = Math.floor(baseCost * Math.pow(1.10, trained)); // C10: moderate exponential scaling for gold sink

  var trainOptions = [
    { stat: 'str', name: '💪 体魄训练', desc: '挥舞重锤,锤炼臂力', attr: 'str' },
    { stat: 'agi', name: '🏃 敏捷训练', desc: '跨越障碍,如风而行', attr: 'agi' },
    { stat: 'int', name: '🧠 智力训练', desc: '研读古籍,开拓心智', attr: 'int' },
    { stat: 'cha', name: '🗣️ 魅力训练', desc: '当众演说,培养气场', attr: 'cha' },
    { stat: 'luk', name: '🍀 幸运训练', desc: '掷骰赌博,听天由命', attr: 'luk' }
  ];

  // 10 sessions max per level tier
  var maxSessions = Math.floor(G.level / 10) * 5 + 5;
  var sessionsUsed = G._trainingSessions || 0;

  html += '<div style="margin-bottom:8px;font-size:0.85em;color:#d4a017">训练费用:' + costPerPoint + ' 💰/次 | 今日剩余:' + Math.max(0, maxSessions - sessionsUsed) + '/' + maxSessions + '</div>';

  for (var i = 0; i < trainOptions.length; i++) {
    var opt = trainOptions[i];
    var canTrain = G.gold >= costPerPoint && sessionsUsed < maxSessions;
    html += '<div style="display:flex;align-items:center;gap:8px;padding:10px;margin:6px 0;background:linear-gradient(135deg,#1a1a10,#222218);border-radius:10px;border:2px solid #3a3a2a">';
    html += '<div style="flex:1">';
    html += '<div style="font-weight:bold">' + opt.name + '</div>';
    html += '<div style="font-size:0.85em;color:#aaa">' + opt.desc + ' → ' + opt.attr.toUpperCase() + '+1</div>';
    html += '</div>';
    html += '<button class="btn" style="min-width:80px;background:linear-gradient(135deg,#2a4a2a,#1a3a1a);border:1px solid #4a6a4a" ' + (canTrain ? 'onclick="doTraining(\'' + opt.attr + '\',' + costPerPoint + ')"' : 'disabled') + '>' + costPerPoint + ' 💰</button>';
    html += '</div>';
  }

  // Special: bulk training (5 sessions at once)
  var bulkCost = costPerPoint * 5;
  if (G.level >= 20) {
    html += '<div style="margin-top:12px;padding:8px;background:#16213e;border-radius:6px">';
    html += '<div style="color:#a335ee;font-weight:bold">⚡ 集中特训(5次)</div>';
    html += '<div style="font-size:0.85em;color:#888;margin:4px 0">一次性获得5点属性点自由分配</div>';
    html += '<div style="font-size:0.85em;color:#d4a017">' + bulkCost + ' 💰</div>';
    var canBulk = G.gold >= bulkCost && sessionsUsed + 5 <= maxSessions;
    html += '<button class="btn" style="margin-top:4px" ' + (canBulk ? '' : 'disabled') + ' onclick="doBulkTraining(' + bulkCost + ')">⚡ 开始特训</button>';
    html += '</div>';
  }
  return html;
}

function renderSkillTraining() {
  var html = '';
  html += '<div style="color:#aaa;font-size:0.85em;margin-bottom:8px">花费金币学习新技能。需要达到对应等级。</div>';

  // Find learnable skills: reqLevel <= player level AND not already known AND not origin skill
  var learnable = [];
  for (var i = 0; i < SKILLS.length; i++) {
    var sk = SKILLS[i];
    if (G.skills.indexOf(sk.id) >= 0) continue; // already known
    if (sk.reqLevel > G.level) continue; // level too low
    // Origin skills are auto-granted, not trained
    if (G.origin && G.origin.originSkill === sk.id) continue;
    learnable.push(sk);
  }

  if (learnable.length === 0) {
    html += '<div class="inv-empty">暂无可学习的新技能。提升等级后可解锁更多!</div>';
    return html;
  }

  // Cost: 30 + reqLevel * 15
  for (var j = 0; j < learnable.length; j++) {
    var ls = learnable[j];
    var learnCost = 30 + (ls.reqLevel || 1) * 15;
    var canLearn = G.gold >= learnCost;
    var catLabel = ls.category === 'spell' ? '🔮' : '⚔️';
    html += '<div style="display:flex;align-items:center;gap:8px;padding:10px;margin:6px 0;background:linear-gradient(135deg,#1a1a10,#222218);border-radius:10px;border:2px solid #3a3a2a">';
    html += '<div style="flex:1">';
    html += '<div style="font-weight:bold;color:' + (ls.category === 'spell' ? '#6fa8dc' : '#d4a017') + '">' + catLabel + ' ' + ls.emoji + ' ' + ls.name + '</div>';
    html += '<div style="font-size:0.85em;color:#aaa">' + ls.desc + '</div>';
    html += '<div style="font-size:0.78em;color:#888;margin-top:2px">' + (ls.dmgMin ? '⚔️伤害:' + ls.dmgMin + '-' + ls.dmgMax + ' ' : '') + (ls.healMin ? '💚治疗:' + ls.healMin + '-' + ls.healMax + ' ' : '') + (ls.shield ? '🛡️护盾:' + ls.shield + ' ' : '') + (ls.stunChance ? '💫眩晕:' + Math.round(ls.stunChance*100) + '% ' : '') + (ls.critBonus ? '💥暴击+' + ls.critBonus + '% ' : '') + '💧消耗:' + ls.cost + ' | Lv' + (ls.reqLevel || 1) + '+</div>';
    html += '</div>';
    html += '<button class="btn" style="min-width:80px;background:linear-gradient(135deg,#2a4a2a,#1a3a1a);border:1px solid #4a6a4a" ' + (canLearn ? 'onclick="learnSkill(\'' + ls.id + '\',' + learnCost + ')"' : 'disabled') + '>' + learnCost + ' 💰</button>';
    html += '</div>';
  }
  return html;
}

function learnSkill(skillId, cost) {
  if (G.gold < cost) { toast('金币不足'); return; }
  if (G.skills.indexOf(skillId) >= 0) { toast('已学会此技能'); return; }
  G.gold -= cost;
  G.skills.push(skillId);
  var sk = SKILLS.find(function(s) { return s.id === skillId; });
  toast('📖 学会了 ' + (sk ? sk.emoji + sk.name : skillId) + '!');
  updateStatus();
  sceneTraining();
}

// C10: Dragon Offering render
function renderDragonOffering() {
  var html = '';
  if (G.level < 30) {
    html += '<div style="text-align:center;padding:30px;color:#666">';
    html += '<div style="font-size:2em;margin-bottom:10px">🐉</div>';
    html += '<div>龙祭将在达到 <b style="color:#d4a017">30级</b> 后开启</div>';
    html += '<div style="font-size:0.85em;color:#555;margin-top:6px">向远古龙族献祭金币,获得永久的属性提升</div>';
    html += '</div>';
    return html;
  }
  html += '<div style="color:#c9a84c;font-size:0.9em;margin-bottom:8px;text-align:center">向远古龙族献祭金币,获得永久的属性提升。每次献祭费用递增。</div>';
  html += '<div style="text-align:center;margin-bottom:10px;font-size:0.85em;color:#d4a017">💰 ' + G.gold + ' 金币</div>';

  var totalSpent = 0;
  for (var i = 0; i < DRAGON_OFFERINGS.length; i++) {
    var off = DRAGON_OFFERINGS[i];
    var lv = getDragonOfferingLevel(off.id);
    var cost = getDragonOfferingCost(off);
    var maxed = lv >= off.maxLevel;
    var canOffer = G.gold >= cost && !maxed;
    totalSpent += cost;

    var borderColor = maxed ? '#4a4' : lv > 0 ? '#d4a017' : '#3a3a2a';
    html += '<div style="padding:10px;margin:6px 0;background:linear-gradient(135deg,#1a1a10,#222218);border-radius:10px;border:2px solid ' + borderColor + '">';
    html += '<div style="display:flex;justify-content:space-between;align-items:center">';
    html += '<div>';
    html += '<div style="font-weight:bold;color:#c9a84c">' + off.name + '</div>';
    html += '<div style="font-size:0.85em;color:#aaa">' + off.desc + '</div>';
    html += '<div style="font-size:0.8em;color:#888;margin-top:2px">' + off.stat + ' +' + off.perLevel + '/级 | 当前 Lv' + lv + '/' + off.maxLevel + '</div>';
    html += '</div>';
    html += '<div style="text-align:right">';
    if (maxed) {
      html += '<div style="color:#4a4;font-weight:bold">✅ 已满级</div>';
    } else {
      html += '<div style="font-size:0.85em;color:#d4a017">' + cost + ' 💰</div>';
      html += '<button class="btn" style="margin-top:4px;min-width:70px" ' + (canOffer ? 'onclick="doDragonOffering(\''+off.id+'\')"' : 'disabled') + '>献祭</button>';
    }
    html += '</div>';
    html += '</div>';
    // Progress bar
    if (!maxed && lv > 0) {
      var pct = Math.floor(lv / off.maxLevel * 100);
      html += '<div style="margin-top:6px;height:4px;background:#1a1a10;border-radius:2px;overflow:hidden"><div style="width:' + pct + '%;height:100%;background:linear-gradient(90deg,#8b4513,#d4a017);border-radius:2px"></div></div>';
    }
    html += '</div>';
  }

  // Total investment summary
  var totalInvested = 0;
  if (G._dragonOfferings) {
    for (var k in G._dragonOfferings) {
      var off2 = null;
      for (var m = 0; m < DRAGON_OFFERINGS.length; m++) {
        if (DRAGON_OFFERINGS[m].id === k) { off2 = DRAGON_OFFERINGS[m]; break; }
      }
      if (off2) {
        for (var l = 0; l < G._dragonOfferings[k]; l++) {
          totalInvested += Math.floor(off2.costBase * Math.pow(off2.costMult, l));
        }
      }
    }
  }
  if (totalInvested > 0) {
    html += '<div style="margin-top:10px;padding:8px;background:#1a1a10;border:1px solid #3a3a2a;border-radius:6px;text-align:center">';
    html += '<div style="color:#c9a84c;font-size:0.9em">🐉 累计献祭: <b>' + totalInvested + '</b> 金币</div>';
    html += '</div>';
  }

  return html;
}

function doTraining(attr, cost) {
  if (G.gold < cost) { toast('金币不足'); return; }
  var trained = G._totalTrained || 0;
  var maxSessions = Math.floor(G.level / 10) * 5 + 5;
  var sessionsUsed = G._trainingSessions || 0;
  if (sessionsUsed >= maxSessions) { toast('今日训练次数已用尽'); return; }

  G.gold -= cost;
  G[attr] = (G[attr] || 0) + 1;
  G._totalTrained = trained + 1;
  G._trainingSessions = sessionsUsed + 1;
  // Recalc derived stats
  G.maxHp = calcMaxHp(); G.maxMp = calcMaxMp();
  G.hp = Math.min(G.hp, G.maxHp); G.mp = Math.min(G.mp, G.maxMp);
  updateStatus();
  toast('💪 ' + attr.toUpperCase() + '+1!训练有成');
  sceneTraining();
}

function doBulkTraining(cost) {
  if (G.gold < cost) { toast('金币不足'); return; }
  var maxSessions = Math.floor(G.level / 10) * 5 + 5;
  var sessionsUsed = G._trainingSessions || 0;
  if (sessionsUsed + 5 > maxSessions) { toast('今日训练次数不足5次'); return; }

  G.gold -= cost;
  G.attrPts = (G.attrPts || 0) + 5;
  G._totalTrained = (G._totalTrained || 0) + 5;
  G._trainingSessions = sessionsUsed + 5;
  updateStatus();
  toast('⚡ 获得5点属性点!自由分配');
  sceneTraining();
}

// C10: Dragon Offering - Late-game gold sink for permanent stat boosts
var DRAGON_OFFERINGS = [
  { id:'drg_atk', name:'🐉 烈焰献祭', desc:'以金币献祭火龙,永久提升攻击力', stat:'atk', perLevel:2, costBase:500, costMult:1.5, maxLevel:10 },
  { id:'drg_def', name:'🛡️ 玄龟献祭', desc:'以金币献祭玄龟,永久提升防御力', stat:'def', perLevel:2, costBase:500, costMult:1.5, maxLevel:10 },
  { id:'drg_matk', name:'🌀 秘法献祭', desc:'以金币献祭秘龙,永久提升魔法攻击', stat:'matk', perLevel:2, costBase:600, costMult:1.5, maxLevel:10 },
  { id:'drg_hp', name:'💚 生机献祭', desc:'以金币献祭木龙,永久提升生命上限', stat:'maxHp', perLevel:15, costBase:400, costMult:1.4, maxLevel:10 },
  { id:'drg_mp', name:'🔵 灵泉献祭', desc:'以金币献祭水龙,永久提升法力上限', stat:'maxMp', perLevel:10, costBase:350, costMult:1.4, maxLevel:10 },
  { id:'drg_crit', name:'⚡ 天雷献祭', desc:'以金币献祭雷龙,永久提升暴击率', stat:'critRate', perLevel:1, costBase:800, costMult:1.6, maxLevel:5 }
];

function getDragonOfferingLevel(id) {
  if (!G._dragonOfferings) G._dragonOfferings = {};
  return G._dragonOfferings[id] || 0;
}
function getDragonOfferingCost(off) {
  var lv = getDragonOfferingLevel(off.id);
  return Math.floor(off.costBase * Math.pow(off.costMult, lv));
}

function doDragonOffering(offId) {
  var off = null;
  for (var i = 0; i < DRAGON_OFFERINGS.length; i++) {
    if (DRAGON_OFFERINGS[i].id === offId) { off = DRAGON_OFFERINGS[i]; break; }
  }
  if (!off) return;
  var lv = getDragonOfferingLevel(off.id);
  if (lv >= off.maxLevel) { toast('已达最大献祭等级'); return; }
  var cost = getDragonOfferingCost(off);
  if (G.gold < cost) { toast('💰 金币不足,需要' + cost + '金'); return; }
  if (G.level < 30) { toast('需达到30级才能进行龙祭'); return; }
  G.gold -= cost;
  if (!G._dragonOfferings) G._dragonOfferings = {};
  G._dragonOfferings[off.id] = lv + 1;
  // Apply permanent stat boost
  if (!G._permStatBoosts) G._permStatBoosts = {};
  G._permStatBoosts[off.stat] = (G._permStatBoosts[off.stat] || 0) + off.perLevel;
  toast('🐉 ' + off.name + ' Lv' + (lv+1) + '! ' + off.stat + ' +' + off.perLevel);
  sceneTraining();
}

function sceneTavern() {
  G._currentScene = 'sceneTavern';
  var loc = LOCATIONS[G.location];
  var townName = loc ? loc.name : '白城';

  // Town-specific tavern flavor
  var tavernDescs = {
    whitecity: '酒保擦拭着杯子,冒险者们高谈阔论。角落的赌桌围满了人',
    ironridge: '矿工和铁匠们围坐痛饮,炉火的影子在墙上跳动。赌桌上硬币叮当作响',
    tidport: '水手们赌着骰子,角落里有个独眼老头低声哼着船歌',
    sunspire: '学者们一边品茶一边讨论古文献,偶尔有人掷两把骰子放松',
    dragonreach: '龙卫们豪迈地对饮,有人掷出龙牙骰子赌个痛快',
    icereef: '冰港渔民围着火炉,骨牌和骰子是漫长的极夜里唯一的消遣'
  };
  var desc = tavernDescs[G.location] || tavernDescs.whitecity;

  var html = '';
  html += '<div class="scene-title">🍺 酒馆</div>';
  html += '<div class="tavern-desc">' + desc + '</div>';

  // Town-specific rumors
  var allRumors = {
    whitecity: [
      '听说坠星湖深处有龙留下的宝藏...',
      '幽暗森林里出现了新的怪物群落...',
      '白城的商队最近总是被抢劫...',
      '破碎堡垒的为首的是个哥布林...',
      '矿洞深处传来奇怪的响声...'
    ],
    ironridge: [
      '铁岭的矿脉越来越深,工人们说下面有东西在回应...',
      '有个铁匠打出一把会发光的剑,第二天人就消失了',
      '北方山脉传来震颤,老矿工说是龙在翻身',
      '铁岭城的锻造秘方据说是龙骨灰烬...不知道真假',
      '秘银的价格又涨了,潮汐港的商人上周来收了一大批'
    ],
    tidport: [
      '远洋船队带回了奇怪的货物,听说来自龙之岛...',
      '码头上出现了黑袍人的身影,他们半夜才出来活动',
      '潮汐港的地下黑市什么都卖,只要你出得起价',
      '有个水手说在海上看到了飞行的巨大黑影...',
      '据说白城那边的商会会长被暗杀了,和龙纹有关...'
    ],
    sunspire: [
      '日冕塔的古籍记载了一道裂隙,通向失落的龙族圣殿',
      '学者们在塔顶观测到了不属于这片天空的星辰',
      '有人偷看了禁书区,第二天就疯了,不停说着龙语',
      '据说月光石能开启某处封印...塔主禁止讨论这个',
      '我的一个同行去调查翠玉沼泽的遗迹,再也没回来'
    ],
    dragonreach: [
      '龙域边境的巡逻兵说,夜里能听到龙的低吟',
      '有人在灰烬平原捡到一片龙鳞,卖了两千金币',
      '龙卫军的招募越来越频繁,一定是出了大事',
      '那条老龙还没死,我爷爷的爷爷见过它',
      '龙庙深处的封印据说正在松动...'
    ],
    icereef: [
      '冰礁港的渔民说,海面下有巨大的影子在移动',
      '极地风暴比往年更频繁,老人们说这是不好的征兆',
      '有人从冰层下面挖出了远古的武器,寒气逼人',
      '冻珠黑市的价格炒到了天价,据说是法术材料',
