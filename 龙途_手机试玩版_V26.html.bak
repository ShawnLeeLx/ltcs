];

function checkAchievements() {
  if (!G.achievements) G.achievements = [];
  if (!G._achRewardClaimed) G._achRewardClaimed = {};
  var newOnes = [];
  for (var i = 0; i < ACHIEVEMENTS.length; i++) {
    var a = ACHIEVEMENTS[i];
    if (G.achievements.indexOf(a.id) < 0 && a.check()) {
      G.achievements.push(a.id);
      // Auto-claim gold reward
      var goldReward = (a.reward && a.reward.gold) || 0;
      if (goldReward > 0) {
        G.gold += goldReward;
        G._achRewardClaimed[a.id] = true;
      }
      newOnes.push(a);
    }
  }
  for (var j = 0; j < newOnes.length; j++) {
    var na = newOnes[j];
    var rewardTxt = (na.reward && na.reward.gold > 0) ? ' (+' + na.reward.gold + '💰)' : '';
    toast('🏆 成就解锁: ' + na.emoji + ' ' + na.name + ' — ' + na.desc + rewardTxt);
  }
  return newOnes;
}

function sceneAchievements() {
  checkAchievements();
  var filter = G._achFilter || 'all';
  var html = '';
  html += '<div class="scene-title">🏆 成就</div>';
  // Stats bar
  var total = ACHIEVEMENTS.length;
  var done = (G.achievements||[]).length;
  var totalGold = 0, earnedGold = 0;
  for (var ti = 0; ti < ACHIEVEMENTS.length; ti++) {
    var ta = ACHIEVEMENTS[ti];
    totalGold += (ta.reward && ta.reward.gold) || 0;
    if ((G.achievements||[]).indexOf(ta.id) >= 0) earnedGold += (ta.reward && ta.reward.gold) || 0;
  }
  html += '<div style="text-align:center;color:#d4a017;margin-bottom:6px;font-size:0.95em">已解锁 ' + done + '/' + total + ' · 累计奖励 ' + earnedGold + '💰</div>';
  // Progress bar
  var pct = total > 0 ? Math.floor(done/total*100) : 0;
  html += '<div style="background:#1a1a2e;border-radius:8px;height:12px;margin-bottom:8px;overflow:hidden">';
  html += '<div style="width:'+pct+'%;height:100%;background:linear-gradient(90deg,#d4a017,#f0c040);border-radius:8px;transition:width 0.3s"></div>';
  html += '</div>';
  // Category filter tabs
  html += '<div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:10px">';
  for (var ci = 0; ci < ACH_CATS.length; ci++) {
    var cat = ACH_CATS[ci];
  var isActive = filter === cat.id;
  html += '<button class="btn ' + (isActive ? 'btn-primary' : '') + '" style="font-size:0.75em;padding:4px 8px" onclick="G._achFilter=\'' + cat.id + '\';sceneAchievements()">' + cat.emoji + cat.name + '</button>';
  }
  html += '</div>';
  // Achievement grid
  html += '<div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">';
  for (var i = 0; i < ACHIEVEMENTS.length; i++) {
    var a = ACHIEVEMENTS[i];
    if (filter !== 'all' && a.cat !== filter) continue;
    var unlocked = (G.achievements||[]).indexOf(a.id) >= 0;
    var bg = unlocked ? '#1a2a1a' : '#1a1a1a';
    var border = unlocked ? '#4a8a4a' : '#333';
    var nameColor = unlocked ? '#7ec8e3' : '#555';
    var descColor = unlocked ? '#aaa' : '#444';
    var rewardStr = (a.reward && a.reward.gold > 0) ? ' +' + a.reward.gold + '💰' : '';
    html += '<div style="padding:8px;background:'+bg+';border:1px solid '+border+';border-radius:8px;text-align:center">';
    html += '<div style="font-size:1.5em">'+(unlocked ? a.emoji : '🔒')+'</div>';
    html += '<div style="color:'+nameColor+';font-size:0.85em;font-weight:bold;margin:4px 0">'+a.name+'</div>';
    html += '<div style="color:'+descColor+';font-size:0.75em">'+a.desc+'</div>';
    if (rewardStr) html += '<div style="color:'+(unlocked?'#d4a017':'#444')+';font-size:0.7em;margin-top:2px">'+(unlocked?'✅':'') + rewardStr+'</div>';
    html += '</div>';
  }
  html += '</div>';
  html += '<div class="btns" style="margin-top:12px">';
  html += '<button class="btn" onclick="scenePlayerInfo()">↩️ 返回角色</button>';
  html += '</div>';
  render(html);
}

