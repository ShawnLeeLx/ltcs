<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>龙途传说</title>
<link rel="manifest" href="pwa/manifest.json">
<meta name="theme-color" content="#0d1117">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<link rel="apple-touch-icon" href="pwa/icon-192.png">
<style>


/* ═══════════════════════════════════════════════════════════
   手绘线稿风格 - Hand-drawn sketch style
   ═══════════════════════════════════════════════════════════ */

:root {
  --bg: #0d0d0d;
  --paper: #1a1a1a;
  --card: #222;
  --border: #3a3a3a;
  --text: #d4c8a8;
  --text-dim: #8a8070;
  --accent: #d4a017;
  --accent2: #c84;
  --hp: #c44;
  --mp: #48a;
  --xp: #4a4;
  --danger: #c44;
  --sketch: #a89070;
}

* { margin:0; padding:0; box-sizing:border-box; -webkit-text-size-adjust:100%; }

body {
  background: var(--bg);
  color: var(--text);
  font-family: 'Georgia', 'Songti SC', 'STSong', serif;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

#status {
  width: 100%;
  max-width: 100%;
  padding: 8px 16px;
  background: var(--card);
  border-bottom: 2px solid var(--border);
  font-size: 13px;
  text-align: center;
  position: sticky;
  top: 0;
  z-index: 100;
  letter-spacing: 1px;
}

#game {
  width: 100%;
  max-width: 100%;
  padding: 16px;
  flex: 1;
}

#toast {
  position: fixed;
  top: 50px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--accent);
  color: #000;
  padding: 8px 20px;
  border-radius: 20px;
  font-size: 14px;
  font-weight: bold;
  opacity: 0;
  transition: opacity 0.3s;
  z-index: 200;
  pointer-events: none;
}

/* ═══════════════════════════════════════════════════════════
   TYPOGRAPHY - Sketch feel
   ═══════════════════════════════════════════════════════════ */

.scene-title {
  font-size: 22px;
  font-weight: bold;
  color: var(--accent);
  text-align: center;
  margin-bottom: 12px;
  letter-spacing: 2px;
  /* Subtle sketch underline */
  position: relative;
  padding-bottom: 8px;
}
.scene-title::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 20%;
  right: 20%;
  height: 2px;
  background: linear-gradient(90deg, transparent, var(--accent), transparent);
}

.scene-desc {
  text-align: center;
  color: var(--text-dim);
  font-size: 13px;
  margin-bottom: 16px;
  font-style: italic;
}

.scene-text {
  line-height: 1.8;
  font-size: 16px;
  margin: 12px 0;
}
.scene-text p { margin-bottom: 8px; }

/* ═══════════════════════════════════════════════════════════
   BUTTONS - Ink brush style
   ═══════════════════════════════════════════════════════════ */

.btn {
  display: block;
  padding: 12px 24px;
  background: var(--card);
  color: var(--text);
  border: 2px solid var(--border);
  border-radius: 6px;
  font-size: 16px;
  font-family: inherit;
  cursor: pointer;
  margin: 4px;
  transition: all 0.2s;
  /* Sketch border effect */
  box-shadow: 2px 2px 0 rgba(0,0,0,0.3);
}
.btn:hover { 
  border-color: var(--accent); 
  color: var(--accent);
  box-shadow: 2px 2px 0 rgba(212,160,23,0.2);
}
.btn:active { transform: translate(1px, 1px); box-shadow: none; }
.btn-primary { 
  border-color: var(--accent); 
  color: var(--accent);
  background: rgba(212,160,23,0.1);
}
.btn-danger {
  border-color: var(--danger);
  color: var(--danger);
  background: rgba(204,68,68,0.1);
}
.btn-attack {
  width: 100%;
  padding: 14px;
  background: rgba(204,68,68,0.15);
  border-color: var(--danger);
  color: var(--danger);
  font-size: 16px;
  font-weight: bold;
  margin-top: 8px;
}
.btn-small {
  padding: 4px 10px;
  font-size: 12px;
  background: var(--card);
  color: var(--text-dim);
  border: 1px solid var(--border);
  border-radius: 3px;
  cursor: pointer;
  font-family: inherit;
}
.btn-small:hover { color: var(--accent); border-color: var(--accent); }

.btns { text-align: center; margin: 12px 0; display: flex; flex-wrap: wrap; gap: 8px; justify-content: center; }

/* ═══════════════════════════════════════════════════════════
   ORIGIN CARDS - Parchment cards
   ═══════════════════════════════════════════════════════════ */

.origin-card {
  background: var(--card);
  border: 2px solid var(--border);
  border-radius: 8px;
  padding: 16px;
  margin: 8px 0;
  cursor: pointer;
  transition: all 0.2s;
  position: relative;
}
.origin-card:hover {
  border-color: var(--accent);
  box-shadow: 0 0 12px rgba(212,160,23,0.15);
}
.origin-emoji {
  font-size: 28px;
  text-align: center;
  margin-bottom: 4px;
}
.origin-name {
  font-size: 18px;
  font-weight: bold;
  color: var(--accent);
  text-align: center;
}
.origin-attrs {
  font-size: 12px;
  text-align: center;
  color: var(--text-dim);
  margin: 4px 0;
}
.origin-skill {
  font-size: 12px;
  text-align: center;
  color: var(--sketch);
}
.origin-story {
  line-height: 1.8;
  font-size: 14px;
  font-style: italic;
  color: var(--text);
  margin: 12px 0;
  padding: 12px;
  background: var(--card);
  border-left: 3px solid var(--accent);
  border-radius: 4px;
}

/* ═══════════════════════════════════════════════════════════
   NAME & ATTRIBUTE ALLOCATION
   ═══════════════════════════════════════════════════════════ */

.name-section {
  margin: 12px 0;
  display: flex;
  gap: 8px;
  align-items: center;
}
.name-section input {
  flex: 1;
  padding: 8px 12px;
  background: var(--card);
  border: 2px solid var(--border);
  border-radius: 4px;
  color: var(--text);
  font-size: 14px;
  font-family: inherit;
}
.name-section input:focus { border-color: var(--accent); outline: none; }

.attr-row-v5 {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px 0;
  border-bottom: 1px solid var(--border);
}
.attr-info { display: flex; flex-direction: column; }
.attr-name-v5 { font-size: 14px; font-weight: bold; }
.attr-hint-v5 { font-size: 11px; color: var(--text-dim); }
.attr-controls { display: flex; align-items: center; gap: 8px; }
.attr-btn {
  width: 44px; height: 44px;
  background: var(--card);
  border: 2px solid var(--border);
  border-radius: 50%;
  color: var(--text);
  font-size: 20px;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: inherit;
}
.attr-btn:hover:not(:disabled) { border-color: var(--accent); color: var(--accent); }
.attr-btn:disabled { opacity: 0.3; cursor: not-allowed; }
.attr-value { font-size: 16px; min-width: 50px; text-align: center; }
.attr-boosted { color: var(--accent); font-weight: bold; }
.pts-remaining { text-align: center; font-size: 14px; margin: 8px 0; }
.pts-num { color: var(--accent); font-weight: bold; font-size: 18px; }

/* ═══════════════════════════════════════════════════════════
   WORLD MAP
   ═══════════════════════════════════════════════════════════ */

.world-map {
  width: 100%;
  aspect-ratio: 1;
  margin: 12px 0;
  border: 2px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
}
.world-svg {
  width: 100%;
  height: 100%;
}
.map-actions { margin: 12px 0; text-align: center; }
.current-loc {
  font-size: 14px;
  margin-bottom: 8px;
  color: var(--text-dim);
}

/* ═══════════════════════════════════════════════════════════
   MINI-MAP
   ═══════════════════════════════════════════════════════════ */

.mini-area {
  background: var(--card);
  border: 2px solid var(--border);
  border-radius: 6px;
  padding: 12px;
  margin: 8px 0;
}
.mini-area-name {
  font-size: 16px;
  font-weight: bold;
  color: var(--accent);
  margin-bottom: 4px;
}
.mini-area-desc {
  font-size: 13px;
  color: var(--text-dim);
  font-style: italic;
  line-height: 1.6;
}
.mini-map-grid {
  margin: 8px 0;
  overflow: hidden;
  -webkit-overflow-scrolling: touch;
  touch-action: manipulation;
}
.mini-directions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8px;
  margin: 8px 0;
}
.dir-btn {
  padding: 10px;
  background: var(--card);
  border: 2px solid var(--border);
  border-radius: 4px;
  color: var(--text);
  font-size: 14px;
  cursor: pointer;
  font-family: inherit;
}
.dir-btn:hover:not(.disabled) { border-color: var(--accent); color: var(--accent); }
.dir-btn.disabled { opacity: 0.3; cursor: not-allowed; }
.mini-actions { margin: 8px 0; text-align: center; }
.mini-msg {
  text-align: center;
  color: var(--accent);
  font-style: italic;
  margin-bottom: 8px;
}

/* ═══════════════════════════════════════════════════════════
   BATTLE - 炎龙骑士团2风格战斗界面
   ═══════════════════════════════════════════════════════════ */

.battle-scene {
  width: 100%;
  margin: 0 auto;
  background: #0a0a08;
  border: 2px solid #5a4a3a;
  border-radius: 4px;
  overflow: hidden;
}
.battle-svg {
  width: 100%;
  display: block;
}

/* Dialog box - DOS-style text window */
.battle-dialog {
  background: #0a0a08;
  border: 2px solid #5a4a3a;
  border-top: none;
  padding: 6px 10px;
  font-size: 12px;
  line-height: 1.6;
  color: #c8c0a0;
  min-height: 50px;
  font-family: 'Noto Serif SC', serif;
}
.dialog-border {
  border: 1px solid #3a3228;
  padding: 4px 8px;
  border-radius: 2px;
}

/* Battle menu - DOS-style action buttons */
.battle-menu {
  margin-top: 4px;
}
.menu-row {
  display: flex;
  gap: 4px;
  margin-bottom: 4px;
}
.menu-btn {
  flex: 1;
  background: #1a1810;
  border: 1px solid #5a4a3a;
  color: #c8c0a0;
  padding: 8px 4px;
  font-size: 13px;
  font-family: 'Noto Serif SC', serif;
  cursor: pointer;
  border-radius: 2px;
  transition: all 0.15s;
  text-align: center;
  position: relative;
}
.menu-btn:hover:not(.disabled) {
  border-color: #d4a017;
  color: #d4a017;
  background: rgba(212,160,23,0.08);
}
.menu-btn.active {
  border-color: #d4a017;
  color: #d4a017;
  background: rgba(212,160,23,0.15);
  box-shadow: inset 0 0 8px rgba(212,160,23,0.1);
}
.menu-btn.disabled {
  opacity: 0.3;
  cursor: not-allowed;
}
.mp-cost {
  font-size: 10px;
  color: #6688cc;
  margin-left: 4px;
}

.hint-text {
  text-align: center;
  color: #888;
  font-size: 12px;
  padding: 6px;
  border: 1px dashed #444;
  border-radius: 2px;
}

/* Legacy display:none removed — real styles defined below */

/* Player panel */
.player-panel {
  background: var(--card);
  border: 2px solid var(--border);
  border-radius: 6px;
  padding: 10px;
  margin: 8px 0;
}
.player-name {
  font-size: 14px;
  font-weight: bold;
  color: var(--accent);
  margin-bottom: 6px;
}

.player-stat {
  display: flex;
  align-items: center;
  gap: 6px;
  margin: 4px 0;
}
.stat-label {
  font-size: 12px;
  min-width: 40px;
  color: var(--text-dim);
}
.stat-bar {
  flex: 1;
  height: 10px;
  background: #333;
  border-radius: 5px;
  overflow: hidden;
  border: 1px solid #444;
}
.stat-fill {
  height: 100%;
  border-radius: 5px;
  transition: width 0.3s;
}
.stat-fill.hp { background: linear-gradient(90deg, #c44, #a33); }
.stat-fill.mp { background: linear-gradient(90deg, #48a, #368); }
.stat-fill.xp { background: linear-gradient(90deg, #4a4, #383); }
.stat-value {
  font-size: 11px;
  color: var(--text-dim);
  min-width: 60px;
  text-align: right;
}

/* Battle log */
.battle-log {
  background: rgba(0,0,0,0.3);
  border: 1px solid var(--border);
  border-radius: 4px;
  padding: 8px;
  margin: 6px 0;
  font-size: 12px;
  line-height: 1.6;
  max-height: 80px;
  overflow-y: auto;
}

/* Battle controls */
.battle-controls {
  margin: 8px 0;
}
.controls-label {
  font-size: 11px;
  color: var(--text-dim);
  margin-bottom: 4px;
}
.attack-modes {
  display: flex;
  flex-wrap: wrap;
  gap: 4px;
  margin: 4px 0;
}
.mode-btn {
  padding: 6px 10px;
  background: var(--card);
  border: 2px solid var(--border);
  border-radius: 4px;
  color: var(--text);
  font-size: 12px;
  cursor: pointer;
  font-family: inherit;
}
.mode-btn:hover:not(.disabled) { border-color: var(--accent); color: var(--accent); }
.mode-btn.active { border-color: var(--accent); color: var(--accent); background: rgba(212,160,23,0.1); }
.mode-btn.disabled { opacity: 0.3; cursor: not-allowed; }

/* Battle result */
.battle-result {
  text-align: center;
  font-size: 20px;
  font-weight: bold;
  padding: 16px;
  margin: 8px 0;
}
.battle-result.win { color: var(--xp); }
.battle-result.lose { color: var(--danger); }

/* Damage text */
.dmg-crit { color: #e84; font-weight: bold; }
.crit-text { color: #fa0; }

/* ═══════════════════════════════════════════════════════════
   TOWN
   ═══════════════════════════════════════════════════════════ */

/* Town panorama SVG */
.town-panorama {
  margin: 4px 0 8px;
  border: 2px solid #3a3228;
  border-radius: 6px;
  overflow: hidden;
  background: #1a1820;
}
.town-svg {
  width: 100%;
  height: auto;
  display: block;
}
.bld-clickable:hover {
  filter: url(#bldGlow);
  opacity: 0.9;
}
.bld-clickable:active {
  opacity: 0.7;
}

/* Damage popup */
.dmg-popup {
  font-size: 20px;
  font-weight: bold;
  color: #ef4444;
  text-shadow: 0 0 4px #000, 0 0 8px #f00;
  pointer-events: none;
  animation: dmgFloat 0.8s ease-out forwards;
  z-index: 100;
}
.dmg-popup-crit {
  font-size: 26px;
  color: #fbbf24;
  text-shadow: 0 0 6px #000, 0 0 12px #fa0;
}
@keyframes dmgFloat {
  0% { opacity: 1; transform: translateY(0); }
  100% { opacity: 0; transform: translateY(-30px); }
}

/* Drop items */
.drop-list {
  color: #d4a017;
  font-weight: bold;
  margin-top: 6px;
}
.drop-item {
  color: #9ca3af;
  padding: 2px 4px;
}
.drop-common { color: #9ca3af; }
.drop-uncommon { color: #22c55e; }
.drop-rare { color: #3b82f6; }
.drop-epic { color: #a855f7; }
.drop-legendary { color: #ff8000; text-shadow: 0 0 6px #ff800055; }

.dmg-player { color: #ef4444; font-weight: bold; }

.town-desc {
  text-align: center;
  color: var(--text-dim);
  font-style: italic;
  margin-bottom: 4px;
}
.town-panorama {
  margin: 8px 0;
  border: 2px solid var(--border);
  border-radius: 6px;
  overflow: hidden;
  background: #1a1820;
}
.town-svg {
  width: 100%;
  display: block;
}
.bld-clickable:hover {
  filter: url(#bldGlow);
  opacity: 0.9;
}
.building:hover { border-color: var(--accent); }
.build-icon { font-size: 28px; margin-bottom: 4px; }
.build-name { font-size: 14px; font-weight: bold; color: var(--text); }
.build-desc { font-size: 11px; color: var(--text-dim); }

/* Damage popup */
.dmg-popup {
  font-size: 20px;
  font-weight: bold;
  color: #ff4444;
  pointer-events: none;
  animation: dmgFloat 0.8s ease-out forwards;
  z-index: 100;
  text-shadow: 0 0 4px #000, 0 0 8px #ff0000;
}
.dmg-popup-crit {
  font-size: 26px;
  color: #ffaa00;
  text-shadow: 0 0 6px #000, 0 0 12px #ffaa00;
}
@keyframes dmgFloat {
  0% { transform: translateY(0); opacity: 1; }
  100% { transform: translateY(-40px); opacity: 0; }
}
.dmg-player { color: #ff6b6b; font-weight: bold; }

/* Drop items */
.drop-list { margin-top: 6px; color: #d4a017; font-weight: bold; }
.drop-item { padding: 2px 0; font-size: 12px; }
.drop-common { color: #9ca3af; }
.drop-uncommon { color: #22c55e; }
.drop-rare { color: #3b82f6; }
.drop-epic { color: #a855f7; }
.drop-legendary { color: #ff8000; text-shadow: 0 0 6px #ff800055; }

/* Inn */
.inn-desc { color: var(--text-dim); font-style: italic; margin-bottom: 8px; }
.inn-service { padding: 8px; background: var(--card); border-radius: 4px; margin: 8px 0; }
.inn-service p { margin: 4px 0; }

/* Shop */
.money-display { text-align: center; font-size: 16px; color: var(--accent); margin-bottom: 8px; }
.shop-items { margin: 8px 0; }
.shop-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 4px;
  margin: 4px 0;
  cursor: pointer;
  transition: all 0.2s;
}
.shop-item:hover { border-color: var(--accent); }
.item-name { font-size: 14px; }
.item-stats { font-size: 12px; color: var(--text-dim); }
.item-price { color: var(--accent); font-size: 14px; }

/* Tavern */
.tavern-desc { color: var(--text-dim); font-style: italic; margin-bottom: 8px; }
.rumor {
  background: var(--card);
  border-left: 3px solid var(--accent);
  padding: 10px;
  margin: 8px 0;
  font-style: italic;
  color: var(--text);
}

/* Smith */
.smith-desc { color: var(--text-dim); font-style: italic; margin-bottom: 8px; }

/* ═══════════════════════════════════════════════════════════
   INVENTORY
   ═══════════════════════════════════════════════════════════ */

.equip-section { margin: 8px 0; }
.equip-title { font-size: 14px; font-weight: bold; color: var(--accent); margin-bottom: 6px; }
.equip-grid { display: grid; gap: 6px; }
.equip-slot {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 4px;
}
.slot-name { font-size: 13px; color: var(--text-dim); }
.equipped-item { font-size: 14px; color: var(--text); }
.empty-slot { font-size: 13px; color: #555; }
.inv-section { margin: 12px 0; }
.inv-title { font-size: 14px; font-weight: bold; color: var(--accent); margin-bottom: 6px; }
.inv-empty { text-align: center; color: #555; padding: 12px; font-style: italic; }
.keys-display { text-align: center; font-size: 13px; color: var(--text-dim); margin: 8px 0; }

/* ═══════════════════════════════════════════════════════════
   PLAYER INFO
   ═══════════════════════════════════════════════════════════ */

.player-basic {
  text-align: center;
  padding: 12px;
  background: var(--card);
  border: 2px solid var(--border);
  border-radius: 6px;
  margin-bottom: 12px;
}
.basic-name { font-size: 20px; font-weight: bold; color: var(--accent); }
.basic-origin { font-size: 14px; color: var(--text-dim); margin: 4px 0; }
.basic-level { font-size: 13px; color: var(--text-dim); }

.skills-display { margin: 8px 0; }
.skills-title { font-size: 14px; font-weight: bold; color: var(--accent); margin-bottom: 4px; }
.skills-list { display: flex; flex-wrap: wrap; gap: 4px; }
.skill-tag {
  padding: 4px 8px;
  background: rgba(72,136,170,0.15);
  border: 1px solid #48a;
  border-radius: 12px;
  font-size: 12px;
  color: #6ac;
}
.skills-empty { color: #555; font-style: italic; }

.origin-skill-display {
  margin: 8px 0;
  padding: 8px;
  background: var(--card);
  border-left: 3px solid var(--accent2);
  border-radius: 4px;
}
.origin-title { font-size: 12px; color: var(--text-dim); margin-bottom: 4px; }
.origin-skill { font-size: 14px; font-weight: bold; color: var(--accent2); }
.origin-desc { font-size: 12px; color: var(--text-dim); margin-top: 2px; }

.attr-allocation { margin: 12px 0; }
.attr-header { margin-bottom: 8px; font-size: 14px; }
.attr-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr 1fr;
  gap: 6px;
}
.attr-block {
  text-align: center;
  padding: 8px 4px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 4px;
}
.attr-n { display: block; font-size: 11px; color: var(--text-dim); }
.attr-v { display: block; font-size: 18px; font-weight: bold; color: var(--text); margin-top: 2px; }

.derived-stats { margin: 12px 0; }
.der-title { font-size: 14px; font-weight: bold; color: var(--accent); margin-bottom: 4px; }
.der-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4px;
}
.der-item {
  padding: 6px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 4px;
  font-size: 12px;
}

.reselect-section { text-align: center; margin: 12px 0; }

/* Victory */
.victory-rewards {
  text-align: center;
  padding: 12px;
  background: var(--card);
  border: 2px solid var(--accent);
  border-radius: 6px;
  margin: 8px 0;
  font-size: 16px;
}
.victory-rewards div { margin: 4px 0; }

/* Death */
.death-msg {
  text-align: center;
  font-size: 16px;
  font-style: italic;
  color: var(--danger);
  margin: 12px 0;
}
.loss-info {
  text-align: center;
  padding: 8px;
  background: var(--card);
  border-radius: 4px;
  margin: 8px 0;
  color: var(--text-dim);
}

/* Skill detail */
.skill-detail {
  padding: 10px;
  background: var(--card);
  border: 1px solid var(--accent);
  border-radius: 6px;
  margin: 8px 0;
}
.skill-name { font-size: 16px; font-weight: bold; color: var(--accent2); }
.skill-meta { font-size: 12px; color: var(--text-dim); }
.skill-desc { font-size: 13px; color: var(--text); margin-top: 4px; }

.pts-info { text-align: center; margin: 8px 0; font-size: 14px; }
.pts-info strong { color: var(--accent); font-size: 18px; }

/* ═══════════════════════════════════════════════════════════
   BUILDING SVG ART
   ═══════════════════════════════════════════════════════════ */

.build-art {
  width: 60px;
  height: 50px;
  margin: 0 auto 4px;
}
.build-svg {
  width: 100%;
  height: 100%;
}

/* ═══════════════════════════════════════════════════════════
   GUILD & QUESTS
   ═══════════════════════════════════════════════════════════ */

.guild-desc {
  color: var(--text-dim);
  font-style: italic;
  margin-bottom: 12px;
  text-align: center;
}

.quest-list-title {
  font-size: 14px;
  font-weight: bold;
  color: var(--accent);
  margin: 12px 0 6px;
  padding-bottom: 4px;
  border-bottom: 1px solid var(--border);
}

.quest-card {
  padding: 10px;
  background: var(--card);
  border: 2px solid var(--border);
  border-radius: 6px;
  margin: 6px 0;
  cursor: pointer;
  transition: all 0.2s;
}
.quest-card:hover {
  border-color: var(--accent);
}
.quest-card.active-quest {
  border-color: var(--accent);
  background: rgba(212,160,23,0.08);
  cursor: default;
}
.quest-card.accepted {
  opacity: 0.7;
  cursor: default;
}
.quest-header {
  font-size: 15px;
  font-weight: bold;
  color: var(--text);
  margin-bottom: 4px;
}
.quest-desc {
  font-size: 13px;
  color: var(--text-dim);
  margin-bottom: 4px;
}
.quest-reward {
  font-size: 12px;
  color: var(--xp);
}
.quest-accept-hint {
  font-size: 11px;
  color: var(--accent);
  text-align: right;
  margin-top: 4px;
}
.quest-badge {
  display: inline-block;
  padding: 2px 6px;
  border-radius: 8px;
  font-size: 10px;
  font-weight: bold;
  vertical-align: middle;
}
.quest-badge.active {
  background: rgba(212,160,23,0.2);
  color: var(--accent);
  border: 1px solid var(--accent);
}
.quest-badge.done {
  background: rgba(74,170,74,0.15);
  color: var(--xp);
  border: 1px solid var(--xp);
}

.active-quest-banner {
  text-align: center;
  padding: 8px;
  background: rgba(212,160,23,0.08);
  border: 1px solid var(--accent);
  border-radius: 6px;
  margin: 8px 0;
  font-size: 13px;
  color: var(--accent);
  cursor: pointer;
}
.active-quest-banner:hover {
  background: rgba(212,160,23,0.15);
}

/* ═══════════════════════════════════════════════════════════
   INVENTORY ITEMS LIST
   ═══════════════════════════════════════════════════════════ */

.inv-list {
  margin: 4px 0;
}
.inv-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8px;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 4px;
  margin: 4px 0;
}
.inv-item-info {
  display: flex;
  flex-direction: column;
}
.inv-item-name {
  font-size: 14px;
  color: var(--text);
}
.inv-item-stats {
  font-size: 12px;
  color: var(--text-dim);
}
/* Grid map styles */
.mini-controls {
  margin: 8px 0;
}
.move-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 6px;
  margin: 10px auto;
  max-width: 240px;
}
.move-btn {
  padding: 10px 6px;
  background: var(--card);
  border: 2px solid var(--border);
  color: var(--text);
  border-radius: 6px;
  cursor: pointer;
  font-size: 14px;
  transition: all 0.15s;
  text-align: center;
}
.move-btn:hover:not(:disabled) {
  border-color: var(--accent);
  background: var(--card-hover);
}
.move-btn:disabled {
  opacity: 0.3;
  cursor: not-allowed;
}
.move-center {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20px;
  color: var(--accent);
}
/* D2: Map experience enhancements */
.mini-radar {
  display: flex;
  flex-wrap: wrap;
  gap: 4px 8px;
  padding: 8px 10px;
  background: rgba(0,0,0,0.3);
  border: 1px solid #2a2a25;
  border-radius: 6px;
  margin: 6px 0;
  font-size: 0.8em;
}
.mini-radar-item {
  display: flex;
  align-items: center;
  gap: 3px;
  color: #aaa;
  cursor: pointer;
  padding: 2px 6px;
  border-radius: 4px;
  transition: background 0.15s;
}
.mini-radar-item:hover { background: rgba(212,160,23,0.12); color: #d4a017; }
.mini-radar-item .dir { color: #d4a017; font-weight: bold; font-size: 0.9em; }
.mini-compass {
  display: grid;
  grid-template-areas: ". n ." "w c e" ". s .";
  grid-template-columns: 1fr 1fr 1fr;
  gap: 2px;
  width: 120px;
  margin: 6px auto;
}
.mini-compass-cell {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75em;
  padding: 4px;
  border-radius: 4px;
  color: #555;
  background: transparent;
}
.mini-compass-cell.active { color: #d4a017; font-weight: bold; }
.mini-compass-cell.poi { color: #2ecc71; }
.mini-compass-cell.danger { color: #e74c3c; }
.mini-compass-cell.center { color: #d4a017; font-size: 1.2em; }
.map-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 6px 12px;
  padding: 8px 10px;
  background: rgba(0,0,0,0.2);
  border: 1px solid #222;
  border-radius: 6px;
  margin: 6px 0;
  font-size: 0.75em;
  color: #777;
}
.map-legend-item { display: flex; align-items: center; gap: 4px; }
.mini-path-hint {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 6px 10px;
  background: rgba(212,160,23,0.06);
  border: 1px solid rgba(212,160,23,0.15);
  border-radius: 6px;
  margin: 4px 0;
  font-size: 0.8em;
  color: #d4a017;
  cursor: pointer;
}
.mini-path-hint:hover { background: rgba(212,160,23,0.12); }
.mini-path-hint .arrow { font-size: 1.1em; }
.mini-weather-bar {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 4px 8px;
  background: rgba(0,0,0,0.2);
  border-radius: 4px;
  font-size: 0.8em;
  color: #888;
  margin: 4px 0;
}
.loc-tag {
  display: inline-block;
  padding: 1px 6px;
  border-radius: 3px;
  font-size: 0.7em;
  margin-left: 4px;
}
.loc-tag.town { background: rgba(46,204,113,0.15); color: #2ecc71; }
.loc-tag.dungeon { background: rgba(231,76,60,0.15); color: #e74c3c; }
.loc-tag.wild { background: rgba(52,152,219,0.15); color: #3498db; }
.loc-tag.explored { background: rgba(212,160,23,0.12); color: #d4a017; }
.loc-tag.unexplored { background: rgba(100,100,100,0.15); color: #666; }
/* Level up */
.level-up-info {
  text-align: center;
  padding: 20px;
}
.level-up-level {
  font-size: 36px;
  color: var(--accent);
  font-weight: bold;
  margin: 10px 0;
}
.level-up-multi {
  font-size: 16px;
  color: #f80;
  margin: 5px 0;
}
.level-up-rewards {
  margin-top: 15px;
  font-size: 15px;
  color: var(--text-dim);
}
.level-up-rewards div {
  margin: 4px 0;
}
/* Mini map grid bigger */
.mini-svg {
  /* No max-height — SVG renders at native size for consistent cell display */
}

/* Story system */
.story-entry {
  background: #1e1e1e;
  border-left: 3px solid #d4a017;
  padding: 12px 16px;
  margin: 8px 0;
  border-radius: 0 6px 6px 0;
  font-style: italic;
  color: #c8c0a8;
  line-height: 1.6;
}
.story-objectives {
  margin: 12px 0;
}
.story-obj-title {
  font-weight: bold;
  color: #d4a017;
  margin-bottom: 6px;
}
.story-obj {
  padding: 6px 10px;
  margin: 3px 0;
  border-radius: 4px;
  background: #252525;
  color: #aaa;
}
.story-obj.obj-done {
  color: #4a4;
  text-decoration: line-through;
  background: #1a2a1a;
}
.chapter-complete {
  text-align: center;
  padding: 20px;
}
.chapter-title {
  font-size: 1.3em;
  color: #d4a017;
  margin-bottom: 10px;
}
.chapter-reward {
  color: #8a8;
  margin: 8px 0;
}
.chapter-next {
  color: #aaa;
  margin-top: 10px;
}

/* Attribute tooltip */
.attr-tooltip {
  background: #2a2a2a;
  border: 1px solid #444;
  border-radius: 8px;
  padding: 12px;
  margin: 8px 0;
  animation: fadeIn 0.2s;
}
.attr-tooltip-header {
  font-size: 1.1em;
  font-weight: bold;
  margin-bottom: 6px;
}
.attr-tooltip-desc {
  color: #bbb;
  margin-bottom: 6px;
  line-height: 1.5;
}
.attr-tooltip-affects {
  color: #999;
  font-size: 0.9em;
}
@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-4px); }
  to { opacity: 1; transform: translateY(0); }
}
/* Chapter intro cinematic */
.chapter-intro {
  background: linear-gradient(135deg, #1a1510 0%, #2a2218 50%, #1a1510 100%);
  border: 2px solid #5a4a3a;
  border-radius: 8px;
  padding: 20px 16px;
  min-height: 300px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.chapter-intro-inner {
  max-width: 400px;
  text-align: center;
}
.chapter-intro-title {
  font-size: 14px;
  color: #8a7a5a;
  letter-spacing: 4px;
  margin-bottom: 4px;
  font-family: 'Noto Serif SC', serif;
}
.chapter-intro-sub {
  font-size: 22px;
  font-weight: bold;
  color: #d4a017;
  margin-bottom: 12px;
  font-family: 'Noto Serif SC', serif;
}
.chapter-divider {
  color: #5a4a3a;
  font-size: 12px;
  margin: 10px 0;
}
.chapter-quote {
  font-style: italic;
  color: #9a8a6a;
  font-size: 12px;
  line-height: 1.8;
  margin-bottom: 4px;
  font-family: 'Noto Serif SC', serif;
}
.chapter-narration {
  color: #c8c0a0;
  font-size: 13px;
  line-height: 1.9;
  text-align: left;
  font-family: 'Noto Serif SC', serif;
}

/* NPC dialog */
.npc-dialog {
  background: #0e0e0c;
  border: 2px solid #5a4a3a;
  border-radius: 6px;
  padding: 16px;
}
.npc-list {
  margin-bottom: 12px;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.npc-list .btn {
  text-align: left;
  font-size: 12px;
  padding: 6px 10px;
}
.npc-portrait {
  font-size: 36px;
  text-align: center;
  margin-bottom: 6px;
}
.npc-name {
  text-align: center;
  font-size: 14px;
  font-weight: bold;
  color: #d4a017;
  margin-bottom: 10px;
  font-family: 'Noto Serif SC', serif;
  border-bottom: 1px solid #3a3228;
  padding-bottom: 6px;
}
.npc-text {
  color: #c8c0a0;
  font-size: 13px;
  line-height: 1.8;
  margin-bottom: 12px;
  padding: 8px;
  background: rgba(90,74,58,0.1);
  border-radius: 4px;
  border-left: 3px solid #5a4a3a;
  font-family: 'Noto Serif SC', serif;
}

/* === TEXT MODE - WORLD MAP === */
.location-list { display:flex; flex-direction:column; gap:8px; margin:10px 0; }
.loc-card { display:flex; align-items:center; gap:12px; padding:12px; background:var(--card); border:2px solid var(--border); border-radius:8px; transition:all 0.2s; }
.loc-card:hover { border-color:var(--accent); background:rgba(212,160,23,0.08); }
.loc-card.loc-current { border-color:var(--accent); background:rgba(212,160,23,0.12); }
.loc-card.loc-locked { opacity:0.5; cursor:not-allowed !important; }
.loc-emoji { font-size:32px; width:48px; text-align:center; }
.loc-info { flex:1; }
.loc-name { font-size:15px; font-weight:bold; color:var(--text); }
.loc-here { font-size:11px; color:var(--accent); margin-left:6px; }
.loc-desc { font-size:12px; color:var(--muted); margin-top:2px; }
.loc-type { font-size:11px; color:var(--muted); margin-top:2px; }

/* === TEXT MODE - TOWN === */
.town-desc { font-size:13px; color:var(--muted); text-align:center; margin-bottom:10px; }
.building-list { display:flex; flex-direction:column; gap:8px; margin:10px 0; }
.bld-card { display:flex; align-items:center; gap:12px; padding:12px; background:var(--card); border:2px solid var(--border); border-radius:8px; transition:all 0.2s; cursor:pointer; }
.bld-card:hover { border-color:var(--accent); background:rgba(212,160,23,0.08); }
.bld-emoji { font-size:28px; width:44px; text-align:center; }
.bld-info { flex:1; }
.bld-name { font-size:14px; font-weight:bold; color:var(--text); }
.bld-desc { font-size:12px; color:var(--muted); margin-top:2px; }
.bld-arrow { font-size:20px; color:var(--muted); }

/* === TEXT MODE - BATTLE === */
.battle-enemies { display:flex; gap:8px; justify-content:center; flex-wrap:wrap; margin:10px 0; }
.enemy-card { display:flex; align-items:center; gap:8px; padding:10px 14px; background:var(--card); border:2px solid #8b0000; border-radius:8px; min-width:140px; transition:all 0.2s; }
.enemy-card.enemy-selected { border-color:var(--accent); box-shadow:0 0 8px rgba(212,160,23,0.5); }
.enemy-card.enemy-dead { opacity:0.4; border-color:#555; filter:grayscale(0.8); animation:killFlash 0.4s ease-out; }
@keyframes killFlash { 0%{opacity:1;border-color:#ff0;box-shadow:0 0 12px rgba(255,0,0,0.5);} 50%{opacity:0.6;} 100%{opacity:0.4;} }
.enemy-emoji { font-size:28px; }
.enemy-info { flex:1; }
.enemy-name { font-size:13px; font-weight:bold; color:var(--danger); }
.enemy-card.enemy-dead .enemy-name { color:var(--muted); }
.enemy-hp-bar { width:100%; height:6px; background:#333; border-radius:3px; overflow:hidden; margin-top:3px; }
.enemy-hp-fill { height:100%; transition:width 0.4s ease-out; border-radius:3px; }
.enemy-hp-fill.hp-high { background: linear-gradient(90deg,#16a34a,#22c55e); transition: width 0.3s ease; }
.enemy-hp-fill.hp-mid { background: linear-gradient(90deg,#ca8a04,#eab308); transition: width 0.3s ease; }
.enemy-hp-fill.hp-low { background: linear-gradient(90deg,#dc2626,#ef4444); transition: width 0.3s ease; }
.enemy-hp-fill.hp-critical { background: linear-gradient(90deg,#991b1b,#dc2626); animation: hpPulse 0.8s infinite; transition: width 0.3s ease; }
@keyframes hpPulse { 0%,100%{opacity:1;} 50%{opacity:0.5;} }
.enemy-hp-text { font-size:10px; color:var(--muted); margin-top:1px; }
.enemy-target-arrow { color:var(--accent); font-size:16px; margin-left:4px; animation:arrowPulse 1s infinite; }
.enemy-intent { font-size:0.7em; color:#999; margin:1px 0; padding:1px 4px; background:rgba(0,0,0,0.2); border-radius:3px; display:inline-block; }
.enemy-status { font-size:0.75em; margin:1px 0; color:#bbb; }
@keyframes arrowPulse { 0%,100%{opacity:1;} 50%{opacity:0.3;} }

.battle-player { margin:10px 0; padding:10px; background:var(--card); border:2px solid var(--accent); border-radius:8px; }
.player-name { font-size:14px; font-weight:bold; color:var(--accent); margin-bottom:6px; }
.player-bars { display:flex; flex-direction:column; gap:4px; }
.player-bar-row { display:flex; align-items:center; gap:8px; font-size:12px; }
.bar-label { width:20px; text-align:center; }
.player-hp-bar, .player-mp-bar { flex:1; height:10px; background:#333; border-radius:5px; overflow:hidden; }
.player-hp-fill { height:100%; background:var(--danger); transition:width 0.4s ease-out; border-radius:5px; }
.player-hp-fill.hp-high { background: linear-gradient(90deg,#16a34a,#22c55e); transition: width 0.3s ease; }
.player-hp-fill.hp-mid { background: linear-gradient(90deg,#ca8a04,#eab308); transition: width 0.3s ease; }
.player-hp-fill.hp-low { background: linear-gradient(90deg,#dc2626,#ef4444); transition: width 0.3s ease; }
.player-hp-fill.hp-critical { background: linear-gradient(90deg,#991b1b,#dc2626); animation: hpPulse 0.8s infinite; transition: width 0.3s ease; }
.player-mp-fill { height:100%; background:linear-gradient(90deg,#1565c0,#1e88e5); transition:width 0.4s ease-out; border-radius:5px; }
.player-mp-low { animation: mpWarnPulse 1s infinite; }
@keyframes mpWarnPulse { 0%,100%{background:linear-gradient(90deg,#1565c0,#1e88e5);} 50%{background:linear-gradient(90deg,#7c3aed,#a855f7);} }
.bar-val { font-size:11px; color:var(--muted); min-width:70px; text-align:right; }
.player-stats-inline { font-size:12px; color:var(--text); margin-top:6px; }

.battle-log { margin:10px 0; padding:8px; background:rgba(0,0,0,0.3); border-radius:6px; max-height:120px; overflow-y:auto; font-size:12px; scroll-behavior:smooth; }
.log-entry { padding:2px 0; border-bottom:1px solid rgba(255,255,255,0.05); }
.log-entry:last-child { color:var(--accent); font-weight:bold; }

.battle-result { margin:10px 0; padding:14px; border-radius:8px; text-align:center; }
.battle-result.victory { background:rgba(46,204,113,0.15); border:2px solid var(--xp); }
.battle-result.defeat { background:rgba(231,76,60,0.15); border:2px solid var(--danger); }
.result-title { font-size:20px; font-weight:bold; margin-bottom:8px; }
.result-rewards { font-size:14px; color:var(--gold); margin:6px 0; }
.result-drops { margin:8px 0; font-size:13px; }
.drop-item { display:inline-block; margin:2px 6px 2px 0; padding:2px 8px; background:rgba(255,255,255,0.08); border-radius:4px; font-size:13px; }
.drop-item.drop-anim { opacity:0; animation:dropFlyIn 0.5s ease-out forwards; }
.drop-item.drop-common { color:#9ca3af; }
.drop-item.drop-uncommon { color:#22c55e; text-shadow:0 0 4px rgba(34,197,94,0.3); }
.drop-item.drop-rare { color:#3b82f6; text-shadow:0 0 6px rgba(59,130,246,0.4); }
.drop-item.drop-epic { color:#a855f7; text-shadow:0 0 8px rgba(168,85,247,0.5); }
.drop-item:hover { background:rgba(255,255,255,0.15); transform:scale(1.05); }
.result-desc { font-size:13px; color:var(--muted); margin:6px 0; }

.battle-actions { display:flex; gap:8px; flex-wrap:wrap; justify-content:center; margin:10px 0; }
.btn-atk { background:var(--danger); color:#fff; }
.btn-skill { background:var(--mp); color:#fff; }
.btn-flee { background:#555; color:#fff; }
.btn-disabled { opacity:0.4; cursor:not-allowed; }
.skill-cost { font-size:10px; opacity:0.7; margin-left:2px; }
.skill-cd { font-size:10px; color:#ff6b6b; font-weight:bold; margin-left:4px; }
.skill-cd-hint { font-size:9px; color:#888; margin-left:2px; }

/* === QUEST BANNER === */
.active-quest-banner { margin:10px 0; padding:8px 12px; background:rgba(212,160,23,0.12); border:1px solid var(--accent); border-radius:6px; font-size:12px; color:var(--accent); cursor:pointer; }

/* === LEVEL UP POPUP === */
.level-up { margin:8px 0; padding:8px; background:rgba(46,204,113,0.15); border:1px solid var(--xp); border-radius:6px; text-align:center; font-size:14px; color:var(--xp); font-weight:bold; }

/* === RESPONSIVE === */
@media (max-width: 480px) {
  .enemy-card { min-width:120px; padding:8px 10px; }
  .battle-actions { gap:5px; }
  .loc-card, .bld-card { padding:10px; gap:8px; }
}


/* ═══════════════════════════════════════════════════════════
   NEW ADDITIONS - Post-v5 features
   ═══════════════════════════════════════════════════════════ */

.attr-alloc { display: flex; align-items: center; justify-content: space-between; margin: 4px 0; }

.attr-alloc-btn { width: 28px; height: 28px; border-radius: 14px; border: 1px solid #3a4a5a; background: #1a2a3a; color: #d4a017; cursor: pointer; font-size: 16px; }

.attr-alloc-name { color: #d4a017; font-weight: bold; width: 30px; }

.attr-alloc-val { color: #e0d5c1; width: 30px; text-align: center; }

.attr-tooltip-title { color: #d4a017; font-weight: bold; margin-bottom: 4px; }

.battle-effect-layer { position: fixed; top: 30%; left: 50%; transform: translateX(-50%); z-index: 1000; pointer-events: none; }

/* === D1: Damage popup improvements === */
.dmg-popup { position:absolute; font-size:22px; font-weight:bold; color:#ff4444; pointer-events:none; animation:dmgFloat 0.9s ease-out forwards; z-index:2000; text-shadow: 1px 1px 2px rgba(0,0,0,0.8), 0 0 8px rgba(255,68,68,0.4); transform: translateX(-50%); white-space:nowrap; }
.dmg-popup-crit { font-size:32px; color:#ffcc00; text-shadow: 1px 1px 3px rgba(0,0,0,0.9), 0 0 12px rgba(255,204,0,0.6); animation:dmgCrit 1.0s ease-out forwards; }
.heal-popup { color:#22c55e !important; text-shadow: 1px 1px 2px rgba(0,0,0,0.8), 0 0 8px rgba(34,197,94,0.4) !important; }
.dmg-popup-dot { font-size:16px; color:#a855f7; }
.dmg-popup-miss { font-size:18px; color:#888; font-style:italic; }
@keyframes dmgFloat { 0%{opacity:1;transform:translateX(-50%) translateY(0) scale(1.3);} 30%{transform:translateX(-50%) translateY(-20px) scale(1.1);} 100%{opacity:0;transform:translateX(-50%) translateY(-60px) scale(0.8);} }
@keyframes dmgCrit { 0%{opacity:1;transform:translateX(-50%) translateY(0) scale(1.8);} 20%{transform:translateX(-50%) translateY(-10px) scale(1.4);} 100%{opacity:0;transform:translateX(-50%) translateY(-80px) scale(0.6);} }

/* === D1: Battle turn counter === */
.battle-turn-counter { display:flex; justify-content:space-between; align-items:center; padding:4px 8px; margin:4px 0; background:rgba(0,0,0,0.3); border-radius:4px; font-size:12px; color:var(--muted); }
.battle-turn-counter .turn-num { color:var(--accent); font-weight:bold; }
.battle-turn-counter .combo-num { color:#ff6b6b; font-weight:bold; }

/* === A3: Wave battle system === */
.wave-progress { font-size:1.1em; color:var(--accent); }
.wave-status { margin:15px 0; padding:10px; border:1px solid var(--border); border-radius:6px; }
.wave-next { margin:12px 0; padding:10px; background:rgba(0,0,0,0.3); border-radius:6px; border-left:3px solid var(--accent); }
.wave-next .wave-label { color:var(--accent); font-weight:bold; margin-bottom:6px; }

/* === D1: Player status effects bar === */
.player-status-bar { display:flex; gap:4px; flex-wrap:wrap; margin:4px 0; min-height:20px; }
.status-icon { display:inline-flex; align-items:center; gap:2px; padding:1px 6px; border-radius:3px; font-size:11px; background:rgba(0,0,0,0.3); border:1px solid rgba(255,255,255,0.1); transition:all 0.2s; }
.status-icon.buff { border-color:rgba(34,197,94,0.4); background:rgba(34,197,94,0.1); color:#86efac; }
.status-icon.debuff { border-color:rgba(239,68,68,0.4); background:rgba(239,68,68,0.1); color:#fca5a5; animation:debuffPulse 2s infinite; }
.status-icon .turns-left { font-size:9px; opacity:0.7; font-weight:bold; }
@keyframes debuffPulse { 0%,100%{opacity:1;} 50%{opacity:0.7;} }

/* === D1: Defending shield indicator === */
.player-defending { position:relative; }
.player-defending::after { content:'🛡️'; position:absolute; right:-4px; top:-4px; font-size:18px; animation:shieldPulse 1.5s infinite; }
@keyframes shieldPulse { 0%,100%{transform:scale(1);opacity:1;} 50%{transform:scale(1.15);opacity:0.7;} }
.player-low-hp { border-color:#dc2626 !important; animation:lowHpPulse 1.2s infinite; }
@keyframes lowHpPulse { 0%,100%{box-shadow:0 0 4px rgba(220,38,38,0.3);} 50%{box-shadow:0 0 16px rgba(220,38,38,0.7);} }

/* === D1: Enemy charging indicator === */
.enemy-charging { animation:enemyCharge 0.6s ease-in-out infinite; border-color:#ff6b00 !important; }
.battle-boss-frame { border:2px solid #8b0000; background:linear-gradient(180deg,rgba(139,0,0,0.15),transparent); border-radius:10px; padding:6px; margin:4px 0; position:relative; }
.battle-boss-frame::before { content:'👑 BOSS'; position:absolute; top:-10px; left:12px; background:var(--bg); padding:0 6px; font-size:11px; color:#ff4444; font-weight:bold; letter-spacing:2px; }
@keyframes enemyCharge { 0%,100%{box-shadow:0 0 4px rgba(255,107,0,0.3);} 50%{box-shadow:0 0 16px rgba(255,107,0,0.6);} }

/* === D1: Improved victory/defeat === */
.battle-result.victory { animation:victorySlide 0.5s ease-out; }
@keyframes victorySlide { 0%{opacity:0;transform:translateY(20px);} 100%{opacity:1;transform:translateY(0);} }
.battle-result.defeat { animation:defeatSlide 0.5s ease-out; }
@keyframes defeatSlide { 0%{opacity:0;transform:translateY(-10px);} 100%{opacity:1;transform:translateY(0);} }
.result-title.victory-title { animation:victoryGlow 1.5s ease-in-out infinite; }
.result-title.defeat-title { animation:defeatShake 0.6s ease-out; }
@keyframes defeatShake { 0%{transform:scale(0.8);opacity:0;} 25%{transform:scale(1.1) rotate(-2deg);} 50%{transform:scale(1.05) rotate(2deg);} 75%{transform:scale(1.02) rotate(-1deg);} 100%{transform:scale(1) rotate(0);opacity:1;} }
.drop-anim { opacity:0; animation:dropFlyIn 0.5s ease-out forwards; }
@keyframes dropFlyIn { 0%{opacity:0;transform:translateY(-20px) scale(0.8);} 100%{opacity:1;transform:translateY(0) scale(1);} }
.result-anim { animation:resultPulse 0.6s ease-out; }
@keyframes resultPulse { 0%{transform:scale(0.8);opacity:0;} 50%{transform:scale(1.1);} 100%{transform:scale(1);opacity:1;} }
.level-up-anim { animation:levelUpCelebration 0.8s ease-out; }
@keyframes levelUpCelebration { 0%{opacity:0;transform:scale(0.5) rotate(-5deg);} 50%{transform:scale(1.3) rotate(3deg);} 100%{opacity:1;transform:scale(1) rotate(0);} }
@keyframes victoryGlow { 0%,100%{text-shadow:0 0 8px rgba(46,204,113,0.4);} 50%{text-shadow:0 0 20px rgba(46,204,113,0.8);} }
.level-up { animation:levelUpBurst 0.8s ease-out; }
@keyframes levelUpBurst { 0%{opacity:0;transform:scale(0.5);} 50%{transform:scale(1.2);} 100%{opacity:1;transform:scale(1);} }
@keyframes battleStartFlash { 0%{opacity:1;} 100%{opacity:0;} }

/* === D1: Battle action button improvements === */
.battle-actions .btn { min-width:60px; position:relative; transition:all 0.15s; }
.battle-actions .btn:active { transform:scale(0.92); }
.battle-actions .btn:hover { filter:brightness(1.2); }
.battle-actions .btn.btn-atk { background:linear-gradient(135deg,#c62828,#b71c1c); }
.battle-actions .btn.btn-skill { background:linear-gradient(135deg,#1565c0,#0d47a1); }
.battle-actions .btn.btn-flee { background:linear-gradient(135deg,#555,#333); }
.skill-cd { font-size:10px; color:#ff6b6b; font-weight:bold; margin-left:4px; }
.skill-cd-hint { font-size:9px; color:#888; margin-left:2px; }
.battle-actions .btn.btn-disabled { filter:grayscale(0.6); }
.skill-cost { font-size:10px; opacity:0.7; margin-left:2px; }
.skill-meta-inline { font-size:9px; opacity:0.5; margin-left:1px; }

.battle-enemy { background: linear-gradient(135deg, #1a1a2e, #2a1a1a); border: 1px solid #4a2a2a; border-radius: 8px; padding: 12px; margin: 8px 0; text-align: center; }

.battle-enemy-desc { color: #888; font-size: 12px; }

.battle-enemy-name { font-weight: bold; color: #c62828; font-size: 16px; }

.battle-fx { text-align: center; animation: fxPop 0.5s ease-out forwards; }

.battle-log-entry { margin: 2px 0; }

.btn-sm { padding: 4px 10px; font-size: 12px; min-width: auto; }

.chapter-subtitle { color: #888; font-size: 14px; margin-top: 4px; }

.equip-slot-item { color: #e0d5c1; font-size: 13px; }

.equip-slot-name { color: #888; font-size: 13px; }

.fx-particle { display: inline-block; font-size: 28px; animation: fxBurst 0.5s ease-out forwards; opacity: 0; }

.hp-fill { background: #c62828; }

.mp-fill { background: #1565c0; }

.origin-skill-desc { color: #555; font-size: 11px; }

.rarity-common { color: #aaa; }

.rarity-epic { color: #a335ee; }

.rarity-legendary { color: #ff8000; }

.rarity-mythic { color: #e6cc80; }

.rarity-rare { color: #0070dd; }

.rarity-uncommon { color: #1eff00; }

.save-slot { background: rgba(255,255,255,0.04); border: 1px solid #2a3a4a; border-radius: 8px; padding: 12px; margin: 8px 0; }

.sdc-desc { font-size: 12px; color: #999; line-height: 1.4; }

.sdc-emoji { font-size: 18px; }

.sdc-header { display: flex; align-items: center; gap: 6px; }

.sdc-meta { font-size: 12px; color: #8a8a9a; margin: 2px 0; }

.sdc-name { color: #e0d5c1; font-weight: bold; font-size: 14px; flex: 1; }

.sdc-target { font-size: 11px; color: #8aa; background: rgba(100,150,150,0.15); padding: 1px 6px; border-radius: 8px; }

.selected { border-color: #d4a017; background: #1a2a3e; }

.skill-category { color: #d4a017; font-size: 14px; font-weight: bold; margin: 10px 0 6px; padding: 4px 0; border-bottom: 1px solid #2a2a4a; }

.skill-detail-card { background: rgba(255,255,255,0.04); border: 1px solid #2a3a4a; border-radius: 8px; padding: 8px 10px; transition: background 0.2s; }

.skill-detail-list { display: flex; flex-direction: column; gap: 6px; margin-bottom: 8px; }

.skill-group-label { font-size: 11px; color: #8a8a9a; margin: 4px 0 2px; padding-left: 4px; }

.skill-meta-inline { font-size: 10px; color: #8aa; }

.slot-btns { display: flex; gap: 8px; }

.slot-header { font-size: 16px; font-weight: bold; color: #d4a017; margin-bottom: 4px; }

.slot-info { font-size: 13px; color: #c4b998; }

.slot-time { font-size: 11px; color: #666; margin: 2px 0 8px; }

.stat-bar-fill { height: 100%; border-radius: 3px; }

.stat-item { font-size: 12px; color: #c4b998; }

.stat-item { font-size: 11px; }

.stat-row { display: flex; flex-wrap: wrap; gap: 6px; align-items: center; }

.tab-bar { display: flex; gap: 0; margin: 8px 0; }

.tab-btn { flex: 1; padding: 6px; text-align: center; background: #1a1a2e; color: #888; border: 1px solid #2a2a4a; cursor: pointer; font-size: 13px; }

.toast-show { display: block !important; animation: toastFade 2s ease-out; }

.xp-fill { background: #2e7d32; }

@keyframes toastFade { 0% { opacity: 1; } 100% { opacity: 0; } }

@keyframes fxPop { 0% { transform: scale(0.3); opacity: 0; } 100% { transform: scale(1); opacity: 1; } }

@keyframes fxBurst { 0% { transform: translate(0,0) scale(0.5); opacity: 0; } 100% { transform: translate(0,0) scale(1.2); opacity: 1; } }

@media (max-width: 380px) {
  .btn { padding: 6px 10px; font-size: 13px; min-width: 70px; }
  .stat-item { font-size: 11px; }
}

/* ═══════════════════════════════════════════════════════════
   D3: MOBILE ADAPTATION - Responsive + touch first
   ═══════════════════════════════════════════════════════════ */

/* === Safe area + root layout === */
@supports (padding-top: env(safe-area-inset-top)) {
  body { padding-top: env(safe-area-inset-top); padding-bottom: env(safe-area-inset-bottom); }
}

/* === Mobile status bar (scrollable if long) === */
@media (max-width: 420px) {
  #status {
    font-size: 11px;
    padding: 6px 8px;
    white-space: nowrap;
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    text-align: left;
  }
  #status::-webkit-scrollbar { display: none; }
  #game { padding: 10px 8px; }

  /* Typography scale down */
  .scene-title { font-size: 18px; margin-bottom: 8px; padding-bottom: 6px; }
  .scene-desc { font-size: 12px; margin-bottom: 10px; }
  .scene-text { font-size: 14px; line-height: 1.7; margin: 8px 0; }

  /* Buttons: minimum 44px touch target */
  .btn {
    min-height: 44px;
    min-width: 44px;
    padding: 8px 12px;
    font-size: 14px;
    margin: 3px;
    flex: 1 1 auto;
  }
  .btns {
    gap: 6px;
    margin: 10px 0;
  }
  .btn-small {
    min-height: 36px;
    min-width: 36px;
  }

  /* Origin selection */
  .origin-card { padding: 12px; margin: 6px 0; }
  .origin-emoji { font-size: 24px; }
  .origin-name { font-size: 16px; }
  .origin-attrs { font-size: 11px; }
  .origin-skill { font-size: 11px; }

  /* Attribute allocation */
  .attr-row-v5 { padding: 6px 0; }
  .attr-name-v5 { font-size: 13px; }
  .attr-hint-v5 { font-size: 10px; }
  .attr-btn { width: 40px; height: 40px; font-size: 18px; }
  .attr-value { font-size: 15px; min-width: 40px; }
  .pts-num { font-size: 16px; }

  /* Cards */
  .loc-card, .bld-card {
    padding: 10px 8px;
    gap: 8px;
    border-width: 1px;
  }
  .bld-emoji { font-size: 22px; }
  .bld-name { font-size: 14px; }
  .bld-desc { font-size: 11px; display: none; }
  .bld-arrow { font-size: 18px; }
  /* Town buildings: 2-column grid on mobile */
  .building-list {
    display: grid !important;
    grid-template-columns: 1fr 1fr;
    gap: 6px;
  }
  .bld-card { flex-direction: column; text-align: center; padding: 8px 4px; gap: 4px; }
  .bld-right { display: none; }
  .bld-info { align-items: center; }

  /* Battle: stack enemies vertically */
  .battle-enemies { flex-direction: column; gap: 6px; align-items: stretch; }
  .enemy-card {
    min-width: auto !important;
    width: 100%;
    padding: 8px 10px;
    gap: 8px;
    text-align: left;
    border-width: 1px;
  }
  .enemy-card .enemy-emoji { font-size: 24px; }
  .enemy-card .enemy-name { font-size: 13px; }
  .enemy-card .enemy-hp-text { font-size: 11px; }
  .battle-boss-frame { padding: 4px; }

  /* Battle player panel */
  .battle-player { padding: 8px; }
  .player-name { font-size: 13px; }
  .player-bars { gap: 3px; }
  .player-bar-row { font-size: 11px; gap: 4px; }
  .player-stats-inline { font-size: 11px; }
  .status-icon { font-size: 10px; padding: 1px 4px; }

  /* Battle actions */
  .battle-actions {
    position: sticky;
    bottom: 0;
    background: linear-gradient(0deg, var(--bg) 70%, transparent);
    padding: 8px 0 12px;
    margin: 0 -8px;
    gap: 6px;
  }
  .battle-actions .btn {
    min-height: 48px;
    min-width: 56px;
    font-size: 13px;
    flex: 1 1 calc(25% - 8px);
    margin: 2px;
    padding: 6px 4px;
  }
  .battle-actions .btn.btn-atk,
  .battle-actions .btn.btn-skill,
  .battle-actions .btn.btn-def,
  .battle-actions .btn.btn-flee {
    font-size: 13px;
  }

  /* Battle log */
  .battle-log { max-height: 90px; font-size: 11px; padding: 6px; margin: 6px 0; }
  .battle-turn-counter { font-size: 11px; padding: 3px 6px; }

  /* Wave intermission */
  .wave-status { padding: 8px; margin: 8px 0; }
  .wave-next { padding: 8px; }
  .wave-progress { font-size: 1em; }

  /* Inventory / shop */
  .inv-tabs { gap: 3px; }
  .inv-tab { min-width: 52px; padding: 5px 2px; font-size: 0.78em; }
  .item-row {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 4px;
    padding: 8px;
  }
  .item-row .item-actions { width: 100%; justify-content: flex-end; }

  /* World map */
  .world-map { margin: 8px 0; }
  .map-actions .btn { flex: 1 1 calc(50% - 8px); }

  /* Mini map */
  .mini-map-grid { height: 260px !important; }
  .mini-area { padding: 8px; }
  .mini-area-name { font-size: 14px; }
  .mini-area-desc { font-size: 12px; }

  /* Map move buttons - bigger touch targets */
  .move-grid { max-width: 200px; gap: 4px; }
  .move-btn { padding: 12px 6px; font-size: 16px; min-height: 48px; }
  .move-center { font-size: 18px; }

  /* Map action buttons: compact 2-column */
  .mini-actions .btn { flex: 1 1 calc(50% - 8px); font-size: 12px; padding: 8px 6px; }

  /* Modals / panels */
  .dialog-box, .story-choice-box, .gift-panel, .trade-panel, .enhance-panel {
    width: 100% !important;
    max-width: 100% !important;
    margin: 0 !important;
    border-radius: 8px 8px 0 0;
    max-height: 85vh;
    overflow-y: auto;
  }

  /* Town bottom buttons: compact 3-column grid */
  .btns { gap: 4px; }
  .btns .btn { flex: 1 1 calc(33% - 8px); font-size: 12px; padding: 8px 4px; min-width: 0; }

  /* Save slots */
  .save-slot { padding: 10px; margin: 6px 0; }
  .slot-header { font-size: 14px; }
  .slot-time { font-size: 10px; }

  /* Trade / caravan tables */
  .trade-table, .caravan-list { font-size: 12px; }
  .trade-table th, .trade-table td { padding: 6px 4px; font-size: 11px; }

  /* Deep Dive panels */
  .dd-shop-item { padding: 8px; }
  .dd-stat { font-size: 12px; }

  /* NPC relations / achievements grid */
  .npc-grid, .achievement-grid {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .npc-card, .achievement-card { padding: 8px; }

  /* Story choice */
  .choice-btn { padding: 10px; font-size: 13px; margin: 4px 0; }

  /* Toast */
  #toast { font-size: 12px; padding: 6px 14px; top: 44px; }

  /* Touch feedback */
  .btn, .bld-card, .loc-card, .enemy-card, .origin-card {
    -webkit-tap-highlight-color: transparent;
  }
  .btn:active, .bld-card:active, .loc-card:active, .enemy-card:active, .origin-card:active {
    transform: scale(0.98);
  }
}

/* Very small devices */
@media (max-width: 360px) {
  .btn { font-size: 13px; padding: 6px 10px; }
  .battle-actions .btn { font-size: 12px; min-height: 44px; }
  .scene-title { font-size: 16px; }
  .enemy-card .enemy-emoji { font-size: 20px; }
}

/* Landscape phones */
@media (max-height: 500px) and (orientation: landscape) {
  #status { font-size: 10px; padding: 4px 8px; }
  .scene-title { font-size: 16px; margin-bottom: 4px; }
  .battle-enemies { flex-direction: row; flex-wrap: wrap; }
  .enemy-card { min-width: 120px !important; width: auto; padding: 6px 8px; }
  .battle-actions { position: static; padding: 6px 0; }
  .battle-actions .btn { min-height: 40px; }
}

/* ═══════════════════════════════════════════════════════════
   IMPROVED LAYOUT - Mobile touch optimization
   ═══════════════════════════════════════════════════════════ */
.save-slot { padding: 14px; margin: 10px 0; }
.save-slot-auto { border-left: 3px solid #4a4; background: rgba(46,125,50,0.08); }
.slot-header { font-size: 17px; margin-bottom: 8px; }
.slot-note { text-align: center; font-size: 12px; color: #666; margin: 12px 0 8px; font-style: italic; }

/* Bigger battle action buttons */
.battle-actions .btn { min-height: 44px; font-size: 15px; }
.skill-group-label { font-size: 13px; color: #8a8a9a; margin: 8px 0 4px; padding-left: 4px; border-bottom: 1px solid #333; }
.skill-meta-inline { font-size: 11px; color: #8aa; }
.skill-cost { font-size: 11px; color: #48a; margin-left: 4px; }

/* Skill detail card - mobile friendly */
.skill-detail-card { padding: 12px; }
.skill-category { font-size: 15px; margin: 12px 0 8px; }
.sdc-header { font-size: 16px; }
.sdc-emoji { font-size: 22px; }

/* Attr allocation - bigger touch targets */
.attr-controls { gap: 14px !important; }
.attr-value { font-size: 20px !important; min-width: 60px !important; }

/* Inventory tabs */
.inv-tabs { display: flex; gap: 4px; margin: 8px 0; flex-wrap: wrap; }
.inv-tab { flex: 1; min-width: 60px; padding: 6px 4px; background: #1a1a10; border: 1px solid #333; border-radius: 6px; color: #888; font-size: 0.85em; text-align: center; cursor: pointer; }
.inv-tab.active { background: #2a2a18; border-color: var(--accent); color: var(--accent); font-weight: bold; }

/* Building badge */
.bld-badge { display: inline-block; background: #d4a017; color: #000; font-size: 0.7em; font-weight: bold; padding: 1px 5px; border-radius: 8px; vertical-align: middle; animation: badge-pulse 2s ease-in-out infinite; }
.bld-right { display:flex; align-items:center; gap:6px; flex-shrink:0; }
@keyframes badge-pulse { 0%,100% { opacity:1; } 50% { opacity:0.6; } }

/* Mini map scroll container */
.mini-map-grid { scrollbar-width: thin; scrollbar-color: #333 transparent; }
.mini-map-grid::-webkit-scrollbar { width: 6px; height: 6px; }
.mini-map-grid::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }
.mini-map-grid::-webkit-scrollbar-track { background: transparent; }

/* === D3: Mobile bottom nav bar === */
.mobile-nav {
  display: none;
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #111;
  border-top: 1px solid #2a2a2a;
  z-index: 150;
  padding: 2px 0;
  padding-bottom: env(safe-area-inset-bottom, 0px);
  justify-content: space-around;
}
.mobile-nav .nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 4px 2px;
  font-size: 10px;
  color: #888;
  cursor: pointer;
  -webkit-tap-highlight-color: transparent;
  min-width: 44px;
  min-height: 44px;
  justify-content: center;
}
.mobile-nav .nav-item:active { color: var(--accent); }
.mobile-nav .nav-emoji { font-size: 18px; margin-bottom: 1px; }
.mobile-nav .nav-label { font-size: 9px; letter-spacing: 0.5px; }

@media (max-width: 420px) {
  .mobile-nav { display: flex; }
  body { padding-bottom: 52px; }
}
@media (max-height: 500px) and (orientation: landscape) {
  .mobile-nav { display: flex; }
  body { padding-bottom: 44px; }
  .mobile-nav .nav-item { padding: 2px; min-height: 36px; }
  .mobile-nav .nav-emoji { font-size: 16px; }
  .mobile-nav .nav-label { font-size: 8px; }
}

</style>
</head>
<body>
<div id="status"></div>
<div id="game"></div>
<div id="toast" class="toast-container"></div>
<!-- D3: Mobile bottom nav -->
<div class="mobile-nav" id="mobileNav">
  <div class="nav-item" onclick="sceneTown()"><span class="nav-emoji">🏰</span><span class="nav-label">城镇</span></div>
  <div class="nav-item" onclick="sceneInventory()"><span class="nav-emoji">🎒</span><span class="nav-label">背包</span></div>
  <div class="nav-item" onclick="_playerInfoReturnTo=G._currentScene||'sceneTown';scenePlayerInfo()"><span class="nav-emoji">👤</span><span class="nav-label">角色</span></div>
  <div class="nav-item" onclick="sceneEquipmentFromTown()"><span class="nav-emoji">⚔️</span><span class="nav-label">装备</span></div>
  <div class="nav-item" onclick="sceneSaveLoad()"><span class="nav-emoji">💾</span><span class="nav-label">存档</span></div>
</div>
<script>
// ═══════════════════════════════════════════════════════════
// 龙途传说 v5 - 手绘线稿风格 + 完整修复
// ═══════════════════════════════════════════════════════════

// Global difficulty: 1.0 = normal, 0.75 = easier, 1.5 = harder
var DIFF_SCALE = 0.75;

// Apply difficulty scaling to an enemy template
function getNpcAffectionTierByMin(minLevel) {
  for (var i = NPC_AFFECTION_TIERS.length - 1; i >= 0; i--) {
    if (minLevel >= NPC_AFFECTION_TIERS[i].min) return NPC_AFFECTION_TIERS[i].title;
  }
  return '陌生人';
}

function getNpcAffection(npcId) {
  if (!G.npcRelations) G.npcRelations = {};
  if (!G.npcRelations[npcId]) return 0;
  return G.npcRelations[npcId].level || 0;
}

function getNpcAffectionTier(npcId) {
  var lv = getNpcAffection(npcId);
  for (var i = NPC_AFFECTION_TIERS.length - 1; i >= 0; i--) {
    if (lv >= NPC_AFFECTION_TIERS[i].min) return NPC_AFFECTION_TIERS[i];
  }
  return NPC_AFFECTION_TIERS[0];
}

function addNpcAffection(npcId, amount) {
  if (!G.npcRelations) G.npcRelations = {};
  if (!G.npcRelations[npcId]) G.npcRelations[npcId] = { level: 0, gifts: 0 };
  // A4: Story choice social bonus (social_bonus = +10% affection)
  if (G._socialBonus) amount = Math.ceil(amount * (1 + G._socialBonus));
  var oldLv = G.npcRelations[npcId].level;
  G.npcRelations[npcId].level = Math.min(100, oldLv + amount);
  G.npcRelations[npcId].gifts = (G.npcRelations[npcId].gifts || 0) + 1;
  var newLv = G.npcRelations[npcId].level;
  // Check unlock thresholds
  var npcDef = NPC_DEFS[npcId];
  if (!npcDef) return newLv - oldLv;
  if (oldLv < 40 && newLv >= 40) {
    G._friendCount = (G._friendCount || 0) + 1;
    if (npcDef.unlockFriend && npcDef.unlockFriend.type) _applyNpcUnlock(npcId, npcDef.unlockFriend, '朋友');
  }
  if (oldLv < 70 && newLv >= 70) {
    G._bestFriendCount = (G._bestFriendCount || 0) + 1;
    if (npcDef.unlockBestFriend && npcDef.unlockBestFriend.type) _applyNpcUnlock(npcId, npcDef.unlockBestFriend, '挚友');
  }
  if (oldLv < 100 && newLv >= 100) {
    G._soulmateCount = (G._soulmateCount || 0) + 1;
    if (npcDef.unlockSoulmate && npcDef.unlockSoulmate.type) _applyNpcUnlock(npcId, npcDef.unlockSoulmate, '知己');
  }
  checkAchievements();
  return newLv - oldLv;
}

function _applyNpcUnlock(npcId, unlock, tierName) {
  var npcDef = NPC_DEFS[npcId];
  var name = npcDef ? npcDef.name : npcId;
  switch (unlock.type) {
    case 'discount':
      if (!G._npcDiscounts) G._npcDiscounts = {};
      var key = unlock.target + '_' + npcId;
      G._npcDiscounts[key] = unlock.pct || 10;
      toast('🎉 ' + name + '成为' + tierName + '! ' + _discountTargetName(unlock.target) + '折扣-' + (unlock.pct||10) + '%');
      break;
    case 'buff':
      if (unlock.stat && unlock.val) {
        if (!G._npcBuffs) G._npcBuffs = {};
        G._npcBuffs[npcId + '_' + unlock.stat] = unlock.val;
        toast('🎉 ' + name + '成为' + tierName + '! ' + unlock.desc);
      }
      break;
    case 'skill':
      if (unlock.skillId) {
        if (!G._npcSkills) G._npcSkills = {};
        G._npcSkills[unlock.skillId] = true;
        // Add to player's known skills
        if (!G.skills) G.skills = [];
        if (G.skills.indexOf(unlock.skillId) < 0) G.skills.push(unlock.skillId);
        toast('🎉 ' + name + '成为' + tierName + '! 传授技能: ' + unlock.desc);
      }
      break;
    case 'recipe':
      if (unlock.recipeId) {
        if (!G._unlockedRecipes) G._unlockedRecipes = {};
        G._unlockedRecipes[unlock.recipeId] = true;
        toast('🎉 ' + name + '成为' + tierName + '! 解锁配方: ' + unlock.desc);
      }
      break;
    case 'item':
      if (unlock.itemId) {
        // Queue item to be given next time player opens inventory
        if (!G._pendingNpcItems) G._pendingNpcItems = [];
        G._pendingNpcItems.push({ itemId: unlock.itemId, desc: unlock.desc, from: name });
        toast('🎉 ' + name + '成为' + tierName + '! ' + unlock.desc);
      }
      break;
    default:
      toast('🎉 ' + name + '成为' + tierName + '!');
  }
}

function _discountTargetName(target) {
  var names = { inn:'旅店', shop:'商店', smith:'铁匠铺' };
  return names[target] || target;
}

function getNpcDiscount(npcId, target) {
  if (!G._npcDiscounts) return 0;
  var total = 0;
  for (var k in G._npcDiscounts) {
    if (k.startsWith(target + '_')) {
      total += G._npcDiscounts[k];
    }
  }
  return Math.min(total, 50); // Cap at 50% discount
}

function giveGiftToNpc(npcId, materialId) {
  var gi = GIFT_ITEMS[materialId];
  if (!gi) { toast('无法赠送此物品'); return; }
  if (!G.materials || !G.materials[materialId] || G.materials[materialId] <= 0) {
    toast('你没有这个材料'); return;
  }
  // Consume material
  G.materials[materialId]--;
  if (G.materials[materialId] <= 0) delete G.materials[materialId];
  // Calculate affection gain (liked items give 2x)
  var npcDef = NPC_DEFS[npcId];
  var base = gi.affectionBase || 5;
  var liked = npcDef && npcDef.likes && npcDef.likes.indexOf(materialId) >= 0;
  var gain = liked ? base * 2 : base;
  var actual = addNpcAffection(npcId, gain);
  G._giftCount = (G._giftCount || 0) + 1;
  var tier = getNpcAffectionTier(npcId);
  var npcName = npcDef ? npcDef.name : npcId;
  toast('🎁 赠送' + gi.name + '给' + npcName + (liked ? ' ❤️喜爱!' : '') + ' 好感度+' + actual + ' (' + tier.emoji + tier.title + ')');
  checkAchievements();
  autoSave(); // Auto-save on gift
}

function showGiftPanel(sceneType) {
  var npcList = [];
  var loc = G.currentLocation || 'whitecity';
  if (sceneType === 'inn') {
    var innNpcMap = {
      whitecity:['innkeep_white','roland','elena','lord_white'],
      ironridge:['innkeep_iron','hank','smithkeep_iron','lord_iron'],
      tidport:['innkeep_tid','captain_storm','lord_tid'],
      sunspire:['innkeep_sun','sage_ilan','lord_sun'],
      dragonreach:['innkeep_dragon','smithkeep_drag','lord_drago'],
      icereef:['smithkeep_ice','frostwing_survivor'],
      misthollow:['mist_spirit','swamp_witch'],
      jademarsh:['jade_guardian'],
      stormcape:['captain_storm'],
      ashplains:['ash_wanderer','flame_seer'],
      abyssgate:['gatekeeper_abyss','shadow_whisperer'],
      dragontemple:['ancient_dragon_spirit'],
      darkforest:['darkblade','mystic_wu']
    };
    npcList = innNpcMap[loc] || [];
  } else if (sceneType === 'blacksmith') {
    var smithNpcMap = {
      whitecity:['roland','hank'],
      ironridge:['smithkeep_iron','hank'],
      dragonreach:['smithkeep_drag'],
      icereef:['smithkeep_ice']
    };
    npcList = smithNpcMap[loc] || [];
  } else if (sceneType === 'shop') {
    var shopNpcMap = {
      whitecity:['shopkeep_white','elena','roland'],
      ironridge:['smithkeep_iron'],
      tidport:['mystic_wu','innkeep_tid'],
      sunspire:['sage_ilan','innkeep_sun'],
      dragonreach:['smithkeep_drag','karis'],
      icereef:['smithkeep_ice','frostwing_survivor'],
      misthollow:['mist_spirit'],
      jademarsh:['swamp_witch'],
      stormcape:['captain_storm'],
      ashplains:['ash_wanderer','flame_seer'],
      abyssgate:['gatekeeper_abyss'],
      dragontemple:['ancient_dragon_spirit']
    };
    npcList = shopNpcMap[loc] || [];
  } else if (sceneType === 'guild') {
    // Guild has all town NPCs
    var guildNpcMap = {
      whitecity:['roland','elena','hank','innkeep_white','shopkeep_white'],
      ironridge:['smithkeep_iron','hank','darkblade'],
      tidport:['mystic_wu','innkeep_tid','captain_storm'],
      sunspire:['sage_ilan','innkeep_sun'],
      dragonreach:['smithkeep_drag','karis','eric'],
      icereef:['smithkeep_ice','frostwing_survivor'],
      misthollow:['mist_spirit','swamp_witch'],
      jademarsh:['jade_guardian','swamp_witch'],
      stormcape:['captain_storm'],
      ashplains:['ash_wanderer','flame_seer'],
      abyssgate:['gatekeeper_abyss','shadow_whisperer'],
      dragontemple:['ancient_dragon_spirit']
    };
    npcList = guildNpcMap[loc] || [];
  }
  if (npcList.length === 0) { toast('这里没有可以送礼的NPC'); return; }
  var html = '<div style="padding:12px;max-height:70vh;overflow-y:auto">';
  html += '<h3 style="margin:0 0 8px;color:#d4a017">🎁 送礼</h3>';
  html += '<div style="margin-bottom:10px"><b>选择NPC:</b><br>';
  for (var i = 0; i < npcList.length; i++) {
    var nd = NPC_DEFS[npcList[i]];
    if (!nd) continue;
    var tier = getNpcAffectionTier(npcList[i]);
    var curLv = G.npcRelations[npcList[i]] ? G.npcRelations[npcList[i]].level : 0;
    html += '<label style="display:block;margin:3px 0;cursor:pointer"><input type="radio" name="giftNpc" value="' + npcList[i] + '"' + (i===0?' checked':'') + '> ' + tier.emoji + ' ' + nd.name + ' (' + tier.title + ' ' + curLv + '/100)</label>';
  }
  html += '</div>';
  var mats = G.materials || {};
  var matKeys = Object.keys(mats).filter(function(k){return mats[k]>0 && GIFT_ITEMS[k]});
  if (matKeys.length === 0) {
    html += '<div style="color:#888;padding:8px">没有可赠送的材料</div>';
  } else {
    html += '<div><b>选择礼物:</b><br>';
    for (var j = 0; j < matKeys.length; j++) {
      var gid = matKeys[j], gi = GIFT_ITEMS[gid], qty = mats[gid];
      var liked = '';
      var nd0 = NPC_DEFS[npcList[0]];
      if (nd0 && nd0.likes && nd0.likes.indexOf(gid)>=0) liked = ' ❤️';
      html += '<label style="display:block;margin:3px 0;cursor:pointer"><input type="radio" name="giftMat" value="'+gid+'"' + (j===0?' checked':'') + '> '+gi.name+liked+' (×'+qty+', +'+gi.affectionBase+'好感)</label>';
    }
    html += '</div>';
    html += '<button class="btn btn-primary" style="margin-top:10px" onclick="doGift()">送出</button>';
  }
  html += ' <button class="btn" style="margin-top:10px" onclick="closeGiftPanel()">关闭</button>';
  html += '</div>';
  closeGiftPanel();
  var panel = document.createElement('div');
  panel.id = 'gift-panel';
  panel.style.cssText = 'position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);background:#1a1a2e;border:2px solid #d4a017;border-radius:12px;z-index:9999;min-width:300px;max-width:90vw;box-shadow:0 4px 20px rgba(0,0,0,0.6)';
  panel.innerHTML = html;
  document.body.appendChild(panel);
}
function doGift() {
  var nr = document.querySelector('input[name="giftNpc"]:checked');
  var mr = document.querySelector('input[name="giftMat"]:checked');
  if (!nr || !mr) { toast('请选择NPC和礼物'); return; }
  giveGiftToNpc(nr.value, mr.value);
  closeGiftPanel();
}
function closeGiftPanel() {
  var p = document.getElementById('gift-panel');
  if (p) p.remove();
}

function sceneNpcRelations() {
  G._currentScene = 'sceneNpcRelations';
  var html = '';
  html += '<div class="scene-title">👥 人际关系</div>';
  html += '<div style="color:#888;font-size:0.85em;margin-bottom:8px">与冒险途中的NPC建立关系,解锁更多可能</div>';
  
  // NPC_DEFS is an object, iterate over keys
  var loc = G.location || 'whitecity';
  var npcData = [];
  for (var npcKey in NPC_DEFS) {
    var npc = NPC_DEFS[npcKey];
    npc._id = npcKey;  // store key for reference
    var aff = getNpcAffection(npcKey);
    var tier = getNpcAffectionTier(npcKey);
    npcData.push({ npc: npc, npcId: npcKey, aff: aff, tier: tier });
  }
  npcData.sort(function(a, b) { return b.aff - a.aff; });
  
  // Current location NPCs
  var hereNpcs = npcData.filter(function(d) { return d.npc.loc === loc; });
  var otherNpcs = npcData.filter(function(d) { return d.npc.loc !== loc; });
  
  if (hereNpcs.length > 0) {
    html += '<div style="color:#6fa8dc;font-weight:bold;margin:8px 0 4px">📍 当前城镇</div>';
    for (var h = 0; h < hereNpcs.length; h++) {
      html += _renderNpcRelationCard(hereNpcs[h]);
    }
  }
  
  if (otherNpcs.length > 0) {
    html += '<div style="color:#888;font-weight:bold;margin:12px 0 4px">🗺️ 其他城镇</div>';
    for (var o = 0; o < otherNpcs.length; o++) {
      html += _renderNpcRelationCard(otherNpcs[o]);
    }
  }
  
  html += '<div style="margin-top:12px">';
  html += '<button class="btn" onclick="sceneTown()">↩️ 返回城镇</button>';
  html += '</div>';
  render(html);
}

function _renderNpcRelationCard(data) {
  var npc = data.npc;
  var npcId = data.npcId;
  var aff = data.aff;
  var tier = data.tier;
  var maxAff = 100;
  var pct = Math.min(100, Math.floor(aff / maxAff * 100));
  var tierTitle = tier.title || tier;
  var tierEmoji = tier.emoji || '👤';
  var tierColor = tier.color || '#666';
  
  var h = '';
  h += '<div style="padding:8px 10px;margin:4px 0;background:#1a1a10;border-radius:8px;border-left:3px solid ' + tierColor + '">';
  h += '<div style="display:flex;justify-content:space-between;align-items:center">';
  h += '<div><b>👤 ' + npc.name + '</b></div>';
  h += '<div style="color:' + tierColor + ';font-size:0.85em;font-weight:bold">' + tierEmoji + ' ' + tierTitle + '</div>';
  h += '</div>';
  // Progress bar
  h += '<div style="background:#222;height:5px;border-radius:2px;margin:4px 0">';
  h += '<div style="background:' + tierColor + ';height:100%;width:' + pct + '%;border-radius:2px"></div>';
  h += '</div>';
  h += '<div style="color:#888;font-size:0.8em">❤️ ' + aff + '/' + maxAff + ' (' + pct + '%)</div>';
  // Show likes if known (aff >= 20)
  if (npc.likes && npc.likes.length > 0 && aff >= 20) {
    var likeNames = npc.likes.map(function(lid) { var gi = GIFT_ITEMS[lid]; return gi ? gi.name : lid; });
    h += '<div style="color:#6fa8dc;font-size:0.8em;margin-top:2px">🎁 喜爱:' + likeNames.join(', ') + '</div>';
  }
  // Show unlocked rewards
  if (npc.unlockFriend && npc.unlockFriend.type && aff >= 40) {
    h += '<div style="color:#d4a017;font-size:0.8em;margin-top:2px">🔓 朋友:' + (npc.unlockFriend.desc || _discountTargetName(npc.unlockFriend.target) + '折扣') + '</div>';
  }
  if (npc.unlockBestFriend && npc.unlockBestFriend.type && aff >= 70) {
    h += '<div style="color:#e74c3c;font-size:0.8em;margin-top:2px">🔓 挚友:' + (npc.unlockBestFriend.desc || '特殊') + '</div>';
  }
  if (npc.unlockSoulmate && npc.unlockSoulmate.type && aff >= 100) {
    h += '<div style="color:#9b59b6;font-size:0.8em;margin-top:2px">🔓 知己:' + (npc.unlockSoulmate.desc || '终极') + '</div>';
  }
  h += '</div>';
  return h;
}

function scaleEnemy(e) {
  var lvScale = 1 + Math.max(0, (G.level || 1) - 1) * 0.02;
  // Regular enemies get extra scaling to stay relevant at higher levels
  var regScale = (!e.isBoss && !e.isElite) ? 2.0 : 1.0;
  e.hp = Math.round(e.hp * DIFF_SCALE * lvScale * regScale);
  e.atk = Math.round(e.atk * DIFF_SCALE * lvScale * regScale);
  if (e.def) e.def = Math.round(e.def * DIFF_SCALE * lvScale * regScale);
  // Story choice: 'neutral_path' makes bosses +10% harder
  if (e.isBoss && G._neutralPath) {
    e.hp = Math.round(e.hp * 1.1);
    e.atk = Math.round(e.atk * 1.1);
  }
  // A4: Story choice shadow reduction (seal_chosen +10%, return_heart +15%)
  if (G._shadowReduction && (e.isBoss || e.isElite || e.ddEnemy)) {
    var reduction = 1 - G._shadowReduction;
    e.atk = Math.round(e.atk * reduction);
  }
  return e;
}

// ═══════════════════════════════════════════════════════════
// DATA: Enemies with SVG-style line art
// ═══════════════════════════════════════════════════════════

// ═══════════════════════════════════════════════════════════
// DATA: Materials - 战斗掉落材料,铁匠铺打造必需品
// ═══════════════════════════════════════════════════════════

var MATERIALS = {
  // Common materials (sell 5-15g)
  scrap_cloth:    { id:'scrap_cloth',    name:'破布',       icon:'🧶', category:'cloth',    rarity:'common',    sellPrice:5,   craftValue:1 },
  wolf_fang:      { id:'wolf_fang',      name:'狼牙',       icon:'🦷', category:'bone',     rarity:'common',    sellPrice:8,   craftValue:1 },
  wolf_pelt:      { id:'wolf_pelt',      name:'狼皮',       icon:'🦊', category:'leather',  rarity:'common',    sellPrice:10,  craftValue:1 },
  tentacle:       { id:'tentacle',       name:'触手',       icon:'🐙', category:'organic',  rarity:'common',    sellPrice:8,   craftValue:1 },
  iron_scrap:     { id:'iron_scrap',     name:'铁碎片',     icon:'🔩', category:'metal',    rarity:'common',    sellPrice:6,   craftValue:1 },
  herb_weed:      { id:'herb_weed',      name:'野草药',     icon:'🌿', category:'herb',     rarity:'common',    sellPrice:5,   craftValue:1 },
  bone_chip:      { id:'bone_chip',      name:'骨碎片',     icon:'🦴', category:'bone',     rarity:'common',    sellPrice:7,   craftValue:1 },
  // Uncommon materials (sell 15-35g)
  goblin_dagger:  { id:'goblin_dagger',  name:'哥布林短刀', icon:'🗡️', category:'metal',    rarity:'uncommon',  sellPrice:15,  craftValue:2 },
  ice_shard:      { id:'ice_shard',      name:'冰晶碎片',   icon:'❄️', category:'elemental',rarity:'uncommon',  sellPrice:20,  craftValue:2 },
  deep_pearl:     { id:'deep_pearl',     name:'深海珍珠',   icon:'🫧', category:'gem',      rarity:'uncommon',  sellPrice:30,  craftValue:2 },
