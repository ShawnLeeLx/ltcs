// Deep Dive enemy templates - scaled by floor
var DEEP_DIVE_ENEMIES = [
  { id:'dd_shadow_frag', name:'暗影碎片', icon:'👤', hp:40, atk:12, def:5, skills:['shadow_strike'], loot_tier:'common' },
  { id:'dd_void_echo', name:'虚空回响', icon:'🌀', hp:50, atk:15, def:7, skills:['void_slash'], loot_tier:'common' },
  { id:'dd_dark_drake', name:'暗渊幼龙', icon:'🐉', hp:65, atk:18, def:10, skills:['shadow_strike', 'fire_breath'], loot_tier:'uncommon' },
  { id:'dd_cursed_knight', name:'被诅咒的骑士', icon:'🗡️', hp:80, atk:22, def:14, skills:['heavy_slam', 'stun_blow'], loot_tier:'uncommon' },
  { id:'dd_soul_eater', name:'噬魂者', icon:'💀', hp:100, atk:28, def:16, skills:['soul_drain', 'shadow_veil'], loot_tier:'rare' },
  { id:'dd_ancient_horror', name:'远古恐惧', icon:'👁️', hp:130, atk:35, def:20, skills:['abyss_call', 'boss_rage'], loot_tier:'rare' },
  { id:'dd_void_dragon', name:'虚空之龙', icon:'🐲', hp:170, atk:42, def:25, skills:['dragon_breath', 'void_slash'], loot_tier:'epic' },
  { id:'dd_primordial_shade', name:'原初暗影', icon:'🌑', hp:220, atk:50, def:30, skills:['primordial_dark', 'shadow_veil'], loot_tier:'epic' },
  { id:'dd_world_ender', name:'终焉之影', icon:'☠️', hp:300, atk:65, def:40, skills:['world_devour', 'boss_rage'], loot_tier:'legendary' }
];

// Deep Dive floor rewards
var DD_MAX_FLOOR = 100; // Hard cap — floor 100 is the final boss
var DD_FLOOR_REWARDS = {
  5:  { type:'material', id:'dark_essence', count:3, label:'暗影精华×3' },
  10: { type:'equip', rarity:'rare', label:'稀有装备1件' },
  15: { type:'gold', amount:500, label:'500金币' },
  20: { type:'material', id:'magic_dust', count:5, label:'魔法粉尘×5' },
  25: { type:'equip', rarity:'epic', label:'史诗装备1件' },
  30: { type:'perm_stat', stat:'luk', amount:2, label:'永久+2幸运' },
  35: { type:'material', id:'deep_pearl', count:5, label:'深海珍珠×5' },
  40: { type:'equip', rarity:'legendary', label:'传说装备1件' },
  50: { type:'title', id:'deep_diver', label:'称号:深渊行者' },
  75: { type:'perm_stat', stat:'str', amount:3, label:'永久+3体魄' },
  100:{ type:'title', id:'abyss_lord', label:'称号:深渊之主' }
};

// Deep Dive boss every 10 floors
var DD_BOSSES = {
  10: { name:'暗影守卫', icon:'👹', hp:200, atk:30, def:18, skills:['shadow_strike'], loot_tier:'rare', permBuff:'dd_pb1' },
